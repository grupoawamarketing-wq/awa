<?xml version="1.0"?>
<ruleset name="AWA Motos — Magento 2 Coding Standard">
    <description>PHP_CodeSniffer ruleset for AWA Motos Magento 2 project</description>

    <!-- Scan only custom modules -->
    <file>app/code/GrupoAwamotos</file>
    <file>app/code/Awa</file>
    <file>app/code/Ayo</file>

    <!-- Exclude third-party, generated, and vendor directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/generated/*</exclude-pattern>
    <exclude-pattern>*/pub/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>
    <exclude-pattern>*/Rokanthemes/*</exclude-pattern>

    <!-- Base: PSR-12 (compatible with Magento 2 conventions) -->
    <rule ref="PSR12"/>

    <!--
        DISABLED: Squiz.Operators.ComparisonOperatorUsage
        This rule requires `=== TRUE` / `=== FALSE` for all boolean checks,
        e.g. banning: if ($x), if (!$x), if (empty($x))
        This conflicts with Magento 2 coding standards and standard PHP idioms.
        Removing it eliminates ~99% of false-positive issues in the Codacy report.
    -->
    <rule ref="Squiz.Operators.ComparisonOperatorUsage">
        <severity>0</severity>
    </rule>

    <!--
        DISABLED: WordPress_Security_EscapeOutput
        This rule is WordPress-specific and flags Magento's __() translation
        helper as XSS risk. It is a false positive in Magento context.
    -->
    <rule ref="WordPress.Security.EscapeOutput">
        <severity>0</severity>
    </rule>

    <!--
        Downgrade MEQP1 file_get_contents warning level for test files.
        file_get_contents() is legitimate in unit tests for reading fixtures.
    -->
    <rule ref="MEQP1.Security.DiscouragedFunction">
        <exclude-pattern>*/Test/*</exclude-pattern>
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <!--
        DISABLED: PSR2.Methods.MethodDeclaration (underscore prefix)
        Magento 2 uses `protected function _construct()` as a second-stage
        initializer in AbstractModel. It is a valid framework pattern,
        not a visibility-indication anti-pattern.
    -->
    <rule ref="PSR2.Methods.MethodDeclaration">
        <severity>0</severity>
    </rule>

    <!--
        DISABLED: PSR2.Classes.PropertyDeclaration (underscore prefix)
        Older Magento 2 modules use protected `$_varName` properties
        (a legacy framework convention). Renaming these would require
        widespread refactoring and break parent-class compatibility.
    -->
    <rule ref="PSR2.Classes.PropertyDeclaration">
        <severity>0</severity>
    </rule>

    <!--
        ADJUSTED: Generic.Files.LineLength
        Default limit is 80 (warning) / 100 (error). Increased to 150/200
        because Magento 2 translation strings (__('...')) and
        complex DI constructor signatures routinely exceed 120 chars.
    -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="150"/>
            <property name="absoluteLineLimit" value="200"/>
        </properties>
    </rule>

    <!--
        DISABLED: PSR12.Properties.ConstantVisibility
        Many Magento 2 modules declare constants without explicit visibility
        (e.g. `const ROUTE = 'something'`). PHP defaults these to public
        visibility, so this is functionally correct; the warning is noise.
    -->
    <rule ref="PSR12.Properties.ConstantVisibility">
        <severity>0</severity>
    </rule>

</ruleset>
