# Magento 2 .gitignore

# Arquivos de configuração sensíveis
/app/etc/env.php
/app/etc/config.php
/app/etc/*.bak
/app/etc/*.bak*
/app/etc/*.bak-*
auth.json

# Arquivos de ambiente (NUNCA comite segredos)
.env
.env.*
!.env.example

# Cache e arquivos temporários
/var/*
!/var/.htaccess
/pub/media/*
!/pub/media/.htaccess
!/pub/media/customer
!/pub/media/downloadable
!/pub/media/import
!/pub/media/theme_customization
/pub/static/*
!/pub/static/.htaccess

# Arquivos gerados
/generated/*
!/generated/.htaccess

# Dependências (gerenciadas pelo Composer)
/vendor/

# Logs
*.log
nohup.out

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
__MACOSX/
**/__MACOSX/
Thumbs.db

# Node modules (se usar frontend build)
node_modules/

# Backup files
*.bak
*.backup
*.sql
*.gz
*.zip
_backups/
artifacts/

# Scripts utilitários e documentos locais
scripts/
docs/
relatorios/
analise_visual/
biblioteca/
_csv/

# Artefatos de sessões AI / documentação descartável (raiz)
CHECKLIST_FINALIZACAO.md
CONFIGURACAO_MELHORES_PRATICAS.md
ENTREGAS.txt
IMPLEMENTACAO_COMPLETA_OTIMIZADA.md
INDICE_DOCUMENTACAO.md
PLANO_ACAO_FINAL.md
RESUMO_IMPLEMENTACAO_FINAL.md
STATUS_SISTEMA_COMPLETO.md
GUIA_RAPIDO_REXIS_ML.md

# Documentação AI gerada dentro de módulos
app/code/GrupoAwamotos/RexisML/COMPLETE_IMPLEMENTATION.md
app/code/GrupoAwamotos/RexisML/ENHANCED_FEATURES.md
app/code/GrupoAwamotos/RexisML/INSTALACAO_CONCLUIDA.md

# Arquivos diversos que não pertencem ao repositório
feature_list.json
performance-config.json
deploy-update.sh
webpack.config.performance.js
______modulos/
vscode-copilot-autonomo/
intelephense.json
static-analysis.datadog.yml
manifest.json
sw.js
web-vitals.js
.lighthouserc.js
.claude-wrapper.sh

# Diretórios temporários
pub/media/import/
qwen-code/
opensearch/
dummy-opensearch/

# Configs de ferramentas AI
.agent/
.anima/
.claude/
.codacy/
.kombai/
.trae/

# Ignore vscode AI rules
.github/instructions/codacy.instructions.md

# Redis
dump.rdb

# MCP config with secrets
.vscode/mcp.json

# MCP debug tools
.mcp-debug-tools/

# PHPUnit cache
.phpunit.cache/
**/.phpunit.cache/

# CSS bundle originals (preserved for reference, not tracked)
**/_originals/

# Rokanthemes Ayo — variantes de tema não usadas (tema ativo: AWA_Custom/ayo_home5_child)
# Somente ayo_home5 (tema pai) é necessário; RTL e demais variantes não são usados
app/design/frontend/ayo/ayo_home1_rtl/
app/design/frontend/ayo/ayo_home2/
app/design/frontend/ayo/ayo_home2_rtl/
app/design/frontend/ayo/ayo_home3/
app/design/frontend/ayo/ayo_home3_rtl/
app/design/frontend/ayo/ayo_home4/
app/design/frontend/ayo/ayo_home4_rtl/
app/design/frontend/ayo/ayo_home5_rtl/
app/design/frontend/ayo/ayo_home6/
app/design/frontend/ayo/ayo_home6_rtl/
app/design/frontend/ayo/ayo_home7/
app/design/frontend/ayo/ayo_home7_rtl/
app/design/frontend/ayo/ayo_home8/
app/design/frontend/ayo/ayo_home9/
app/design/frontend/ayo/ayo_home10/
app/design/frontend/ayo/ayo_home11/
app/design/frontend/ayo/ayo_home12/
app/design/frontend/ayo/ayo_home13/
app/design/frontend/ayo/ayo_home14/
app/design/frontend/ayo/ayo_home15/
app/design/frontend/ayo/ayo_home16/

# Arquivos temporários / screenshots de análise (raiz do projeto)
awamotos-home-livechat.png
footer_after_fix.png
footer_full_page.png
footer_mid_screenshot.png
footer_mobile*.png
footer_screenshot.png
google-*.png
livechat-*.png
awa-bundle-site.unmin.css.bak-*

# Scripts de análise temporários (sfooter*.js, screenshot*.js)
sfooter*.js
screenshot-*.js
inspect-cart.js
web-vitals.js

# Backups/dumps não versionados
composer.lock.bak-*
vendor.bak-*/
dump.rdb

# Scripts de manutenção temporários
remove_maintenance.php
