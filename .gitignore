app/design/frontend/ayo/ayo_home1_rtl/
app/design/frontend/ayo/ayo_home2/
app/design/frontend/ayo/ayo_home2_rtl/
app/design/frontend/ayo/ayo_home3/
app/design/frontend/ayo/ayo_home3_rtl/
app/design/frontend/ayo/ayo_home4/
app/design/frontend/ayo/ayo_home4_rtl/
app/design/frontend/ayo/ayo_home5_rtl/
app/design/frontend/ayo/ayo_home6/
app/design/frontend/ayo/ayo_home6_rtl/
app/design/frontend/ayo/ayo_home7/
app/design/frontend/ayo/ayo_home7_rtl/
app/design/frontend/ayo/ayo_home8/
app/design/frontend/ayo/ayo_home9/
app/design/frontend/ayo/ayo_home10/
app/design/frontend/ayo/ayo_home11/
app/design/frontend/ayo/ayo_home12/
app/design/frontend/ayo/ayo_home13/
app/design/frontend/ayo/ayo_home14/
app/design/frontend/ayo/ayo_home15/
app/design/frontend/ayo/ayo_home16/

# Arquivos temporários / screenshots de análise (raiz do projeto)
awamotos-home-livechat.png
footer_after_fix.png
footer_full_page.png
footer_mid_screenshot.png
footer_mobile*.png
footer_screenshot.png
google-*.png
livechat-*.png
awa-bundle-site.unmin.css.bak-*

# Scripts de análise temporários (sfooter*.js, screenshot*.js)
sfooter*.js
screenshot-*.js
inspect-cart.js
web-vitals.js

# Backups/dumps não versionados
composer.lock.bak-*
vendor.bak-*/
dump.rdb

# Scripts de manutenção temporários
remove_maintenance.php
checkout-desktop-snapshot.md

# Screenshots e imagens de auditoria/validação (root)
*.png
*.jpg
*.jpeg
alignment-*.png
header-*.png
home-*.png
homepage-*.jpg
homepage-*.jpeg
pdp-*.jpg
pdp-*.png
plp-*.png
width-*.png

# Artefatos do Playwright MCP e test-results
# Playwright auth state (contém cookies de sessão)
tests/e2e/.auth-state.json

# Relatórios e screenshots de UX audit (gerados automaticamente)
tests/e2e/reports/
tests/e2e/screenshots/ux-audit/

# Backups versionados de CSS (*.v10bak, *.v9bak, etc.)
*.v*bak
.playwright-mcp/
test-results/

# Relatórios gerados automaticamente (root)
LOG_OBSERVABILITY_REPORT_*.json
LOG_OBSERVABILITY_REPORT_*.md
OBSERVABILITY_NEXT_STEP_*.md
FOOTER_AUDIT_REPORT.md
FOOTER_REFINEMENTS_*.md

# Artefatos gerados em audit/ (PDFs, PNGs, HTML, CSV)
audit/pdp_disable_blocks/
audit/pdp_refinement_validation/
audit/technical_audit_latest/

# Caminhos Windows (arquivos locais que aparecem no git status remoto)
C:\\*
/C:/*

# Arquivos temporários de debug/audit na raiz
/var/debug/
debug_overflow*.js
awa-audit*.js
awa-visual-audit.js
home_ss*.js
home_audit.js
home_viewport.js
quick_ss.js
verify_fixes.js
tmp_inspect_minicart*.js
sw.js
nul
*.bak
*.bak_*
*.bak-*
/tmp_header_snapshot.html
/blocos/

# CSS archives / snapshots locais
app/design/frontend/AWA_Custom/ayo_home5_child/web/css/_archive_*/

# Arquivos de teste e trabalho temporário
pub/pdp-test.html
deploy-update.sh.bak*

# Documentação local / design system interno
design-system/
blocos/
blocos/
blocos/
blocos
infra/typebot/.env
infra/evolution/.env
