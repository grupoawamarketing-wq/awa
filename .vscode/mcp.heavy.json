{
	"_comment": "Perfil PESADO — só Playwright (1 Chrome). Ativar: scripts/mcp-performance.sh heavy-on",
	"servers": {
		"filesystem": {
			"type": "stdio",
			"command": "mcp-server-filesystem",
			"args": [
				"${workspaceFolder}/app/code/GrupoAwamotos",
				"${workspaceFolder}/app/code/Awa",
				"${workspaceFolder}/app/design/frontend/AWA_Custom",
				"${workspaceFolder}/app/etc",
				"${workspaceFolder}/var/log"
			],
			"env": {
				"NODE_OPTIONS": "--max-old-space-size=128"
			}
		},
		"playwright": {
			"type": "stdio",
			"command": "/usr/bin/playwright-mcp",
			"args": [
				"--browser",
				"chrome",
				"--no-sandbox",
				"--headless"
			],
			"env": {
				"PATH": "/usr/bin:/bin:/usr/local/bin",
				"NODE_OPTIONS": "--max-old-space-size=256"
			}
		}
	},
	"inputs": []
}
