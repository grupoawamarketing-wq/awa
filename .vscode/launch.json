{
    "version": "0.2.0",
    "configurations": [
        // ── Xdebug — aguarda conexão do PHP-FPM na porta 9003 ─────────────────
        {
            "name": "PHP: Xdebug Listen (port 9003)",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/home/jessessh/htdocs/srv1113343.hstgr.cloud": "${workspaceFolder}"
            },
            "ignore": [
                "**/vendor/**/*.php",
                "**/generated/**/*.php"
            ],
            "log": false
        },
        // ── PHP CLI: executa o arquivo PHP atual no terminal ──────────────────
        {
            "name": "PHP: Run Current File",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "port": 9003,
            "runtimeExecutable": "php",
            "pathMappings": {
                "/home/jessessh/htdocs/srv1113343.hstgr.cloud": "${workspaceFolder}"
            }
        }
    ]
}
