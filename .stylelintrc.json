{
  "extends": [
    "stylelint-config-standard"
  ],
  "rules": {
    "selector-class-pattern": null,
    "no-descending-specificity": null,
    "selector-id-pattern": null,
    "color-no-hex": [true, {
      "severity": "warning",
      "message": "Hardcoded hex color detected in source LESS. Use @awa-* token instead (see app/design/frontend/AWA_Custom/ayo_home5_child/web/css/source/_awa-variables.less)"
    }],
    "color-named": ["never", {
      "severity": "warning",
      "message": "Named colors not allowed. Use hex or @awa-* token"
    }]
  },
  "overrides": [
    {
      "files": ["**/source/*.less"],
      "rules": {
        "color-no-hex": [true, {
          "severity": "error"
        }]
      }
    },
    {
      "files": ["**/awa-bundle-*.unmin.css"],
      "rules": {
        "no-duplicate-selectors": null
      }
    }
  ]
}
