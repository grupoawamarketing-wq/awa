# Headwind MDM Community - variaveis de ambiente
# Copie para .env e preencha os valores

# Dominio publico do painel MDM
BASE_DOMAIN=monitoramento.awamotos.com

# E-mail do administrador (tambem usado no SSL)
ADMIN_EMAIL=admin@awamotos.com

# Banco PostgreSQL
SQL_BASE=hmdm
SQL_USER=hmdm
SQL_PASS=TROQUE_POR_SENHA_FORTE

# Segredo compartilhado do servidor (min 16 chars)
SHARED_SECRET=TROQUE_POR_SEGREDO_FORTE

# Variante e artefato oficial Community
HMDM_VARIANT=os
DOWNLOAD_CREDENTIALS=
HMDM_URL=https://h-mdm.com/files/hmdm-5.38.1-os.war
CLIENT_VERSION=6.31

# Idioma da base inicial (en|ru)
INSTALL_LANGUAGE=en

# Forca reconfiguracao do container no boot (true|false)
# Use true apenas para reconfiguracoes pontuais
FORCE_RECONFIGURE=false
