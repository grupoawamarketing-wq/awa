# Evolution API — variáveis de ambiente
# Copie para .env e preencha os valores
# NUNCA commite o .env no Git

# Chave de acesso global da API (min 32 chars — gere com: openssl rand -hex 32)
EVOLUTION_API_KEY=TROQUE_POR_CHAVE_FORTE_32CHARS

# Senha do banco PostgreSQL dedicado
EVOLUTION_DB_PASS=TROQUE_POR_SENHA_FORTE

# Senha do Redis do Magento (mesmo valor de app/etc/env.php)
REDIS_PASS=Aw4R3d1s2026Sec
