<?php declare(strict_types=1);
/**
 * AWA Override: Mirasvit_SearchLanding description.phtml
 *
 * Bug original: template do vendor usava $block->escapeHtml($description) que
 * renderizava o HTML da descrição como texto literal (tags visíveis na página).
 * Fix: o campo "description" é preenchido no Admin (conteúdo controlado) —
 * renderização como HTML é correta e segura. Usando @noEscape conforme padrão Magento.
 *
 * @var \Mirasvit\SearchLanding\Block\View $block
 */
if ($description = $block->getDescription()): ?>
    <div class="mst-search-landing__description category-description">
        <?= /* @noEscape */ $description ?>
    </div>
<?php endif; ?>
