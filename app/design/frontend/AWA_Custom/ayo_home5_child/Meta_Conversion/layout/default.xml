<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- AWA QA: remove pixel do head.additional para evitar execução precoce no head -->
        <referenceBlock name="meta.pixel.head" remove="true"/>

        <!-- Reinjeta Pixel no fim do body com boot em idle (requestIdleCallback + fallback) -->
        <referenceContainer name="before.body.end">
            <block class="Meta\Conversion\Block\Pixel\Head"
                   name="meta.pixel.idle"
                   ifconfig="facebook_business_extension/general/active"
                   template="Meta_Conversion::pixel/head-idle.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
