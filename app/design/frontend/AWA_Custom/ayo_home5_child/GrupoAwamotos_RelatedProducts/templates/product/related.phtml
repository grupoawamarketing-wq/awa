<?php
/**
 * AWA PDP — Produtos Relacionados (AWA Product Shelf Carousel)
 *
 * @var \GrupoAwamotos\RelatedProducts\Block\Product\Related $block
 */
declare(strict_types=1);

$collection = $block->getRelatedCollection();
if (!$collection || !$collection->getSize()) {
    return;
}

$canShowPrice = $block->canShowPrice();
$imageType    = 'category_page_grid';
$addLabel     = $block->escapeHtml((string) __('Adicionar'));
$soldOutLabel = $block->escapeHtml((string) __('Produto esgotado'));
$loginUrl     = $block->escapeUrl($block->getUrl('b2b/account/login'));
?>

<section class="awa-pdp-related awa-shelf awa-shelf--carousel"
         data-awa-shelf="related"
         aria-labelledby="awa-pdp-related-heading">

    <header class="rokan-product-heading rokan-featured-heading awa-shelf__header">
        <h2 id="awa-pdp-related-heading" class="awa-shelf__title">
            <?= $block->escapeHtml((string) __('Produtos Relacionados')) ?>
        </h2>
    </header>

    <div class="rokan-mostviewed">
        <div class="awa-carousel">
            <div class="awa-carousel__viewport awa-cq-card-wrapper"
                 role="region"
                 aria-roledescription="<?= $block->escapeHtmlAttr((string) __('carrossel')) ?>"
                 aria-label="<?= $block->escapeHtmlAttr((string) __('Produtos Relacionados')) ?>">
                <ul class="owl awa-carousel__track" aria-live="polite">
                    <?php foreach ($collection as $product): ?>
                    <li class="item awa-carousel__slide">
                        <div class="item-product awa-carousel-card-slot">
                            <div class="content-item-product awa-product-card">

                                <?php $productImage = $block->getImage($product, $imageType); ?>
                                <div class="product-thumb">
                                    <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>"
                                       class="product-thumb-link product photo product-item-photo"
                                       aria-label="<?= $block->escapeHtmlAttr($product->getName()) ?>">
                                        <span class="first-thumb">
                                            <?php
                                            $imgHtml = $productImage->toHtml();
                                            $imgHtml = str_replace('loading="eager"', 'loading="lazy"', $imgHtml);
                                            if (strpos($imgHtml, 'loading=') === false) {
                                                $imgHtml = str_replace('<img ', '<img loading="lazy" decoding="async" ', $imgHtml);
                                            }
                                            echo $imgHtml;
                                            ?>
                                        </span>
                                    </a>
                                </div>

                                <div class="product-info">
                                    <h3 class="product-name">
                                        <a class="product-item-link"
                                           href="<?= $block->escapeUrl($product->getProductUrl()) ?>"
                                           title="<?= $block->escapeHtmlAttr($product->getName()) ?>">
                                            <?= $block->escapeHtml($product->getName()) ?>
                                        </a>
                                    </h3>

                                    <?php if ($canShowPrice): ?>
                                    <div class="info-price">
                                        <div class="price-box">
                                            <?= /* @noEscape */ $block->getProductPrice($product) ?>
                                        </div>
                                    </div>
                                    <?php else: ?>
                                    <div class="info-price">
                                        <div class="price-box price-box--hidden awa-related-price-box--hidden b2b-login-to-see-price">
                                            <span class="awa-related-price-notice">
                                                <a class="awa-related-price-notice__login-link"
                                                   href="<?= /* @noEscape */ $loginUrl ?>">
                                                    <?= $block->escapeHtml((string) __('Faça login')) ?>
                                                </a>
                                                <span class="awa-related-price-notice__suffix">
                                                    <?= $block->escapeHtml((string) __('para ver preços')) ?>
                                                </span>
                                            </span>
                                        </div>
                                    </div>
                                    <?php endif; ?>

                                    <div class="product-info-cart">
                                        <div class="actions-primary addcart-link product-actions">
                                            <?php if ($canShowPrice && $product->isSaleable()): ?>
                                                <?php $postParams = $block->getAddToCartPostParams($product); ?>
                                                <?php if (!empty($postParams['action']) && !empty($postParams['data']) && is_array($postParams['data'])): ?>
                                                <form data-role="tocart-form"
                                                      class="related-tocart-form"
                                                      action="<?= $block->escapeUrl((string) $postParams['action']) ?>"
                                                      method="post">
                                                    <?php foreach ($postParams['data'] as $key => $value): ?>
                                                    <input type="hidden"
                                                           name="<?= $block->escapeHtmlAttr((string) $key) ?>"
                                                           value="<?= $block->escapeHtmlAttr((string) $value) ?>">
                                                    <?php endforeach; ?>
                                                    <button type="submit"
                                                            class="action tocart primary btn-add-to-cart related-addtocart"
                                                            aria-label="<?= $block->escapeHtmlAttr((string) __('Adicionar %1 ao carrinho', $product->getName())) ?>">
                                                        <span><?= /* @noEscape */ $addLabel ?></span>
                                                    </button>
                                                </form>
                                                <?php endif; ?>
                                            <?php elseif ($canShowPrice): ?>
                                                <div class="stock unavailable" aria-live="polite">
                                                    <span><?= /* @noEscape */ $soldOutLabel ?></span>
                                                </div>
                                            <?php endif; ?>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </li>
                    <?php endforeach; ?>
                </ul>
            </div>
        </div>
    </div>
</section>

<script type="text/x-magento-init">
{
    "[data-role=tocart-form]": {
        "catalogAddToCart": {}
    }
}
</script>
