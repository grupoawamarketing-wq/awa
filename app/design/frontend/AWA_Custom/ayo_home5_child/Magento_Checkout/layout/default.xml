<?xml version="1.0"?>
<!--
/**
 * AWA Motos — blocos B2B no painel do minicart (minicart.addons).
 * Montados via JS em #awa-minicart-addons-mount após a lista de itens.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="minicart.addons">
            <block class="GrupoAwamotos\B2B\Block\Cart\MinOrderProgress"
                   name="awa.minicart.min.order.progress"
                   template="GrupoAwamotos_B2B::cart/min-order-progress-minicart.phtml"
                   before="-"/>
            <block class="GrupoAwamotos\ERPIntegration\Block\Cart\FreeShippingProgress"
                   name="awa.minicart.free.shipping"
                   template="GrupoAwamotos_ERPIntegration::cart/free-shipping-progress.phtml"
                   after="awa.minicart.min.order.progress">
                <arguments>
                    <argument name="minicart_mode" xsi:type="boolean">true</argument>
                </arguments>
            </block>
            <block class="GrupoAwamotos\ERPIntegration\Block\Cart\MinicartCoupon"
                   name="awa.minicart.coupon"
                   template="GrupoAwamotos_ERPIntegration::cart/minicart-coupon.phtml"
                   after="awa.minicart.free.shipping"/>
        </referenceContainer>
    </body>
</page>
