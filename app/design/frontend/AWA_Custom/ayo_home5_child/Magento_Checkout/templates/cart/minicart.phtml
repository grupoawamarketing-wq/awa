<?php
declare(strict_types=1);

/**
 * Child-theme minicart override.
 * - Preserve AWA visual markup
 * - Remove ObjectManager usage
 * - Harden JSON/static URLs against control characters
 *
 * @var \Magento\Checkout\Block\Cart\Sidebar $block
 */

$sanitizeUrl = static function (?string $value): string {
    $sanitized = (string) $value;
    $sanitized = preg_replace('/[\x00-\x1F\x7F]+/u', '', $sanitized);

    return $sanitized ?? '';
};

$request = $block->getRequest();
$isHomeUiDefer = $request && (string) $request->getFullActionName() === 'cms_index_index';

$serializedCheckoutConfig = method_exists($block, 'getSerializedConfig')
    ? (string) $block->getSerializedConfig()
    : (string) json_encode($block->getConfig(), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);

$blockLoaderUrl = $sanitizeUrl($block->getViewFileUrl('images/loader-1.gif'));
?>

<div data-block="minicart" class="minicart-wrapper">
    <a class="action showcart header-mini-cart" href="<?= $block->escapeUrl($block->getShoppingCartUrl()) ?>"
       style="opacity:1 !important; visibility:visible !important; display:flex !important;"
       aria-haspopup="dialog"
       title="<?= $block->escapeHtmlAttr(__('Ver carrinho de compras')) ?>"
       aria-label="<?= $block->escapeHtmlAttr(__('Ver carrinho de compras')) ?>"
       aria-expanded="false"
       aria-controls="minicart-content-wrapper"
       data-bind="scope: 'minicart_content'">
        <span class="awa-sr-only"><?= $block->escapeHtml(__('Carrinho de compras')) ?> </span>
        <svg class="awa-minicart-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block !important; width:20px !important; height:20px !important; min-width:20px !important; min-height:20px !important; visibility:visible !important; opacity:1 !important;">
            <circle cx="9" cy="20" r="1"></circle>
            <circle cx="18" cy="20" r="1"></circle>
            <path d="M3.5 4h2l2.2 10.2a1 1 0 0 0 1 .8h8.6a1 1 0 0 0 1-.8L20 7H7.1"></path>
        </svg>
        <span class="counter qty empty"
              aria-live="polite"
              aria-atomic="true"
              data-bind="css: { empty: !!getCartParam('summary_count') == false }, blockLoader: isLoading">
            <span class="total-mini-cart-item">
            <!-- ko if: getCartParam('summary_count') -->
                <!-- ko text: getCartParam('summary_count') --><!-- /ko -->
            <!-- /ko -->
            <!-- ko if: !getCartParam('summary_count') -->
                0
            <!-- /ko -->
            </span>
        </span>
    </a>
    <?php if ($block->getIsNeedToDisplaySideBar()): ?>
        <div class="block block-minicart empty"
                 data-role="dropdownDialog"
                 <?php if (!$isHomeUiDefer): ?>
                 data-mage-init='{"dropdownDialog":{
                    "appendTo":"[data-block=minicart]",
                    "triggerTarget":".showcart",
                    "timeout": "0",
                    "closeOnMouseLeave": false,
                    "closeOnEscape": true,
                    "triggerClass":"is-open",
                    "parentClass":"is-open",
                    "buttons":[]}}'
                 <?php endif; ?>>
            <div id="minicart-content-wrapper"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="minicart-title"
                 data-bind="scope: 'minicart_content'">
                <!-- ko template: getTemplate() --><!-- /ko -->
            </div>

            <?= $block->getChildHtml('minicart.addons') ?>
            <div class="awa-minicart-b2b-trust">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                <span><strong><?= $block->escapeHtml(__('Ambiente Seguro B2B')) ?></strong> | <?= $block->escapeHtml(__('Faturamento CNPJ')) ?></span>
            </div>
        </div>

    <?php endif ?>
    <script>
        (function () {
            var minicartConfig = <?= /* @noEscape */ $serializedCheckoutConfig ?> || {};
            // applyCartIcon removido: o SVG inline em .awa-minicart-icon já garante
            // visibilidade com estilos inline próprios. Background-image duplicava o ícone.

            var fallbackCheckoutConfig = Object.assign({
                storeCode: '',
                quoteData: {
                    entity_id: null,
                    is_virtual: 0,
                    is_persistent: 0
                },
                quoteItemData: [],
                totalsData: {
                    items: [],
                    subtotal: 0,
                    total_segments: []
                },
                priceFormat: minicartConfig.priceFormat || {},
                basePriceFormat: minicartConfig.basePriceFormat || minicartConfig.priceFormat || {}
            }, minicartConfig);

            window.checkout = minicartConfig;
            window.checkoutConfig = Object.assign(
                {},
                fallbackCheckoutConfig,
                window.checkoutConfig || {}
            );
        }());
    </script>
    <?php if (!$isHomeUiDefer): ?>
    <script type="text/x-magento-init">
    {
        "[data-block='minicart']": {
            "Magento_Ui/js/core/app": <?= /* @noEscape */ $block->getJsLayout() ?>
        },
        "*": {
            "Magento_Ui/js/block-loader": "<?= $block->escapeJs($block->escapeUrl($blockLoaderUrl)) ?>"
        }
    }
    </script>
    <?php endif; ?>
</div>
