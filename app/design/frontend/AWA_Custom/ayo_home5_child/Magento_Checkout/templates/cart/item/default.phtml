<?php
declare(strict_types=1);
/**
 * AWA — Cart item row override.
 * Idêntico ao vendor default, exceto que as imagens de thumbnail do carrinho
 * são renderizadas com loading="eager" (não "lazy").
 *
 * Motivação: itens do carrinho são always-above-fold. O Magento renderiza o
 * product/image_with_borders.phtml com loading="lazy" hardcoded (vendor), o que
 * causa caixas brancas no first-load de carrinhos com itens. Override 2026-05-27.
 *
 * @var \Magento\Checkout\Block\Cart\Item\Renderer $block
 */

// phpcs:disable Magento2.Templates.ThisInTemplate
// phpcs:disable Generic.Files.LineLength

$_item = $block->getItem();
$product = $_item->getProduct();
$isVisibleProduct = $product->isVisibleInSiteVisibility();
/** @var \Magento\Msrp\Helper\Data $helper */
$helper = $this->helper(Magento\Msrp\Helper\Data::class);
$canApplyMsrp = $helper->isShowBeforeOrderConfirm($product) && $helper->isMinimalPriceLessMsrp($product);

// Captura o HTML da imagem e força loading=eager (above-fold no carrinho)
$thumbnailHtml = $block->getImage($block->getProductForThumbnail(), 'cart_page_product_thumbnail')->toHtml();
$thumbnailHtml = str_replace(' loading="lazy"', ' loading="eager"', $thumbnailHtml);

$ariaItemLabel = $block->escapeHtmlAttr(
    (string) __('Cart line: %1, quantity %2', $block->getProductName(), $block->getQty())
);
?>
<tbody class="cart item" role="rowgroup" aria-label="<?= $ariaItemLabel ?>">
    <tr class="item-info" role="row">
        <td data-th="<?= $block->escapeHtml(__('Produto')) ?>"
            class="col item"
            role="cell"
            headers="awa-cart-col-item">
            <?php if ($block->hasProductUrl()): ?>
                <?php /* tabindex="-1": produto já é acessível pelo link do nome logo abaixo; evitar dupla tabulação para o mesmo destino */ ?>
                <a href="<?= $block->escapeUrl($block->getProductUrl()) ?>"
                   title="<?= $block->escapeHtml($block->getProductName()) ?>"
                   tabindex="-1"
                   class="product-item-photo">
            <?php else: ?>
                <span class="product-item-photo">
            <?php endif; ?>
            <?= /* @noEscape */ $thumbnailHtml ?>
            <?php if ($block->hasProductUrl()): ?>
                </a>
            <?php else: ?>
                </span>
            <?php endif; ?>
            <div class="product-item-details">
                <strong class="product-item-name">
                    <?php if ($block->hasProductUrl()): ?>
                        <a href="<?= $block->escapeUrl($block->getProductUrl()) ?>"><?= $block->escapeHtml($block->getProductName()) ?></a>
                    <?php else: ?>
                        <?= $block->escapeHtml($block->getProductName()) ?>
                    <?php endif; ?>
                </strong>
                <?php if ($_sku = $_item->getSku()): ?>
                    <span class="awa-cart-item-sku">Ref: <?= $block->escapeHtml($_sku) ?></span>
                <?php endif; ?>
                <?php if ($_options = $block->getOptionList()): ?>
                    <dl class="item-options">
                        <?php foreach ($_options as $_option): ?>
                            <?php $_formatedOptionValue = $block->getFormatedOptionValue($_option) ?>
                            <dt><?= $block->escapeHtml($_option['label']) ?></dt>
                            <dd>
                                <?php if (isset($_formatedOptionValue['full_view'])): ?>
                                        <?= $block->escapeHtml($_formatedOptionValue['full_view'], ['span', 'a']) ?>
                                    <?php else: ?>
                                        <?= $block->escapeHtml($_formatedOptionValue['value'], ['span', 'a']) ?>
                                <?php endif; ?>
                            </dd>
                        <?php endforeach; ?>
                    </dl>
                <?php endif; ?>
                <?php if ($messages = $block->getMessages()): ?>
                    <?php foreach ($messages as $message): ?>
                        <div class="cart item message <?= $block->escapeHtmlAttr($message['type']) ?>">
                            <div><?= $block->escapeHtml($message['text']) ?></div>
                        </div>
                    <?php endforeach; ?>
                <?php endif; ?>
                <?php $addInfoBlock = $block->getProductAdditionalInformationBlock(); ?>
                <?php if ($addInfoBlock): ?>
                    <?= $addInfoBlock->setItem($_item)->toHtml() ?>
                <?php endif; ?>
                <div class="awa-cart-item-actions actions-toolbar">
                    <?= /* @noEscape */ $block->getActions($_item) ?>
                </div>
            </div>
        </td>

        <?php if ($canApplyMsrp): ?>
            <td class="col msrp"
                data-th="<?= $block->escapeHtml(__('Preço unit.')) ?>"
                role="cell"
                headers="awa-cart-col-price">
                <span class="pricing msrp">
                    <span class="msrp notice"><?= $block->escapeHtml(__('See price before order confirmation.')) ?></span>
                    <?php $helpLinkId = 'cart-msrp-help-' . $_item->getId(); ?>
                    <a href="#" class="action help map"
                       id="<?= ($block->escapeHtmlAttr($helpLinkId)) ?>"
                       data-mage-init='{"addToCart":{
                                            "origin": "info",
                                            "helpLinkId": "#<?= $block->escapeJs($block->escapeHtml($helpLinkId)) ?>",
                                            "productName": "<?= $block->escapeJs($block->escapeHtml($product->getName())) ?>",
                                            "showAddToCart": false
                                            }
                                        }'
                    >
                        <span><?= $block->escapeHtml(__("What's this?")) ?></span>
                    </a>
                </span>
            </td>
        <?php else: ?>
            <td class="col price"
                data-th="<?= $block->escapeHtml(__('Preço unit.')) ?>"
                role="cell"
                headers="awa-cart-col-price">
                <?= $block->getUnitPriceHtml($_item) ?>
            </td>
        <?php endif; ?>
        <td class="col qty"
            data-th="<?= $block->escapeHtml(__('Qtd.')) ?>"
            role="cell"
            headers="awa-cart-col-qty">
            <div class="field qty">
                <label class="label awa-sr-only" for="cart-<?= $block->escapeHtmlAttr($_item->getId()) ?>-qty">
                    <span><?= $block->escapeHtml(__('Qtd.')) ?></span>
                </label>
                <div class="control qty awa-qty-stepper"
                     data-mage-init='{"js/awa-qty-control": {}}'>
                    <button type="button"
                            class="awa-qty-btn"
                            data-awa-role="qty-trigger"
                            data-awa-direction="decrement"
                            aria-label="<?= $block->escapeHtmlAttr(__('Diminuir quantidade')) ?>">−</button>
                    <input id="cart-<?= $block->escapeHtmlAttr($_item->getId()) ?>-qty"
                           name="cart[<?= $block->escapeHtmlAttr($_item->getId()) ?>][qty]"
                           data-cart-item-id="<?= $block->escapeHtmlAttr($_item->getSku()) ?>"
                           value="<?= $block->escapeHtmlAttr($block->getQty()) ?>"
                           type="number"
                           min="0"
                           step="1"
                           title="<?= $block->escapeHtmlAttr(__('Qtd.')) ?>"
                           class="input-text qty"
                           data-awa-role="qty-input"
                           data-validate="{required:true,'validate-greater-than-zero':true}"
                           data-item-qty="<?= $block->escapeHtmlAttr($block->getQty()) ?>"
                           data-role="cart-item-qty"/>
                    <button type="button"
                            class="awa-qty-btn"
                            data-awa-role="qty-trigger"
                            data-awa-direction="increment"
                            aria-label="<?= $block->escapeHtmlAttr(__('Aumentar quantidade')) ?>">+</button>
                </div>
            </div>
        </td>

        <td class="col subtotal"
            data-th="<?= $block->escapeHtml(__('Subtotal')) ?>"
            role="cell"
            headers="awa-cart-col-subtotal">
            <?php if ($canApplyMsrp): ?>
                <span class="cart msrp subtotal">--</span>
            <?php else: ?>
                <?= $block->getRowTotalHtml($_item) ?>
            <?php endif; ?>
        </td>
    </tr>
</tbody>
