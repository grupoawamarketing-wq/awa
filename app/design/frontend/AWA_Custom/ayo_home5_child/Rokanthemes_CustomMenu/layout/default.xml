<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            Remove original custom.topnav declaration from module (it binds to
            group="navigation-sections" and gets rendered twice in this theme).
        -->
        <referenceBlock name="custom.topnav" remove="true"/>

        <!--
            Re-create custom.topnav without navigation-sections group.
            It will still be moved to toki_header by theme layout default.xml.
        -->
        <referenceContainer name="page.top">
            <block class="Rokanthemes\CustomMenu\Block\Topmenu"
                   name="custom.topnav"
                   template="Rokanthemes_CustomMenu::topmenu.phtml"
                   ttl="3600"
                   before="-"/>
        </referenceContainer>
    </body>
</page>
