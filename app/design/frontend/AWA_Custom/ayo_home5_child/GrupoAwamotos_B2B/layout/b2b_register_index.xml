<?xml version="1.0"?>
<!--
/**
 * AWA Custom B2B Register Form — Layout Override
 *
 * Carrega CSS de override após o CSS do módulo para garantir que as melhorias
 * de UX/UI do tema (awa-bundle-auth.css, b2b/auth/refine.css) não sejam
 * sobrescritas pelo register.css do módulo.
 *
 * Ordem de carregamento:
 * 1. b2b_auth_shell.xml (tema) → awa-bundle-auth.css, awa-bundle-inner-pages.css
 * 2. b2b_register_index.xml (módulo) → GrupoAwamotos_B2B::css/account/register.css
 * 3. b2b_register_index.xml (ESTE arquivo - tema OVERRIDE) → css/b2b/register-override.css ← FINAL
 *
 * Solução: b2b/register-override.css sobrescreve register.css com proper specificity
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- Override do register.css do módulo — garantir que form improvements do tema prevaleçam -->
        <css src="css/b2b/register-override.css"/>
        <!-- Carrega refine.css específico para auth B2B if needed -->
        <css src="css/b2b/auth/refine.css"/>
    </head>
</page>
