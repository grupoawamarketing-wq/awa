<?xml version="1.0"?>
<!--
    AWA B2B auth shell — performance + a11y (login, forgot, claim, register).
    Header/footer e bundles globais omitidos do DOM; CSS crítico cobre o shell auth.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <remove src="css/print.css"/>
        <css src="css/awa-b2b-auth-shell-final.css" order="10000"/>
    </head>
    <body>
        <referenceContainer name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.b2b.auth.critical.css"
                   template="GrupoAwamotos_B2B::html/awa-b2b-auth-critical-css.phtml"
                   before="-"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.b2b.auth.seo"
                   template="GrupoAwamotos_B2B::html/awa-b2b-auth-seo.phtml"
                   after="awa.b2b.auth.critical.css"/>
        </referenceContainer>

        <referenceBlock name="add_custom_theme_head" remove="true"/>
        <referenceBlock name="authentication-popup" remove="true"/>
        <referenceBlock name="toki_header" remove="true"/>
        <referenceBlock name="toki_footer" remove="true"/>
        <referenceBlock name="grupoawamotos.menu.bootstrap" remove="true"/>
        <referenceBlock name="awa.nav.quick.links" remove="true"/>
        <referenceBlock name="awa.cls.nav.fix" remove="true"/>
        <referenceBlock name="awa.critical.inline.css" remove="true"/>
        <referenceBlock name="awa.deferred.interaction.css" remove="true"/>
        <referenceBlock name="awa.deferred.cosmetic.css" remove="true"/>
        <referenceBlock name="awa.styles.l.last" remove="true"/>
        <referenceBlock name="awa.search.autocomplete.head.css" remove="true"/>
        <referenceBlock name="awa.search.autocomplete.body.css" remove="true"/>
        <referenceBlock name="awa.mobile.nav" remove="true"/>
        <referenceBlock name="awa.audit.bundle.css" remove="true"/>
        <referenceBlock name="awa.header.impeccable.critical.global" remove="true"/>
        <referenceBlock name="awa.impeccable.audit.uncached.global.v10" remove="true"/>
        <referenceBlock name="awa.impeccable.loopback.guard.global" remove="true"/>
        <referenceBlock name="awa.shelf.carousel" remove="true"/>
        <referenceBlock name="awa.back.to.top" remove="true"/>
        <referenceBlock name="awa.a11y.product.links" remove="true"/>
        <referenceBlock name="awa.a11y.nav.links" remove="true"/>
        <referenceBlock name="awa.card.enhance" remove="true"/>
        <referenceBlock name="grupoawamotos_whatsapp_btn" remove="true"/>
        <referenceBlock name="meta.pixel.idle" remove="true"/>
        <referenceBlock name="pagebuilder.widget.initializer" remove="true"/>
        <referenceBlock name="customer.customer.data" remove="true"/>
        <referenceBlock name="sale.reorder.sidebar" remove="true"/>
        <referenceBlock name="awa.og.meta" remove="true"/>
        <referenceBlock name="autocomplete.injection.js" remove="true"/>
        <referenceBlock name="autocomplete.injection.template" remove="true"/>
        <referenceBlock name="quickview" remove="true"/>
        <referenceBlock name="ajaxWishlistJs" remove="true"/>
        <referenceBlock name="ajaxsuite.popup.wrapper" remove="true"/>
        <referenceBlock name="grupoawamotos.schema.organization" remove="true"/>
        <referenceBlock name="awa.cookie.consent.fix.css" remove="true"/>
        <referenceBlock name="awa.cookie.consent.defer.loader" remove="true"/>
        <referenceBlock name="awa.custom.global.js.loader" remove="true"/>
        <referenceBlock name="newsletter_popup" remove="true"/>

        <!-- tabindex=-1 em #maincontent: awa-b2b-auth-critical-css.phtml (layout <attribute> inválido no XSD 2.4) -->
    </body>
</page>
