<?xml version="1.0"?>
<!--
    AWA B2B — Customer Login Page Layout Override
    Injeta bloco de informações B2B na sidebar do login
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- AWA Design System — Login page styling -->
        <css src="css/awa-customer-pages.css" order="1320"/>
    </head>
    <body>
        <!-- B2B Info Block acima do formulário de login -->
        <referenceContainer name="customer.login.container">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.b2b.login.info"
                   template="Magento_Theme::html/awa-b2b-login-info.phtml"
                   before="-"/>
        </referenceContainer>
    </body>
</page>
