<?xml version="1.0"?>
<!--
    AWA Motos — Set new password auth layout
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <attribute name="class" value="awa-auth-password-page"/>
        <referenceBlock name="page.main.title">
            <arguments>
                <argument name="css_class" xsi:type="string">awa-auth-page-title</argument>
            </arguments>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.auth.footer.minimal.createpassword"
                   template="Magento_Theme::html/awa-auth-footer-minimal.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
