<?php
/** @var \Magento\Framework\View\Element\Template $block */
?>
<?php
$links = $block->getLinks();
if (empty($links)) {
    return;
}
?>
<div class="account-nav-wrapper" role="navigation" aria-label="<?= $block->escapeHtmlAttr(__('Account Navigation')) ?>">
    <div class="account-nav-title">
        <strong><?= $block->escapeHtml(__('Account')) ?></strong>
    </div>
    <ul class="account-nav-items" role="menubar">
        <?php foreach ($links as $link): ?>
            <li class="account-nav-item<?= $link['active'] ? ' current' : '' ?>" role="none">
                <?php if ($link['current']): ?>
                    <strong class="account-nav-text" role="menuitem" aria-current="page">
                        <?= $block->escapeHtml($link['label']) ?>
                    </strong>
                <?php else: ?>
                    <a href="<?= $block->escapeUrl($link['href']) ?>" class="account-nav-link" role="menuitem" tabindex="0">
                        <?= $block->escapeHtml($link['label']) ?>
                    </a>
                <?php endif; ?>
            </li>
        <?php endforeach; ?>
    </ul>
</div>
