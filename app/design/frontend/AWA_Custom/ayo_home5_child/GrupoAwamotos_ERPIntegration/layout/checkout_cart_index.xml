<?xml version="1.0"?>
<!--
/**
 * Child-theme layout merge for ERP Suggestions on Cart.
 * Removes the sidebar duplicate widget so the main widget renders
 * full-width below the cart table.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="erp.cart.suggestions.sidebar" remove="true"/>
    </body>
</page>
