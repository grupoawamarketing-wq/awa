            var isHomePage = /^\/(?:index\.php\/?)*$/.test(pathName) || /\bcms-index-index\b|\bcms-home\b|\bcms-homepage_ayo_home5\b/.test(bodyClassName);


            // Homepage: bloquear carga antecipada do awa-search-autocomplete-compat via minicart UI.
            // O minicart check busca #searchAutocompletePlaceholder antes de carregar o compat.
