<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- AWA QA Fix: remove bpopup do <head> (bloqueante) — reinjetado via defer em before.body.end -->
        <remove src="Rokanthemes_Themeoption::js/jquery.bpopup.min.js"/>
    </head>
    <body>
        <!-- NOTE (2026-03-23): AsyncCSS blocks consolidated in Magento_Theme/layout/default_head_blocks.xml
             for proper ordering and consistency across all page types.
             This prevents potential layout resolution order issues.
        -->
        <referenceContainer name="head.additional">
            <!-- awa.post.themeoption.css: DESATIVADO — 5 CSS migrados para awa-bundle-site.css (2026-03-16).
                 Bloco consolidado em Magento_Theme/layout/default_head_blocks.xml. -->
            <!-- awa.deferred.interaction.css: Consolidado em Magento_Theme/layout/default_head_blocks.xml (2026-03-23). -->
        </referenceContainer>

        <referenceContainer name="page.wrapper">
            <block class="Rokanthemes\Themeoption\Block\Themeoption" name="toki_header" template="html/header.phtml" before="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\HeaderData</argument>
                    <argument name="contact_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\ContactInfo</argument>
                </arguments>
                <block class="Magento\Cms\Block\Block" name="top-contact">
                    <arguments>
                        <argument name="block_id" xsi:type="string">top-contact</argument>
                    </arguments>
                </block>
                <block class="Magento\Cms\Block\Block" name="top-left-static">
                    <arguments>
                        <argument name="block_id" xsi:type="string">top-left-static</argument>
                    </arguments>
                </block>
                <block class="Magento\Cms\Block\Block" name="hotline_header">
                    <arguments>
                        <argument name="block_id" xsi:type="string">hotline_header</argument>
                    </arguments>
                </block>
                <block class="Magento\Framework\View\Element\Template"
                       name="awa.header.contact.links"
                       as="headerContactLinks"
                       template="Magento_Theme::html/awa-header-contact-links.phtml"
                       cacheable="true">
                    <arguments>
                        <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\ContactInfo</argument>
                    </arguments>
                </block>
                <block class="Magento\Framework\View\Element\Template" name="awa.top.search" as="topSearch" template="Magento_Search::form.mini.phtml">
                    <arguments>
                        <argument name="configProvider" xsi:type="object">Magento\Search\ViewModel\ConfigProvider</argument>
                        <argument name="additionalSearchFormData" xsi:type="object">Magento\Search\ViewModel\AdditionalSearchFormData</argument>
                    </arguments>
                </block>
                <block class="Magento\Framework\View\Element\Template" name="top.navigation.sections" template="Magento_Theme::html/sections.phtml">
                    <arguments>
                        <argument name="group_name" xsi:type="string">navigation-sections</argument>
                        <argument name="group_css" xsi:type="string">nav-sections category-dropdown</argument>
                    </arguments>
                    <block class="Rokanthemes\VerticalMenu\Block\Verticalmenu" name="menu.vertical" template="Rokanthemes_VerticalMenu::sidemenu.phtml" group="navigation-sections" before="-" ttl="3600">
                        <arguments>
                            <argument name="cache_lifetime" xsi:type="number">7200</argument>
                        </arguments>
                    </block>
                </block>
            </block>
        </referenceContainer>

        <move element="store_language" destination="toki_header"/>
        <move element="currency" destination="toki_header"/>
        <move element="header" destination="toki_header"/>
        <move element="header.links" destination="toki_header"/>
        <move element="logo" destination="toki_header"/>
        <move element="minicart" destination="toki_header"/>
        <move element="top.search" destination="toki_header"/>
        <move element="top.links" destination="toki_header"/>
        <move element="notifications" destination="toki_header"/>
        <move element="slideshow.top" destination="toki_header"/>
        <move element="custom.topnav" destination="toki_header"/>

        <referenceBlock name="my-account-link" template="Rokanthemes_Themeoption::customer/account/link.phtml"/>
        <referenceBlock name="register-link" template="Rokanthemes_Themeoption::customer/account/register_link.phtml">
            <arguments>
                <argument name="label" xsi:type="string" translate="true">create account</argument>
            </arguments>
        </referenceBlock>
        <referenceBlock name="logo" template="Rokanthemes_Themeoption::html/header/logo.phtml"/>

        <referenceContainer name="header.container" remove="true"/>
        <referenceContainer name="header.panel" remove="true"/>
        <referenceContainer name="header-wrapper" remove="true"/>
        <referenceContainer name="navigation.sections" remove="true"/>

        <!-- compatibility sink for 3rd-party blocks that still target magento default
             header/footer containers removed by ayo. kept display=false to avoid visual output. -->
        <referenceContainer name="page.wrapper">
            <container name="awa.layout.compat" as="awa_layout_compat">
                <container name="header"/>
                <container name="notifications"/>
                <container name="global.notices"/>
                <container name="page.menu"/>
                <container name="page.breadcrumbs"/>
                <container name="page.formkey"/>
                <container name="main.top"/>
                <container name="page.messages"/>
                <container name="page.main.actions"/>
                <container name="footer"/>
            </container>
        </referenceContainer>
        <referenceContainer name="awa.layout.compat" display="false"/>

        <referenceContainer name="footer-container">
            <block class="Rokanthemes\Themeoption\Block\Themeoption" name="toki_footer" template="html/footer.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\FooterData</argument>
                </arguments>
                <block class="Magento\Cms\Block\Block" name="footer-tags">
                    <arguments>
                        <argument name="block_id" xsi:type="string">footer-tags</argument>
                    </arguments>
                </block>
                <!-- awa_footer_business_contact removido: seção renderizada inline em footer.phtml -->
                <block class="Magento\Framework\View\Element\Template"
                       name="footer_static5"
                       template="Rokanthemes_Themeoption::html/footer/footer-static5.phtml">
                    <arguments>
                        <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\FooterData</argument>
                    </arguments>
                </block>
                <block class="Magento\Cms\Block\Block" name="fixed_right">
                    <arguments>
                        <argument name="block_id" xsi:type="string">fixed_right</argument>
                    </arguments>
                </block>
                <block class="Magento\Cms\Block\Block" name="footer_payment">
                    <arguments>
                        <argument name="block_id" xsi:type="string">footer_payment</argument>
                    </arguments>
                </block>
                <block class="Rokanthemes\Brand\Block\BrandList"
                       name="footer_brand_list"
                       as="footer_brand_list"
                       template="Rokanthemes_Brand::block/brand_list_owl.phtml"
                       ifconfig="rokanthemesbrand/general_settings/enable"/>
            </block>
        </referenceContainer>

        <move element="footer_links" destination="toki_footer"/>
        <move element="store_switcher" destination="toki_footer"/>
        <!-- remove o bloco copyright do magento default para evitar conflito de alias
             com toki_copyright (as="copyright") ja definido no tema pai ayo_default -->
        <referenceBlock name="copyright" remove="true"/>

        <referenceContainer name="report.bugs" remove="1"/>
        <referenceContainer name="form.subscribe" remove="1"/>

        <referenceContainer name="page.top">
            <container name="nav.breadcrumbs" htmlTag="div" htmlClass="nav-breadcrumbs">
                <container name="nav.breadcrumbs.container" htmlTag="div" htmlClass="container">
                    <container name="menu.rowbar" htmlTag="div" htmlClass="row">
                        <container name="menu.bar.col2" htmlTag="div" htmlClass="col-sm-12" after="-">
                            <block class="Magento\Theme\Block\Html\Breadcrumbs" name="breadcrumbs" as="breadcrumbs"/>
                        </container>
                    </container>
                </container>
            </container>
        </referenceContainer>

        <!-- wishlist e compare sidebar restaurados — fidelidade ao demo ayo home5 -->
    </body>
</page>
