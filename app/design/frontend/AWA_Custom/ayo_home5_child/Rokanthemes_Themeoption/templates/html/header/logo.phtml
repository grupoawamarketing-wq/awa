<?php
/**
 * AWA Custom Logo Template
 * Refactored for performance (lazy loading + fetchpriority) and accessibility.
 *
 * @var \Magento\Theme\Block\Html\Header\Logo $block
 * @var \Magento\Framework\Escaper $escaper
 */

$storeName = $block->getThemeName() ? $block->getThemeName() : $block->getLogoAlt();
$logoUrl = $block->getUrl('');
$logoSrc = $block->getLogoSrc();
$logoAlt = $block->getLogoAlt();

$logoWidth = (int)$block->getLogoWidth() ?: 180;
$logoHeight = (int)$block->getLogoHeight() ?: 55;
?>
<div class="logo">
    <a href="<?= $escaper->escapeUrl($logoUrl) ?>" title="<?= $escaper->escapeHtmlAttr($storeName) ?>">
        <img src="<?= $escaper->escapeUrl($logoSrc) ?>"
             alt="<?= $escaper->escapeHtmlAttr($logoAlt) ?>"
             width="<?= $escaper->escapeHtmlAttr($logoWidth) ?>"
             height="<?= $escaper->escapeHtmlAttr($logoHeight) ?>"
             loading="eager" 
             fetchpriority="high" />
    </a>
</div>
