$headerExperimentActive = !empty($headerExperimentPayload['is_active']);
$headerExperimentStateClass = $headerExperimentActive ? ' awa-header-exp-active' : ' awa-header-exp-control';
$headerExperimentVariantClass = ' awa-header-exp--' . preg_replace('/[^a-z0-9_-]+/i', '-', strtolower($headerExperimentVariant));

