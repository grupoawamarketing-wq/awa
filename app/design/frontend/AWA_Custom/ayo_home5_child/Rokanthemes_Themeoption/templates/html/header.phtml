<script>
/* awa-header-runtime-bootstrap: defer idle na home (sticky/focus-trap não são críticos no first paint) */
(function (w, d) {
    'use strict';
    var done = false;
    function boot() {
        if (done) { return; }
        done = true;
        if (typeof w.require !== 'function') { w.setTimeout(boot, 200); done = false; return; }
        var s = d.createElement('script');
        s.type = 'text/x-magento-init';
        s.textContent = JSON.stringify({ '*': { 'awa-header-runtime-bootstrap': {} } });
        d.body.appendChild(s);
        w.require(['mage/apply/main']);
    }
    var events = ['pointerdown', 'touchstart', 'keydown'];
    events.forEach(function (ev) {
        w.addEventListener(ev, boot, { capture: true, passive: ev !== 'keydown', once: true });
    });
})(window, document);
</script>
<?php else: ?>
<script type="text/x-magento-init">
{
    "*": {
        "awa-header-runtime-bootstrap": {}
    }
}
</script>
