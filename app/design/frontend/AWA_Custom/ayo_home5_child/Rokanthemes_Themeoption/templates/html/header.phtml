<?php
declare(strict_types=1);

/** @var \Rokanthemes\Themeoption\Block\Themeoption $block */
/** @var \Magento\Framework\Escaper $escaper */
$headerExperimentPayload = [
    'enabled' => false,
    'rollout_percentage' => 0,
    'bucket' => 0,
    'seed' => 'guest:anonymous',
    'variant' => 'control',
    'is_active' => false,
];

try {
    $headerExperimentHelper = $this->helper('GrupoAwamotos\Theme\Helper\HeaderExperiment');
    $resolvedPayload = $headerExperimentHelper->getPayload();

    if (is_array($resolvedPayload)) {
        $headerExperimentPayload = array_merge($headerExperimentPayload, $resolvedPayload);
    }
} catch (\Throwable $exception) {
    // Mantem o header funcional mesmo se o rollout estiver indisponivel.
}

$headerExperimentVariant = (string) ($headerExperimentPayload['variant'] ?? 'control');
$headerExperimentRollout = (int) ($headerExperimentPayload['rollout_percentage'] ?? 0);
$headerExperimentBucket = (int) ($headerExperimentPayload['bucket'] ?? 0);
$headerExperimentSeed = (string) ($headerExperimentPayload['seed'] ?? 'guest:anonymous');
$headerExperimentEnabled = !empty($headerExperimentPayload['enabled']);
$headerExperimentActive = !empty($headerExperimentPayload['is_active']);
$headerExperimentStateClass = $headerExperimentActive ? ' awa-header-exp-active' : ' awa-header-exp-control';
$headerExperimentVariantClass = ' awa-header-exp--' . preg_replace('/[^a-z0-9_-]+/i', '-', strtolower($headerExperimentVariant));

$logoChildBlock = $block->getChildBlock('logo');
$mobileLogoUrl = $block->getUrl('');
$mobileLogoSrc = '';
$mobileLogoAlt = (string) __('AWA Motos');
$mobileLogoTitle = $mobileLogoAlt;
$mobileLogoWidth = 170;
$mobileLogoHeight = 55;

if ($logoChildBlock instanceof \Magento\Theme\Block\Html\Header\Logo) {
	$mobileLogoSrc = (string) $logoChildBlock->getLogoSrc();
	$mobileLogoAlt = (string) $logoChildBlock->getLogoAlt();
	$mobileLogoTitle = (string) ($logoChildBlock->getThemeName() ?: $logoChildBlock->getLogoAlt());
	$mobileLogoWidth = (int) ($logoChildBlock->getLogoWidth() ?: $mobileLogoWidth);
	$mobileLogoHeight = (int) ($logoChildBlock->getLogoHeight() ?: $mobileLogoHeight);
}
