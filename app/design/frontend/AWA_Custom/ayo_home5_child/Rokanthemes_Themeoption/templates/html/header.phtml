    if (is_array($resolvedPayload)) {
        $headerExperimentPayload = array_merge($headerExperimentPayload, $resolvedPayload);
    }
} catch (\Throwable $exception) {
    // Mantem o header funcional mesmo se o rollout estiver indisponivel.
}

