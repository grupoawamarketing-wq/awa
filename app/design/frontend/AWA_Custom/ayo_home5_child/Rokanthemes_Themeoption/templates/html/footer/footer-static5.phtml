$isStrictB2b = $isB2bEnabled && $b2bConfig->isStrictB2B();
$accountUrl = $isStrictB2b ? $block->getUrl('b2b/account/login') : $block->getUrl('customer/account');
$accountLabel = $isStrictB2b ? 'Acesse Sua Conta' : 'Crie Sua Conta';
