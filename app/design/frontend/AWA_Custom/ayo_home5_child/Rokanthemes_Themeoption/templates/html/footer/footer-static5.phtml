$emailUrl = $footerData instanceof \GrupoAwamotos\Theme\ViewModel\FooterData
    ? $footerData->getEmailUrl()
    : 'mailto:contato@awamotos.com.br';

$instagramUrl = $footerData instanceof \GrupoAwamotos\Theme\ViewModel\FooterData
    ? $footerData->getInstagramUrl()
    : 'https://www.instagram.com/awamotos';

$facebookUrl = $footerData instanceof \GrupoAwamotos\Theme\ViewModel\FooterData
    ? $footerData->getFacebookUrl()
    : 'https://www.facebook.com/awamotos';

$youtubeUrl = $footerData instanceof \GrupoAwamotos\Theme\ViewModel\FooterData
    ? $footerData->getYoutubeUrl()
    : 'https://www.youtube.com/@awamotos';

$socialLinks = [
    [
        'url' => $instagramUrl,
        'class' => 'instagram',
        'icon' => 'fa-instagram',
        'label' => (string) __('Instagram'),
        'aria' => (string) __('AWA Motos no Instagram'),
