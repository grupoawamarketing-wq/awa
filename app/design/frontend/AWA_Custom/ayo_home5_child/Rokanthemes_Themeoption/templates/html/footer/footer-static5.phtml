$storeName = $footerData instanceof \GrupoAwamotos\Theme\ViewModel\FooterData
    ? $footerData->getStoreName()
    : 'AWA Motos';

$addressLabel = $footerData instanceof \GrupoAwamotos\Theme\ViewModel\FooterData
    ? $footerData->getFormattedAddress()
    : 'Rua Castro Alves, 1234 - Araraquara-SP';

$phoneLabel = $footerData instanceof \GrupoAwamotos\Theme\ViewModel\FooterData
