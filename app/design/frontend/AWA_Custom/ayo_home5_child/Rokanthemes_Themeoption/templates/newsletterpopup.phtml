<?php
/** @var \Magento\Framework\View\Element\Template $block */

/** @var \Magento\Framework\App\Request\Http|null $request */
$request = $block->getRequest();
$fullActionName = $request ? (string) $request->getFullActionName() : '';
$pathInfo = $request ? (string) ($request->getOriginalPathInfo() ?: $request->getPathInfo()) : '';
$pathSlug = trim($pathInfo, '/');

$isHomeDemoCms = $fullActionName === 'cms_index_index'
    && str_contains((string) (($block->getLayout()->getUpdate()->getHandles() ? implode(' ', $block->getLayout()->getUpdate()->getHandles()) : '')), 'cms_page_view_id_homepage_ayo_home5_demo_stage');

// Path-based fallback covers cases where fullActionName/handles are unavailable in this block render context.
if ($pathSlug === '' || in_array($pathSlug, ['homepage_ayo_home5_stage', 'homepage_ayo_home5_demo_stage'], true)) {
    return;
}

if ($isHomeDemoCms) {
    return;
}
?>
<?php if ($block->getConfig('enable') > 0) { ?>
<?php
    $imagelogoUrl = '';
    if ($block->getConfig('lg_image')) {
        $folderName = \Rokanthemes\Themeoption\Model\Config\Newsletterlogo::UPLOAD_DIR;
        $path = $folderName . '/' . $block->getConfig('lg_image');
        $objectManager = \Magento\Framework\App\ObjectManager::getInstance();
        $storeManager = $objectManager->get('\Magento\Store\Model\StoreManagerInterface');
        $imagelogoUrl = $storeManager->getStore()->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA) . $path;
    }
?>
<div id="newsletter_pop_up" class="newsletterpopup">
    <a href="javascript: void(0);" class="btn-close newletter_popup_close"><span></span></a>
    <div class="row">
        <div class="content-popup">
            <div class="content">
                <?php if ($imagelogoUrl) { ?>
                    <div class="logo_popup"><img src="<?= $block->escapeUrl($imagelogoUrl) ?>" alt="<?= $block->escapeHtml(__('Logo Newsletter')) ?>" loading="lazy" decoding="async"></div>
                <?php } ?>
                <?php echo $block->getConfig('content'); ?>
            </div>
            <form class="form subscribe"
                novalidate
                action="<?php /* @escapeNotVerified */ echo $block->getFormActionUrl() ?>"
                method="post"
                data-mage-init='{"validation": {"errorClass": "mage-error"}}'
                id="newsletter-validate-popup">
                <div class="field newsletter">
                    <div class="control">
                        <input name="email" type="email" id="newsletter-popup"
                                    aria-label="Seu e-mail"
                                    placeholder="<?php /* @escapeNotVerified */ echo __('Enter Your Email Address Here...') ?>"
                                    data-validate="{required:true, 'validate-email':true}" />
                    </div>
                </div>
                <div class="actions">
                    <button class="action subscribe primary" title="<?php /* @escapeNotVerified */ echo __('Inscrever-se') ?>" type="submit">
                        <span><?php echo __('Inscreva-se e receba promoções!'); ?></span>
                    </button>
                </div>
                <div class="discription">
                    <h4><a href="javascript:void(0);" class="newletter_popup_close"><?php echo __('Não, obrigado') ?></a></h4>
                    <div class="newsletterDescription"><?php echo __('Ao se inscrever, você receberá novidades e ofertas exclusivas da AWA Motos.') ?></div>
                </div>
                <div class="subscribe-bottom">
                    <input type="checkbox" id="newsletter_popup_dont_show_again">
                    <label for="newsletter_popup_dont_show_again"><?php echo __('Não mostrar este popup novamente') ?></label>
                </div>
            </form>
        </div>
    </div>
</div>
<?php
    $speed = 500;
?>
<script type="text/x-magento-init">
{
    "#newsletter_pop_up": {
        "js/awa-newsletter-popup-init": {
            "cookieName": "shownewsletter",
            "cookieDays": 1,
            "popupHeight": <?php echo (int) $block->getConfig('height'); ?>,
            "popupSpeed": <?php echo ($speed !== '' ? (int) $speed : 450); ?>,
            "homeOnly": <?php echo ($block->getConfig('enable') == 1) ? 'true' : 'false'; ?>
        }
    }
}
</script>
<?php } ?>
