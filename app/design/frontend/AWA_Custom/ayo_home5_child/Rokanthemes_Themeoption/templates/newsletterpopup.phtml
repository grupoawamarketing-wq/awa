<script>
require(["jquery"], function ($) {
    function setCookie(name, value, days)
    {
        if (days) {
            var date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
            var expires = "; expires=" + date.toGMTString();
        } else {
            var expires = "";
        }
        document.cookie = name + "=" + value + expires + "; path=/";
    }

    function getCookie(name)
    {
        var nameEQ = name + "=";
        var ca = document.cookie.split(';');
        for (var i = 0; i < ca.length; i++) {
            var c = ca[i];
            while (c.charAt(0) == ' ') c = c.substring(1, c.length);
            if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length, c.length);
        }
        return null;
    }

    $(document).ready(function () {
        <?php if ($block->getConfig('enable') == 1) { ?>
        if ($("body").hasClass("cms-index-index")) {
        <?php } ?>
            if (getCookie("shownewsletter") != 1) {
                var pPopup = null;
                var height_window = $(window).height();
                var height_pupup = <?php echo $block->getConfig('height'); ?>;
                var fixed_height = (height_window - height_pupup) / 2;

                if (typeof $.fn.bPopup === 'function') {
                    pPopup = $('#newsletter_pop_up').bPopup({
                        position: ['auto', fixed_height],
                        speed: <?php if ($speed != '') echo $speed; else echo '450' ?>,
                        transition: 'slideDown',
                        onClose: function () {
                        }
                    });
                } else {
                    // Fallback sem plugin: mantém popup funcional e evita erro JS.
                    $('#newsletter_pop_up')
                        .addClass('nl-popup-fallback-open')
                        .css('display', 'block');
                }

                $('.newletter_popup_close').on('click', function (event) {
                    event.preventDefault();
                    if (pPopup && typeof pPopup.close === 'function') {
                        try { pPopup.close(); } catch (e) {}
                    } else {
                        $('#newsletter_pop_up')
                            .removeClass('nl-popup-fallback-open')
                            .css('display', 'none');
                    }
                });
            }

            $("#newsletter_pop_up form").submit(function () {
                setCookie("shownewsletter", '1', 1);
            });

            $('#newsletter_popup_dont_show_again').on('change', function () {
                if (getCookie("shownewsletter") != 1) {
                    setCookie("shownewsletter", '1', 1);
                } else {
                    setCookie("shownewsletter", '0', 1);
                }
            });
        <?php if ($block->getConfig('enable') == 1) { ?>
        }
        <?php } ?>
    });
});
</script>
