<?xml version="1.0"?>
<!--
/**
 * AWA Motos — High Quality View Configuration
 * Overrides parent theme to ensure sharp images and premium display.
 */
-->
<view xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Config/etc/view.xsd">
    <media>
        <images module="Magento_Catalog">
            <!-- Grid principal: aumentado para 1000px para garantir nitidez em telas Retina/4K -->
            <image id="category_page_grid" type="small_image">
                <width>1000</width>
                <height>1000</height>
            </image>
            <!-- Grid mobile: aumentado para 500px -->
            <image id="category_page_grid_sm" type="small_image">
                <width>500</width>
                <height>500</height>
            </image>
            <!-- PDP Main Image -->
            <image id="product_page_main_image" type="image">
                <width>1000</width>
                <height>1000</height>
            </image>
            <!-- PDP Medium Image -->
            <image id="product_page_image_medium" type="image">
                <width>800</width>
                <height>800</height>
            </image>
            <!-- PDP Large (Zoom) Image -->
            <image id="product_page_image_large" type="image">
                <width>1200</width>
                <height>1200</height>
            </image>
            <!-- Imagem de listagem e carrosséis -->
            <image id="category_page_list" type="small_image">
                <width>600</width>
                <height>600</height>
            </image>
            <!-- Hover thumbnail -->
            <image id="category_page_grid-1" type="thumbnail">
                <width>600</width>
                <height>600</height>
            </image>
            <!-- Widgets carrossel (new, bestseller, etc) -->
            <image id="new_products_content_widget_grid" type="small_image">
                <width>600</width>
                <height>600</height>
            </image>
        </images>
    </media>
    <vars module="Magento_Catalog">
        <!-- Qualidade JPEG aumentada para 95 (padrão é 80) -->
        <var name="product_image_quality">95</var>
        <!-- Desativa bordas brancas automáticas que degradam a estética -->
        <var name="product_image_white_borders">0</var>
    </vars>
</view>
