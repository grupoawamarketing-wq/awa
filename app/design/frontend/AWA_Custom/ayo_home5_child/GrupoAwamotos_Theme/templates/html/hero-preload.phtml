<?php
/**
 * LCP Hero Image Preload
 *
 * Injeta <link rel="preload" as="image" fetchpriority="high"> para a imagem
 * hero do primeiro slide ativo do Rokanthemes SlideBanner.
 *
 * Usa media queries para separar desktop e mobile:
 * - media="(min-width: 768px)" → preload do slider desktop (.hidden-xs)
 * - media="(max-width: 767px)" → preload do slider mobile (.visible-xs)
 *
 * Isso evita que o browser em mobile viewport baixe o preload desktop,
 * que seria "consumido" pelo <img> do desktop slider antes do CSS
 * display:none ser aplicado, desperdiçando bandwidth e causando CLS.
 *
 * @var GrupoAwamotos\Theme\Block\Html\HeroPreload $block
 */
$heroUrl = $block->getHeroImageUrl();
if (!$heroUrl) {
    return;
}
// Usa imagem mobile se disponível (campo slide_image_mobile no DB),
// senão usa a mesma imagem desktop (Rokanthemes usa a mesma para ambos).
$heroMobileUrl = $block->getHeroImageMobileUrl() ?: $heroUrl;
?>
<!-- LCP Hero Image Preload (Swiper SlideBanner - first active slide) -->
<!-- Desktop: slider .hidden-xs — só carregado em viewport ≥ 768px -->
<link rel="preload" href="<?= $block->escapeUrl($heroUrl) ?>" as="image" fetchpriority="high" media="(min-width: 768px)"/>
<!-- Mobile: slider .visible-xs — só carregado em viewport ≤ 767px -->
<link rel="preload" href="<?= $block->escapeUrl($heroMobileUrl) ?>" as="image" fetchpriority="high" media="(max-width: 767px)"/>
