<?php
/**
 * LCP Hero Image Preload
 *
 * Injeta <link rel="preload" as="image" fetchpriority="high"> para a imagem
 * hero do primeiro slide ativo do Rokanthemes SlideBanner.
 *
 * Renderiza no <head> (head.additional) ANTES do body, garantindo que o
 * browser descubra e priorize o download da imagem LCP.
 *
 * @var GrupoAwamotos\Theme\Block\Html\HeroPreload $block
 */
$heroUrl = $block->getHeroImageUrl();
if (!$heroUrl) {
    return;
}
?>
<!-- LCP Hero Image Preload (Swiper SlideBanner - first active slide) -->
<link rel="preload" href="<?= $block->escapeUrl($heroUrl) ?>" as="image" fetchpriority="high"/>
