 */

// @codingStandardsIgnoreFile
if ($banners = $block->getBannerCollection()):
    /** @var \GrupoAwamotos\Theme\ViewModel\HeroResponsiveImage|null $heroResponsive */
    $heroResponsive = $block->getData('hero_responsive_view_model');
    $slider = $block->getSlider();
    $sliderId = $block->getSliderId();
    $settings = $slider->getSliderSetting();
    $owlConfig = [
        'singleItem' => true,
        'autoHeight' => true,
        'lazyLoad' => true,
        'touchDrag' => true,
        'mouseDrag' => true,
        'transitionStyle' => 'fade',
    ];
    $booleanKeys = ['autoPlay', 'navigation', 'stopOnHover', 'pagination', 'scrollPerPage'];

    $legacyHosts = ['srv1113343.hstgr.cloud', 'www.srv1113343.hstgr.cloud'];
    $baseUrl = rtrim((string) $block->getBaseUrl(), '/');
    $baseHost = (string) parse_url($baseUrl, PHP_URL_HOST);
    $baseScheme = (string) parse_url($baseUrl, PHP_URL_SCHEME);
    $resolveSlideLink = static function (?string $link) use ($legacyHosts, $baseHost, $baseScheme): string {
        if (!is_string($link)) {
            return '';
        }

        $link = trim($link);
        if ($link === '') {
            return '';
        }

        $parts = parse_url($link);
        if (!is_array($parts)) {
            return $link;
        }

        $linkHost = isset($parts['host']) ? strtolower((string) $parts['host']) : '';
        if ($linkHost === '' || !in_array($linkHost, $legacyHosts, true) || $baseHost === '' || $baseScheme === '') {
            return $link;
        }

        $path = isset($parts['path']) ? (string) $parts['path'] : '/';
        $path = $path !== '' ? $path : '/';
        $query = isset($parts['query']) ? ('?' . $parts['query']) : '';
        $fragment = isset($parts['fragment']) ? ('#' . $parts['fragment']) : '';

        return $baseScheme . '://' . $baseHost . $path . $query . $fragment;
    };

    foreach ($settings as $key => $value) {
        if (in_array($key, $booleanKeys, true)) {
            $owlConfig[$key] = ((int) $value) === 1;
            continue;
        }

        if (is_string($value)) {
            $trimmed = trim($value);

            if (is_numeric($trimmed)) {
                $owlConfig[$key] = (strpos($trimmed, '.') !== false) ? (float) $trimmed : (int) $trimmed;
                continue;
            }
        }

        $owlConfig[$key] = $value;
    }
?>
<div class="wrapper_slider hidden-xs slider_<?php echo (int) $sliderId; ?>">
    <div class="owl">
        <?php $__deskIdx = 0; foreach ($banners as $banner) { if ($banner->getSlideStatus() == '2') { continue; } $__isFirst = ($__deskIdx === 0); $__deskIdx++; ?>
            <div class="banner_item">
                <div class="banner_item_bg">
                    <?php
                    $slideAlt = $banner->getSlideText() ?: ($banner->getSlideTitle() ?: '');
                    if ($__isFirst && $heroResponsive) {
                        $html = $heroResponsive->buildLcpPictureHtml(
                            (string) $banner->getSlideImage(),
                            $slideAlt,
                            false,
                            false
                        );
                    } else {
                        $html = $block->getImageElement($banner->getSlideImage(), $slideAlt, $__isFirst);
                        if ($__isFirst && preg_match('/src="([^"]+)"/', $html, $_wm)) {
                            $_webp = $_wm[1] . '.webp';
                            $html = '<picture>'
                                . '<source type="image/webp" srcset="' . $block->escapeUrl($_webp) . '">'
                                . $html
                                . '</picture>';
                        }
                    }
                    $link = $resolveSlideLink($banner->getSlideLink());
                    if ($link !== '') {
                        $html = '<a href="' . $block->escapeUrl($link) . '">' . $html . '</a>';
                    }
                    echo $html;
                    ?>
                </div>
                <div class="text-banner">
                    <?php if ($text = $banner->getSlideText()) {
                        echo $block->getContentText($text);
                    }
                    ?>
                </div>
            </div>
        <?php } ?>
    </div>
</div>
<div class="wrapper_slider visible-xs slider_<?php echo (int) $sliderId; ?>_mobile">
    <div class="owl">
        <?php $__mobIdx = 0; foreach ($banners as $banner) { if ($banner->getSlideStatus() == '2') { continue; } $__isFirstMob = ($__mobIdx === 0); $__mobIdx++; ?>
            <div class="banner_item">
                <div class="banner_item_bg">
                    <?php
                    $slideAlt = $banner->getSlideText() ?: ($banner->getSlideTitle() ?: '');
                    $_mobSrc = $banner->getSlideImageMobile() ?: $banner->getSlideImage();
                    if ($__isFirstMob && $heroResponsive) {
                        $html = $heroResponsive->buildLcpPictureHtml(
                            (string) $_mobSrc,
                            $slideAlt,
                            true,
                            true
                        );
                    } else {
                        $html = $block->getImageElementMobile($_mobSrc, $slideAlt, $__isFirstMob);
                        if ($__isFirstMob && preg_match('/src="([^"]+)"/', $html, $_wmm)) {
                            $_webpm = $_wmm[1] . '.webp';
                            $html = '<picture>'
                                . '<source type="image/webp" srcset="' . $block->escapeUrl($_webpm) . '">'
                                . $html
                                . '</picture>';
                        }
                    }
                    $link = $resolveSlideLink($banner->getSlideLink());
                    if ($link !== '') {
                        $html = '<a href="' . $block->escapeUrl($link) . '">' . $html . '</a>';
                    }
                    echo $html;
                    ?>
                </div>
                <div class="text-banner">
                    <?php if ($text = $banner->getSlideText()) {
                        echo $block->getContentText($text);
                    }
                    ?>
                </div>
            </div>
        <?php } ?>
    </div>
</div>
<script>
    require([
        'jquery',
        'mage/mage',
        'rokanthemes/owl'
    ], function ($) {
        'use strict';

        function doAnimations(elems) {
            var animEndEv = 'webkitAnimationEnd animationend';
            elems.each(function () {
                var $this = $(this),
                    $animationType = $this.data('animation');
                if ($animationType) {
                    $this.addClass($animationType).one(animEndEv, function () {
                        $this.removeClass($animationType);
                    });
                }
            });
        }

        var owlConfig = $.extend(true, {}, <?php echo json_encode($owlConfig, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES); ?>, {
            afterInit: function (elem) {
                var $firstSlide = elem.find('.owl-item').eq(0);
                doAnimations($firstSlide.find('.text-banner').find("[data-animation ^= 'animated']"));
            },
            afterMove: function (elem) {
                var $currentSlide = elem.find('.owl-item').eq(this.currentItem);
                doAnimations($currentSlide.find('.text-banner').find("[data-animation ^= 'animated']"));
            }
        });

        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            owlConfig.autoPlay = false;
        }

        $(".slider_<?php echo (int) $sliderId; ?> .owl").owlCarousel(owlConfig);
        $(".slider_<?php echo (int) $sliderId; ?>_mobile .owl").owlCarousel(owlConfig);

        /**
         * Duas instâncias Owl (desktop + mobile) existem no DOM; apenas uma está visível (CSS hidden-xs / visible-xs).
         * Reforça aria-hidden no par inativo para leitores de tela e modos de leitura que ignorem display:none de forma inconsistente.
         */
        (function () {
            var mq = window.matchMedia('(max-width: 767px)');
            var $desk = $('.wrapper_slider.hidden-xs.slider_<?php echo (int) $sliderId; ?>');
            var $mob = $('.wrapper_slider.visible-xs.slider_<?php echo (int) $sliderId; ?>_mobile');
            if (!$desk.length || !$mob.length) {
                return;
            }
            function syncAwaSlideBannerAria() {
                var isMobile = mq.matches;
                $desk.attr('aria-hidden', isMobile ? 'true' : 'false');
                $mob.attr('aria-hidden', isMobile ? 'false' : 'true');
            }
            syncAwaSlideBannerAria();
            if (mq.addEventListener) {
                mq.addEventListener('change', syncAwaSlideBannerAria);
            } else if (mq.addListener) {
                mq.addListener(syncAwaSlideBannerAria);
            }
        }());
    });
</script>
<?php endif; ?>
