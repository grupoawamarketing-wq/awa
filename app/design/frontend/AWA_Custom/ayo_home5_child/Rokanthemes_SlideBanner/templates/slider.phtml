<?php
/**
 * AWA Motos - Slideshow Template
 * Refatorado para usar um componente de UI Magento 2 e data-mage-init.
 * A lógica de inicialização e acessibilidade foi movida para o JS.
 */

// @codingStandardsIgnoreFile
/** @var \Rokanthemes\SlideBanner\Block\Slider $block */
if ($banners = $block->getBannerCollection()):
    $slider = $block->getSlider();
    $sliderId = $block->getSliderId();
    $sliderSettings = $slider->getSliderSetting();
    $totalSlides = is_countable($banners) ? count($banners) : 0;

    // Prepara a configuração do slider para o componente JS
    $sliderConfig = [
        'lazyLoad' => true,
        'singleItem' => true,
    ];
    foreach ($sliderSettings as $key => $value) {
        if (in_array($key, ['autoPlay', 'navigation', 'stopOnHover', 'pagination', 'scrollPerPage'])) {
            $sliderConfig[$key] = (bool)$value;
        } else {
            $sliderConfig[$key] = $value;
        }
    }
    $mageInitConfig = [
        'rokanthemes/slideBanner' => [
            'sliderConfig' => $sliderConfig,
            'totalSlides' => $totalSlides
        ]
    ];
?>

<?php
// Preload hint para a primeira imagem (melhora LCP)
$firstBanner = null;
foreach ($banners as $b) {
    if ($b->getSlideStatus() != '2') {
        $firstBanner = $b;
        break;
    }
}
if ($firstBanner):
    $firstImgSrc = $firstBanner->getSlideImageMobile() ?: $firstBanner->getSlideImage();
    if ($firstImgSrc):
        $mediaUrl = $block->getUrl('media');
        $preloadUrl = rtrim($mediaUrl, '/') . '/' . ltrim($firstImgSrc, '/');
?>
<link rel="preload" as="image" href="<?php echo $block->escapeUrl($preloadUrl); ?>" fetchpriority="high" />
<?php endif; endif; ?>

<!-- Schema.org ItemList para SEO de carrosséis -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "<?php echo $block->escapeHtml($slider->getSliderTitle() ?: __('Destaques')); ?>",
  "numberOfItems": <?php echo $totalSlides; ?>,
  "itemListElement": [
    <?php
    $schemaIndex = 0;
    foreach ($banners as $banner):
        if ($banner->getSlideStatus() == '2') { continue; }
        $schemaIndex++;
        $itemName = trim(strip_tags($banner->getSlideTitle() ?: $banner->getSlideText() ?: ''));
        $itemUrl = $banner->getSlideLink() ?: '';
        if ($itemName):
    ?>
    {
      "@type": "ListItem",
      "position": <?php echo $schemaIndex; ?>,
      "name": "<?php echo $block->escapeHtml($itemName); ?>"<?php if ($itemUrl): ?>,
      "url": "<?php echo $block->escapeUrl($itemUrl); ?>"<?php endif; ?>
    }<?php if ($schemaIndex < $totalSlides): ?>,<?php endif; ?>
    <?php endif; endforeach; ?>
  ]
}
</script>

<!-- Slider refatorado para usar componente UI via data-mage-init -->
<div class="wrapper_slider slider_<?php echo $sliderId; ?>"
     role="region"
     aria-label="<?php echo $block->escapeHtml(__('Apresentação de slides promocional')); ?>"
     aria-roledescription="carousel"
     aria-live="off"
     data-mage-init='<?php echo json_encode($mageInitConfig, JSON_HEX_APOS | JSON_HEX_QUOT); ?>'>
    <div class="owl" role="list">
        <?php
        $slideIndex = 0;
        foreach ($banners as $banner):
            if ($banner->getSlideStatus() == '2') { continue; }
            $slideIndex++;
            $slideAlt = $banner->getSlideText() ?: ($banner->getSlideTitle() ?: __('Slide %1', $slideIndex));
        ?>
        <div class="banner_item" role="listitem" aria-label="<?php echo $block->escapeHtml(__('Slide %1 de %2', $slideIndex, $totalSlides)); ?>">
            <?php
                $isFirst = ($slideIndex === 1);
                $desktopSrc = $banner->getSlideImage();
                $mobileSrc = $banner->getSlideImageMobile();
                $pictureHtml = $block->getPictureElement($desktopSrc, $mobileSrc, $slideAlt, $isFirst, true);
                if ($link = $banner->getSlideLink()) {
                    $pictureHtml = '<a href="' . $block->escapeUrl($link) . '" title="' . $block->escapeHtml($slideAlt) . '">' . $pictureHtml . '</a>';
                }
                echo $pictureHtml;
            ?>
        </div>
        <?php endforeach; ?>
    </div>
    <div class="slide-controls">
        <button type="button" class="play-pause-button" aria-label="<?php echo __('Pausar slides'); ?>">
            <span class="icon-pause" aria-hidden="true"></span>
            <span class="icon-play icon-play--hidden" aria-hidden="true"></span>
        </button>
        <div class="progress-bar-container" aria-hidden="true">
            <div class="progress-bar"></div>
        </div>
    </div>
</div>
<?php endif; ?>
