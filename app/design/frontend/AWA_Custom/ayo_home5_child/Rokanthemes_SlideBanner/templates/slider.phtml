<?php
/**
 * AWA Motos - Slideshow Template
 * Refatorado para usar um componente de UI Magento 2 e data-mage-init.
 * A lógica de inicialização e acessibilidade foi movida para o JS.
 */

// @codingStandardsIgnoreFile
/** @var \Rokanthemes\SlideBanner\Block\Slider $block */
if ($banners = $block->getBannerCollection()):
    $slider = $block->getSlider();
    $sliderId = $block->getSliderId();
    $sliderSettings = $slider->getSliderSetting();
    $totalSlides = is_countable($banners) ? count($banners) : 0;

    // Prepara a configuração do slider para o componente JS
    $sliderConfig = [
        'lazyLoad' => true,
        'singleItem' => true,
    ];
    foreach ($sliderSettings as $key => $value) {
        if (in_array($key, ['autoPlay', 'navigation', 'stopOnHover', 'pagination', 'scrollPerPage'])) {
            $sliderConfig[$key] = (bool)$value;
        } else {
            $sliderConfig[$key] = $value;
        }
    }
    $mageInitConfig = [
        'rokanthemes/slideBanner' => [
            'sliderConfig' => $sliderConfig,
            'totalSlides' => $totalSlides
        ]
    ];
?>

<?php
// Build Schema.org ItemList as PHP array + json_encode (prevents JSON injection via banner titles/urls)
$sliderTitle = (string)($slider->getSliderTitle() ?: __('Destaques'));
$schemaItems = [];
$schemaPos = 0;
foreach ($banners as $schemaBanner) {
    if ($schemaBanner->getSlideStatus() == '2') { continue; }
    $schemaPos++;
    $schemaItemName = trim(strip_tags((string)($schemaBanner->getSlideTitle() ?: $schemaBanner->getSlideText() ?: '')));
    if ($schemaItemName && $schemaItemName !== '.') {
        $schemaItem = [
            '@type'    => 'ListItem',
            'position' => $schemaPos,
            'name'     => $schemaItemName,
        ];
        if ($schemaBanner->getSlideLink()) {
            $schemaItem['url'] = $schemaBanner->getSlideLink();
        }
        $schemaItems[] = $schemaItem;
    }
}
$jsonLdSchema = [
    '@context'        => 'https://schema.org',
    '@type'           => 'ItemList',
    'name'            => $sliderTitle,
    'numberOfItems'   => $totalSlides,
    'itemListElement' => $schemaItems,
];
?>
<!-- Schema.org ItemList para SEO de carrosséis -->
<script type="application/ld+json">
<?= /* @noEscape */ json_encode($jsonLdSchema, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT) ?>
</script>

<!-- Slider refatorado para usar componente UI via data-mage-init -->
<div class="wrapper_slider slider_<?php echo $block->escapeHtmlAttr((string)$sliderId); ?>"
     role="region"
     aria-label="<?php echo $block->escapeHtml(__('Apresentação de slides promocional')); ?>"
     aria-roledescription="carousel"
     aria-live="off"
     data-mage-init='<?php echo json_encode($mageInitConfig, JSON_HEX_APOS | JSON_HEX_QUOT); ?>'>
    <div class="owl" role="group" aria-roledescription="slides">
        <?php
        $sliderMediaUrl = rtrim($block->getUrl('media'), '/');
        $sliderMediaDir = BP . '/pub/media/';

        /**
         * Gera <picture> responsivo com suporte a WebP + fallback JPEG.
         * Usa file_exists para evitar <source> com WebP inexistente.
         */
        $renderPicture = static function (
            string $desktopSrc,
            ?string $mobileSrc,
            string $altText,
            bool $isFirst
        ) use ($block, $sliderMediaUrl, $sliderMediaDir): string {
            $alt      = $block->escapeHtmlAttr($altText);
            $loading  = $isFirst ? 'eager' : 'lazy';
            $priority = $isFirst ? ' fetchpriority="high"' : '';
            $mSrc     = $mobileSrc ?: $desktopSrc;

            $dUrl = $sliderMediaUrl . '/' . ltrim($desktopSrc, '/');
            $mUrl = $sliderMediaUrl . '/' . ltrim($mSrc, '/');

            $dWebp    = (string) preg_replace('/\.(jpg|jpeg|png)$/i', '.webp', $desktopSrc);
            $mWebp    = (string) preg_replace('/\.(jpg|jpeg|png)$/i', '.webp', $mSrc);
            $dWebpUrl = file_exists($sliderMediaDir . ltrim($dWebp, '/'))
                ? $sliderMediaUrl . '/' . ltrim($dWebp, '/')
                : '';
            $mWebpUrl = file_exists($sliderMediaDir . ltrim($mWebp, '/'))
                ? $sliderMediaUrl . '/' . ltrim($mWebp, '/')
                : '';

            $html = '<picture>';
            // WebP sources — um elemento para ambas as resoluções se forem a mesma imagem
            if ($dWebpUrl === $mWebpUrl && $dWebpUrl) {
                $html .= '<source type="image/webp" srcset="' . $block->escapeUrl($dWebpUrl) . '" />';
            } else {
                if ($dWebpUrl) {
                    $html .= '<source type="image/webp" media="(min-width: 768px)" srcset="'
                        . $block->escapeUrl($dWebpUrl) . '" width="1920" height="600" />';
                }
                if ($mWebpUrl) {
                    $html .= '<source type="image/webp" srcset="'
                        . $block->escapeUrl($mWebpUrl) . '" width="768" height="400" />';
                }
            }
            // JPEG desktop source (apenas quando há imagem mobile distinta)
            if ($dUrl !== $mUrl) {
                $html .= '<source media="(min-width: 768px)" srcset="'
                    . $block->escapeUrl($dUrl) . '" width="1920" height="600" />';
            }
            // Fallback <img> (mobile JPEG ou única imagem)
            $html .= '<img src="' . $block->escapeUrl($mUrl) . '"'
                . ' alt="' . $alt . '"'
                . ' loading="' . $loading . '"'
                . ' decoding="async"'
                . ' width="768" height="400"'
                . $priority . ' />';
            $html .= '</picture>';
            return $html;
        };

        $slideIndex = 0;
        foreach ($banners as $banner):
            if ($banner->getSlideStatus() == '2') { continue; }
            $slideIndex++;
            $slideTextRaw = (string)$banner->getSlideText();
            $slideTitleRaw = (string)$banner->getSlideTitle();
            $slideAlt = trim(strip_tags($slideTextRaw));
            if ($slideAlt === '') {
                $slideAlt = trim(strip_tags($slideTitleRaw));
            }
            if ($slideAlt === '') {
                $slideAlt = (string)__('Slide %1', $slideIndex);
            }
        ?>
        <div class="banner_item" role="group" aria-roledescription="slide" aria-label="<?php echo $block->escapeHtml(__('Slide %1 de %2', $slideIndex, $totalSlides)); ?>">
            <?php
                $isFirst = ($slideIndex === 1);
                $desktopSrc = $banner->getSlideImage();
                $mobileSrc = $banner->getSlideImageMobile();
                $pictureHtml = $renderPicture($desktopSrc, $mobileSrc, (string)$slideAlt, $isFirst);
                if ($link = $banner->getSlideLink()) {
                    $pictureHtml = '<a href="' . $block->escapeUrl($link) . '" title="' . $block->escapeHtml($slideAlt) . '">' . $pictureHtml . '</a>';
                }
            ?>
            <div class="banner_item_bg">
                <?php echo /* @noEscape */ $pictureHtml; ?>
            </div>
            <?php
            $cleanText  = trim(strip_tags($slideTextRaw));
            $hasText    = ($cleanText !== '' && $cleanText !== '.');
            $ctaLink    = $banner->getSlideLink(); // re-fetch to avoid scope issue
            $showBanner = $hasText || $ctaLink !== '';
            if ($showBanner): ?>
            <div class="text-banner">
                <?php if ($hasText): ?>
                    <?php echo /* @noEscape */ $block->getContentText($slideTextRaw); ?>
                <?php endif; ?>
                <?php if ($ctaLink !== ''): ?>
                <a href="<?php echo $block->escapeUrl($ctaLink); ?>"
                   class="awa-slide-cta"
                   aria-label="<?php echo $block->escapeHtmlAttr(__('Ver produtos')); ?>">
                    <?= $block->escapeHtml(__('Ver Produtos')) ?>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
                <?php endif; ?>
            </div>
            <?php endif; ?>
        </div>
        <?php endforeach; ?>
    </div>
    <div class="slide-controls">
        <button type="button" class="play-pause-button" aria-label="<?php echo $block->escapeHtml(__('Pausar slides')); ?>">
            <span class="icon-pause" aria-hidden="true"></span>
            <span class="icon-play icon-play--hidden" aria-hidden="true"></span>
        </button>
        <div class="progress-bar-container" aria-hidden="true">
            <div class="progress-bar"></div>
        </div>
    </div>
</div>
<?php endif; ?>
