<?php
	$enable = $this->getConfig('enable_frontend');
	$auto = $this->getConfig('auto');
	$speed = $this->getConfig('speed');
	$default = $this->getConfig('default');
	$desktop = $this->getConfig('desktop');
	$desktop_small = $this->getConfig('desktop_small');
	$tablet = $this->getConfig('tablet');
	$mobile = $this->getConfig('mobile');
	$pagination = $this->getConfig('pagination');
	$show_next_back = $this->getConfig('show_next_back');
	$show_navigation_control = $this->getConfig('show_navigation_control');
	$title = $this->getConfig('title');
	if($show_next_back)
		$show_next_back = 'true';
	else
		$show_next_back = 'false';
	$show_navigation_control = $this->getConfig('show_navigation_control');
	if($show_navigation_control)
		$show_navigation_control = 'true';
	else
		$show_navigation_control = 'false';
	$_postCollection = $block->getPostCollection();
?>
<?php if ($_postCollection->count() && $enable) { ?>
<section class="widget box-section block-recent-posts" data-bind="scope: 'recemt-posts'">
	<div class="container">
		<div class="rokan-product-heading rokan-onsale-heading">
			<h2><?php echo $block->escapeHtml(__($title)) ?></h2>
		</div>
		<div class="swiper-container">
			<div class="block-content">
				<div class="swiper awa-blog-swiper">
					<div class="swiper-wrapper">
					<?php foreach ($_postCollection as $_post) { ?>
						<div class="swiper-slide item">
							<div class="product-item">
								<div class="blog-image">
									<a href="<?php echo $block->escapeUrl($_post->getPostUrl()) ?>">
										<img alt="<?php echo $block->escapeHtmlAttr($_post->getTitle()) ?>" src="<?php echo $block->escapeUrl($this->getMediaFolder().$_post->getThumbnailimage()) ?>" loading="lazy"/>
									</a>

								</div>
								<div class="blog-content">
									<div class="time-conment">
										<?php
											$date = $_post->getPublishTime();
										?>
										<span class="date-time"><span class="date"><?php echo $block->escapeHtml(__(date("d", strtotime($date)))) ?></span><span class="separator">/</span><span class="month"><?php echo $block->escapeHtml(__(date("M", strtotime($date)))) ?></span></span>
									</div>
									<div class="blog-content-inner">
										 <h3 class="blog-title"><a href="<?php echo $block->escapeUrl($_post->getPostUrl()) ?>"><?php echo $block->escapeHtml($_post->getTitle()) ?></a></h3>
										<p class="short-des"><?php echo $block->escapeHtml($_post->getShortContent()) ?></p>
										<a class="readmore" href="<?php echo $block->escapeUrl($_post->getPostUrl()) ?>">
											<?php echo $block->escapeHtml(__('Read more')) ?>
										</a>
									</div>
								</div>
							</div>
						</div><!-- .swiper-slide.item -->
					<?php } ?>
					</div><!-- .swiper-wrapper -->
					<?php if($show_next_back === 'true'){ ?>
					<div class="swiper-button-prev" aria-label="<?= $block->escapeHtmlAttr(__('Anterior')) ?>"></div>
					<div class="swiper-button-next" aria-label="<?= $block->escapeHtmlAttr(__('Próximo')) ?>"></div>
					<?php } ?>
					<?php if($show_navigation_control === 'true'){ ?>
					<div class="swiper-pagination"></div>
					<?php } ?>
				</div><!-- .awa-blog-swiper -->
			</div>
		</div>
    </div>
</section>

<?php /* CONVERSÃO AMD: Inline script → text/x-magento-init para performance e CSP compliance */ ?>
