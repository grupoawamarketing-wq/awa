<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <!-- AWA Blog — carrega CSS de polimento para a categoria do blog -->
    <body>
        <!-- H1 para páginas de categoria do blog (blog_default.xml remove page.main.title).
             Reutiliza awa-blog-index-h1.phtml que extrai título via getPageTitle() sem sufixo. -->
        <referenceContainer name="content">
            <block class="Magento\Theme\Block\Html\Title"
                   name="awa.blog.category.h1"
                   template="Rokanthemes_Blog::awa-blog-index-h1.phtml"
                   before="-"/>
        </referenceContainer>
    </body>
</page>
