<?xml version="1.0"?>
<!--
    AWA Blog — blog_default.xml (tema AWA_Custom/ayo_home5_child)
    Aplica-se a TODAS as páginas do blog (índice, post, categoria, arquivo, busca).
    Correção: adiciona <link rel="canonical"> via head.additional
    (módulo Rokanthemes_Blog original não gera canonical em nenhuma página)
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.blog.canonical"
                   template="Rokanthemes_Blog::awa-blog-canonical.phtml"
                   before="-"/>
        </referenceBlock>
    </body>
</page>
