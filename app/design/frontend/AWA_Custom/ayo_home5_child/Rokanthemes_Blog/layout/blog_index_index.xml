<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <!-- AWA Blog — CSS de polimento para a listagem do blog -->
    <head>
        <css src="css/awa-bundle-blog.css"/>
    </head>
    <body>
        <!-- H1 para a página índice do blog (blog_default.xml remove page.main.title).
             Usa template personalizado que chama getPageTitle() em vez de getPageHeading()
             pois o Rokanthemes_Blog nunca define setShortHeading(). -->
        <referenceContainer name="content">
            <block class="Magento\Theme\Block\Html\Title"
                   name="awa.blog.index.h1"
                   template="Rokanthemes_Blog::awa-blog-index-h1.phtml"
                   before="-"/>
        </referenceContainer>
    </body>
</page>
