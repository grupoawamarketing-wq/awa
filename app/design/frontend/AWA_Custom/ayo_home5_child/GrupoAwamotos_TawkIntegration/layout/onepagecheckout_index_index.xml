<?xml version="1.0"?>
<!--
    Remove Tawk.to widget do checkout OPC (Rokanthemes OnePageCheckout).
    Motivo: va.tawk.to/log-performance/v3 gera CORS error no checkout
    pois o endpoint nao retorna Access-Control-Allow-Origin. O chat nao
    e necessario durante o processo de finalizacao de compra.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="tawk.integration.widget" remove="true"/>
    </body>
</page>
