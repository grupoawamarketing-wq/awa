<?xml version="1.0"?>
<!--
    AWA B2B — Custom 404 Page Layout
    Overrides default no-route page with branded B2B 404.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <meta name="robots" content="NOINDEX,NOFOLLOW"/>
        <!-- AWA Design System — 404 page styling -->
    </head>
    <body>
        <!-- Remove page title H1 (template has its own H1) -->
        <referenceBlock name="page.main.title" remove="true"/>
        <!-- Remove default CMS page content (replaced by custom template) -->
        <referenceBlock name="cms_page" remove="true"/>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.noroute.custom"
                   template="Magento_Cms::noroute.phtml"/>
        </referenceContainer>
    </body>
</page>
