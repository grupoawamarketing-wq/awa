<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <!-- R35: awa-consistency-home5.css carregado apenas na homepage (antes era global via default_head_blocks.xml) -->
    <head>
        <title>Peças e Acessórios para Motos</title>
        <!-- awa-home-polish-critical: async stagger em awa-head-preload.phtml (TBT/LCP 2026-06-10) -->
        <remove src="css/awa-home-polish-critical.min.css"/>
        <!-- Remove legacy parent homepage CSS (now in bundle or global bundles) -->
        <remove src="css/awa-round9-post-themeoption-overrides.css"/>
        <remove src="css/awa-components-b2b-foundation.css"/>
        <remove src="css/awa-compat-b2b-nav-plp-cart-checkout.css"/>
        <remove src="css/awa-page-home-category-premium.css"/>
        <remove src="css/awa-home-final-polish.css"/>
        <!--
            awa-round2-home-owl-tabs.css — Owl tab CSS homepage-only.
            awa-home-carousel-standard.css + awa-carousel-modern.css — carousel CSS.
            GrupoAwamotos_B2B::marketing/suggestion.css — B2B suggestions (below-fold).
            Todos removidos do merged bundle 2026-05-09. Asyncados via awa-head-preload.phtml.
        -->
        <remove src="css/awa-round2-home-owl-tabs.css"/>
        <remove src="css/awa-consistency-home5.css"/>
        <remove src="css/awa-category-carousel.css"/>
        <!-- <css src="css/awa-plp-final-polish.css"/> Removido por TICKET-002: PLP em Home -->
        <remove src="css/awa-home-carousel-standard.css"/>
        <remove src="css/awa-carousel-modern.css"/>
        <remove src="GrupoAwamotos_B2B::css/marketing/suggestion.css"/>
        <!-- awa-visual-qa-home.css: movido para async via awa-head-preload.phtml ($__qaCssByAction) 2026-05-08 -->
        <!-- Homepage terminal CSS servido: awa-home-terminal-bundle.min.css (fonte: .css; build: scripts/build-awa-home-terminal-bundle.sh) -->
        <remove src="css/awa-home-premium.css"/>
        <!-- awa-homepage-bento.css → _awa-layout-grid-card-unified.less (2026-05-15) -->
        <remove src="css/awa-homepage-bento.css"/>
        <remove src="css/awa-homepage-sidebar.css"/>
        <remove src="css/awa-homepage-ux.css"/>
        <remove src="css/awa-homepage-polish.css"/>
        <!-- awa-phase1-bugfixes.css → unified hero + grid (2026-05-15) -->
        <remove src="css/awa-phase1-bugfixes.css"/>
        <!-- B2B UX: já async em default_head_blocks.xml (evita duplicate blocking na home) -->
        <remove src="css/awa-home-initial-fix.css"/>
        <remove src="css/awa-home-cascade-final.css"/>
        <remove src="css/awa-home-visual-fix-2026-05-15.css"/>
        <remove src="css/awa-home-polish-2026-05-16.css"/>
        <remove src="css/awa-homepage-container-fix.css"/>
        <!-- flex-grid-flow: global async em default_head_blocks + awa-head-preload -->
        <remove src="css/awa-flex-grid-flow.min.css"/>
        <remove src="css/awa-touch-final.min.css"/>
        <!-- login-to-cart.css: async na home (awa-login-to-cart-home-async) + hide inline anti-FOUC -->
        <remove src="GrupoAwamotos_B2B::css/product/login-to-cart.css"/>
        <!-- S3-01 home: header-stack (58KB) async via awa-head-preload — critical-home cobre 1º paint -->
        <remove src="css/awa-header-stack-2026-05-28.min.css"/>
        <!-- CMS shell (cms_page_view.xml) não se aplica à home: o Magento adiciona o handle
             cms_page_view à homepage CMS, então removemos aqui o CSS + loader (regras escopadas
             a body.cms-page-view — só desperdiçavam requests na home) -->
        <remove src="css/awa-cms-shell-final.css"/>
        <css src="css/awa-home-shell-final.css"/>
    </head>
    <body>
        <attribute name="data-mage-init">{}</attribute>
        <!-- Remover sidebar padrão de reorder da Home Page (evita título quebrado gigante flutuando no layout) -->
        <referenceBlock name="sale.reorder.sidebar" remove="true"/>
        <!-- safe5: jsbuild poller (setInterval 25ms×200) trava Chrome com require-stub na home -->
        <referenceBlock name="awa.jsbuild.runtime.fallback" remove="true"/>
        <referenceBlock name="awa.cookie.consent.fix.css" remove="true"/>
        <referenceBlock name="awa.cms.shell.final" remove="true"/>
        <referenceBlock name="awa.align.grid.terminal.cms" remove="true"/>
        <referenceBlock name="awa.styles.l.last" remove="true"/>
        <referenceBlock name="awa.cls.nav.fix" remove="true"/>
        <referenceBlock name="awa.critical.inline.css" remove="true"/>
        <!-- opt15: mobile-grid-critical-v10 + cascade-lock-v12 cobrem o 1º paint; evita ~3KB duplicado -->
        <referenceBlock name="awa.header.impeccable.critical.global" remove="true"/>

        <referenceBlock name="head.additional">
            <!-- LCP: preload hero antes de ~110KB CSS inline (load delay PSI) -->
            <block class="GrupoAwamotos\Theme\Block\Html\HeroPreload"
                   name="awa.hero.preload.links"
                   template="Magento_Theme::html/awa-hero-preload-links.phtml"
                   before="-"/>
            <!-- 2026-06-11: 4 folhas críticas → 1 bundle (awa-home-critical-stack, −3 RTT) -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.home.critical.stack"
                   template="Magento_Theme::html/awa-home-critical-stack.phtml"
                   after="awa.hero.preload.links"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.critical.inline.home"
                   template="Magento_Theme::html/awa-critical-fold-home.phtml"
                   after="awa.header.mobile.grid.critical.v10"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.cls.nav.fix.home"
                   template="Magento_Theme::html/awa-cls-nav-fix-home.phtml"
                   after="awa.critical.inline.home"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.header.home.hotfix"
                   template="Magento_Theme::html/awa-header-home-hotfix-home.phtml"
                   after="awa.cls.nav.fix.home"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.cookie.consent.fix.css.home"
                   template="Magento_Theme::html/awa-cookie-consent-home-head.phtml"
                   after="awa.search.autocomplete.head.css"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.footer.accordion.inline.home"
                   template="Magento_Theme::html/awa-mobile-accordion-loader.phtml"
                   after="awa.cookie.consent.fix.css.home"/>
            <referenceBlock name="awa.footer.accordion.inline" remove="true"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.styles.l.last.home"
                   template="Magento_Theme::html/awa-styles-l-last-home.phtml"
                   after="awa.deferred.cosmetic.css"/>
            <!-- Home: audit/footer via awa-home-cosmetic-bundle em awa-head-preload.phtml -->
            <referenceBlock name="awa.audit.bundle.css" remove="true"/>
        </referenceBlock>

        <!-- OG meta: mantém bloco global (default.xml). Remove+recreate quebrava o layout na home. -->
        <move element="awa.og.meta" destination="head.additional" after="awa.styles.l.last.home"/>
        <!-- VQA fixes: carregado via awa-head-preload.phtml ($__qaCssByAction['cms_index_index'])
             porque o bloco awa.visual.qa.fixes.css fica órfão quando awa.audit.bundle.css é removido. -->

        <referenceBlock name="theme.active.editor" remove="true"/>
        <referenceBlock name="google.maps.api" remove="true"/>
        <!-- Home CMS usa só blocos html; widget-initializer PageBuilder (~2,2 KB mage-init) é desnecessário -->
        <referenceBlock name="pagebuilder.widget.initializer" remove="true"/>
        <!-- P11: section-config + customer-data adiados na home -->
        <referenceBlock name="customer.section.config"
                        template="Magento_Theme::html/awa-customer-sections-defer.phtml">
            <arguments>
                <argument name="sectionNamesProvider" xsi:type="object">Magento\Customer\Block\SectionNamesProvider</argument>
                <argument name="auth" xsi:type="object">Magento\Customer\ViewModel\Customer\Auth</argument>
                <argument name="cookie_settings" xsi:type="object">Magento\Customer\ViewModel\CookieSettings</argument>
            </arguments>
        </referenceBlock>
        <referenceBlock name="customer.customer.data" remove="true"/>
        <!-- Home B2B: login via /b2b/account/login — popup KO (~860 B) desnecessário no critical path -->
        <referenceBlock name="authentication-popup" remove="true"/>
        <!-- P13: phase3 minicart via awa-minicart-ui-bootstrap após customer-data -->
        <referenceBlock name="awa.minicart.phase3.init" remove="true"/>
        <!-- P14: storage-manager + invalidation-processor fora do mage-init síncrono -->
        <referenceBlock name="frontend-storage-manager"
                        template="Magento_Theme::html/awa-frontend-storage-defer.phtml"/>
        <referenceBlock name="customer.data.invalidation.rules"
                        template="Magento_Theme::html/awa-customer-invalidation-defer.phtml"/>

        <referenceContainer name="head.additional">
            <!-- LCP critical CSS hero (links em awa.hero.preload.links no topo do head) -->
            <block class="GrupoAwamotos\Theme\Block\Html\HeroPreload"
                   name="awa.hero.preload"
                   template="Magento_Theme::html/awa-hero-preload.phtml"
                   before="awa.seo.head"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.seo.head"
                   template="Magento_Cms::awa-seo-head.phtml"/>
        </referenceContainer>

        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.seo.h1"
                   template="Magento_Cms::awa-seo-h1.phtml"
                   before="-"/>
        </referenceContainer>

        <referenceBlock name="nav.bar.title" remove="true"/>
        <!-- Um único H1: awa.seo.h1 (sr-only). Evita duplicata com page.main.title visível. -->
        <referenceBlock name="page.main.title" remove="true"/>

        <!-- Conteúdo da CMS page `home` é renderizado em top-home.phtml (blocos individuais). -->
        <referenceBlock name="cms_page" remove="true"/>

        <!-- Benefits bar: CSS final após custom_default (ui-ux-pro-max H11) -->
        <referenceContainer name="before.body.end">
            <!-- CSS estático inline — sem dados dinâmicos, seguro cachear. -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.home.benefits.final.inline"
                   template="Magento_Theme::html/awa-home-benefits-final-inline.phtml"
                   before="-"/>
            <!-- Home body-end bundle (consolidado 2026-05-29):
                 substitui layout-r2, layout-clean, polish, adapt e shelf-promax em 1 arquivo. -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.home.body.end.bundle.css"
                   template="Magento_Theme::html/awa-home-layout-r2-css.phtml"
                   after="awa.home.benefits.final.inline"/>
        </referenceContainer>

        <!-- Notification Ticker — DESATIVADO a pedido (2026-05-19) -->
        <referenceBlock name="awa_notification_ticker" remove="true"/>

        <referenceBlock name="awa.impeccable.audit.uncached.global.v10" remove="true"/>

        <!-- Hero único via top_home/slider.main — evita slideshow duplicado no header -->
        <referenceBlock name="slideshow.top" remove="true"/>

        <!-- Remove container vazio herdado do 1column.xml do tema pai -->
        <referenceContainer name="sidebar.additional" remove="true"/>

        <referenceBlock name="top_home">
            <arguments>
                <argument name="category_carousel_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\CategoryCarouselData</argument>
                <argument name="home_guest_pricing_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\HomeGuestPricing</argument>
                <argument name="home_shelf_display_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\HomeShelfDisplay</argument>
                <argument name="home_recent_orders_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\HomeRecentOrders</argument>
                <argument name="hero_responsive_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\HeroResponsiveImage</argument>
            </arguments>
            <block class="Rokanthemes\SlideBanner\Block\Slider"
                   name="slider.main"
                   template="Rokanthemes_SlideBanner::slider_home5.phtml">
                <arguments>
                    <argument name="slider_id" xsi:type="string">homepageslider</argument>
                    <argument name="hero_responsive_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\HeroResponsiveImage</argument>
                </arguments>
            </block>
        </referenceBlock>

        <referenceBlock name="awa.custom.global.js.loader" remove="true"/>
        <move element="autocomplete.injection.js" destination="before.body.end" before="awa.custom.home.owl.tabs.js"/>
        <referenceBlock name="awa.round2.home.owl.tabs.js" remove="true"/>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.custom.home.owl.tabs.js"
                   template="Magento_Theme::html/awa-custom-js-loader.phtml">
                <arguments>
                    <argument name="is_primary_loader" xsi:type="boolean">true</argument>
                    <argument name="load_header_js" xsi:type="boolean">true</argument>
                    <argument name="skip_minicart_defer_init" xsi:type="boolean">true</argument>
                    <argument name="load_home_owl_tabs_js" xsi:type="boolean">true</argument>
                    <argument name="load_footer_ux_js" xsi:type="boolean">false</argument>
                    <argument name="load_pdp_sticky_cta_js" xsi:type="boolean">false</argument>
                    <argument name="load_search_compat_js" xsi:type="boolean">false</argument>
                    <argument name="load_b2b_checkout_compat_js" xsi:type="boolean">false</argument>
                    <argument name="load_home_category_compat_js" xsi:type="boolean">true</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.home.category.carousel.init"
                   template="Magento_Theme::html/awa-home-category-carousel-init.phtml"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.home.product.promo.banners.init"
                   template="Magento_Theme::html/awa-home-product-promo-banners-init.phtml"/>
            <!-- awa-carousel-nav: redundante na home — awa-shelf-carousel cobre vitrines -->
            <referenceBlock name="awa.carousel.nav.loader" remove="true"/>
            <block class="GrupoAwamotos\B2B\Block\LoginToCart"
                   name="b2b.login.to.cart.home"
                   template="GrupoAwamotos_B2B::product/login-to-cart.phtml"
                   after="-"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.image.fallback.init"
                   template="Magento_Theme::html/awa-image-fallback-init.phtml"
                   after="-"/>
            <!-- Scroll reveal: carregado via awa-custom-js-loader (idle na home) -->
            <referenceBlock name="awa.scroll.reveal.js" remove="true"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.seo.jsonld"
                   template="Magento_Cms::awa-seo-jsonld.phtml"
                   after="-"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.home.customer.defer.loader"
                   template="Magento_Theme::html/awa-home-customer-defer-loader.phtml"
                   after="awa.seo.jsonld"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.home.minicart.ui.defer"
                   template="Magento_Theme::html/awa-minicart-ui-defer.phtml"
                   after="awa.home.customer.defer.loader"/>
        </referenceContainer>
    </body>
</page>
