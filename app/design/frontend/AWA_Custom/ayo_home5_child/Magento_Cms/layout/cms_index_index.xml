<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <!-- R35: awa-consistency-home5.css carregado apenas na homepage (antes era global via default_head_blocks.xml) -->
    <head>
        <!-- Remove legacy parent homepage CSS (now in bundle or global bundles) -->
        <remove src="css/awa-round9-post-themeoption-overrides.css"/>
        <remove src="css/awa-components-b2b-foundation.css"/>
        <remove src="css/awa-compat-b2b-nav-plp-cart-checkout.css"/>
        <remove src="css/awa-page-home-category-premium.css"/>
        <remove src="css/awa-home-final-polish.css"/>
        <css src="css/awa-round2-home-owl-tabs.css"/>
        <remove src="css/awa-consistency-home5.css"/>
        <remove src="css/awa-category-carousel.css"/>
        <!-- <css src="css/awa-plp-final-polish.css"/> Removido por TICKET-002: PLP em Home -->
        <css src="css/awa-home-carousel-standard.css"/>
        <css src="css/awa-carousel-modern.css"/>
        <css src="css/awa-visual-qa-home.css"/>
    </head>
    <body>
        <referenceBlock name="theme.active.editor" remove="true"/>
        <referenceBlock name="google.maps.api" remove="true"/>

        <referenceContainer name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.seo.head"
                   template="Magento_Cms::awa-seo-head.phtml"/>
        </referenceContainer>

        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.seo.h1"
                   template="Magento_Cms::awa-seo-h1.phtml"
                   before="-"/>
        </referenceContainer>

        <referenceBlock name="nav.bar.title" remove="true"/>

        <referenceBlock name="cms_page_content" remove="true"/>

        <referenceBlock name="top_home">
            <action method="setData">
                <argument name="name" xsi:type="string">cache_lifetime</argument>
                <argument name="value" xsi:type="boolean">false</argument>
            </action>
            <arguments>
                <argument name="category_carousel_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\CategoryCarouselData</argument>
            </arguments>
            <block class="Rokanthemes\SlideBanner\Block\Slider"
                   name="slider.main"
                   template="Rokanthemes_SlideBanner::slider_home5.phtml">
                <arguments>
                    <argument name="slider_id" xsi:type="string">homepageslider</argument>
                </arguments>
            </block>
        </referenceBlock>

        <referenceBlock name="awa.round2.home.owl.tabs.js" remove="true"/>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.custom.home.owl.tabs.js"
                   template="Magento_Theme::html/awa-custom-js-loader.phtml">
                <arguments>
                    <argument name="load_header_js" xsi:type="boolean">true</argument>
                    <argument name="load_home_owl_tabs_js" xsi:type="boolean">true</argument>
                    <argument name="load_footer_ux_js" xsi:type="boolean">false</argument>
                    <argument name="load_pdp_sticky_cta_js" xsi:type="boolean">false</argument>
                    <argument name="load_search_compat_js" xsi:type="boolean">false</argument>
                    <argument name="load_b2b_checkout_compat_js" xsi:type="boolean">false</argument>
                    <argument name="load_home_category_compat_js" xsi:type="boolean">false</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.home.category.carousel.init"
                   template="Magento_Theme::html/awa-home-category-carousel-init.phtml"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.carousel.nav.js"
                   template="Magento_Theme::html/awa-carousel-nav-loader.phtml"
                   after="awa.home.category.carousel.init"/>
            <block class="GrupoAwamotos\B2B\Block\LoginToCart"
                   name="b2b.login.to.cart.home"
                   template="GrupoAwamotos_B2B::product/login-to-cart.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
