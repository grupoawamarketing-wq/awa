<?php

declare(strict_types=1);

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \GrupoAwamotos\Theme\ViewModel\HomeRecentOrders|null $viewModel */

$viewModel = $block->getData('view_model');
if (!$viewModel instanceof \GrupoAwamotos\Theme\ViewModel\HomeRecentOrders) {
    return;
}

$state = $viewModel->getState();
$recentItems = $viewModel->getRecentItems();
$bestsellersUrl = $viewModel->getBestsellersUrl();
$loginUrl = $viewModel->getLoginUrl();
$registerUrl = $viewModel->getRegisterUrl();
$whatsappUrl = $viewModel->getWhatsAppUrl();
$ordersUrl = $viewModel->getOrdersUrl();
$layoutAnchor = (string) ($block->getData('layout_anchor') ?: 'top');
$layoutAnchorClass = $layoutAnchor === 'end'
    ? 'awa-home-recent-orders--layout-end'
    : 'awa-home-recent-orders--layout-top';
?>

<section class="top-home-content awa-home-section awa-home-recent-orders ayo-home5-section <?= $block->escapeHtmlAttr($layoutAnchorClass) ?>"
         aria-label="<?= $block->escapeHtmlAttr(__('Pedidos feitos recentemente')) ?>"
         data-awa-home-recent-state="<?= $block->escapeHtmlAttr($state) ?>"
         data-awa-home-recent-layout="<?= $block->escapeHtmlAttr($layoutAnchor) ?>">
    <div class="container">
        <header class="awa-section-header awa-section-header--compact awa-home-recent-orders__header">
            <div class="awa-section-header__left">
                <h2 class="awa-section-header__title"><?= $block->escapeHtml(__('Pedidos feitos recentemente')) ?></h2>
                <p class="awa-section-header__subtitle"><?= $block->escapeHtml(__('Últimos itens comprados')) ?></p>
            </div>
            <?php if ($state === \GrupoAwamotos\Theme\ViewModel\HomeRecentOrders::STATE_HAS_ITEMS): ?>
                <a href="<?= $block->escapeUrl($ordersUrl) ?>"
                   class="awa-section-header__link awa-shelf__view-all"
                   aria-label="<?= $block->escapeHtmlAttr(__('Ver todos os pedidos')) ?>">
                    <?= $block->escapeHtml(__('Ver pedidos')) ?>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
            <?php endif; ?>
        </header>

        <?php if ($state === \GrupoAwamotos\Theme\ViewModel\HomeRecentOrders::STATE_HAS_ITEMS): ?>
            <ul class="awa-home-recent-orders__list" aria-label="<?= $block->escapeHtmlAttr(__('Itens do último pedido')) ?>">
                <?php foreach ($recentItems as $item): ?>
                    <li class="awa-home-recent-orders__item">
                        <?php if (!empty($item['url'])): ?>
                            <a href="<?= $block->escapeUrl((string) $item['url']) ?>"
                               class="awa-home-recent-orders__item-link">
                                <?= $block->escapeHtml((string) ($item['name'] ?? '')) ?>
                            </a>
                        <?php else: ?>
                            <span class="awa-home-recent-orders__item-name">
                                <?= $block->escapeHtml((string) ($item['name'] ?? '')) ?>
                            </span>
                        <?php endif; ?>
                    </li>
                <?php endforeach; ?>
            </ul>
        <?php else: ?>
            <div class="awa-home-recent-orders__empty" role="status">
                <div class="awa-home-recent-orders__empty-icon" aria-hidden="true">
                    <svg class="awa-icon--lg"
                         width="48"
                         height="48"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.6"
                         stroke-linecap="round"
                         stroke-linejoin="round"
                         aria-hidden="true"
                         focusable="false">
                        <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                        <rect x="9" y="3" width="6" height="4" rx="1"/>
                        <path d="M9 12h6"/>
                        <path d="M9 16h4"/>
                    </svg>
                </div>

                <?php if ($state === \GrupoAwamotos\Theme\ViewModel\HomeRecentOrders::STATE_GUEST): ?>
                    <p class="awa-home-recent-orders__empty-message">
                        <a href="<?= $block->escapeUrl($loginUrl) ?>" class="awa-home-recent-orders__inline-link">
                            <?= $block->escapeHtml(__('Entre')) ?>
                        </a>
                        <?= $block->escapeHtml(__(' ou ')) ?>
                        <a href="<?= $block->escapeUrl($registerUrl) ?>" class="awa-home-recent-orders__inline-link">
                            <?= $block->escapeHtml(__('cadastre seu CNPJ')) ?>
                        </a>
                        <?= $block->escapeHtml(__(' para ver seus pedidos')) ?>
                    </p>
                    <div class="awa-home-recent-orders__empty-actions" role="group" aria-label="<?= $block->escapeHtmlAttr(__('Próximos passos')) ?>">
                        <?php if ($bestsellersUrl !== '' && $bestsellersUrl !== '#'): ?>
                            <a href="<?= $block->escapeUrl($bestsellersUrl) ?>"
                               class="awa-home-recent-orders__action awa-home-recent-orders__action--secondary">
                                <?= $block->escapeHtml(__('Ver mais vendidos')) ?>
                            </a>
                        <?php endif; ?>
                        <a href="<?= $block->escapeUrl($whatsappUrl) ?>"
                           class="awa-home-recent-orders__action awa-home-recent-orders__action--secondary awa-home-recent-orders__action--wa"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="<?= $block->escapeHtmlAttr(__('Falar com vendedor (abre no WhatsApp em nova aba)')) ?>">
                            <svg class="awa-icon--md"
                                 width="24"
                                 height="24"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2"
                                 stroke-linecap="round"
                                 stroke-linejoin="round"
                                 aria-hidden="true"
                                 focusable="false">
                                <path d="M21 11.5a8.38 8.38 0 0 1-9 8.4 8.5 8.5 0 0 1-4.1-1.2L3 20l1.3-4.5a8.47 8.47 0 1 1 16.7-4z"/>
                                <path d="M8.5 9.5c.6 2 2 3.4 4 4l1.2-1.2c.2-.2.5-.3.8-.2 1 .3 2 .5 3 .5"/>
                            </svg>
                            <?= $block->escapeHtml(__('Falar com vendedor (WhatsApp)')) ?>
                        </a>
                    </div>
                <?php else: ?>
                    <p class="awa-home-recent-orders__empty-message">
                        <?= $block->escapeHtml(__('Você ainda não fez pedidos. Comece pelos mais pedidos por lojistas.')) ?>
                    </p>
                    <div class="awa-home-recent-orders__empty-actions" role="group" aria-label="<?= $block->escapeHtmlAttr(__('Próximos passos')) ?>">
                        <?php if ($bestsellersUrl !== '' && $bestsellersUrl !== '#'): ?>
                            <a href="<?= $block->escapeUrl($bestsellersUrl) ?>"
                               class="awa-home-recent-orders__action awa-home-recent-orders__action--secondary">
                                <?= $block->escapeHtml(__('Ver mais vendidos')) ?>
                            </a>
                        <?php endif; ?>
                    </div>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>
