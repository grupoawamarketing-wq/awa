                    <span class="awa-hero-benefits__icon" aria-hidden="true">
                        <?= /* @noEscape */ $renderBenefitIcon((string) ($benefit['icon'] ?? 'price')) ?>
                    </span>
                    <span class="awa-hero-benefits__copy">
                        <strong class="awa-hero-benefits__title"><?= $block->escapeHtml($benefit['title']) ?></strong>
                        <span class="awa-hero-benefits__text"><?= $block->escapeHtml($benefit['text']) ?></span>
                    </span>
                    <?php if ($isLink): ?>
                        </a>
                    <?php endif; ?>
                </li>
            <?php endforeach; ?>
        </ul>
    </div>
</section>
