                <?php
                $isLink = ($benefit['href'] ?? null) !== null && ($benefit['href'] ?? '') !== '';
                $itemClass = 'awa-hero-benefits__item' . ($isLink ? ' awa-hero-benefits__item--interactive' : '');
                ?>
                <li class="<?= $block->escapeHtmlAttr($itemClass) ?>">
                    <?php if ($isLink): ?>
                        <a href="<?= $block->escapeUrl((string) $benefit['href']) ?>"
                           class="awa-hero-benefits__link"
