$renderBenefitIcon = static function (string $icon): string {
    $svgAttrs = ' width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" focusable="false"';
    return match ($icon) {
        'catalog' => '<svg' . $svgAttrs . '><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>',
        'order' => '<svg' . $svgAttrs . '><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6"/><path d="M9 16h4"/></svg>',
        'whatsapp' => '<svg' . $svgAttrs . '><path d="M21 11.5a8.38 8.38 0 0 1-9 8.4 8.5 8.5 0 0 1-4.1-1.2L3 20l1.3-4.5a8.47 8.47 0 1 1 16.7-4z"/><path d="M8.5 9.5c.6 2 2 3.4 4 4l1.2-1.2c.2-.2.5-.3.8-.2 1 .3 2 .5 3 .5"/></svg>',
        default => '<svg' . $svgAttrs . '><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    };
};
