$renderNicheShelves = static function (
	string $bauletosHtml,
	string $retrovisoresHtml,
	callable $directUrl
) use ($block): string {
	$shelves = [];

	if ($bauletosHtml !== '') {
		$shelves[] = [
			'label' => (string) __('Bauletos'),
			'subtitle' => (string) __('Modelos 29L e 41L: os mais pedidos para reposição'),
			'html' => $bauletosHtml,
			'view_all_url' => $directUrl('bauletos.html'),
			'view_all_label' => (string) __('Ver todos os bauletos'),
		];
	}

	if ($retrovisoresHtml !== '') {
		$shelves[] = [
			'label' => (string) __('Retrovisores'),
			'subtitle' => (string) __('Arrow, esportivos, linha original e mini: giro alto no estoque'),
			'html' => $retrovisoresHtml,
			'view_all_url' => $directUrl('retrovisores.html'),
			'view_all_label' => (string) __('Ver todos os retrovisores'),
		];
	}

	if ($shelves === []) {
		return '';
	}

	return (string) $block->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
		->setTemplate('Magento_Cms::home/niche-shelves-tabs.phtml')
		->setData('shelves', $shelves)
		->toHtml();
};
