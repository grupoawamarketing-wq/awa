$buildCarouselImage = function (string $asset, string $alt, int $idx = 0) use ($carouselIconSize, $block): string {
	$webpAsset = str_replace('.png', '.webp', $asset);
	return '<picture>'
		. '<source srcset="'
		. $block->escapeUrl($block->getViewFileUrl('images/category-carousel/' . $webpAsset))
		. '" type="image/webp" />'
		. '<img src="'
		. $block->escapeUrl($block->getViewFileUrl('images/category-carousel/' . $asset))
        . '" alt="' . $block->escapeHtmlAttr($alt) . '" loading="lazy" decoding="async" width="'
		. $carouselIconSize
		. '" height="'
		. $carouselIconSize
                . '" />'
                . '</picture>';
};

