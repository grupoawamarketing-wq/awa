/* Category carousels — Product Carousel (OWL) filtrado por categoria.
 * Usa GrupoAwamotos\Theme\Block\CategoryProductCarousel (estende BestsellerProduct).
 * category_ids: IDs de subcategoria separados por vírgula.
 * Bauletos (45)     -> subcats: 34L(46), 41L(75), Acessorios(76), 29L(77)
 * Retrovisores (41) -> subcats: Arrow(89), Cromados(51), Esportivos(81), Mini(79), Original(42), Pr.Haste(50)
 * Bagageiros (67)   -> sem subcats, usa categoria pai
 */
$makeCatProductCarousel = function (string $categoryIds, string $viewportKey, string $carouselTitle) use ($layout, $homeCategoryCarouselQty, $homeShelfDisplayViewModel): string {
    /** @var \GrupoAwamotos\Theme\Block\CategoryProductCarousel|null $b */
    $b = $layout->createBlock(\GrupoAwamotos\Theme\Block\CategoryProductCarousel::class);
    if (!$b) return '';
    $b->setData('category_ids', $categoryIds);
    $b->setData('qty', $homeCategoryCarouselQty);
    $b->setData('title', $carouselTitle);
    $b->setData('show_price', 1);
    $b->setData('awa_shelf_viewport_key', $viewportKey);
    if ($homeShelfDisplayViewModel instanceof \GrupoAwamotos\Theme\ViewModel\HomeShelfDisplay) {
        $b->setData('home_shelf_display_view_model', $homeShelfDisplayViewModel);
    }
    $b->setTemplate('Rokanthemes_BestsellerProduct::bestseller.phtml');
    return trim((string)$b->toHtml());
};

/* opt15: vitrines abaixo da dobra — só categorias de maior saída; demais via carrossel de categorias */
