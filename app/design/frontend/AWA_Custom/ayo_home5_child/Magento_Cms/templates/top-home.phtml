$buildCarouselImage = function (string $asset, string $alt) use ($carouselIconSize): string {
	$webpAsset = str_replace('.png', '.webp', $asset);
	return '<picture>'
		. '<source srcset="'
		. $this->escapeUrl($this->getViewFileUrl('images/category-carousel/' . $webpAsset))
		. '" type="image/webp" />'
		. '<img src="'
		. $this->escapeUrl($this->getViewFileUrl('images/category-carousel/' . $asset))
		. '" alt="'
		. $this->escapeHtmlAttr(__($alt))
		. '" loading="eager" decoding="async" width="'
		. $carouselIconSize
		. '" height="'
