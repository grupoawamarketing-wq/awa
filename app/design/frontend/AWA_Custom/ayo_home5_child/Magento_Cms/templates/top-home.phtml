	foreach ($categoryCarouselCategories as &$cat) {
		$urlOverride = $cat['url'] ?? null;
		$displayName = $cat['name'] ?? '';
		$categoryData = $categoryCarouselViewModel->getCategoryData((int) $cat['id']);
		$cat['url'] = $urlOverride ?: $categoryData['url'];
		$cat['name'] = $categoryDisplayNames[(int) $cat['id']] ?? ($displayName !== '' ? $displayName : $categoryData['name']);
		$cat['count'] = $categoryData['count'];
	}
	unset($cat);
}
