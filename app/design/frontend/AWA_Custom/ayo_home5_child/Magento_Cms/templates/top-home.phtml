 * Retrovisores (41) → subcats ordered by count: Arrow(89,17), Cromados(51,13), Esportivos(81,3), Mini(79,2), Original(42,1), Pr.Haste(50,1)
 * Bagageiros (67)   → no subcategories, use parent directly
 */
$makeCatCarousel = static function (string $catId, string $identify) use ($layout): string {
	/** @var \Rokanthemes\Categorytab\Block\CateWidget|null $b */
	$b = $layout->createBlock('Rokanthemes\Categorytab\Block\CateWidget');
	if (!$b) return '';
	$b->setData('category_id', $catId);
	$b->setData('identify', $identify);
	return trim((string)$b->setTemplate('Rokanthemes_Categorytab::categorytab/grid-original.phtml')->toHtml());
};

