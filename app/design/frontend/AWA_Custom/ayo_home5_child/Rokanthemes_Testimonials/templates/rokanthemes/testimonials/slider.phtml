<?php
$helperData = $this->helper('Rokanthemes\Testimonials\Helper\Data');
$helperImage = $this->helper('Rokanthemes\Testimonials\Helper\Image');

if (!$helperData->isEnabled()) {
    return false;
}

$_testimonialsCollection = $block->getTestimonials();
$title = $block->getTitle();
$imgWidth = $helperData->getImgRizeWidth();
$imgHeight = $helperData->getImgRizeHeight();
$allTestimonialsUrl = $block->getUrl('testimonials');
?>
<?php if ($_testimonialsCollection->count()): ?>
<div class="box-bottom-home2 box-testimo">
    <h2><?= $block->escapeHtml(__($title)) ?></h2>
    <div class="testimo-slider slider-home2">
        <div class="swiper awa-testimo-swiper">
            <div class="swiper-wrapper wrap-item">
                <?php foreach ($_testimonialsCollection as $_testimonial): ?>
                    <?php
                    $authorName = trim((string) $_testimonial->getName());
                    $authorJob = trim((string) $_testimonial->getJob());
                    $avatarAlt = $authorName !== '' ? $authorName : (string) __('Cliente AWA Motos');
                    $avatarUrl = $helperImage->resize($_testimonial->getAvatar(), $imgWidth, $imgHeight, true);
                    ?>
                    <div class="swiper-slide item-testimo">
                    <div class="author-testimo">
                        <div class="author-test-link">
                            <a href="<?= $block->escapeUrl($allTestimonialsUrl) ?>" aria-label="<?= $block->escapeHtmlAttr($avatarAlt) ?>">
                                <img
                                    src="<?= $block->escapeUrl($avatarUrl) ?>"
                                    alt="<?= $block->escapeHtmlAttr($avatarAlt) ?>"
                                    width="<?= $block->escapeHtmlAttr($imgWidth) ?>"
                                    height="<?= $block->escapeHtmlAttr($imgHeight) ?>"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </a>
                        </div>
                    </div>
                    <div class="info-testimonial">
                        <div class="desc">
                            <?= /* @noEscape */ $_testimonial->getTestimonial(); ?>
                        </div>
                        <div class="author-test-info">
                            <h3><a href="<?= $block->escapeUrl($allTestimonialsUrl) ?>"><?= $block->escapeHtml($authorName) ?></a></h3>
                            <span><?= $block->escapeHtml($authorJob) ?></span>
                        </div>
                    </div>
                    </div><!-- .swiper-slide.item-testimo -->
                <?php endforeach; ?>
            </div><!-- .swiper-wrapper -->
            <div class="swiper-pagination"></div>
        </div><!-- .awa-testimo-swiper -->
    </div>
    <a href="<?= $block->escapeUrl($allTestimonialsUrl) ?>" class="viewall"><?= $block->escapeHtml(__('View All')) ?></a>
</div>
<script type="text/x-magento-init">
{
    ".testimo-slider": {
        "js/tab-swiper-init": {
            "carouselSelector": ".awa-testimo-swiper",
            "owl": {
                "items": 1,
                "navigation": false,
                "pagination": true
            }
        }
    }
}
</script>
<?php else: ?>
<div class="box-bottom-home2 box-testimo">
    <span><?= $block->escapeHtml(__('Testimonial records not available.')) ?></span>
</div>
<?php endif; ?>
