<?php
/**
 * AWA Motos — Newproduct widget override
 * Matches ProductTab card structure for visual consistency.
 */
use Magento\Framework\App\Action\Action;

if (!$this->getConfig('enabled')) {
    return;
}

$_productCollection = $this->getProducts();

if ($block->getMode() === 'grid') {
    $viewMode = 'grid';
    $image = 'category_page_grid';
    $showDescription = false;
    $templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::SHORT_VIEW;
} else {
    $viewMode = 'list';
    $image = 'category_page_list';
    $showDescription = true;
    $templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::FULL_VIEW;
}

$pos = $block->getPositioned();
$rows = (int) $this->getConfig('items_show') ?: 1;
$showCart = (bool) $this->getConfig('addtocart');
$showReview = (bool) $this->getConfig('review');
$isHomePage = $block->getRequest()->getFullActionName() === 'cms_index_index';
$sectionTitle = trim((string) $this->getConfig('title'));
$carouselLabel = $sectionTitle !== '' ? $sectionTitle : (string) __('Lançamentos');
?>
<div class="rokan-newproduct awa-shelf awa-shelf--carousel" data-awa-shelf="newproduct">
    <?php if ($this->getConfig('title')): ?>
    <div class="rokan-product-heading rokan-onsale-heading" aria-hidden="true">
        <h2><?= $block->escapeHtml($this->getConfig('title')) ?></h2>
        <div class="des-title"><?= $block->escapeHtml($this->getConfig('shortdec')) ?></div>
    </div>
    <?php endif; ?>

    <?php if (!$_productCollection->getSize()): ?>
        <div class="rokan-newproduct-slider">
            <p class="note-msg"><?= $block->escapeHtml(__('There are no products matching the selection.')) ?></p>
        </div>
    <?php else: ?>
        <div class="awa-carousel">
            <div class="awa-carousel__viewport awa-cq-card-wrapper"
                 role="region"
                 aria-roledescription="<?= $block->escapeHtmlAttr(__('carrossel')) ?>"
                 aria-label="<?= $block->escapeHtmlAttr($carouselLabel) ?>">
            <ul class="owl awa-carousel__track" aria-live="polite">
                <?php
                $i = 0;
                foreach ($_productCollection as $_product):
                    if ($i % $rows === 0) {
                        echo "<li class='item newproductslider-item'>";
                    }

                    $productImage = $block->getImage($_product, $image);
                    $productImageThumb = $block->getImage($_product, 'category_page_grid-1');
                    $productImageHtml = (string) $productImage->toHtml();
                    $productImageThumbHtml = (string) $productImageThumb->toHtml();
                    $productImageThumbUrl = (string) $productImageThumb->getImageUrl();

                    if (!$isHomePage && $i < 2) {
                        // Fora da home: primeiras 2 imagens acima do fold
                        $productImageHtml = str_replace(' loading="lazy"', ' loading="eager" fetchpriority="high"', $productImageHtml);
                    } else {
                        // Home: LCP é o hero — prateleiras sempre lazy, sem fetchpriority
                        $productImageHtml = str_replace([' loading="eager"', ' fetchpriority="high"'], [' loading="lazy"', ''], $productImageHtml);
                    }

                    if ($productImageThumbUrl === '' || strpos($productImageThumbUrl, '/placeholder/') !== false) {
                        $productImageThumbHtml = $productImageHtml;
                    }

                    $now = date('Y-m-d H:i:s');
                    $specialprice = $_product->getSpecialPrice();
                    $specialPriceFromDate = $_product->getSpecialFromDate();
                    $specialPriceToDate = $_product->getSpecialToDate();
                    $newFromDate = $_product->getNewsFromDate();
                    $newToDate = $_product->getNewsToDate();
                    $isSale = $specialprice && ($specialPriceFromDate <= $now && $specialPriceToDate >= $now);
                    $isNew = !$isSale && ($newFromDate <= $now && $newToDate >= $now);

                    if ($pos !== null) {
                        $position = ' style="left:' . $productImage->getWidth() . 'px;'
                            . 'top:' . $productImage->getHeight() . 'px;"';
                    }
                ?>
                    <div class="item-product awa-carousel-card-slot" data-product-id="<?= (int) $_product->getId() ?>">
                        <div class="content-item-product awa-product-card">
                            <div class="product-thumb">
                                <a href="<?= $block->escapeUrl($_product->getProductUrl()) ?>"
                                   class="product-thumb-link"
                                   aria-label="<?= $block->escapeHtmlAttr($_product->getName()) ?>">
                                    <span class="first-thumb">
                                        <?= /* @noEscape */ $productImageHtml ?>
                                    </span>
                                    <?php if (!$isHomePage): ?>
                                    <span class="second-thumb">
                                        <?= /* @noEscape */ $productImageThumbHtml ?>
                                    </span>
                                    <?php endif; ?>
                                </a>
                                <div class="hot-onsale">
                                    <?php if ($isSale): ?>
                                        <div class="onsale"><span class="sale-bg"></span><span class="sale-text"><label><?= $block->escapeHtml(__('Promoção')) ?></label></span></div>
                                    <?php elseif ($isNew): ?>
                                        <div class="onsale new-lable"><span class="sale-bg"></span><span class="sale-text"><label><?= $block->escapeHtml(__('Novo')) ?></label></span></div>
                                    <?php endif; ?>
                                </div>
                                <?php if (!$isHomePage): ?>
                                <div class="actions-secondary">
                                    <ul class="product-extra-link add-to-links">
                                        <li class="wishlist-product">
                                            <?php if ($this->helper('Magento\Wishlist\Helper\Data')->isAllow()): ?>
                                            <a href="#"
                                               class="wishlist-link action towishlist"
                                               data-post='<?= /* @noEscape */ $block->getAddToWishlistParams($_product) ?>'
                                               data-action="add-to-wishlist"
                                               title="<?= $block->escapeHtmlAttr(__('Adicionar à Lista de Desejos')) ?>"
                                               aria-label="<?= $block->escapeHtmlAttr(__('Adicionar à Lista de Desejos')) ?>">
                                                <i class="fa fa-heart" aria-hidden="true"></i>
                                            </a>
                                            <?php endif; ?>
                                        </li>
                                        <li class="quickview-product">
                                            <a data-role="quickview-button"
                                               data-id="<?= (int) $_product->getId() ?>"
                                               href="javascript:void(0);"
                                               data-href="<?= $block->escapeUrl($block->getUrl('quickview/product/quickview/id/' . $_product->getId())) ?>"
                                               class="quickview-link"
                                               title="<?= $block->escapeHtmlAttr(__('Visualização Rápida')) ?>"
                                               aria-label="<?= $block->escapeHtmlAttr(__('Visualização Rápida') . ': ' . $_product->getName()) ?>">
                                                <i class="fa fa-eye" aria-hidden="true"></i>
                                            </a>
                                        </li>
                                        <li class="compare-product">
                                            <?php $compareHelper = $this->helper('Magento\Catalog\Helper\Product\Compare'); ?>
                                            <a href="#"
                                               class="compare-link action tocompare"
                                               data-post='<?= /* @noEscape */ $compareHelper->getPostDataParams($_product) ?>'
                                               title="<?= $block->escapeHtmlAttr(__('Adicionar ao Comparador')) ?>"
                                               aria-label="<?= $block->escapeHtmlAttr(__('Adicionar ao Comparador')) ?>">
                                                <i class="fa fa-retweet" aria-hidden="true"></i>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                                <?php endif; ?>
                            </div>

                            <div class="product-info-cart">
                                <?php if ($showCart): ?>
                                <div class="actions-primary addcart-link">
                                    <?php if ($_product->isSaleable()): ?>
                                        <?php $postParams = $block->getAddToCartPostParams($_product); ?>
                                        <form data-role="tocart-form"
                                              action="<?= /* @noEscape */ $postParams['action'] ?>"
                                              method="post">
                                            <input type="hidden" name="product" value="<?= (int) $postParams['data']['product'] ?>">
                                            <input type="hidden"
                                                   name="<?= /* @noEscape */ Action::PARAM_NAME_URL_ENCODED ?>"
                                                   value="<?= /* @noEscape */ $postParams['data'][Action::PARAM_NAME_URL_ENCODED] ?>">
                                            <?= $block->getBlockHtml('formkey') ?>
                                            <button type="submit"
                                                    title="<?= $block->escapeHtmlAttr(__('Adicionar ao Carrinho')) ?>"
                                                    aria-label="<?= $block->escapeHtmlAttr(__('Adicionar ao Carrinho') . ': ' . $_product->getName()) ?>"
                                                    class="btn-add-to-cart action tocart">
                                                <span><?= $block->escapeHtml(__('Adicionar ao Carrinho')) ?></span>
                                            </button>
                                        </form>
                                    <?php else: ?>
                                        <?php if ($_product->getIsSalable()): ?>
                                            <div class="stock available"><span><?= $block->escapeHtml(__('Em estoque')) ?></span></div>
                                        <?php else: ?>
                                            <div class="stock unavailable"><span><?= $block->escapeHtml(__('Esgotado')) ?></span></div>
                                        <?php endif; ?>
                                    <?php endif; ?>
                                </div>
                                <?php endif; ?>
                            </div>

                            <div class="product-info">
                                <h3 class="product-name">
                                    <a class="product-item-link"
                                       title="<?= $block->escapeHtmlAttr($_product->getName()) ?>"
                                       href="<?= $block->escapeUrl($_product->getProductUrl()) ?>">
                                        <?= $block->escapeHtml($_product->getName()) ?>
                                    </a>
                                </h3>

                                <?php if ($_product->getSku()): ?>
                                    <span class="awa-b2b-sku"><span class="awa-b2b-sku__label">REF: </span><span class="awa-b2b-sku__value"><?= $block->escapeHtml($_product->getSku()) ?></span></span>
                                <?php endif; ?>

                                <?php if ($showReview): ?>
                                <div class="product-rating">
                                    <?= $block->getReviewsSummaryHtml($_product, $templateType) ?>
                                </div>
                                <?php endif; ?>

                                <div class="info-price">
                                    <?php if ($this->getConfig('show_price')): ?>
                                        <?= /* @noEscape */ $this->helper('Rokanthemes\Themeoption\Helper\Data')->getPriceDisplayCustom($block->getProductPrice($_product)) ?>
                                    <?php endif; ?>
                                </div>
                            </div>
                        </div>
                    </div>
                <?php
                    $i++;
                    if ($i % $rows === 0) {
                        echo '</li>';
                    }
                endforeach;
                if ($i % $rows !== 0) {
                    echo '</li>';
                }
                ?>
            </ul>
            </div>
        </div>

        <?php
        $awaIsHomePage = $block->getRequest()->getFullActionName() === 'cms_index_index';
        ?>
        <?php if (!$block->isRedirectToCartEnabled()): ?>
        <script type="text/x-magento-init">
        {
            "[data-role=tocart-form]": {
                "catalogAddToCart": {}
            }
        }
        </script>
        <?php endif; ?>
    <?php endif; ?>
</div>
