<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!--
            Search CSS optimization (2026-03-19): awa-bundle-search replaces 3 requests:
            awa-bundle-plp (plp+plp-final-polish) + awa-bundle-inner-pages (4 files)
            awa-bundle-site.css stays in default (correct cascade before refinements).
        -->
        <css src="css/awa-bundle-search.css"/>
        <!-- awa-custom-page-home-category-premium.css: excluído (homepage/categoria only) -->
    </head>
    <body>
        <!--
            B2B: Inicializa o modal de login e o JS que injeta o botão "Entrar para Comprar"
            nos cards de produto em resultados de busca.
        -->
        <referenceContainer name="before.body.end">
            <block class="GrupoAwamotos\B2B\Block\LoginToCart"
                   name="b2b.login.to.cart.search"
                   template="GrupoAwamotos_B2B::product/login-to-cart.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
