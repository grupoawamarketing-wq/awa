<?xml version="1.0"?>
<!--
  AWA Motos — Search Results Page Layout Overrides
  Carrega awa-category-layout-fix.css na página de resultados de busca.
  Mesmas correções que catalog_category_view.xml — o CSS já usa :is() targeting
  ambas body.catalog-category-view e body.catalogsearch-result-index.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="css/awa-category-layout-fix.css" order="1200"/>
        <css src="css/awa-bundle-category.css" order="1202"/>
    </head>
    <body>
        <referenceContainer name="before.body.end">
            <block class="GrupoAwamotos\B2B\Block\LoginToCart"
                   name="b2b.login.to.cart.search"
                   template="GrupoAwamotos_B2B::product/login-to-cart.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
