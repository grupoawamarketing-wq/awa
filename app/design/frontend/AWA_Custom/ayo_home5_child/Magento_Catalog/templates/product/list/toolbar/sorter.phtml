<?php
/**
 * AWA override: adiciona <label> para o <select> de ordenação.
 * Fase 3.10 — WCAG 1.3.1 / 4.1.2: controle de formulário deve ter label associado.
 *
 * @var $block \Magento\Catalog\Block\Product\ProductList\Toolbar
 */
declare(strict_types=1);
?>
<div class="toolbar-sorter sorter">
    <label for="sorter" class="sorter-label"><?= $block->escapeHtml(__('Ordenar por:')) ?></label>
    <select id="sorter" data-role="sorter" class="sorter-options">
        <?php foreach ($block->getAvailableOrders() as $_key => $_order): ?>
            <option value="<?= $block->escapeHtml($_key) ?>"
                <?php if ($block->isOrderCurrent($_key)): ?>
                    selected="selected"
                <?php endif; ?>>
                <?= $block->escapeHtml(__($_order)) ?>
            </option>
        <?php endforeach; ?>
    </select>
</div>
