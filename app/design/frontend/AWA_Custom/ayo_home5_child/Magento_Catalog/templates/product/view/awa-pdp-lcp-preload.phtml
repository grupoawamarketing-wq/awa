<?php
/**
 * AWA PDP — LCP Image Preload
 *
 * Emite <link rel="preload" as="image"> para a imagem principal do produto.
 * Reduz o LCP (Largest Contentful Paint) adiantando o download da imagem hero.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
declare(strict_types=1);

$viewModel = $block->getData('view_model');
if (!$viewModel instanceof \GrupoAwamotos\Theme\ViewModel\ProductStructuredData) {
    return;
}

$imageUrl = $viewModel->getProductLcpImageUrl();
if ($imageUrl === '') {
    return;
}
?>
<link rel="preload" as="image" href="<?= $block->escapeUrl($imageUrl) ?>" fetchpriority="high"/>
