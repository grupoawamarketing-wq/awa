<?php
/**
 * PDP secondary links — child theme override
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
declare(strict_types=1);

$catalogHelper = $this->helper(Magento\Catalog\Helper\Product::class);
$_product = $block->getProduct();
?>
<?php if ($block->canEmailToFriend()): ?>
    <a title="<?= $this->escapeHtmlAttr(__('Email')) ?>"
       href="<?= $this->escapeUrl($catalogHelper->getEmailToFriendUrl($_product)) ?>"
       class="action email-link"
       aria-label="<?= $this->escapeHtmlAttr(__('Email')) ?>">
        <i class="fa fa-envelope" aria-hidden="true"></i>
        <span class="awa-pdp-social-label"><?= $this->escapeHtml(__('E-mail')) ?></span>
    </a>
<?php endif; ?>
<a href="#"
   onclick="window.print();return false;"
   title="<?= $this->escapeHtmlAttr(__('Print')) ?>"
   class="action print-link"
   aria-label="<?= $this->escapeHtmlAttr(__('Print')) ?>">
    <i class="fa fa-print" aria-hidden="true"></i>
    <span class="awa-pdp-social-label"><?= $this->escapeHtml(__('Imprimir')) ?></span>
</a>
<a href="https://www.facebook.com/sharer.php?u=<?= $this->escapeUrl($block->getProductUrl($_product)) ?>"
   title="<?= $this->escapeHtmlAttr(__('Share')) ?>"
   onclick="return !window.open(this.href, 'Facebook', 'width=500,height=500')"
   aria-label="<?= $this->escapeHtmlAttr(__('Share')) ?>">
    <i class="fa fa-share" aria-hidden="true"></i>
    <span class="awa-pdp-social-label"><?= $this->escapeHtml(__('Compartilhar')) ?></span>
</a>
