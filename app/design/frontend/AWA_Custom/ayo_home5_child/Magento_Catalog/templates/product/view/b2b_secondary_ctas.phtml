$whatsappMsg = rawurlencode(sprintf(
    "Olá, gostaria de solicitar cotação para lote do produto: %s (SKU: %s) — %s",
    $_product->getName(),
    $_product->getSku(),
    $block->getUrl($_product->getUrlKey() . '.html')
));
$whatsappUrl = 'https://wa.me/5516997367588?text=' . $whatsappMsg;
?>
<?php if (!$b2bCanAddToCart): ?>
<div class="awa-b2b-secondary-ctas awa-b2b-secondary-ctas--gated">
    <p class="awa-b2b-secondary-ctas__note"><?= $block->escapeHtml(__('Após a aprovação da sua conta, sua empresa terá acesso a preços, compra recorrente e condições comerciais negociadas.')) ?></p>
    <div class="awa-b2b-gate-card__actions">
        <a href="<?= $block->escapeUrl($b2bHelper->getPriceGatePrimaryUrl()) ?>" class="awa-b2b-gate-card__action">
            <?= $block->escapeHtml($b2bHelper->getPriceGatePrimaryLabel()) ?>
