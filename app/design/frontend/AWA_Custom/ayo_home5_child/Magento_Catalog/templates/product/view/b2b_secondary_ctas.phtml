        <a href="<?= $block->escapeUrl($whatsappUrl) ?>" class="awa-b2b-gate-card__action awa-b2b-gate-card__action--secondary" target="_blank" rel="noopener">
            <?= $block->escapeHtml(__('Falar com consultor')) ?>
        </a>
    </div>
