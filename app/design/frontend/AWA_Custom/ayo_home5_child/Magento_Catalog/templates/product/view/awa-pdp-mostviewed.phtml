                "itemsMobile": [479, 1],
                "navigation": true,
                "pagination": false,
                "margin": 16
            }
        }
    }
}
</script>

<script>
(function () {
    var section = document.querySelector('.awa-pdp-mostviewed');
    if (!section) { return; }
    var slides = section.querySelectorAll('.swiper-slide[data-brand]');
    var tabsEl = document.getElementById('awa-pdp-mv-tabs');
    if (!slides.length || !tabsEl) { return; }
    var brands = [];
    slides.forEach(function (s) {
        var b = (s.getAttribute('data-brand') || '').trim();
        if (b && brands.indexOf(b) === -1) { brands.push(b); }
    });
    if (brands.length < 2) { tabsEl.style.display = 'none'; return; }
    function makeTab(label, value) {
        var btn = document.createElement('button');
        btn.className = 'awa-pdp-mv-tab' + (value === '' ? ' awa-active' : '');
        btn.type = 'button';
        btn.textContent = label;
        btn.setAttribute('data-filter', value);
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-selected', value === '' ? 'true' : 'false');
        btn.addEventListener('click', function () {
            tabsEl.querySelectorAll('.awa-pdp-mv-tab').forEach(function (t) {
                t.classList.remove('awa-active');
                t.setAttribute('aria-selected', 'false');
            });
            btn.classList.add('awa-active');
            btn.setAttribute('aria-selected', 'true');
            var filter = btn.getAttribute('data-filter');
            slides.forEach(function (s) {
                var brand = (s.getAttribute('data-brand') || '').trim();
                if (filter === '' || brand === filter) {
                    s.removeAttribute('data-brand-hidden');
                } else {
                    s.setAttribute('data-brand-hidden', '');
                }
            });
        });
        return btn;
    }
    tabsEl.appendChild(makeTab('Todos', ''));
    brands.forEach(function (b) { tabsEl.appendChild(makeTab(b, b)); });
})();
</script>