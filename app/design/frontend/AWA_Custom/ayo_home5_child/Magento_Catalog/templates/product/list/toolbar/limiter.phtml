<?php
/**
 * AWA override — limiter com rótulo acessível.
 * Mantém a marcação enxuta do tema (sem label visível) e adiciona
 * aria-label ao select, que estava sem nome acessível (auditoria UX).
 *
 * @var \Magento\Catalog\Block\Product\ProductList\Toolbar $block
 * @var \Magento\Framework\Escaper $escaper
 */
?>
<div class="field limiter">
    <div class="control">
        <select id="limiter"
                data-role="limiter"
                class="limiter-options"
                aria-label="<?= $escaper->escapeHtmlAttr(__('Itens por página')) ?>">
            <?php foreach ($block->getAvailableLimit() as $_key => $_limit): ?>
                <option value="<?= $escaper->escapeHtmlAttr($_key) ?>"
                    <?php if ($block->isLimitCurrent($_key)): ?> selected="selected"<?php endif ?>>
                    <?= $escaper->escapeHtml($_limit) ?>
                </option>
            <?php endforeach; ?>
        </select>
    </div>
</div>
