<?php
/**
 * AWA PDP — Descrição em acordeão (fallback inteligente).
 * Nota: o ficheiro chama-se awa-pdp-tabs por histórico; o markup é `<details>` de descrição,
 * não o tablist `.awa-pdp-tabs` usado por `awa-pdp-b2b-pro.js`.
 *
 * Prioridade: description > short_description > atributos básicos (marca, modelo).
 * Nunca exibe seção vazia — sempre mostra algo útil para o cliente.
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
declare(strict_types=1);

$_product = $block->getProduct();
if (!$_product) {
    return;
}

$_helper = $this->helper(\Magento\Catalog\Helper\Output::class);
$description = $_helper->productAttribute($_product, $_product->getDescription(), 'description');
$shortDescription = $_helper->productAttribute($_product, $_product->getShortDescription(), 'short_description');

$content = '';
$sectionTitle = __('Descrição');

// 1. Descrição completa
if (trim(strip_tags((string) $description)) !== '') {
    $content = $description;
// 2. Descrição curta
} elseif (trim(strip_tags((string) $shortDescription)) !== '') {
    $content = $shortDescription;
// 3. Fallback: montar resumo com atributos do produto
} else {
    $name = $block->escapeHtml($_product->getName());
    $sku  = $block->escapeHtml($_product->getSku());

    $attrs = [];
    foreach (['marca_moto', 'modelo_moto', 'ano_moto', 'material', 'cor'] as $code) {
        try {
            $attr = $_product->getResource()->getAttribute($code);
            if ($attr && $attr->usesSource()) {
                $val = $_product->getAttributeText($code);
                if ($val && $val !== 'N/A' && $val !== '-') {
                    $attrs[$code] = is_array($val) ? implode(', ', $val) : (string) $val;
                }
            }
        } catch (\Throwable $e) {
            continue;
        }
    }

    if (!empty($attrs) || $name) {
        $sectionTitle = __('Sobre este produto');
        $lines = ['<p><strong>' . $name . '</strong></p>'];
        if ($sku) {
            $lines[] = '<p>Código do produto: <strong>' . $sku . '</strong></p>';
        }
        $labelMap = [
            'marca_moto'  => 'Marca',
            'modelo_moto' => 'Modelo',
            'ano_moto'    => 'Ano',
            'material'    => 'Material',
            'cor'         => 'Cor',
        ];
        foreach ($attrs as $code => $val) {
            $label = $labelMap[$code] ?? $code;
            $lines[] = '<p>' . $block->escapeHtml($label) . ': <strong>' . $block->escapeHtml($val) . '</strong></p>';
        }
        $content = implode("\n", $lines);
    }
}

if (trim(strip_tags((string) $content)) === '') {
    return;
}
?>

<details class="awa-pdp-accordion-item" open>
    <summary><?= $block->escapeHtml($sectionTitle) ?></summary>
    <div class="awa-accordion-body product attribute description awa-pdp-basic-description__content"
         role="region">
        <?= /* @noEscape */ $content ?>
    </div>
</details>
