<?php
/**
 * AWA PDP — Bloco básico de descrição
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
declare(strict_types=1);

$_product = $block->getProduct();
if (!$_product) {
    return;
}

$_helper = $this->helper(\Magento\Catalog\Helper\Output::class);
$description = $_helper->productAttribute($_product, $_product->getDescription(), 'description');
$shortDescription = $_helper->productAttribute($_product, $_product->getShortDescription(), 'short_description');

$content = trim((string) $description) !== '' ? $description : $shortDescription;
if (trim(strip_tags((string) $content)) === '') {
    return;
}
?>

<div class="awa-pdp-tabs awa-pdp-basic-description" id="awa-pdp-basic-description">
    <div class="awa-pdp-tabs__panel active"
         role="region"
         aria-label="<?= $block->escapeHtmlAttr(__('Descrição do produto')) ?>"
         aria-hidden="false">
        <h2 class="awa-pdp-basic-description__title"><?= $block->escapeHtml(__('Descrição')) ?></h2>
        <div class="product attribute description awa-pdp-basic-description__content">
            <?= /* @noEscape */ $content ?>
        </div>
    </div>
</div>
