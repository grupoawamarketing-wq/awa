                </div>
                <div>
                    <div class="awa-pdp-info-card__label"><?= $block->escapeHtml(__('Peso')) ?></div>
                    <div class="awa-pdp-info-card__value"><?= $block->escapeHtml(number_format((float) $weight, 2, ',', '.')) ?> kg</div>
                </div>
            </div>
            <?php endif; ?>

            <div class="awa-pdp-info-card">
                <div class="awa-pdp-info-card__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                    <div class="awa-pdp-info-card__label"><?= $block->escapeHtml(__('Prazo de entrega')) ?></div>
                    <div class="awa-pdp-info-card__value"><?= $block->escapeHtml(__('Calcule no carrinho')) ?></div>
                </div>
            </div>

            <div class="awa-pdp-info-card">
                <div class="awa-pdp-info-card__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                    <div class="awa-pdp-info-card__label"><?= $block->escapeHtml(__('Garantia')) ?></div>
                    <div class="awa-pdp-info-card__value"><?= $block->escapeHtml(__('Garantia do fabricante')) ?></div>
                </div>
            </div>

            <div class="awa-pdp-info-card">
                <div class="awa-pdp-info-card__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                </div>
                <div>
                    <div class="awa-pdp-info-card__label"><?= $block->escapeHtml(__('Certificações')) ?></div>
                    <div class="awa-pdp-info-card__value"><?= $block->escapeHtml(__('INMETRO / CONTRAN')) ?></div>
