<?php
/**
 * AWA PDP B2B Pro — Content Tabs
 * Tabs: Descrição, Especificações, Avaliações, Informações
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
declare(strict_types=1);

$_product = $block->getProduct();
if (!$_product) {
    return;
}

$_helper = $this->helper(\Magento\Catalog\Helper\Output::class);

/* Description */
$description = $_helper->productAttribute($_product, $_product->getDescription(), 'description');
$shortDescription = $_helper->productAttribute($_product, $_product->getShortDescription(), 'short_description');

/* Specs: get additional attributes from the attributes block if available */
$attributesBlock = $block->getLayout()->getBlock('product.attributes.above.fold');
$additionalData = [];
if ($attributesBlock) {
    try {
        $additionalData = $attributesBlock->getAdditionalData() ?: [];
    } catch (\Throwable $e) {
        $additionalData = [];
    }
}

/* Weight */
$weight = $_product->getWeight();
?>

<div class="awa-pdp-tabs" id="awa-pdp-tabs">
    <!-- Tab Navigation -->
    <ul class="awa-pdp-tabs__nav" role="tablist" aria-label="<?= $block->escapeHtmlAttr(__('Informações do produto')) ?>">
        <?php if ($description || $shortDescription): ?>
        <li class="awa-pdp-tabs__nav-item" role="presentation">
            <button class="awa-pdp-tabs__nav-btn"
                    role="tab"
                    id="awa-tab-desc"
                    aria-controls="awa-panel-desc"
                    aria-selected="true"
                    tabindex="0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                <?= $block->escapeHtml(__('Descrição')) ?>
            </button>
        </li>
        <?php endif; ?>

        <?php if (!empty($additionalData)): ?>
        <li class="awa-pdp-tabs__nav-item" role="presentation">
            <button class="awa-pdp-tabs__nav-btn"
                    role="tab"
                    id="awa-tab-specs"
                    aria-controls="awa-panel-specs"
                    aria-selected="false"
                    tabindex="-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                <?= $block->escapeHtml(__('Especificações')) ?>
                <span class="awa-badge"><?= (int) count($additionalData) ?></span>
            </button>
        </li>
        <?php endif; ?>

        <li class="awa-pdp-tabs__nav-item" role="presentation">
            <button class="awa-pdp-tabs__nav-btn"
                    role="tab"
                    id="awa-tab-reviews"
                    aria-controls="awa-panel-reviews"
                    aria-selected="false"
                    tabindex="-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <?= $block->escapeHtml(__('Avaliações')) ?>
            </button>
        </li>

        <li class="awa-pdp-tabs__nav-item" role="presentation">
            <button class="awa-pdp-tabs__nav-btn"
                    role="tab"
                    id="awa-tab-info"
                    aria-controls="awa-panel-info"
                    aria-selected="false"
                    tabindex="-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                <?= $block->escapeHtml(__('Informações')) ?>
            </button>
        </li>
    </ul>

    <!-- Tab Panels -->

    <!-- TAB 1: Description -->
    <?php if ($description || $shortDescription): ?>
    <div class="awa-pdp-tabs__panel active"
         role="tabpanel"
         id="awa-panel-desc"
         aria-labelledby="awa-tab-desc"
         aria-hidden="false">
        <div class="product attribute description">
            <?php if ($shortDescription): ?>
                <div class="product attribute overview">
                    <?= /* @noEscape */ $shortDescription ?>
                </div>
            <?php endif; ?>
            <?php if ($description): ?>
                <div class="product attribute full-description">
                    <?= /* @noEscape */ $description ?>
                </div>
            <?php endif; ?>
        </div>
    </div>
    <?php endif; ?>

    <!-- TAB 2: Specifications -->
    <?php if (!empty($additionalData)): ?>
    <div class="awa-pdp-tabs__panel"
         role="tabpanel"
         id="awa-panel-specs"
         aria-labelledby="awa-tab-specs"
         aria-hidden="true">
        <table class="awa-pdp-specs-table" id="awa-product-specs-table">
            <caption class="awa-sr-only"><?= $block->escapeHtml(__('Especificações técnicas do produto')) ?></caption>
            <tbody>
            <?php foreach ($additionalData as $_data): ?>
                <tr>
                    <th scope="row"><?= $block->escapeHtml($_data['label']) ?></th>
                    <td data-th="<?= $block->escapeHtmlAttr($_data['label']) ?>">
                        <?= /* @noEscape */ $_helper->productAttribute($_product, $_data['value'], $_data['code']) ?>
                    </td>
                </tr>
            <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <?php endif; ?>

    <!-- TAB 3: Reviews -->
    <div class="awa-pdp-tabs__panel"
         role="tabpanel"
         id="awa-panel-reviews"
         aria-labelledby="awa-tab-reviews"
         aria-hidden="true">
        <?php
        $reviewsTabBlock = $block->getLayout()->getBlock('reviews.tab');
        if ($reviewsTabBlock) {
            echo $reviewsTabBlock->toHtml();
        }
        ?>
        <div id="awa-reviews-container">
            <?php
            $reviewBlock = $block->getLayout()->getBlock('product.info.product_additional_data');
            if ($reviewBlock) {
                echo $reviewBlock->toHtml();
            }
            ?>
        </div>
        <?php
        $reviewFormBlock = $block->getLayout()->getBlock('product.review.form');
        if ($reviewFormBlock) {
            echo $reviewFormBlock->toHtml();
        }
        ?>
    </div>

    <!-- TAB 4: Additional Information -->
    <div class="awa-pdp-tabs__panel"
         role="tabpanel"
         id="awa-panel-info"
         aria-labelledby="awa-tab-info"
         aria-hidden="true">
        <div class="awa-pdp-info-grid">
