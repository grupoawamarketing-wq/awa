<?php
/**
 * AWA B2B — Product Structured Data (Schema.org JSON-LD) + BreadcrumbList
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
declare(strict_types=1);

$viewModel = $block->getData('product_structured_data_view_model') ?: $block->getData('view_model');
if (!$viewModel instanceof \GrupoAwamotos\Theme\ViewModel\ProductStructuredData) {
    return;
}

$schema = $viewModel->getProductStructuredData();
if ($schema === []) {
    return;
}

$breadcrumb = $viewModel->getBreadcrumbStructuredData();
?>
<script type="application/ld+json">
<?= /* @noEscape */ json_encode($schema, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT) ?>
</script>
<?php if ($breadcrumb !== []): ?>
<script type="application/ld+json">
<?= /* @noEscape */ json_encode($breadcrumb, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT) ?>
</script>
<?php endif; ?>
