    <button class="awa-sku-copy-btn" type="button"
            data-sku="<?= $block->escapeHtmlAttr($_product->getSku()) ?>"
            aria-label="<?= $block->escapeHtmlAttr(__('Copiar código')) ?>">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span class="awa-sku-copy-btn__text">Copiar</span>
    </button>
    <span class="awa-sku-copy-feedback" id="awa-sku-feedback" aria-live="polite"></span>
</div>
<script>
(function () {
    var btn = document.querySelector('.awa-sku-copy-btn');
    if (!btn || !navigator.clipboard) { return; }
    btn.addEventListener('click', function () {
        navigator.clipboard.writeText(btn.getAttribute('data-sku')).then(function () {
            btn.setAttribute('data-copied', '');
            btn.querySelector('.awa-sku-copy-btn__text').textContent = 'Copiado!';
            var fb = document.getElementById('awa-sku-feedback');
            if (fb) { fb.textContent = 'SKU copiado'; fb.classList.add('visible'); }
            setTimeout(function () {
                btn.removeAttribute('data-copied');
                btn.querySelector('.awa-sku-copy-btn__text').textContent = 'Copiar';
                if (fb) { fb.textContent = ''; fb.classList.remove('visible'); }
            }, 2000);
        });
    });
})();
</script>
<?php endif; ?>
<?php
    /* Stock level indicator */
    $_stockItem = null;
    try {
        $_stockItem = $_product->getExtensionAttributes()
            ? $_product->getExtensionAttributes()->getStockItem()
            : null;
    } catch (\Throwable $_e) { /* silent */ }
    $_stockQty = $_stockItem ? (int)$_stockItem->getQty() : null;
?>
<?php if ($_stockQty !== null && $_stockQty > 0): ?>
<?php
    if ($_stockQty <= 3) {
        $_stockClass = 'awa-stock-level--critical';
        $_stockMsg   = __('%1 unidade restante', $_stockQty);
        if ($_stockQty > 1) { $_stockMsg = __('%1 unidades restantes', $_stockQty); }
    } elseif ($_stockQty <= 10) {
        $_stockClass = 'awa-stock-level--low';
        $_stockMsg   = __('Apenas %1 em estoque', $_stockQty);
    } else {
        $_stockClass = 'awa-stock-level--ok';
        $_stockMsg   = __('Em estoque');
    }
?>
<div class="awa-stock-level <?= $block->escapeHtmlAttr($_stockClass) ?>">
    <span class="awa-stock-level__dot" aria-hidden="true"></span>
    <?= $block->escapeHtml($_stockMsg) ?>
</div>
