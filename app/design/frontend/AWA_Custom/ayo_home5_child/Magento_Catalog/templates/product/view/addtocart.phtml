/** @var \Magento\Catalog\Block\Product\View $block */
?>
<?php $_product = $block->getProduct(); ?>
<?php $buttonTitle = __('Add to Cart'); ?>
<?php $b2bHelper = $this->helper('GrupoAwamotos\B2B\Helper\Data'); ?>
<?php $b2bCanAddToCart = $b2bHelper->canAddToCart(); ?>
<?php $b2bGateState = $block->escapeHtmlAttr($b2bHelper->getPriceGateState()); ?>
<?php $b2bGateHeadline = $block->escapeHtml($b2bHelper->getPriceGateHeadline()); ?>
<?php $b2bGateDescription = $block->escapeHtml($b2bHelper->getPriceGateDescription()); ?>
<?php $b2bPrimaryUrl = $block->escapeUrl($b2bHelper->getPriceGatePrimaryUrl()); ?>
<?php $b2bPrimaryLabel = $block->escapeHtml($b2bHelper->getPriceGatePrimaryLabel()); ?>
<?php $b2bSecondaryUrl = $block->escapeUrl($b2bHelper->getPriceGateSecondaryUrl()); ?>
<?php $b2bSecondaryLabel = $block->escapeHtml($b2bHelper->getPriceGateSecondaryLabel()); ?>

<?php /* =========================================================
         B2B TECHNICAL SUMMARY & SECONDARY ACTIONS
         ========================================================= */ ?>
<div class="awa-b2b-pdp-technical-summary">
    <table>
        <tbody>
            <tr>
                <td><?= $block->escapeHtml(__('SKU')) ?></td>
                <td><?= $block->escapeHtml($_product->getSku()) ?></td>
            </tr>
            <tr>
                <td><?= $block->escapeHtml(__('Código de Barras (EAN)')) ?></td>
                <td><?= $block->escapeHtml($_product->getData('ean') ?: 'N/A') ?></td>
            </tr>
            <tr>
                <td><?= $block->escapeHtml(__('Master Box')) ?></td>
                <td><?= $block->escapeHtml($_product->getData('master_box_qty') ?: 'N/A') ?></td>
            </tr>
        </tbody>
    </table>

    <div class="awa-b2b-secondary-actions">
        <?php $pdfUrl = $_product->getData('product_manual_pdf'); ?>
        <?php if ($pdfUrl): ?>
            <a href="<?= $block->escapeUrl($pdfUrl) ?>" target="_blank" class="awa-b2b-action-btn">
                <?= $block->escapeHtml(__('Baixar PDF')) ?>
            </a>
        <?php else: ?>
            <button type="button" class="awa-b2b-action-btn" title="<?= $block->escapeHtmlAttr(__('Ficha técnica indisponível')) ?>" disabled>
                <?= $block->escapeHtml(__('Baixar PDF')) ?>
            </button>
        <?php endif; ?>
        <button type="button" class="awa-b2b-action-btn">
            <?= $block->escapeHtml(__('Criar Tabela')) ?>
        </button>
    </div>
</div>

<?php if (!$b2bCanAddToCart) : ?>
<div class="awa-b2b-gate-card awa-b2b-pdp-gate" data-awa-gate-state="<?= $b2bGateState ?>">
    <span class="awa-b2b-gate-card__badge"><?= $block->escapeHtml(__('Conta B2B')) ?></span>
    <div class="awa-b2b-gate-card__title"><?= /* @noEscape */ $b2bGateHeadline ?></div>
    <div class="awa-b2b-gate-card__description"><?= /* @noEscape */ $b2bGateDescription ?></div>
    <div class="awa-b2b-gate-card__actions">
        <a class="awa-b2b-gate-card__action" href="<?= $b2bPrimaryUrl ?>"><?= $b2bPrimaryLabel ?></a>
        <a class="awa-b2b-gate-card__action awa-b2b-gate-card__action--secondary" href="<?= $b2bSecondaryUrl ?>"><?= $b2bSecondaryLabel ?></a>
    </div>
</div>
<?php elseif ($_product->isSaleable()) :?>
<div class="box-tocart">
    <div class="fieldset">
        <?php if ($block->shouldRenderQuantity()) :?>
        <div class="awa-catalog-qty-box field qty">
            <label class="label awa-sr-only" for="qty"><span><?= $block->escapeHtml(__('Qty')) ?></span></label>
            <div class="control">
                <input type="number"
                       name="qty"
                       id="qty"
                       min="0"
                       value="<?= $block->getProductDefaultQty() * 1 ?>"
                       title="<?= $block->escapeHtmlAttr(__('Qty')) ?>"
                       class="input-text qty"
                       data-validate="<?= $block->escapeHtml(json_encode($block->getQuantityValidators())) ?>"
                       />
            </div>
        </div>
        <?php endif; ?>
        <div class="actions">
            <button type="submit"
                    title="<?= $block->escapeHtmlAttr($buttonTitle) ?>"
                    class="action primary tocart b2b-primary-btn"
                    id="product-addtocart-button" disabled>
                <span><?= $block->escapeHtml($buttonTitle) ?></span>
            </button>
            <?= $block->getChildHtml('', true) ?>
        </div>
    </div>
</div>
<?php endif; ?>
<script type="text/x-magento-init">
    {
        "#product_addtocart_form": {
            "Magento_Catalog/js/validate-product": {}
        }
    }
</script>
