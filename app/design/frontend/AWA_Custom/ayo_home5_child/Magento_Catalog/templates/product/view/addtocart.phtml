/** @var \Magento\Catalog\Block\Product\View $block */
?>
<?php $_product = $block->getProduct(); ?>
<?php $buttonTitle = __('Add to Cart'); ?>
<?php
// GrupoAwamotos_B2B may be disabled — check via Module Manager
$_b2bActive = \Magento\Framework\App\ObjectManager::getInstance()
    ->get(\Magento\Framework\Module\Manager::class)
    ->isEnabled('GrupoAwamotos_B2B');
if ($_b2bActive) {
    $b2bHelper         = $this->helper('GrupoAwamotos\B2B\Helper\Data');
    $b2bCanAddToCart   = $b2bHelper->canAddToCart();
    $b2bGateState      = $block->escapeHtmlAttr($b2bHelper->getPriceGateState());
    $b2bGateHeadline   = $block->escapeHtml($b2bHelper->getPriceGateHeadline());
    $b2bGateDescription= $block->escapeHtml($b2bHelper->getPriceGateDescription());
    $b2bPrimaryUrl     = $block->escapeUrl($b2bHelper->getPriceGatePrimaryUrl());
    $b2bPrimaryLabel   = $block->escapeHtml($b2bHelper->getPriceGatePrimaryLabel());
    $b2bSecondaryUrl   = $block->escapeUrl($b2bHelper->getPriceGateSecondaryUrl());
    $b2bSecondaryLabel = $block->escapeHtml($b2bHelper->getPriceGateSecondaryLabel());
} else {
    $b2bHelper = null; $b2bCanAddToCart = true; $b2bGateState = '';
    $b2bGateHeadline = ''; $b2bGateDescription = ''; $b2bPrimaryUrl = '';
    $b2bPrimaryLabel = ''; $b2bSecondaryUrl = ''; $b2bSecondaryLabel = '';
}
?>

<?php if (!$b2bCanAddToCart) : ?>
<div class="awa-b2b-gate-card awa-b2b-pdp-gate" data-awa-gate-state="<?= /* @noEscape */ $b2bGateState ?>">
    <span class="awa-b2b-gate-card__badge"><?= $block->escapeHtml(__('Acesso B2B Exclusivo')) ?></span>
    <div class="awa-b2b-gate-card__title"><?= /* @noEscape */ $b2bGateHeadline ?></div>
    <div class="awa-b2b-gate-card__description"><?= /* @noEscape */ $b2bGateDescription ?></div>
    <div class="awa-b2b-gate-card__actions">
        <a class="awa-b2b-gate-card__action" href="<?= /* @noEscape */ $b2bPrimaryUrl ?>"><?= /* @noEscape */ $b2bPrimaryLabel ?></a>
        <a class="awa-b2b-gate-card__action awa-b2b-gate-card__action--secondary" href="<?= /* @noEscape */ $b2bSecondaryUrl ?>"><?= /* @noEscape */ $b2bSecondaryLabel ?></a>
    </div>
</div>
<?php elseif ($_product->isSaleable()) :?>
<?php
    /* Stock level indicator */
    $_stockItem = null;
    try {
        $_stockItem = $_product->getExtensionAttributes()
            ? $_product->getExtensionAttributes()->getStockItem()
            : null;
    } catch (\Throwable $_e) { /* silent */ }
    $_stockQty = $_stockItem ? (int)$_stockItem->getQty() : null;
?>
<?php if ($_stockQty !== null && $_stockQty > 0): ?>
<?php
    if ($_stockQty <= 3) {
        $_stockClass = 'awa-stock-level--critical';
        $_stockMsg   = __('%1 unidade restante', $_stockQty);
        if ($_stockQty > 1) { $_stockMsg = __('%1 unidades restantes', $_stockQty); }
    } elseif ($_stockQty <= 10) {
        $_stockClass = 'awa-stock-level--low';
        $_stockMsg   = __('Apenas %1 em estoque', $_stockQty);
    } else {
        $_stockClass = 'awa-stock-level--ok';
        $_stockMsg   = __('Em estoque');
    }
?>
<div class="awa-stock-level <?= $block->escapeHtmlAttr($_stockClass) ?>">
    <span class="awa-stock-level__dot" aria-hidden="true"></span>
    <?= $block->escapeHtml($_stockMsg) ?>
</div>
<?php endif; ?>
<div class="box-tocart">
    <div class="fieldset">
        <?php if ($block->shouldRenderQuantity()) :?>
        <div class="awa-catalog-qty-box field qty"
             data-mage-init='{"js/awa-qty-control": {}}'>
            <label class="label awa-sr-only" for="qty"><span><?= $block->escapeHtml(__('Qty')) ?></span></label>
            <div class="control awa-qty-stepper">
                <button type="button" class="awa-qty-btn"
                        data-awa-role="qty-trigger"
                        data-awa-direction="decrement"
                        aria-label="<?= $block->escapeHtmlAttr(__('Diminuir quantidade')) ?>">−</button>
                <input type="number"
                       name="qty"
                       id="qty"
                       min="1"
                       value="<?= $block->getProductDefaultQty() * 1 ?>"
                       title="<?= $block->escapeHtmlAttr(__('Qty')) ?>"
                       class="input-text qty"
                       data-awa-role="qty-input"
                       data-validate="<?= $block->escapeHtml(json_encode($block->getQuantityValidators())) ?>"
                       />
                <button type="button" class="awa-qty-btn"
                        data-awa-role="qty-trigger"
                        data-awa-direction="increment"
                        aria-label="<?= $block->escapeHtmlAttr(__('Aumentar quantidade')) ?>">+</button>
            </div>
        </div>
        <?php endif; ?>
        <div class="actions">
            <button type="submit"
                    title="<?= $block->escapeHtmlAttr($buttonTitle) ?>"
                    class="action primary tocart b2b-primary-btn"
                    id="product-addtocart-button" disabled>
                <span><?= $block->escapeHtml($buttonTitle) ?></span>
            </button>
            <?= $block->getChildHtml('', true) ?>
        </div>
    </div>
</div>
<?php endif; ?>
<script type="text/x-magento-init">
    {
        "#product_addtocart_form": {
            "Magento_Catalog/js/validate-product": {}
        }
    }
</script>
