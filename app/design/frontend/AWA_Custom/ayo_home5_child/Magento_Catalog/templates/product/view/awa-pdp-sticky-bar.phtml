<?php
/**
 * AWA PDP — Sticky Add-to-Cart Bar
 *
 * Aparece quando o botão original de compra sai da viewport.
 * Contém: thumbnail, nome, SKU, preço (clonado via JS do preço KO), botão Comprar.
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */
declare(strict_types=1);

$_product = $block->getProduct();
if (!$_product || !$_product->isSaleable()) {
    return;
}

$_imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);
$_thumbUrl = $_imageHelper->init($_product, 'product_thumbnail_image')
    ->setImageFile($_product->getSmallImage())
    ->resize(60, 60)
    ->getUrl();
$_productName = $block->escapeHtml($_product->getName());
$_sku = $block->escapeHtml($_product->getSku());
?>
<div class="awa-pdp-sticky-bar" id="awa-pdp-sticky-bar" aria-hidden="true">
    <div class="awa-pdp-sticky-bar__inner">
        <img src="<?= /* @noEscape */ $_thumbUrl ?>"
             alt=""
             class="awa-pdp-sticky-bar__thumb"
             width="48" height="48"
             loading="lazy" decoding="async"/>
        <div class="awa-pdp-sticky-bar__info">
            <span class="awa-pdp-sticky-bar__name"><?= $_productName ?></span>
            <span class="awa-pdp-sticky-bar__sku">Cód: <?= $_sku ?></span>
        </div>
        <div class="awa-pdp-sticky-bar__price" id="awa-sticky-price" aria-live="polite"></div>
        <button type="button"
                class="awa-pdp-sticky-bar__btn"
                id="awa-pdp-sticky-add"
                aria-label="<?= $block->escapeHtmlAttr(__('Adicionar ao Carrinho')) ?>">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <span><?= $block->escapeHtml(__('Comprar')) ?></span>
        </button>
    </div>
</div>
<script>
(function() {
    'use strict';
    var bar = document.getElementById('awa-pdp-sticky-bar');
    var btn = document.getElementById('awa-pdp-sticky-add');
    var priceSlot = document.getElementById('awa-sticky-price');
    if (!bar || !btn) return;

    var target = document.getElementById('product-addtocart-button');
    if (!target) return;

    /* Mirror the price from the main product-info-price box */
    function syncPrice() {
        var src = document.querySelector('.product-info-price .price-wrapper .price');
        if (src && priceSlot) {
            priceSlot.textContent = src.textContent;
        }
    }
    syncPrice();
    /* Re-sync when KO updates the price (configurable, tier, etc.) */
    var priceBox = document.querySelector('.product-info-price');
    if (priceBox) {
        new MutationObserver(syncPrice).observe(priceBox, {
            childList: true, subtree: true, characterData: true
        });
    }

    var addToCartVisible = true;
    var detailsVisible = false;

    function updateStickyVisibility() {
        var showSticky = !addToCartVisible && !detailsVisible;
        bar.classList.toggle('awa-pdp-sticky-bar--visible', showSticky);
        /* defer-global / flex-grid usam .is-visible — manter paridade */
        bar.classList.toggle('is-visible', showSticky);
        bar.setAttribute('aria-hidden', showSticky ? 'false' : 'true');
        /* Harden: manter botão fora do tab order quando a barra está oculta */
        btn.setAttribute('tabindex', showSticky ? '0' : '-1');
    }

    /* Show/hide sticky bar based on original button visibility */
    var io = new IntersectionObserver(function(entries) {
        addToCartVisible = entries[0].isIntersecting;
        updateStickyVisibility();
    }, { threshold: 0 });
    io.observe(target);

    var details = document.querySelector('.product.info.detailed, .product.data.items');
    if (details) {
        var detailsObserver = new IntersectionObserver(function(entries) {
            detailsVisible = entries.some(function(entry) {
                return entry.isIntersecting;
            });
            updateStickyVisibility();
        }, {
            rootMargin: '0px 0px -20% 0px',
            threshold: 0.05
        });
        detailsObserver.observe(details);
    }

    /* Click handler: scroll to and trigger the real add-to-cart */
    btn.addEventListener('click', function() {
        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        target.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'center' });
        setTimeout(function() { target.click(); }, reducedMotion ? 0 : 400);
    });
})();
</script>
