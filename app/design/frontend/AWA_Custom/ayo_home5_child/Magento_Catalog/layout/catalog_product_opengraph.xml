<?xml version="1.0"?>
<!--
    AWA Motos — Desativa OG tags do core Magento na PDP.
    Motivo: awa-og-meta.phtml (Magento_Theme/layout/default.xml) já injeta Open Graph
    de melhor qualidade com fallback hierárquico, og:image:width/height, og:locale e
    twitter:card. O bloco opengraph.general do core gera tags duplicadas e inferiores
    (og:description vazia, og:title com HTML entities, sem og:site_name/og:locale).
    Corrigido em: 2026-06-26
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="opengraph.general" remove="true"/>
    </body>
</page>
