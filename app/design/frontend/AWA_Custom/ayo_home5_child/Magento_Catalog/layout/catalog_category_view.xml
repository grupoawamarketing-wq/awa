<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!--
            Category CSS: awa-bundle-category = PLP styles (plp+plp-final-polish, additive).
            awa-bundle-site stays in default_head_blocks — correct cascade before refinements.
            awa-plp-final-polish.css removed: already merged in bundle-category.
            social-proof.css removed: merged into bundle-category.
        -->
        <remove src="css/awa-plp-final-polish.css"/>
        <remove src="GrupoAwamotos_SocialProof::css/social-proof.css"/>
        <css src="css/awa-bundle-category.css"/>
    </head>
    <body>
        <!--
            B2B: Inicializa o modal de login e o JS que injeta o botão "Entrar para Comprar"
            nos cards de produto (lista e carrossel). Necessário para substituir button.tocart
            pelo b2b-login-to-buy-btn em modo restrito para guests/não-aprovados.
        -->
        <referenceContainer name="before.body.end">
            <block class="GrupoAwamotos\B2B\Block\LoginToCart"
                   name="b2b.login.to.cart.category"
                   template="GrupoAwamotos_B2B::product/login-to-cart.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
