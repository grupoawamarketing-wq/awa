<?xml version="1.0"?>
<!--
 | AWA Motos — child theme override for catalog_product_view
 | Corrige bugs e carrega CSS de conversão/polish de forma não-bloqueante.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!--
            BUG-07: Remove os dois arquivos CSS bloqueantes herdados do ayo_home5
            (awa-round3-pdp-conversion.css e awa-pdp-final-polish.css).
            Os estilos críticos já estão no awa-pdp-cascade-terminal.min.css
            e no awa-ui-simplify-terminal.min.css carregados via defer.
        -->
        <remove src="css/awa-round3-pdp-conversion.css"/>
        <remove src="css/awa-pdp-final-polish.css"/>
        <!-- awa-pdp-shell-final.css: arquivo movido para _deprecated/ em Jun-2026; referência removida (404 ativo). Estilos cobertos por awa-pdp-premium.css + critical inline. -->
    </head>
    <body>
        <!-- Rokanthemes PriceCountdown declara cacheable="false" na PDP — remove para FPC/Varnish -->
        <referenceBlock name="product.info.pricecountdown.product.page" remove="true"/>
        <referenceBlock name="awa.header.impeccable.critical.global" remove="true"/>
        <!-- Terminal lock — align-grid após pdp-shell (§41 PDP mobile + badges) -->
        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.align.grid.terminal.pdp"
                   template="Magento_Theme::html/awa-align-grid-terminal-loader.phtml"
                   after="-"/>
        </referenceBlock>
        <!--
            BUG-01: Remove o container duplicado de social links do tema pai ayo_default.
            O container "awa.product.info.social" (class "product-social-extra") renderiza
            os mesmos links Imprimir/Compartilhar já fornecidos pelo container padrão
            Magento "product.info.social" (class "product-social-links").
        -->
        <referenceBlock name="awa.product.info.addto" remove="true"/>
        <referenceBlock name="awa.product.info.mailto" remove="true"/>

        <!--
            MELHORIA-01: Bloco de compatibilidade inline (Marca/Modelo/Ano) acima do add-to-cart.
            Renderiza somente quando os atributos estão preenchidos (50 produtos).
        -->
        <referenceContainer name="product.info.main">
            <block class="Magento\Catalog\Block\Product\View"
                   name="awa.product.info.compatibility"
                   template="Magento_Catalog::product/view/awa-compatibility.phtml"
                   after="product.info.price"
                   before="product.info.addtocart"/>
        </referenceContainer>

        <!--
            BUG-07: Carrega os CSS de conversão/polish de forma não-bloqueante.
            Os arquivos são servidos com media="print" onload="this.media='all'" para
            não bloquear o render. Lidos pelo browser antes do DOMContentLoaded.
        -->
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.pdp.conversion.async.css"
                   template="Magento_Theme::html/awa-pdp-conversion-async.phtml"
                   before="-"/>
        </referenceContainer>

        <!--
            BUG-03: Schema.org Product JSON-LD — gerado via ProductStructuredData ViewModel.
            Emitido no fim do body (válido para Google; evita bytes extras no <head>).
            Inclui: Product (@type), Offer (preço/disponibilidade), AggregateRating
            (quando há avaliações), BreadcrumbList.
        -->
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.schema.product.jsonld"
                   template="Magento_Catalog::product/view/awa-product-jsonld.phtml"
                   after="awa.pdp.conversion.async.css">
                <arguments>
                    <argument name="product_structured_data_view_model"
                              xsi:type="object">GrupoAwamotos\Theme\ViewModel\ProductStructuredData</argument>
                </arguments>
            </block>
            <!-- F1-04 (2026-06-27): FAQPage JSON-LD para rich results do Google -->
            <block class="GrupoAwamotos\SchemaOrg\Block\ProductFaq"
                   name="awa.schema.product.faq.jsonld"
                   template="GrupoAwamotos_SchemaOrg::product_faq_jsonld.phtml"
                   after="awa.schema.product.jsonld"/>
        </referenceContainer>

        <!--
            F1-04 (2026-06-27): Seção visual de FAQ na PDP (acordeão semântico)
            Renderiza bloco GrupoAwamotos\SchemaOrg\Block\ProductFaq com template FAQ visível.
            O template Magento_Theme::product.info.details.phtml customizado itera
            apenas o grupo detailed_info; então posicionamos o FAQ como bloco
            independente no content.aside (que existe no tema filho) via
            content.bottom e usamos move para alocar após product.info.details.
        -->
        <referenceContainer name="content">
            <block class="GrupoAwamotos\SchemaOrg\Block\ProductFaq"
                   name="awa.product.faq"
                   template="GrupoAwamotos_SchemaOrg::product_faq.phtml"
                   after="product.info.details"/>
        </referenceContainer>
    </body>
</page>
