<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <remove src="css/awa-round3-pdp-conversion.css"/>
        <!--
            PDP CSS optimization (2026-03-19): awa-bundle-pdp replaces 3 CSS requests:
            pdp-conversion + pdp-final-polish + awa-bundle-inner-pages (4 files)
            Total: 6 requests → 1. awa-bundle-site removed (homepage/category only).
            awa-custom-page-home-category-premium.css excluído: homepage/categoria only.
        -->
        <css src="css/awa-bundle-pdp.css"/>
        <!-- AWA PDP B2B Pro Redesign (2026-03-28) -->
        <css src="css/awa-pdp-b2b-pro.css"/>
        <!-- awa-custom-page-home-category-premium.css: excluído no PDP (homepage/categoria only) -->
    </head>
    <body>
        <!-- page.main.title positioning handled by ayo_default:
             move to box.inner1 before="-", junto com product.info.price.
             Override aqui causava broken reference (parents diferentes). -->

        <!-- wishlist e compare restaurados — fidelidade ao demo ayo home5 -->
        <referenceBlock name="awa.round3.pdp.sticky.cta.js" remove="true"/>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.custom.pdp.sticky.cta.js"
                   template="Magento_Theme::html/awa-custom-js-loader.phtml">
                <arguments>
                    <argument name="load_header_js" xsi:type="boolean">false</argument>
                    <argument name="load_home_owl_tabs_js" xsi:type="boolean">false</argument>
                    <argument name="load_footer_ux_js" xsi:type="boolean">false</argument>
                    <argument name="load_pdp_sticky_cta_js" xsi:type="boolean">true</argument>
                </arguments>
            </block>
        </referenceContainer>

        <!-- AWA Phase 5: Prominent B2B SKU on PDP -->
        <referenceContainer name="product.info.main">
            <block class="Magento\Catalog\Block\Product\View"
                   name="awa.b2b.pdp.sku"
                   template="Magento_Catalog::product/view/b2b_sku.phtml"
                   after="-" />

            <!-- Hide the default Magento SKU to prevent duplication -->
            <referenceBlock name="product.info.sku" remove="true" />

            <!-- AWA Phase 6: Move Tech Specs Above Fold -->
            <block class="Magento\Catalog\Block\Product\View\Attributes"
                   name="product.attributes.above.fold"
                   template="Magento_Catalog::product/view/attributes.phtml"
                   after="product.info.price" />
        </referenceContainer>

        <!-- Hide original attributes tab -->
        <referenceBlock name="product.attributes" remove="true" />

        <!-- AWA Phase 4: Product JSON-LD Schema.org -->
        <referenceContainer name="content">
            <block class="Magento\Catalog\Block\Product\View"
                   name="awa.product.jsonld"
                   template="Magento_Catalog::product/view/awa-product-jsonld.phtml"
                   after="-"/>
        </referenceContainer>
        <!-- AWA Phase 5: UI/UX Pro Max - Trust & Authority Badges under Add to Cart -->
        <referenceContainer name="product.info.extrahint">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.trust.badges"
                   template="Magento_Theme::html/awa-trust-badges.phtml"
                   after="-"/>
        </referenceContainer>

        <!-- AWA PDP B2B Pro: Content Tabs (Description, Specs, Reviews, Info) -->
        <referenceContainer name="content">
            <block class="Magento\Catalog\Block\Product\View"
                   name="awa.pdp.b2b.tabs"
                   template="Magento_Catalog::product/view/awa-pdp-tabs.phtml"
                   after="catalog.product.view"/>
        </referenceContainer>

        <!-- AWA PDP B2B Pro: Sidebar (Promo, Chat, Share, Similar) -->
        <referenceContainer name="content">
            <block class="Magento\Catalog\Block\Product\View"
                   name="awa.pdp.b2b.sidebar"
                   template="Magento_Catalog::product/view/awa-pdp-sidebar.phtml"
                   after="awa.pdp.b2b.tabs"/>
        </referenceContainer>

        <!-- AWA PDP B2B Pro: JS -->
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.pdp.b2b.pro.js"
                   template="Magento_Catalog::product/view/awa-pdp-b2b-pro-js.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
