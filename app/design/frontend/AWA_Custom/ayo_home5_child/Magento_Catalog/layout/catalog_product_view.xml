<?xml version="1.0"?>
<page layout="2columns-left" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <remove src="css/awa-round3-pdp-conversion.css"/>
        <!-- social-proof.css merged into awa-bundle-pdp.css (2026-03-29) — -1 CSS request -->
        <remove src="GrupoAwamotos_SocialProof::css/social-proof.css"/>
        <!--
            PDP CSS optimization (2026-03-19): awa-bundle-pdp replaces 3 CSS requests:
            pdp-conversion + pdp-final-polish + awa-bundle-inner-pages (4 files)
            Total: 6 requests → 1. awa-bundle-site removed (homepage/categoria only).
            awa-custom-page-home-category-premium.css excluído: homepage/categoria only.
        -->
        <css src="css/awa-bundle-pdp.css"/>
        <!-- AWA PDP B2B Pro Redesign (2026-03-28) -->
        <css src="css/awa-pdp-b2b-pro.css"/>
        <css src="css/awa-pdp-clean-refinement.css"/>
        <remove src="GrupoAwamotos_Fitment::css/fitment-application.css"/>
        <!-- awa-home-vertical-menu-shell-fix.css: somente homepage (todos seletores usam body.cms-index-index) -->
        <remove src="css/awa-home-vertical-menu-shell-fix.css"/>
        <!-- awa-custom-page-home-category-premium.css: excluído no PDP (homepage/categoria only) -->
    </head>
    <body>
        <!-- PDP básico: manter apenas foto, título, preço, comprar e descrição -->
        <referenceBlock name="breadcrumbs" remove="true"/>
        <referenceBlock name="product.info.sku" remove="true"/>
        <referenceBlock name="product.info.stock.sku" remove="true"/>
        <referenceBlock name="product.info.review" remove="true"/>
        <referenceBlock name="product.info.overview" remove="true"/>
        <!-- product.info.price RESTAURADO: preço é renderizado pelo mecanismo padrão do Magento
             (Knockout.js). Removê-lo causava ausência total do preço (desktop e mobile).  -->
        <referenceBlock name="product.info.addto" remove="true"/>
        <referenceBlock name="product.info.mailto" remove="true"/>
        <referenceBlock name="product.info.social" remove="true"/>
        <referenceBlock name="product.info.extrahint" remove="true"/>

        <referenceBlock name="product.attributes" remove="true"/>
        <referenceBlock name="product.attributes.above.fold" remove="true"/>
        <referenceBlock name="reviews.tab" remove="true"/>
        <referenceBlock name="product.review.form" remove="true"/>

        <referenceBlock name="catalog.product.related" remove="true"/>
        <referenceBlock name="product.info.related" remove="true"/>
        <referenceBlock name="product.info.upsell" remove="true"/>

        <!-- Esconde tabs padrão do Magento; descrição será exibida no bloco simplificado -->
        <referenceBlock name="product.info.description" remove="true"/>
        <referenceBlock name="product.info.details">
            <arguments>
                <argument name="css_class" xsi:type="string">awa-hidden-default-tabs</argument>
            </arguments>
        </referenceBlock>

        <!-- Mantém JSON-LD para SEO -->
        <referenceContainer name="content">
            <block class="Magento\Catalog\Block\Product\View"
                   name="awa.product.jsonld"
                   template="Magento_Catalog::product/view/awa-product-jsonld.phtml"
                   after="-"/>
        </referenceContainer>

        <!-- Mantém preload da imagem principal para LCP -->
        <referenceBlock name="head.additional">
            <block class="Magento\Catalog\Block\Product\View\Gallery"
                   name="awa.pdp.lcp.preload"
                   template="Magento_Catalog::product/view/awa-pdp-lcp-preload.phtml"
                   before="-"/>
        </referenceBlock>

        <!-- Bloco de descrição simplificado -->
        <referenceContainer name="content">
            <block class="Magento\Catalog\Block\Product\View"
                   name="awa.pdp.b2b.tabs"
                   template="Magento_Catalog::product/view/awa-pdp-tabs.phtml"
                   after="catalog.product.view"/>
        </referenceContainer>

        <referenceBlock name="awa.pdp.b2b.sidebar" remove="true"/>
        <referenceBlock name="product.fitment.applications" remove="true"/>
    </body>
</page>
