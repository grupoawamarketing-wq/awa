<?xml version="1.0"?>
<!--
  AWA Motos — Product Detail Page (PDP) Layout Overrides
-->
<page layout="1column"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- awa-pdp-visual-fix, awa-pdp-b2b-pro, awa-pdp-final-polish e fitment-application
             movidos para carregamento async em awa-pdp-info-final-css-v2.phtml
             (media="print" onload) — elimina 4 requests bloqueantes na PDP. -->
        <remove src="css/awa-pdp-visual-fix.css"/>
        <remove src="css/awa-pdp-b2b-pro.css"/>
        <remove src="css/awa-pdp-final-polish.css"/>
        <remove src="GrupoAwamotos_Fitment::css/fitment-application.css"/>
    </head>
    <body>
        <!-- Remove Magento native OG (duplicates awa.og.meta in default_head_blocks.xml) -->
        <referenceBlock name="opengraph.general" remove="true"/>
        <!-- PDP info cleanup: parent Ayo renders duplicate print/share buttons here. -->
        <referenceBlock name="awa.product.info.addto" remove="true"/>
        <referenceBlock name="awa.product.info.mailto" remove="true"/>
        <referenceContainer name="awa.product.info.social" remove="true"/>
        <referenceBlock name="product.info.review" remove="true"/>
        <referenceBlock name="reviews.tab" remove="true"/>
        <referenceBlock name="product.info.details.reviews" remove="true"/>
        <referenceBlock name="review_form" remove="true"/>
        <referenceBlock name="product.review.form" remove="true"/>

        <!-- LCP Preload: adiantamento da imagem principal do produto (melhoria de LCP/CWV) -->
        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.pdp.info.final.css"
                   template="Magento_Catalog::product/view/awa-pdp-info-final-css-v2.phtml"
                   after="awa.styles.l.last"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.pdp.lcp.preload"
                   template="Magento_Catalog::product/view/awa-pdp-lcp-preload.phtml"
                   before="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\ProductStructuredData</argument>
                </arguments>
            </block>
        </referenceBlock>

        <!-- Product JSON-LD + BreadcrumbList for SEO rich results -->
        <referenceContainer name="after.body.start">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.schema.product.jsonld"
                   template="Magento_Catalog::product/view/awa-product-jsonld.phtml"
                   after="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\ProductStructuredData</argument>
                    <argument name="product_structured_data_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\ProductStructuredData</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
