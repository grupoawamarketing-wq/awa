<?php
/**
 * Rokanthemes_Toprate template override - AWA Custom child theme
 *
 * Performance improvements:
 * - Inline JS → AMD pattern with js/rokanthemes-owl-element-init
 * - Proper output escaping
 * - Loading lazy for images
 * - Accessibility improvements (aria-labels)
 */
use Magento\Framework\App\Action\Action;

if ($this->getConfig('enabled')): // start enable module
    $_productCollection = $this->getProducts();
    $_helper = $this->helper('Magento\Catalog\Helper\Output');
    ?>
    <div class="rokan-toprate">

        <?php
        if ($block->getMode() == 'grid') {
            $viewMode = 'grid';
            $image = 'category_page_grid';
            $showDescription = false;
            $templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::SHORT_VIEW;
        } else {
            $viewMode = 'list';
            $image = 'category_page_list';
            $showDescription = true;
            $templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::FULL_VIEW;
        }
        $pos = $block->getPositioned();
        ?>

        <?php if ($this->getConfig('title')): ?>
            <div class="rokan-product-heading rokan-featured-heading">
                <h2><?php echo $block->escapeHtml($this->getConfig('title')); ?></h2>
            </div>
        <?php endif; ?>

        <?php if (!$_productCollection->getSize()): ?>
            <div class="rokan-featured-slider">
                <p class="note-msg"><?php echo $block->escapeHtml(__('There are no products matching the selection.')); ?></p>
            </div>
        <?php else: ?>
            <?php
            $rows = 1;
            ?>
            <div class="row">
                <div class="swiper awa-toprate-swiper"><div class="swiper-wrapper">
                    <?php $_collectionSize = $_productCollection->count() ?>
                    <?php $i = 0; foreach ($_productCollection as $_product): ?>
                        <?php if ($i % $rows == 0) echo "<div class='swiper-slide item toprateslider-item'>"; ?>

                        <div class="product-item">
                            <?php
                            $newFromDate = $_product->getNewsFromDate();
                            $newToDate = $_product->getNewsToDate();
                            $now = date('Y-m-d H:i:s');
                            // Get the Special Price
                            $specialprice = $_product->getSpecialPrice();
                            // Get the Special Price FROM date
                            $specialPriceFromDate = $_product->getSpecialFromDate();
                            // Get the Special Price TO date
                            $specialPriceToDate = $_product->getSpecialToDate();
                            // Get Current date
                            if ($specialprice && ($specialPriceFromDate <= $now && $specialPriceToDate >= $now)) {
                                echo "<span class='icon-sale icon-product'>" . $block->escapeHtml(__('Sale')) . "</span>";
                            } else {
                                if ($newFromDate && $newToDate) {
                                    if (($newFromDate <= $now) && ($now <= $newToDate)) {
                                        echo "<span class='icon-new icon-product'>" . $block->escapeHtml(__('New')) . "</span>";
                                    }
                                }
                            }

                            $productImage = $block->getImage($_product, $image);
                            if ($pos != null) {
                                $position = ' style="left:' . $productImage->getWidth() . 'px;'
                                    . 'top:' . $productImage->getHeight() . 'px;"';
                            }
                            ?>

                            <?php // Product Image ?>
                            <a href="<?php echo $block->escapeUrl($_product->getProductUrl()); ?>"
                               class="product photo product-item-photo"
                               tabindex="-1"
                               aria-label="<?php echo $block->escapeHtmlAttr($_product->getName()); ?>">
                                <?php
                                $_imgHtml = $productImage->toHtml();
                                if (strpos($_imgHtml, 'loading=') === false) {
                                    $_imgHtml = str_replace('<img ', '<img loading="lazy" decoding="async" ', $_imgHtml);
                                }
                                echo $_imgHtml;
                            ?>
                            </a>

                            <?php $_productNameStripped = $block->stripTags($_product->getName(), null, true); ?>
                            <strong class="product name product-item-name">
                                <a class="product-item-link"
                                   href="<?php echo $block->escapeUrl($_product->getProductUrl()); ?>">
                                    <?php echo $block->escapeHtml($_helper->productAttribute($_product, $_product->getName(), 'name')); ?>
                                </a>
                            </strong>

                            <?php if ($this->getConfig('show_price')): ?>
                                <?php echo $this->helper('Rokanthemes\Themeoption\Helper\Data')->getPriceDisplayCustom($block->getProductPrice($_product)); ?>
                            <?php endif; ?>

                            <div class="product-ratting">
                                <?php if ($this->getConfig('review')): ?>
                                    <?php echo $block->getReviewsSummaryHtml($_product, $templateType); ?>
                                <?php endif; ?>
                            </div>

                            <div class="actions clearfix">
                                <div class="action-inner">
                                    <div class="actions-primary"<?php echo strpos((string)$pos, $viewMode . '-primary') ? $position : ''; ?>>
                                        <?php if ($_product->isSaleable()): ?>
                                            <?php $postParams = $block->getAddToCartPostParams($_product); ?>
                                            <form data-role="tocart-form"
                                                  action="<?php echo $block->escapeUrl($postParams['action']); ?>"
                                                  method="post">
                                                <input type="hidden"
                                                       name="product"
                                                       value="<?php echo $block->escapeHtmlAttr($postParams['data']['product']); ?>">
                                                <input type="hidden"
                                                       name="<?php echo Action::PARAM_NAME_URL_ENCODED; ?>"
                                                       value="<?php echo $block->escapeHtmlAttr($postParams['data'][Action::PARAM_NAME_URL_ENCODED]); ?>">
                                                <?php echo $block->getBlockHtml('formkey'); ?>
                                                <button type="submit"
                                                        title="<?php echo $block->escapeHtmlAttr(__('Add to Cart')); ?>"
                                                        class="action tocart primary"
                                                        aria-label="<?php echo $block->escapeHtmlAttr(__('Add to Cart')); ?>">
                                                    <span><?php echo $block->escapeHtml(__('Add to Cart')); ?></span>
                                                </button>
                                            </form>
                                        <?php else: ?>
                                            <?php if ($_product->isAvailable()): ?>
                                                <div class="stock available">
                                                    <span><?php echo $block->escapeHtml(__('In stock')); ?></span>
                                                </div>
                                            <?php else: ?>
                                                <div class="stock unavailable">
                                                    <span><?php echo $block->escapeHtml(__('Out of stock')); ?></span>
                                                </div>
                                            <?php endif; ?>
                                        <?php endif; ?>
                                    </div>

                                    <?php /* B2B: wishlist/compare nativos removidos */ ?>
                                </div>
                            </div>
                            <?php $i++; ?>
                        </div>
                        <?php if ($i % $rows == 0) echo "</div>"; ?>
                    <?php endforeach; ?>
                    <?php if ($i % $rows != 0) echo "</div>"; ?>
                </div><!-- .swiper-wrapper -->
                    <div class="swiper-button-prev" aria-label="<?= $block->escapeHtmlAttr(__('Anterior')) ?>"></div>
                    <div class="swiper-button-next" aria-label="<?= $block->escapeHtmlAttr(__('Próximo')) ?>"></div>
                </div><!-- .awa-toprate-swiper -->
            </div>

            <?php if (!$block->isRedirectToCartEnabled()): ?>
                <script type="text/x-magento-init">
                {
                    "[data-role=tocart-form], .form.map.checkout": {
                        "catalogAddToCart": {}
                    }
                }
                </script>
            <?php endif; ?>

            <script type="text/x-magento-init">
            {
                ".rokan-toprate": {
                    "js/tab-swiper-init": {
                        "carouselSelector": ".awa-toprate-swiper",
                        "owl": {
                            "items": 4,
                            "itemsDesktop": [1366, 4],
                            "itemsDesktopSmall": [980, 3],
                            "itemsTablet": [768, 2],
                            "itemsMobile": [479, 1],
                            "navigation": true,
                            "pagination": false,
                            "scrollPerPage": true
                        }
                    }
                }
            }
            </script>
        <?php endif; ?>
    </div>

<?php endif; ?>
