<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!--
            AWA CSS Bundle System (consolidado em 2026-03-16)
            Reduz ~30 CSS individuais para 4 bundles + themes5.css
            Originais preservados em web/css/_originals/
        -->

        <!-- Remove parent's individual CSS (agora servidos via bundles) -->
        <remove src="css/awa-core.css"/>
        <remove src="css/awa-layout.css"/>
        <remove src="css/awa-components.css"/>
        <remove src="css/awa-consistency.css"/>
        <remove src="css/awa-consistency-ui.css"/>
        <remove src="css/awa-fixes.css"/>
        <remove src="css/awa-grid-unified.css"/>
        <remove src="css/awa-round2-brand-bridge.css"/>
        <remove src="css/awa-round2-header-minicart.css"/>
        <remove src="css/awa-round3-footer-trust.css"/>
        <remove src="css/awa-round4-global-brand.css"/>
        <remove src="css/awa-round5-ux-refine.css"/>
        <remove src="css/awa-round6-b2b-gate-refine.css"/>
        <remove src="css/awa-round7-auth-refine.css"/>
        <remove src="css/awa-round8-plp-search-cart-refine.css"/>
        <remove src="css/awa-premium-finish.css"/>

        <!-- Remove external Google Fonts (now self-hosted) -->
        <remove src="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&amp;display=swap"/>

        <!--
            CSS de interação diferidos (carregados via preload/onload em awa-deferred-interaction-css.phtml)
            São carregados de forma não-bloqueante — apenas needed após interação do usuário.
        -->
        <remove src="mage/calendar.css"/>
        <remove src="jquery/uppy/dist/uppy-custom.css"/>
        <remove src="Rokanthemes_RokanBase::css/chosen.css"/>
        <remove src="Rokanthemes_RokanBase::css/jquery.fancybox.css"/>
        <remove src="Rokanthemes_QuickView::css/rokan_quickview.css"/>

        <!--
            Rokanthemes vendor libs (ayo_default/Magento_Theme/layout/default_head_blocks.xml)
            Substituídos por awa-bundle-vendor-libs.css (6 arquivos → 1 request)
        -->
        <remove src="css/bootstrap.css"/>
        <remove src="css/font-awesome.min.css"/>
        <remove src="css/owl.carousel.css"/>
        <remove src="css/animation_theme.css"/>
        <remove src="css/icomoon.css"/>
        <remove src="css/simple-line-icons.css"/>
        <!-- awa-fonts-rubik.css mergeado em awa-fonts-extra.css (abaixo) -->
        <remove src="css/awa-fonts-rubik.css"/>

        <!-- Bundle Rokanthemes vendor libs (Bootstrap + Font Awesome + Owl + Animations + icons) -->
        <css src="css/awa-bundle-vendor-libs.css"/>

        <!-- Theme base (compiled LESS — keep as-is) -->
        <css src="css/themes5.css"/>

        <!-- Design tokens (fonte canônica de variáveis CSS — carregar PRIMEIRO) -->
        <css src="css/awa-design-tokens.css"/>

        <!-- Bundle 1/3: Foundation (core + layout + components + consistency + fixes + grid) -->
        <css src="css/awa-bundle-core.css"/>
        <!-- Bundle 2/3: Custom rounds (brand-bridge through global-polish) -->
        <css src="css/awa-bundle-custom.css"/>
        <!-- Bundle 3/3: Phases & features (B2B phases 3-8 + menus + design system) -->
        <css src="css/awa-bundle-phases.css"/>

        <!-- Self-hosted fonts (Lexend + Source Sans 3, replacing Google Fonts link) -->
        <css src="css/awa-fonts-extra.css"/>

        <!--
            Module CSS bundle (3 módulos sem url() refs → 1 request)
            Fontes: Rokanthemes_Themeoption::css/loader.css
                    Rokanthemes_Brand::css/styles.css
                    GrupoAwamotos_RexisML::css/rexis-recommendations.css
        -->
        <remove src="Rokanthemes_Themeoption::css/loader.css"/>
        <remove src="Rokanthemes_Brand::css/styles.css"/>
        <remove src="GrupoAwamotos_RexisML::css/rexis-recommendations.css"/>
        <css src="css/awa-bundle-modules.css"/>

        <!-- Rokanthemes overrides extraídos do inline <style> do head.phtml (AWA_Custom) -->
        <css src="css/awa-rokanthemes-overrides.css"/>
    </head>

    <body>
        <referenceBlock name="awa.round2.header.minicart.js" remove="true"/>

        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.master.fix.js"
                   template="Magento_Theme::html/awa-js-loader.phtml"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.custom.header.minicart.js"
                   template="Magento_Theme::html/awa-custom-js-loader.phtml">
                <arguments>
                    <argument name="load_header_js" xsi:type="boolean">true</argument>
                    <argument name="load_home_owl_tabs_js" xsi:type="boolean">false</argument>
                    <argument name="load_footer_ux_js" xsi:type="boolean">true</argument>
                    <argument name="load_pdp_sticky_cta_js" xsi:type="boolean">false</argument>
                    <argument name="load_search_compat_js" xsi:type="boolean">true</argument>
                    <argument name="load_b2b_checkout_compat_js" xsi:type="boolean">true</argument>
                    <!-- Hotfix: disabled while fixing observer self-trigger loop causing frontend freeze -->
                    <argument name="load_home_category_compat_js" xsi:type="boolean">false</argument>
                </arguments>
            </block>
            <!-- AWA Phase 3: WhatsApp Floating Action Button -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.whatsapp.fab"
                   template="Magento_Theme::html/awa-whatsapp-fab.phtml"
                   after="-"/>
            <!-- AWA Phase 4: Quick Quote Modal -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.quote.modal"
                   template="Magento_Theme::html/awa-quote-modal.phtml"
                   after="awa.whatsapp.fab"/>
        </referenceContainer>

        <referenceContainer name="before.body.end">
            <!-- AWA Phase 4: Sticky Header JS -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.sticky.header.js"
                   template="Magento_Theme::html/awa-sticky-header-loader.phtml"/>
            <!-- AWA Phase 6: Back-to-Top Button -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.back.to.top"
                   template="Magento_Theme::html/awa-back-to-top.phtml"
                   after="-"/>
            <!-- AWA Phase 6: Organization JSON-LD -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.organization.jsonld"
                   template="Magento_Theme::html/awa-organization-jsonld.phtml"/>
            <!-- AWA Phase 6: OG Meta Tags -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.og.meta"
                   template="Magento_Theme::html/awa-og-meta.phtml"/>
        </referenceContainer>
    </body>
</page>
