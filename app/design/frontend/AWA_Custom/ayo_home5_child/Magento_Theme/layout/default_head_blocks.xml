<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!--
            DNS Prefetch + CSS/Font Preload + Async CSS Bundles
            Movidos para PHTML template (awa-head-preload.phtml) porque o schema
            page_configuration.xsd não suporta <link href>, <css onload>, <noscript>.
            Registrado em head.additional (body section) abaixo.
        -->

        <!--
            AWA CSS Bundle System (consolidado em 2026-03-16)
            Reduz ~30 CSS individuais para 4 bundles + themes5.css
            Originais preservados em web/css/_originals/

            OTIMIZAÇÕES FASE 1 + 2 (2026-03-23):
            - Preload de 3 CSS críticos (core, refinements, visual-fixes)
            - Async load de 4 bundles secundários (custom, phases, tail, site)
            - Total deferrido: 624KB minificado (~125KB gzip)
            - Ganho estimado: FCP -15% a -20%, LCP -10% a -15%
        -->

        <!-- Remove parent blocking CSS to reload async (PageSpeed fix 2026-04-11) -->
        <!-- styles-l.css: remove from parent, re-added last via awa-styles-l-last.phtml (was duplicated) -->
        <remove src="css/styles-l.css"/>
        <!-- themes.css: kept blocking — async caused CLS 0.511 (reverted 2026-04-11) -->
        <!-- Remove parent's individual CSS (agora servidos via bundles) -->
        <remove src="css/awa-core.css"/>
        <remove src="css/awa-layout.css"/>
        <remove src="css/awa-components.css"/>
        <remove src="css/awa-consistency.css"/>
        <remove src="css/awa-consistency-ui.css"/>
        <remove src="css/awa-fixes.css"/>
        <remove src="css/awa-grid-unified.css"/>
        <remove src="css/awa-round2-brand-bridge.css"/>
        <remove src="css/awa-round2-header-minicart.css"/>
        <remove src="css/awa-round3-footer-trust.css"/>
        <remove src="css/awa-round4-global-brand.css"/>
        <remove src="css/awa-round5-ux-refine.css"/>
        <remove src="css/awa-round6-b2b-gate-refine.css"/>
        <remove src="css/awa-round7-auth-refine.css"/>
        <remove src="css/awa-round8-plp-search-cart-refine.css"/>
        <remove src="css/awa-premium-finish.css"/>

        <!-- Remove external Google Fonts (now self-hosted) -->
        <remove src="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&amp;display=swap"/>

        <!--
            CSS de interação diferidos (carregados via preload/onload em head.phtml)
            São carregados de forma não-bloqueante — apenas needed após interação do usuário.
        -->
        <!-- b2b-marketing.css: modal B2B (opacity:0/visibility:hidden por padrão) → seguro deferir -->
        <remove src="GrupoAwamotos_B2B::css/b2b-marketing.css"/>
        <!-- suggestion.css: B2B marketing widget — 37KB, carregado via preload+onload (não-bloqueante) -->
        <remove src="GrupoAwamotos_B2B::css/marketing/suggestion.css"/>
        <remove src="mage/calendar.css"/>
        <remove src="jquery/uppy/dist/uppy-custom.css"/>
        <!-- chosen, fancybox, quickview: removidos do head render-blocking;
             carregados via preload+onload em awa-deferred-interaction-css.phtml -->
        <remove src="Rokanthemes_RokanBase::css/chosen.css"/>
        <remove src="Rokanthemes_RokanBase::css/jquery.fancybox.css"/>
        <remove src="Rokanthemes_QuickView::css/rokan_quickview.css"/>

        <!--
            Rokanthemes vendor libs (ayo_default/Magento_Theme/layout/default_head_blocks.xml)
            Substituídos por awa-bundle-vendor-libs.css (6 arquivos → 1 request)
        -->
        <remove src="css/bootstrap.css"/>
        <remove src="css/font-awesome.min.css"/>
        <remove src="css/owl.carousel.css"/>
        <remove src="css/animation_theme.css"/>
        <remove src="css/icomoon.css"/>
        <remove src="css/simple-line-icons.css"/>
        <!-- awa-fonts-rubik.css mergeado em awa-fonts-extra.css (abaixo) -->
        <remove src="css/awa-fonts-rubik.css"/>

        <!-- Core Variables: CSS design tokens (colors, spacing, typography, z-index, shadows, etc.) -->
        <!-- MUST load FIRST (before vendor-libs) to enable CSS variable inheritance across all bundles -->
        <css src="css/awa-core-variables.css"/>

        <!-- Bundle Rokanthemes vendor libs (merged 2026-03-16) -->
        <!-- (Bootstrap + Font Awesome + Owl + icons — CSS vars moved to awa-core-variables) -->
        <!-- vendor-libs: moved to async (PageSpeed fix 2026-04-11) -->
        <!-- <css src="css/awa-bundle-vendor-libs.css"/> -->

        <!-- Swiper 11 + Animate.css: carregados async via awa-head-preload.phtml -->

        <!-- Theme base (compiled LESS — keep as-is) -->
        <css src="css/themes5.css"/>

        <!-- Preloads (CSS + Fonts) movidos para awa-head-preload.phtml -->

        <!-- Swiper 11 CSS — bloqueante (sync): garante display:flex no wrapper ANTES do JS inicializar os carouseis -->
        <css src="css/swiper-bundle.min.css"/>

        <!-- Bundle 1/3: Foundation (core + layout + components + consistency + fixes + grid) -->
        <css src="css/awa-bundle-core.css"/>

        <!-- MCP Header + Classic Redesign: carregamento sync (crítico para evitar FOUC no header) -->
        <!-- awa-bundle-mcp-header.css: conteúdo crítico migrado para classic-redesign (2026-04-10) -->
        <css src="css/awa-header-classic-redesign.css"/>
        <!-- CRO Priority Layer: tokens e overrides de alto impacto sem alterar HTML -->
        <css src="css/awa-cro-priority.css"/>
        <!-- merged into awa-bundle-refinements: <css src="css/awa-ux-improvements.css"/> -->
        <!-- merged into awa-bundle-refinements: <css src="css/awa-layout-standardization.css"/> -->

        <!-- Visual Audit CSS (v2–v12): merged into awa-bundle-refinements (2026-04-09) -->

        <!-- Vertical Menu Shell Fix: global styling for vertical menu (all pages).
             Seletores atualizados para body-only scope em 2026-04-08 (antes: body.cms-index-index).
             Garante estilização consistente do menu vertical em home + páginas internas. -->
        <!-- awa-home-vertical-menu-shell-fix.css: movido para async 2026-04-17 (-40KB blocking)
             Menu vertical aparece somente em hover/interacao. Carregado via asyncBundles. -->

        <!-- =================================================================
             DEFERRED SECONDARY BUNDLES — Async Load (não-críticos)
             Técnica: media="print" onload="this.media='all'" + noscript fallback
             Economia: -226KB fora do critical rendering path
             ================================================================= -->
        <!-- Bundle 2/3 + 3/3: carregados async via awa-head-preload.phtml -->
        <!-- Vertical menu refinements: merged into awa-bundle-refinements (2026-03-19 → -1 request) -->

        <!--
            Bundle Tail: fonts-extra + modules (3 módulos) + rokanthemes-overrides (merged 2026-03-16)
            Fontes originais: awa-fonts-extra.css + awa-bundle-modules.css + awa-rokanthemes-overrides.css
            (Rokanthemes_Themeoption::css/loader.css, Rokanthemes_Brand::css/styles.css,
             GrupoAwamotos_RexisML::css/rexis-recommendations.css)
             83KB — defer (fontes extras + módulos não-críticos)
        -->
        <remove src="Rokanthemes_Themeoption::css/loader.css"/>
        <remove src="Rokanthemes_Brand::css/styles.css"/>
        <remove src="GrupoAwamotos_RexisML::css/rexis-recommendations.css"/>
        <!-- awa-bundle-tail: carregado async via awa-head-preload.phtml -->
        <!--
            Bundle Site: 5 CSS de awa-post-themeoption-head-css.phtml consolidados (2026-03-16)
            Reduz 5 requests bloqueantes → 1. Homepage remove via cms_index_index.xml.
            221KB — defer (não é crítico para FCP)
        -->
        <!-- awa-bundle-site: carregado async via awa-head-preload.phtml -->
        <!--
            Bundle Refinements: 15 CSS layers consolidados em 1 request (2026-03-19)
            Substitui: awa-b2b-home-refinements + awa-design-system-v2 + awa-ux-components-v2
            + awa-carousel-ui-v3 + awa-search-forms-v4 + awa-polish-alto-nivel-v5
            + awa-rokanthemes-final-v6 + awa-custom-footer-dark-gradient
            + phases 10–16 (visual-audit → quick-order)
            Economia: 14 requests bloqueantes eliminados.
        -->
        <!-- Critical Fold CSS: merged into awa-bundle-core.css (2026-04 — Issue #5 consolidation)
             T2.4 (2026-03-28): original 299KB async, ~4.5KB sync extraction.
             Now folded into awa-bundle-core to reduce 1 SYNC request. -->
        <!-- <css src="css/awa-critical-fold.css"/> — MERGED into awa-bundle-core -->
        <!-- Vertical Menu Shell Fix: migrado de volta ao global (2026-04-08).
             Seletores atualizados para body-only scope — agora se aplica a todas as páginas.
             Removido de Magento_Cms/layout/cms_index_index.xml para evitar duplicata. -->
        <!-- awa-bundle-refinements movido para async em awa-head-preload.phtml (T2.4 2026-03-28)
             Economia: -299KB render-blocking → FCP/LCP improvement -->
        <!-- Visual Fixes + Polish: movidos para async via awa-head-preload.phtml (2026-03-26)
             70KB removidos do critical rendering path → FCP/LCP improvement -->
        <remove src="css/awa-visual-fixes-critical.css"/>
        <remove src="css/awa-polish-sweep.css"/>
        <!-- Phase 17: Print stylesheet — media="print" = 0 bytes on critical path (browser defers) -->
        <css src="css/awa-phase17-print.css" media="print"/>
        <!-- Performance: remove box-shadow, text-shadow, backdrop-filter, animacoes nao-compostas -->
        <!-- Carregado SYNC para garantir que anule sombras antes do first paint -->
        <css src="css/awa-perf-no-shadows.css"/>
        <!--
            Cosmetic/decorative layers (2026-03-17):
            Moved to non-render-blocking preload via awa-deferred-cosmetic-css.phtml
            Saves ~33 KiB from critical rendering path (5 fewer blocking CSS)
            Loaded via head.additional → download in parallel, apply after FCP
        -->
        <remove src="css/awa-brand-lock.css"/>
        <remove src="css/awa-brand-lock-strict.css"/>
        <remove src="css/awa-qa-accessibility-safe.css"/>
        <remove src="css/awa-b2b-gate-enterprise.css"/>
        <remove src="css/awa-typography-best-practices.css"/>
    </head>

    <body>
        <referenceBlock name="awa.round2.header.minicart.js" remove="true"/>
        <!-- Bloco desativado: 5 CSS individuais migrados para awa-bundle-site.css (2026-03-16) -->
        <referenceBlock name="awa.post.themeoption.css" remove="true"/>

        <!-- AWA Head Preload: dns-prefetch + CSS preload + font preload + async bundles -->
        <referenceBlock name="head.additional">
            <block class="GrupoAwamotos\Theme\Block\Html\HeroPreload"
                   name="awa.head.preload"
                   template="Magento_Theme::html/awa-head-preload.phtml"
                   before="-"/>
        </referenceBlock>

        <!-- Deferred Interaction CSS: calendar, uppy, chosen, fancybox, quickview (2026-03-17) -->
        <!-- Consolidated from Rokanthemes_Themeoption/layout/default.xml for consistency -->
        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.deferred.interaction.css"
                   template="Magento_Theme::html/awa-deferred-interaction-css.phtml"
                   after="awa.head.preload"/>
        </referenceBlock>

        <!-- Cosmetic CSS loaded non-blocking via preload+onload (2026-03-17) -->
        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.deferred.cosmetic.css"
                   template="Magento_Theme::html/awa-deferred-cosmetic-css.phtml"
                   after="awa.deferred.interaction.css"/>
        </referenceBlock>

        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.search.autocomplete.head.css"
                   template="Magento_Theme::html/awa-search-autocomplete-head-css.phtml"
                   after="awa.deferred.cosmetic.css"/>
        </referenceBlock>

        <!-- styles-l.css DEVE ser o ÚLTIMO stylesheet — após todos os bundles e deferred templates.
             LESS compilado do child theme vence em cascata (mesmo specificity → último ganha). -->
        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.styles.l.last"
                   template="Magento_Theme::html/awa-styles-l-last.phtml"
                   after="awa.search.autocomplete.head.css"/>
        </referenceBlock>

        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.og.meta"
                   template="Magento_Theme::html/awa-og-meta.phtml"
                   after="awa.styles.l.last">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\OpenGraph</argument>
                    <argument name="open_graph_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\OpenGraph</argument>
                </arguments>
            </block>
        </referenceBlock>

        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.master.fix.js"
                   template="Magento_Theme::html/awa-js-loader.phtml"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.custom.header.minicart.js"
                   template="Magento_Theme::html/awa-custom-js-loader.phtml">
                <arguments>
                    <argument name="load_header_js" xsi:type="boolean">true</argument>
                    <argument name="load_home_owl_tabs_js" xsi:type="boolean">false</argument>
                    <argument name="load_footer_ux_js" xsi:type="boolean">true</argument>
                    <argument name="load_pdp_sticky_cta_js" xsi:type="boolean">false</argument>
                    <argument name="load_search_compat_js" xsi:type="boolean">true</argument>
                    <argument name="load_b2b_checkout_compat_js" xsi:type="boolean">true</argument>
                    <!-- Observer loop fixed: smarter MutationObserver skips owl-item clones -->
                    <argument name="load_home_category_compat_js" xsi:type="boolean">true</argument>
                </arguments>
            </block>
            <!-- AWA Phase 3: WhatsApp Floating Action Button -->
            <!-- cacheable=true: ContactInfo usa apenas ScopeConfig + Request, sem dados de sessão -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.whatsapp.fab"
                   template="Magento_Theme::html/awa-whatsapp-fab.phtml"
                   after="-">
                <arguments>
                    <argument name="contact_info" xsi:type="object">GrupoAwamotos\Theme\ViewModel\ContactInfo</argument>
                </arguments>
            </block>
            <!-- AWA Phase 4: Quick Quote Modal -->
            <!-- cacheable=true: form_key injetado via window.FORM_KEY (JS), sem serverside session -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.quote.modal"
                   template="Magento_Theme::html/awa-quote-modal.phtml"
                   after="awa.whatsapp.fab">
                <arguments>
                    <argument name="contact_info" xsi:type="object">GrupoAwamotos\Theme\ViewModel\ContactInfo</argument>
                </arguments>
            </block>
        </referenceContainer>

        <referenceContainer name="before.body.end">
            <!-- AWA Phase 4: Sticky Header JS -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.sticky.header.js"
                   template="Magento_Theme::html/awa-sticky-header-loader.phtml"/>
            <!-- AWA Phase 6: Back-to-Top Button -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.back.to.top"
                   template="Magento_Theme::html/awa-back-to-top.phtml"
                   after="-"/>
            <!-- AWA Phase 6: Organization JSON-LD — DESATIVADO: duplicava SchemaOrg::organization.phtml -->
            <!-- <block class="Magento\Framework\View\Element\Template"
                   name="awa.organization.jsonld"
                   template="Magento_Theme::html/awa-organization-jsonld.phtml"/> -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.qa.accessibility.safe.js"
                   template="Magento_Theme::html/awa-qa-accessibility-safe-loader.phtml"/>
        </referenceContainer>
    </body>
</page>
