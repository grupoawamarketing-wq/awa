<?xml version="1.0"?>
<!--
    AWA Motos — Magento_Theme/layout/default_head_blocks.xml
    Assets adicionados ao <head> em todas as páginas do child theme.

    O CSS principal vem do pipeline LESS via _extend.less (não precisa de
    declaração aqui). Este arquivo cobre:
      - Open Graph + Twitter Card meta tags (SEO social)
      - Fallback para JS build runtime
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!--
            Grid unificado legado removido: o source of truth atual é o pipeline
            LESS (_grid-system.less + bundles AWA). Manter este CSS causa conflito
            de layout na PDP.
        -->
        <remove src="css/awa-grid-unified.css"/>

        <!-- CSS Consolidation 2026-04-26: 6 CSS do tema pai movidos para _extend.less via _awa-consolidated.less -->
        <remove src="css/awa-core.css"/>
        <remove src="css/awa-layout.css"/>
        <remove src="css/awa-components.css"/>
        <remove src="css/awa-consistency.css"/>
        <remove src="css/awa-consistency-ui.css"/>
        <remove src="css/awa-fixes.css"/>

        <!-- Mantém owl.carousel.css do tema pai para restaurar carrosséis padrão Ayo. -->

        <!--
            animation_theme.css (94KB) — CSS de animações puras, seguro para async.
            Carregado via awa-deferred-cosmetic-css.phtml (media=print + onload swap).
        -->
        <remove src="css/animation_theme.css"/>

        <!--
            Google Fonts (Rubik) — redundante: Rubik já é self-hosted no tema AWA.
            Manter causa download duplo do woff2 (googleapis + self-hosted).
        -->
        <remove src="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&amp;display=swap"/>
        <!--
            Montserrat é a fonte base do tema — self-hosted pelo tema pai (ayo_home5).
            Não carregamos fonte externa aqui para evitar requisição extra ao Google Fonts.
            Meta tags de SEO/performance gerenciadas via
            Admin > Content > Design > Configuration (não duplicar aqui).
        -->
        <!-- AWA Canonical Layout Layer — final-wins -->
        <css src="css/awa-layout-canonical.css"/>

        <!-- awa-visual-bugfix-2026-04-30.css REMOVIDO do merge (2026-05-03):
             Conteúdo consolidado em awa-visual-bugfix.css (carregado por awa-head-preload.phtml).
             Remove ~312KB de duplicação do CSS merged. -->
        <!-- AWA Final Layout Override 2026-05-01 -->
        <css src="css/awa-layout-fixed.css"/>
        
        <!-- AWA Clean UI Final (Redução de ruído e alinhamentos globais) -->
        <css src="css/awa-clean-ui-final.css"/>
    </head>
    <body>
        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.jsbuild.runtime.fallback"
                   template="Magento_Theme::html/awa-jsbuild-fallback.phtml"/>
            <!--
                AWA: Open Graph + Twitter Card meta tags.
                Audit 2026-04-23: zero og:* encontradas em nenhuma página.
                Template detecta contexto (Home/PLP/PDP/CMS) e gera tags corretas.
            -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.og.meta"
                   template="Magento_Theme::html/awa-og-meta.phtml"/>
        </referenceBlock>
    </body>
</page>
