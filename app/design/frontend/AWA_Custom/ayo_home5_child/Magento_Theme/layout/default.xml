<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Override blank theme logo_width=170 with natural dimensions of logo_161x92_1.png -->
        <referenceBlock name="logo">
            <arguments>
                <argument name="logo_width" xsi:type="number">161</argument>
                <argument name="logo_height" xsi:type="number">92</argument>
            </arguments>
        </referenceBlock>

        <!-- A11Y-001: adiciona aria-label em links de produto sem texto acessível (widgets Rokanthemes) -->
        <!-- NAV-FIX: nav.fixed-bottom renderizado FORA do <footer> para evitar bug Chrome -->
        <!-- position:fixed dentro de footer com scrollHeight > clientHeight = posicionamento errado -->
        <referenceContainer name="before.body.end">
            <!-- Flyout: escapa stacking context do header (slider/home + páginas com menu vertical) -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.vertical.menu.flyout.fix"
                   template="Magento_Theme::html/awa-vertical-menu-flyout-fix.phtml"
                   before="-"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.mobile.nav"
                   template="Magento_Theme::html/awa-mobile-nav.phtml"
                   after="awa.vertical.menu.flyout.fix">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\FooterData</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.a11y.product.links"
                   template="Magento_Theme::html/awa-a11y-product-links.phtml"
                   after="-"/>
            <!-- AWA: Scripts globais -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.card.enhance"
                   template="Magento_Theme::html/awa-scripts.phtml"
                   after="awa.a11y.product.links"/>
            <!-- Botao Voltar ao Topo -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.back.to.top"
                   template="Magento_Theme::html/awa-back-to-top.phtml"
                   after="awa.card.enhance"/>
        </referenceContainer>

        <!--
            head.additional blocks — movidos de default_head_blocks.xml para cá
            porque <referenceBlock> em handles carregados via <update> não
            adiciona filhos corretamente ao bloco head.additional do Magento.
            O handle default é sempre ativo e resolve o merge.
        -->
        <referenceBlock name="head.additional">
            <!--
                AWA CLS Fix v5.0 — inline CSS no head para evitar layout shift no nav.
                Replica as regras de layout de awa-header-premium.css (carregado async)
                garantindo que o header já tenha layout final no first paint → CLS → 0.
                Deve vir ANTES do critical inline CSS para aplicar antes do primeiro paint.
            -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.cls.nav.fix"
                   template="Magento_Theme::html/awa-cls-nav-fix.phtml"
                   before="-"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.critical.inline.css"
                   template="Magento_Theme::html/awa-critical-inline.phtml"
                   after="awa.cls.nav.fix"/>

            <block class="GrupoAwamotos\Theme\Block\Html\HeroPreload"
                   name="awa.head.preload"
                   template="Magento_Theme::html/awa-head-preload.phtml"
                   after="awa.critical.inline.css"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.deferred.interaction.css"
                   template="Magento_Theme::html/awa-deferred-interaction-css.phtml"
                   after="awa.head.preload"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.deferred.cosmetic.css"
                   template="Magento_Theme::html/awa-deferred-cosmetic-css.phtml"
                   after="awa.deferred.interaction.css"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.search.autocomplete.head.css"
                   template="Magento_Theme::html/awa-search-autocomplete-head-css.phtml"
                   after="awa.deferred.cosmetic.css"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.styles.l.last"
                   template="Magento_Theme::html/awa-styles-l-last.phtml"
                   after="awa.search.autocomplete.head.css"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.visual.audit.final.css"
                   template="Magento_Theme::html/awa-visual-audit-final-css-v2.phtml"
                   after="awa.styles.l.last"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.visual.consistency.css"
                   template="Magento_Theme::html/awa-visual-consistency-css.phtml"
                   after="awa.visual.audit.final.css"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.header.audit.fix.css"
                   template="Magento_Theme::html/awa-header-audit-fix-css.phtml"
                   after="awa.visual.consistency.css"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.og.meta"
                   template="Magento_Theme::html/awa-og-meta.phtml"
                   after="awa.visual.audit.final.css">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\OpenGraph</argument>
                    <argument name="open_graph_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\OpenGraph</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
