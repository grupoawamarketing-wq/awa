<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- Header Stack e Refine Terminal migrados para _extend.less como partials LESS
             (_awa-header-stack.less e _awa-header-refine-terminal.less — imports 43.01 e 43.02).
             Eliminado 1 request CSS blocking (order=10120). -->
    </head>
    <body>

        <!-- Override blank theme logo_width=170 with natural dimensions of logo_161x92_1.png -->
        <referenceBlock name="logo">
            <arguments>
                <argument name="logo_width" xsi:type="number">161</argument>
                <argument name="logo_height" xsi:type="number">92</argument>
            </arguments>
        </referenceBlock>

        <!-- A11Y-001: adiciona aria-label em links de produto sem texto acessível (widgets Rokanthemes) -->
        <referenceBlock name="skip_to_content.target" remove="true"/>
        <!-- NAV-FIX: nav.fixed-bottom renderizado FORA do <footer> para evitar bug Chrome -->
        <!-- position:fixed dentro de footer com scrollHeight > clientHeight = posicionamento errado -->
        <referenceContainer name="before.body.end">
            <!-- Bloco A: CSS final após bundles async da home -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.search.autocomplete.body.css"
                   template="Magento_Theme::html/awa-search-autocomplete-head-css.phtml"
                   before="-"/>
            <!-- Header/minicart JS — defer-init + ui-v2 em todas as páginas (PLP/PDP/etc.) -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.custom.global.js.loader"
                   template="Magento_Theme::html/awa-custom-js-loader.phtml"
                   after="awa.search.autocomplete.body.css">
                <arguments>
                    <argument name="load_header_js" xsi:type="boolean">true</argument>
                    <argument name="skip_minicart_defer_init" xsi:type="boolean">false</argument>
                    <argument name="load_home_owl_tabs_js" xsi:type="boolean">false</argument>
                    <argument name="load_footer_ux_js" xsi:type="boolean">false</argument>
                    <argument name="load_pdp_sticky_cta_js" xsi:type="boolean">false</argument>
                    <argument name="load_search_compat_js" xsi:type="boolean">false</argument>
                    <argument name="load_b2b_checkout_compat_js" xsi:type="boolean">false</argument>
                    <argument name="load_home_category_compat_js" xsi:type="boolean">false</argument>
                </arguments>
            </block>
            <!-- Runtime: flyout portal + teclado/a11y (1 request, intent-deferred) -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.vertical.menu.runtime"
                   template="Magento_Theme::html/awa-vertical-menu-runtime.phtml"
                   after="awa.custom.global.js.loader"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.vertical.menu.stack.css"
                   template="Magento_Theme::html/awa-vertical-menu-stack-css.phtml"
                   after="awa.vertical.menu.runtime"/>
            <!-- CSS estático — seguro cachear no FPC (sem dados de sessão ou cliente). -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.impeccable.audit.uncached.global.v10"
                   template="Magento_Theme::html/awa-impeccable-audit-terminal-css-v10.phtml"
                   after="-"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.mobile.nav"
                   template="Magento_Theme::html/awa-mobile-nav.phtml"
                   after="awa.vertical.menu.stack.css">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\FooterData</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.a11y.product.links"
                   template="Magento_Theme::html/awa-a11y-product-links.phtml"
                   after="-"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.a11y.nav.links"
                   template="Magento_Theme::html/awa-a11y-nav-links.phtml"
                   after="awa.a11y.product.links"/>
            <!-- AWA: Scripts globais -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.card.enhance"
                   template="Magento_Theme::html/awa-scripts.phtml"
                   after="awa.a11y.product.links"/>
            <!-- Botao Voltar ao Topo -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.back.to.top"
                   template="Magento_Theme::html/awa-back-to-top.phtml"
                   after="awa.card.enhance"/>
            <!-- Meta Pixel — idle boot; visibilidade controlada em head-idle.phtml (isActive) -->
            <block class="Meta\Conversion\Block\Pixel\Head"
                   name="meta.pixel.idle"
                   template="Meta_Conversion::pixel/head-idle.phtml"
                   after="-"/>
        </referenceContainer>

        <!--
            head.additional blocks — movidos de default_head_blocks.xml para cá
            porque <referenceBlock> em handles carregados via <update> não
            adiciona filhos corretamente ao bloco head.additional do Magento.
            O handle default é sempre ativo e resolve o merge.
        -->
        <referenceBlock name="head.additional">
            <!--
                AWA CLS Fix v5.0 — inline CSS no head para evitar layout shift no nav.
                Replica as regras de layout de awa-header-premium.css (carregado async)
                garantindo que o header já tenha layout final no first paint → CLS → 0.
                Deve vir ANTES do critical inline CSS para aplicar antes do primeiro paint.
            -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.cls.nav.fix"
                   template="Magento_Theme::html/awa-cls-nav-fix.phtml"
                   before="-"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.header.impeccable.critical.global"
                   template="Magento_Theme::html/awa-header-impeccable-critical-global.phtml"
                   after="awa.cls.nav.fix"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.critical.inline.css"
                   template="Magento_Theme::html/awa-critical-inline.phtml"
                   after="awa.cls.nav.fix"/>

            <!-- HeroPreload lê slides do banco — conteúdo estático, seguro no FPC. -->
            <block class="GrupoAwamotos\Theme\Block\Html\HeroPreload"
                   name="awa.head.preload"
                   template="Magento_Theme::html/awa-head-preload.phtml"
                   after="awa.critical.inline.css"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.deferred.interaction.css"
                   template="Magento_Theme::html/awa-deferred-interaction-css.phtml"
                   after="awa.head.preload"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.deferred.cosmetic.css"
                   template="Magento_Theme::html/awa-deferred-cosmetic-css.phtml"
                   after="awa.deferred.interaction.css"/>

            <block class="Magento\Framework\View\Element\Template"
                   name="awa.styles.l.last"
                   template="Magento_Theme::html/awa-styles-l-last.phtml"
                   after="awa.deferred.cosmetic.css"/>

            <!-- AWA Audit Bundle: consolida 4 audit CSS em 1 request (2026-05-09)
                 Antes: awa-visual-audit-final (59KB) + awa-visual-consistency (51KB)
                      + awa-header-audit-fix (5KB) + awa-deep-audit (44KB) = 4 requests
                 Depois: awa-audit-bundle (162KB) = 1 request — reduz 3 HTTP round-trips
                 FPC: output é puramente links CSS estáticos — seguro cachear. -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.audit.bundle.css"
                   template="Magento_Theme::html/awa-audit-bundle-css.phtml"
                   after="awa.styles.l.last"/>

            <!-- OG Meta: gerado por URL (mesmo conteúdo para todos os visitantes na mesma URL).
                 FPC cacheia por URL — correto. Removido cacheable=false que impedia caching do site inteiro. -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.og.meta"
                   template="Magento_Theme::html/awa-og-meta.phtml"
                   after="awa.audit.bundle.css">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\OpenGraph</argument>
                    <argument name="open_graph_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\OpenGraph</argument>
                </arguments>
            </block>

            <!-- AWA Product Shelf Carousel — CSS + JS único (todas as páginas) -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.shelf.carousel"
                   template="Magento_Theme::html/awa-shelf-carousel-loader.phtml"
                   after="awa.og.meta"/>

            <!-- Rodada 2 Bloco A — autocomplete/busca: último CSS no head (sync) -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.search.autocomplete.head.css"
                   template="Magento_Theme::html/awa-search-autocomplete-head-css.phtml"
                   after="awa.shelf.carousel"/>

            <!-- Cookie LGPD — card flutuante, não cobre conteúdo -->
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.cookie.consent.fix.css"
                   template="Magento_Theme::html/awa-cookie-consent-fix-css.phtml"
                   after="awa.search.autocomplete.head.css"/>
        </referenceBlock>
    </body>
</page>
