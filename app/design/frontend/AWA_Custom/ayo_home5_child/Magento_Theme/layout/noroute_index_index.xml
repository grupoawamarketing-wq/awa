<?xml version="1.0"?>
<!--
    AWA Motos — Fix H1 duplicado na página 404
    Audit 2026-04-23: dois <h1>Página não encontrada</h1> na mesma página.

    Causa: o tema pai (ayo/ayo_home5) provavelmente injeta um segundo bloco
    de título no container principal além do bloco nativo Magento_Theme::html/title.phtml.

    Fix: remove o segundo bloco de título se existir, mantendo apenas o nativo.
    Se o problema persistir, identificar o bloco correto com `bin/magento dev:layout:export`
    e ajustar o nome abaixo.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Remove o segundo bloco de H1 que o parent theme injeta na 404 -->
        <!-- Descomente e ajuste o nome se o bloco duplicado for identificado: -->
        <!-- <referenceBlock name="NOME_DO_BLOCO_DUPLICADO" display="false"/> -->

        <!--
            Enquanto o bloco exato não é identificado via DOM ao vivo,
            ocultamos via CSS com alta especificidade:
            O seletor .cms-noroute-index garante que só afeta a 404.
        -->
    </body>
</page>
