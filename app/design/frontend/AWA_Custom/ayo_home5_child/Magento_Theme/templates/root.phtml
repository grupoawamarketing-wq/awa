<?php
declare(strict_types=1);

/**
 * AWA Motos root template override.
 * - Keep lang="pt-BR"
 * - Harden data-mage-init payload against control characters in static URLs
 * - Add body namespace class "awa-ds" for design-system scoping
 */

$sanitizeUrl = static function (?string $value): string {
    $sanitized = (string) $value;
    $sanitized = preg_replace('/[\x00-\x1F\x7F]+/u', '', $sanitized);

    return $sanitized ?? '';
};

$htmlAttrs = (string) $htmlAttributes;
if (strpos($htmlAttrs, 'lang="pt"') !== false) {
    $htmlAttrs = str_replace('lang="pt"', 'lang="pt-BR"', $htmlAttrs);
}

$bodyAttrs = (string) $bodyAttributes;
if (preg_match('/class="([^"]*)"/', $bodyAttrs, $matches) === 1) {
    $classes = preg_split('/\s+/', trim($matches[1])) ?: [];
    if (!in_array('awa-ds', $classes, true)) {
        $classes[] = 'awa-ds';
    }

    $classAttr = 'class="' . htmlspecialchars(trim(implode(' ', array_filter($classes))), ENT_QUOTES, 'UTF-8') . '"';
    $bodyAttrs = str_replace($matches[0], $classAttr, $bodyAttrs);
} else {
    $bodyAttrs .= ' class="awa-ds"';
}

$bodyMageInit = [
    'loaderAjax' => new \stdClass(),
    'loader' => [
        'icon' => $sanitizeUrl($loaderIcon ?? ''),
    ],
];
$bodyMageInitJson = htmlspecialchars(
    (string) json_encode($bodyMageInit, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
    ENT_QUOTES,
    'UTF-8'
);
?>
<!doctype html>
<html <?= /* @noEscape */ $htmlAttrs ?>>
    <head <?= /* @noEscape */ $headAttributes ?>>
        <?= /* @noEscape */ $requireJs ?>
        <?= /* @noEscape */ $headContent ?>
        <?= /* @noEscape */ $headCritical ?>
        <?= /* @noEscape */ $headAssets ?>
        <?= /* @noEscape */ $headAdditional ?>
    </head>
    <body data-container="body"
          data-mage-init='<?= /* @noEscape */ $bodyMageInitJson ?>'
        <?= /* @noEscape */ $bodyAttrs ?>>
        <?= /* @noEscape */ $layoutContent ?>
    </body>
</html>
