<?php
declare(strict_types=1);
/**
 * AWA — styles-l.css carregado por ÚLTIMO (após todos os bundles e deferred templates).
 *
 * Posicionado via default_head_blocks.xml com after="awa.search.autocomplete.head.css"
 * para garantir que o LESS compilado do tema filho vença em cascata:
 *   !important empate → último stylesheet no DOM ganha.
 *
 * Contém: _header-main, _header-classic-reference, _header-pixelperfect,
 *         _extend.less imports e todo o LESS customizado do child theme.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$stylesLUrl = $block->getViewFileUrl('css/styles-l.css');
?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($stylesLUrl) ?>"
      media="all"
      data-awa-styles-l="1"/>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($block->getViewFileUrl('css/awa-header-premium.css')) ?>"
      media="all"
      data-awa-header-premium="1"/>
<script>
/* awa-header-premium: remove inline !important override aplicado por fixSearchBtn()
   que forçava background:transparent no botão de busca */
(function () {
  'use strict';
  var PROPS = ['background', 'background-color', 'color', 'border-width', 'border-style', 'border-color', 'border-image'];
  function restoreBtn() {
    var btn = document.querySelector('#search_mini_form .action.search, form.minisearch button.action.search, .awa-professional-search button.action.search');
    if (!btn) return;
    PROPS.forEach(function (p) { btn.style.removeProperty(p); });
    var svg = btn.querySelector('svg');
    if (svg) { svg.style.removeProperty('color'); svg.style.removeProperty('stroke'); }
  }
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', restoreBtn); }
  else { restoreBtn(); }
  setTimeout(restoreBtn, 400);
  setTimeout(restoreBtn, 1500);
}());
</script>
