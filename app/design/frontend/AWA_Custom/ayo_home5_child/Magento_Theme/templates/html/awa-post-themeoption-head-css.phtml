/** @var \Magento\Framework\View\Element\Template $block */
$request = $block->getRequest();
$fullActionName = $request ? (string) $request->getFullActionName() : '';
$pathInfo = $request ? (string) ($request->getOriginalPathInfo() ?: $request->getPathInfo()) : '';
$pathSlug = trim($pathInfo, '/');
$isHomeRoute = $fullActionName === 'cms_index_index' || $pathSlug === '';
$isDemoStagePreview = $fullActionName === 'cms_page_view'
    && in_array($pathSlug, ['homepage_ayo_home5_stage', 'homepage_ayo_home5_demo_stage'], true);
$disableAwaPostThemeoptionCss = (bool) $block->getData('disable_awa_post_themeoption_css');

if ($isHomeRoute || $isDemoStagePreview) {
    $disableAwaPostThemeoptionCss = true;
}

if ($disableAwaPostThemeoptionCss) {
    return;
}
