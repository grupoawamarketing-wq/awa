/* 5. LCP CRITICAL: Hero pré-JS — owl.carousel.css oculta .owl-carousel com display:none
   Sem isto, a imagem hero só pinta quando o Swiper JS inicializa (~4-5s com throttle 4x)
   :not(.swiper-initialized) reverte automaticamente após o Swiper adicionar a classe */
.wrapper_slider .owl:not(.swiper-initialized),
.wrapper_slider .owl-carousel:not(.owl-loaded):not(.swiper-initialized){display:block!important;overflow:hidden}
.wrapper_slider .owl:not(.swiper-initialized)>.banner_item:not(:first-child),
.wrapper_slider .owl-carousel:not(.owl-loaded):not(.swiper-initialized)>.banner_item:not(:first-child){display:none!important}
