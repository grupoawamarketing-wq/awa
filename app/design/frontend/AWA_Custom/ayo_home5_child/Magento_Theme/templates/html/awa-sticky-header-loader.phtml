<?php
/**
 * AWA B2B — Sticky Header Loader
 * Carrega o script de sticky header em first-interaction ou idle para tirar
 * trabalho do caminho crítico sem perder funcionalidade em rolagem inicial.
 */
?>
<?php $stickyHeaderUrl = $block->escapeUrl($block->getViewFileUrl('js/awa-sticky-header.js')); ?>
<script>
(function (w, d) {
	var src = <?= /* @noEscape */ json_encode($stickyHeaderUrl, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT) ?>;
	var loaded = false;

	function loadStickyHeader() {
		if (loaded || d.querySelector('script[data-awa-lazy-src="' + src + '"]')) {
			return;
		}

		loaded = true;
		w.removeEventListener('scroll', loadStickyHeader, true);

		var script = d.createElement('script');
		script.src = src;
		script.defer = true;
		script.setAttribute('data-awa-lazy-src', src);
		(d.body || d.documentElement).appendChild(script);
	}

	w.addEventListener('scroll', loadStickyHeader, { passive: true, capture: true, once: true });

	if ('requestIdleCallback' in w) {
		w.requestIdleCallback(loadStickyHeader, { timeout: 1200 });
	} else {
		w.setTimeout(loadStickyHeader, 1200);
	}
})(window, document);
</script>
