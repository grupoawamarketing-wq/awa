/* awa-head-preload-critical-vmenu-polish: anti-flicker + CLS guard */

/* Trigger: dimensão estável antes do JS */
.awa-vmenu-trigger,.awa-department-trigger,[data-awa-vmenu-trigger],
.page-wrapper .navigation.verticalmenu .togge-menu-btn,.page-wrapper .awa-vmenu-toggle{
  min-height:var(--awa-touch-target,44px);
  min-width:var(--awa-touch-target,44px);
  box-sizing:border-box;
}
/* Mobile: prep de will-change para transição suave */
@media(max-width:991px){
  .page-wrapper .navigation.verticalmenu.side-verticalmenu .verticalmenu-content,
  .page-wrapper .navigation.verticalmenu.side-verticalmenu .nav-sections{
    will-change:transform;
  }
}
/* Desktop: pointer-events em submenus inativos */
@media(min-width:992px){
  body .page-wrapper .navigation.verticalmenu.side-verticalmenu
    .togge-menu > li.level0 > .submenu:not(.awa-vmf-active),
  body .page-wrapper .navigation.verticalmenu.side-verticalmenu
    .togge-menu > li.level0 > .navigation__submenu:not(.awa-vmf-active){
    pointer-events:none;
  }
  body .page-wrapper .navigation.verticalmenu.side-verticalmenu
    .togge-menu > li.level0.awa-vmf-active > .submenu,
  body .page-wrapper .navigation.verticalmenu.side-verticalmenu
    .togge-menu > li.level0.awa-vmf-active > .navigation__submenu{
    pointer-events:auto;
  }
}
/* Busca vmenu: dimensão estável */
.awa-vmenu-search-wrap{min-height:44px;box-sizing:border-box}
.awa-vmenu-search-input{min-height:44px;box-sizing:border-box;width:100%}
