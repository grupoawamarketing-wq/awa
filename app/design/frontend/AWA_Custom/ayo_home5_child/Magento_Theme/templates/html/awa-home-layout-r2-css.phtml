<script>
(function () {
  'use strict';
  function setVisible(clearBtn, visible) {
    clearBtn.hidden = !visible;
    clearBtn.style.display = visible ? 'inline-flex' : 'none';
    clearBtn.setAttribute('aria-hidden', visible ? 'false' : 'true');
  }
  function initSearchClear() {
    var searchInput = document.querySelector('#search, .block-search input.input-text');
    if (!searchInput || document.getElementById('awa-search-clear')) return;
    var clearBtn = document.createElement('button');
    clearBtn.id = 'awa-search-clear';
    clearBtn.type = 'button';
    clearBtn.className = 'awa-search-clear-btn';
    clearBtn.setAttribute('aria-label', 'Limpar busca');
    clearBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
    var control = searchInput.closest('.control[data-awa-search-control], .field.search .control, .control') || searchInput.parentElement;
    if (control) {
      if (window.getComputedStyle(control).position === 'static') control.style.position = 'relative';
      control.appendChild(clearBtn);
    }
    setVisible(clearBtn, false);
    searchInput.classList.add('awa-search-input--clearable');
    searchInput.addEventListener('input', function () { setVisible(clearBtn, !!this.value); });
    clearBtn.addEventListener('click', function () {
      searchInput.value = '';
      setVisible(clearBtn, false);
      searchInput.dispatchEvent(new Event('input', { bubbles: true }));
      searchInput.focus();
    });
  }
  function normalizeHomeHeaderSearch() {
    if (!window.matchMedia('(max-width: 991px)').matches) return;
    if (!document.body || !document.body.matches('.cms-index-index, .cms-home, .cms-homepage_ayo_home5')) return;

    var width = 'calc(100vw - 56px)';
    var searchCol = document.querySelector('.awa-site-header .awa-header-search-col.top-search.awa-header-actions');
    var block = searchCol ? searchCol.querySelector('.block-search') : null;
    var form = searchCol ? searchCol.querySelector('form#search_mini_form') : null;
    var input = form ? form.querySelector('input#search') : null;

    if (searchCol) {
      searchCol.style.setProperty('grid-template-columns', 'minmax(0, 1fr)', 'important');
      searchCol.style.setProperty('min-height', '44px', 'important');
    }

    [block, form].forEach(function (element) {
      if (!element) return;
      element.style.setProperty('width', width, 'important');
      element.style.setProperty('min-width', width, 'important');
      element.style.setProperty('max-width', width, 'important');
      element.style.setProperty('flex', '0 0 ' + width, 'important');
    });

    if (input) {
      input.style.setProperty('height', '44px', 'important');
      input.style.setProperty('min-height', '44px', 'important');
      input.style.setProperty('box-sizing', 'border-box', 'important');
    }
  }
  if (document.readyState !== 'loading') initSearchClear();
  else document.addEventListener('DOMContentLoaded', function () {
    initSearchClear();
    normalizeHomeHeaderSearch();
  }, { once: true });
  normalizeHomeHeaderSearch();
  window.addEventListener('resize', normalizeHomeHeaderSearch, { passive: true });
  setTimeout(initSearchClear, 300);
  setTimeout(normalizeHomeHeaderSearch, 300);
}());
</script>
