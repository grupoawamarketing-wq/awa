<?php
/**
 * A11Y-001 — Fix de acessibilidade: aria-label em links de produto sem texto.
 * Widgets Rokanthemes (ProductTab, BestsellerProduct, etc.) geram anchors de imagem
 * sem aria-label. Este script corrige todos ao carregar a página.
 */
?>
<script>
require(['domReady!'], function () {
    'use strict';
    var LINK_SELECTOR = '.product-item-photo, .product-thumb-link, a.product-item-photo';
    var THUMB_SELECTOR = '.product-thumb';
    var observer = null;
    var normalizeTimer = null;
    var HOVER_GUARD_ATTR = 'data-awa-hover-guard';

    function isHomePage() {
        var body = document.body;

        if (!body) {
            return false;
        }

        return body.classList.contains('cms-index-index')
            || body.classList.contains('cms-home')
            || body.classList.contains('cms-homepage_ayo_home5');
    }

    function setImportantStyle(element, property, value) {
        if (!element) {
            return;
        }
        element.style.setProperty(property, value, 'important');
    }

    function keepPrimaryImageVisible(thumb) {
        if (!thumb) {
            return;
        }

        var first = thumb.querySelector('.first-thumb');
        var second = thumb.querySelector('.second-thumb');
        var secondImage = second ? second.querySelector('img.product-image-photo, img') : null;

        if (first) {
            setImportantStyle(first, 'opacity', '1');
            setImportantStyle(first, 'visibility', 'visible');
            setImportantStyle(first, 'display', 'block');
            setImportantStyle(first, 'position', 'relative');
            setImportantStyle(first, 'z-index', '2');
        }

        if (second) {
            setImportantStyle(second, 'display', 'none');
            setImportantStyle(second, 'position', 'absolute');
            setImportantStyle(second, 'inset', '0');
            setImportantStyle(second, 'opacity', '0');
            setImportantStyle(second, 'visibility', 'hidden');
            setImportantStyle(second, 'pointer-events', 'none');
        }

        if (secondImage) {
            setImportantStyle(secondImage, 'opacity', '0');
            setImportantStyle(secondImage, 'visibility', 'hidden');
            setImportantStyle(secondImage, 'pointer-events', 'none');
        }
    }

    function addHoverGuard(thumb) {
        if (!thumb || thumb.getAttribute(HOVER_GUARD_ATTR) === 'true') {
            return;
        }

        thumb.addEventListener('mouseenter', function () {
            keepPrimaryImageVisible(thumb);
        });
        thumb.addEventListener('mouseleave', function () {
            keepPrimaryImageVisible(thumb);
        });
        thumb.addEventListener('touchstart', function () {
            keepPrimaryImageVisible(thumb);
        }, { passive: true });

        thumb.setAttribute(HOVER_GUARD_ATTR, 'true');
    }

    function fixProductLinks(root) {
        var scope = root && root.querySelectorAll ? root : document;
        var links = scope.querySelectorAll(LINK_SELECTOR);

        links.forEach(function (link) {
            if (link.getAttribute('aria-label') ||
                link.getAttribute('aria-labelledby') ||
                link.textContent.trim()) {
                return;
            }

            var img = link.querySelector('img[alt]');
            if (img && img.alt && img.alt.trim()) {
                link.setAttribute('aria-label', img.alt.trim());
            }
        });
    }

    function normalizeProductThumb(thumb) {
        if (!thumb || thumb.getAttribute('data-awa-image-normalized') === 'true') {
            return;
        }

        var link = thumb.querySelector('.product-thumb-link, a.product-item-photo, .product-item-photo');
        var first = thumb.querySelector('.first-thumb');
        var second = thumb.querySelector('.second-thumb');
        var container = first ? first.querySelector('.product-image-container') : null;
        var wrapper = first ? first.querySelector('.product-image-wrapper') : null;
        var image = first ? first.querySelector('img.product-image-photo, img') : null;

        if (!link || !first || !container || !wrapper || !image) {
            return;
        }

        setImportantStyle(link, 'display', 'block');
        setImportantStyle(link, 'position', 'relative');
        setImportantStyle(link, 'width', '100%');
        setImportantStyle(link, 'min-width', '0');
        setImportantStyle(link, 'margin-bottom', '0');
        setImportantStyle(link, 'overflow', 'visible');
        setImportantStyle(link, 'background', 'transparent');

        setImportantStyle(first, 'display', 'block');
        setImportantStyle(first, 'position', 'relative');
        setImportantStyle(first, 'z-index', '2');
        setImportantStyle(first, 'width', '100%');
        setImportantStyle(first, 'min-width', '0');
        setImportantStyle(first, 'line-height', '0');
        setImportantStyle(first, 'opacity', '1');
        setImportantStyle(first, 'visibility', 'visible');

        setImportantStyle(container, 'display', 'block');
        setImportantStyle(container, 'position', 'relative');
        setImportantStyle(container, 'width', '100%');
        setImportantStyle(container, 'height', 'auto');
        setImportantStyle(container, 'aspect-ratio', '1 / 1');
        setImportantStyle(container, 'min-height', 'var(--card-photo-min-h, 220px)');

        setImportantStyle(wrapper, 'display', 'block');
        setImportantStyle(wrapper, 'position', 'absolute');
        setImportantStyle(wrapper, 'inset', '0');
        setImportantStyle(wrapper, 'width', '100%');
        setImportantStyle(wrapper, 'height', '100%');
        setImportantStyle(wrapper, 'padding-bottom', '0');
        setImportantStyle(wrapper, 'overflow', 'hidden');

        setImportantStyle(image, 'display', 'block');
        setImportantStyle(image, 'position', 'absolute');
        setImportantStyle(image, 'inset', '0');
        setImportantStyle(image, 'width', '100%');
        setImportantStyle(image, 'height', '100%');
        setImportantStyle(image, 'max-width', '100%');
        setImportantStyle(image, 'max-height', '100%');
        setImportantStyle(image, 'opacity', '1');
        setImportantStyle(image, 'visibility', 'visible');
        setImportantStyle(image, 'object-fit', 'contain');
        setImportantStyle(image, 'object-position', 'center');

        keepPrimaryImageVisible(thumb);
        addHoverGuard(thumb);

        thumb.setAttribute('data-awa-image-normalized', 'true');
    }

    function normalizeThumbs(root) {
        var scope = root && root.querySelectorAll ? root : document;
        var thumbs = scope.querySelectorAll(THUMB_SELECTOR);

        thumbs.forEach(normalizeProductThumb);
    }

    function runFixes(root) {
        fixProductLinks(root);
        normalizeThumbs(root);
    }

    function scheduleRun(root) {
        var target = root && root.nodeType === 1 ? root : document;

        if (normalizeTimer) {
            window.clearTimeout(normalizeTimer);
        }

        normalizeTimer = window.setTimeout(function () {
            runFixes(target);
        }, 60);
    }

    function bootstrapHeavyFixes() {
        if (window.__awaA11yProductLinksBooted) {
            return;
        }

        window.__awaA11yProductLinksBooted = true;

        runFixes(document);
        window.setTimeout(function () {
            runFixes(document);
        }, 400);

        document.addEventListener('contentUpdated', function (event) {
            scheduleRun(event && event.target ? event.target : document);
        });

        if (window.MutationObserver && document.body) {
            observer = new MutationObserver(function (mutations) {
                var shouldRun = false;

                mutations.forEach(function (mutation) {
                    if (shouldRun) {
                        return;
                    }

                    Array.prototype.forEach.call(mutation.addedNodes, function (node) {
                        if (shouldRun || !node || node.nodeType !== 1) {
                            return;
                        }

                        if ((node.matches && (node.matches(LINK_SELECTOR) || node.matches(THUMB_SELECTOR))) ||
                            (node.querySelector && (node.querySelector(LINK_SELECTOR) || node.querySelector(THUMB_SELECTOR)))) {
                            shouldRun = true;
                        }
                    });
                });

                if (shouldRun) {
                    scheduleRun(document);
                }
            });

            observer.observe(document.body, {
                childList: true,
                subtree: true
            });

            window.addEventListener('pagehide', function () {
                if (observer) {
                    observer.disconnect();
                }
            }, { once: true });
        }
    }

    if (isHomePage()) {
        // Home PERF: mantém apenas ajuste leve de aria-label no critical path.
        // A normalização pesada de thumbs fica desativada na home para evitar long tasks.
        fixProductLinks(document);

        document.addEventListener('contentUpdated', function (event) {
            var target = event && event.target && event.target.querySelectorAll ? event.target : document;
            fixProductLinks(target);
        });
    } else {
        bootstrapHeavyFixes();
    }
});
</script>

<?php /* A11Y-002 — Fix global: logo, minicart, empty links, duplicate IDs (2026-04-27) */ ?>
<script>
require(['domReady!'], function () {
    'use strict';

    /* #8: Fix logo accessibility — remove aria-hidden, ensure aria-label */
    var logo = document.querySelector('.logo a, a.logo');
    if (logo) {
        logo.removeAttribute('aria-hidden');
        if (!logo.getAttribute('aria-label')) {
            logo.setAttribute('aria-label', 'AWA Motos - Página inicial');
        }
    }

    /* #8: Minicart image alt */
    var minicartImgs = document.querySelectorAll('.minicart-wrapper img:not([alt]), .minicart-wrapper img[alt=""]');
    minicartImgs.forEach(function (img) {
        img.setAttribute('alt', 'Produto no carrinho');
    });

    /* #6: Fix empty links — add aria-label to known empty-text links */
    var emptyLinkSelectors = [
        '.action.showcart',
        '.action.nav-toggle',
        '.action.wishlist',
        '.action.tocompare',
        'a.action.quickview-handler'
    ];
    var labelMap = {
        'showcart': 'Carrinho de compras',
        'nav-toggle': 'Menu de navegação',
        'wishlist': 'Lista de desejos',
        'tocompare': 'Comparar produto',
        'quickview-handler': 'Visualização rápida'
    };
    emptyLinkSelectors.forEach(function (sel) {
        document.querySelectorAll(sel).forEach(function (link) {
            if (!link.getAttribute('aria-label') && !link.textContent.trim()) {
                var key = sel.split('.').pop();
                if (labelMap[key]) {
                    link.setAttribute('aria-label', labelMap[key]);
                }
            }
        });
    });

    /* #10: Fix duplicate toolbar IDs — suffix bottom toolbar elements */
    var toolbars = document.querySelectorAll('.toolbar.toolbar-products');
    if (toolbars.length > 1) {
        for (var i = 1; i < toolbars.length; i++) {
            var dupes = toolbars[i].querySelectorAll('[id]');
            dupes.forEach(function (el) {
                el.id = el.id + '-bottom-' + i;
            });
        }
    }

    /* #5: Fix cart heading hierarchy — h1 jumps to h3, add aria-level to bridge */
    if (document.body.classList.contains("checkout-cart-index")) {
        document.querySelectorAll(".cart-summary h3, .block.crosssell h3").forEach(function (h3) {
            h3.setAttribute("role", "heading");
            h3.setAttribute("aria-level", "2");
        });
    }

    /* #11: Fix duplicate product IDs on homepage tabs */
    var seen = {};
    document.querySelectorAll('.product-item[id]').forEach(function (el) {
        if (seen[el.id]) {
            el.id = el.id + '-tab-' + (Object.keys(seen).length);
        }
        seen[el.id] = true;
    });
});
</script>
