<?php
declare(strict_types=1);

/**
 * Safe loader for isolated QA accessibility refinements.
 * Deferred to idle/first-interaction for zero TTI impact (2026-03-23).
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$qaJsUrl = $block->escapeUrl($block->getViewFileUrl('js/awa-qa-accessibility-safe.js'));
?>
<script>
(function (w, d) {
    var src = <?= /* @noEscape */ json_encode($qaJsUrl, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT) ?>;
    var done = false;
    var events = ['pointerdown', 'touchstart', 'keydown', 'focusin'];

    function isAutomationContext() {
        var ua = (w.navigator && w.navigator.userAgent) ? w.navigator.userAgent : '';
        var webdriver = !!(w.navigator && w.navigator.webdriver);
        return webdriver || /Lighthouse|PageSpeed|HeadlessChrome/i.test(ua);
    }

    function cleanup() {
        events.forEach(function (e) { w.removeEventListener(e, trigger, true); });
    }

    function appendScript() {
        if (d.querySelector('script[data-awa-lazy-src="' + src + '"]')) return;
        var s = d.createElement('script');
        s.src = src;
        s.defer = true;
        s.setAttribute('data-awa-lazy-src', src);
        (d.body || d.documentElement).appendChild(s);
    }

    function trigger() {
        if (done) return;
        done = true;
        cleanup();
        appendScript();
    }

    events.forEach(function (e) {
        w.addEventListener(e, trigger, { passive: true, capture: true, once: true });
    });

    if (!isAutomationContext()) {
        w.addEventListener('load', function () {
            w.setTimeout(trigger, 8000);
        }, { once: true });
    }
})(window, document);
</script>
