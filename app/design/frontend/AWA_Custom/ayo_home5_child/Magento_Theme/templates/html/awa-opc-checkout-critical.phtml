declare(strict_types=1);
/**
 * AWA OPC Checkout — critical CSS inline + async loader.
 *
 * Estratégia de performance:
 *  - Inline (~3KB): tokens CSS (--awa-cc-*, --awa-checkout-*, --awa-csh-*) +
 *    regras de ocultação do header (hide top-bar, nav, minicart, search) +
 *    background da página e skeleton do container — previnem CLS durante FCP.
 *  - Async (3 arquivos, total ~119KB):
 *      cart-checkout-premium.css (107KB)  — layout completo cart+checkout
 *      cart-checkout.css         (360B)   — camada CSS de grid/gap
 *      checkout-simplified-header.css (11KB) — header minimal OPC
 *
 * awa-checkout-polish.css (13KB) é carregado async via checkout_index_index
 * handle → awa-checkout-polish-async.phtml (evita duplicata no OPC que
 * inclui o handle checkout_index_index via <update>).
 *
 * Substitui os 3 <css> bloqueantes em onepagecheckout_index_index.xml.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$premiumUrl  = $block->getViewFileUrl('css/b2b/pages/cart-checkout-premium.min.css');
$layerUrl    = $block->getViewFileUrl('css/layers/pages/cart-checkout.min.css');
$headerUrl   = $block->getViewFileUrl('css/b2b/pages/checkout-simplified-header.min.css');
$polishUrl   = $block->getViewFileUrl('css/awa-checkout-polish.min.css');
$layoutLockUrl = $block->getViewFileUrl('css/awa-checkout-layout-lock.css');
$layoutProbeUrl = $block->getViewFileUrl('js/awa-opc-layout-probe.js');
$asyncInit = json_encode(
    ['js/awa-async-stylesheet' => ['urls' => [$premiumUrl, $layerUrl, $headerUrl, $polishUrl]]],
    JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP
);
?>
