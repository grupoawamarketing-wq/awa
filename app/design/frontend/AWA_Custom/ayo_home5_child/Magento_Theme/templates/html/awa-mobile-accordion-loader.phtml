<?php
declare(strict_types=1);
/**
 * M09+M10: Mobile accordion JS loader
 * Carrega apenas em viewports mobile via matchMedia
 */
?>
<script>
(function(){
    if (window.matchMedia && window.matchMedia('(max-width:767px)').matches) {
        var s = document.createElement('script');
        s.src = '<?= $block->escapeJs($block->getViewFileUrl('js/awa-mobile-accordion.js')) ?>';
        s.async = true;
        document.body.appendChild(s);
    }
})();
</script>
