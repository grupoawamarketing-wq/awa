<div class="awa-b2b-quick-order-container" id="awa-quick-order-app">
    <div class="awa-quick-order-header">
        <h2><?php echo __('Compra Rápida B2B') ?></h2>
        <p><?php echo __('Digite os códigos SKU e as quantidades que deseja comprar, separados por vírgula. Ex: SKU123, 50') ?></p>
    </div>

    <div class="awa-quick-order-body">
        <div class="awa-quick-order-input-area">
            <textarea id="awa-quick-order-textarea"
                      class="awa-ds-form-control"
                      rows="8"
                      placeholder="SKU-CAVALETE, 10&#10;SKU-CAPACETE-AZUL, 5&#10;SKU-ESPELHO, 20"></textarea>
            <p class="awa-quick-order-hint"><?php echo __('Pressione Validar para checar os estoques antes de adicionar ao carrinho.') ?></p>
        </div>

        <div class="awa-quick-order-actions">
            <button type="button" id="awa-btn-validate-skus" class="action secondary awa-ds-btn--secondary">
                <span><?php echo __('1. Validar SKUs') ?></span>
            </button>
            <button type="button" id="awa-btn-add-all-tocart" class="action primary awa-ds-btn--primary" disabled>
                <span><?php echo __('2. Adicionar Tudo ao Carrinho') ?></span>
            </button>
        </div>

        <div class="awa-quick-order-results" id="awa-quick-order-results-container" style="display: none;">
            <table class="data table awa-b2b-zebra-table" id="awa-quick-order-table">
                <thead>
                    <tr>
                        <th>SKU</th>
                        <th>Status</th>
                        <th>Qtd</th>
                        <th>Ação</th>
                    </tr>
                </thead>
                <tbody id="awa-quick-order-tbody">
                    <!-- Javascript will populate rows here -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
require(['jquery', 'Magento_Customer/js/customer-data', 'mage/url', 'mage/translate', 'mage/cookies'], function($, customerData, urlBuilder, $t) {
    $(document).ready(function() {
        var formKey = $.mage.cookies.get('form_key');

        $('#awa-btn-validate-skus').on('click', function() {
            var lines = $('#awa-quick-order-textarea').val().split('\n');
            var tbody = $('#awa-quick-order-tbody');
            tbody.empty();

            var validCount = 0;

            lines.forEach(function(line) {
                if (line.trim() === '') return;
                var parts = line.split(',');
                var sku = parts[0] ? parts[0].trim() : '';
                var qty = parts[1] ? parseInt(parts[1].trim()) : 1;

                if (sku) {
                    var row = $('<tr></tr>');
                    row.append('<td><strong>' + sku + '</strong></td>');
                    row.append('<td class="row-status"><span class="status-badge valid" style="color: green;">Pronto para Adicionar</span></td>');
                    row.append('<td>' + qty + '</td>');
                    row.append('<td><button type="button" class="remove-row" style="color: red; border: none; background: none; cursor: pointer;">X</button></td>');
                    row.data('sku', sku).data('qty', qty);
                    row.addClass('pending-item');
                    tbody.append(row);
                    validCount++;
                }
            });

            if (validCount > 0) {
                $('#awa-quick-order-results-container').show();
                $('#awa-btn-add-all-tocart').prop('disabled', false).text($t('2. Adicionar Tudo ao Carrinho')).css('background-color', '');
            }
        });

        $(document).on('click', '.remove-row', function() {
            $(this).closest('tr').remove();
            if ($('#awa-quick-order-tbody tr.pending-item').length === 0) {
                $('#awa-btn-add-all-tocart').prop('disabled', true);
            }
        });

        $('#awa-btn-add-all-tocart').on('click', function() {
            var btn = $(this);
            btn.text($t('Processando...')).prop('disabled', true);

            var items = $('.pending-item').toArray();
            var currentIndex = 0;

            function processNext() {
                if (currentIndex >= items.length) {
                    btn.text($t('Finalizado!')).css('background-color', 'green');
                    customerData.reload(['cart'], true);
                    return;
                }

                var row = $(items[currentIndex]);
                var sku = row.data('sku');
                var qty = row.data('qty');
                var statusCell = row.find('.row-status');

                statusCell.html('<span style="color: orange;">Adicionando...</span>');

                // Using standard Magento POST for add to cart by SKU (advanced checkout style)
                // Note: Standard Magento /checkout/cart/add requires Product ID, not SKU directly.
                // For a true SKU-only add-to-cart, we either need a custom controller or the B2B QuickOrder API.
                // Assuming we use a standard AJAX trick if it\'s a simple product, or query REST API.
                // For pure B2B, magento provides /rest/V1/carts/mine/items

                var payload = {
                    cartItem: {
                        sku: sku,
                        qty: qty,
                        quote_id: "active" // This works for logged in if integrated with standard cart api
                    }
                };

                // Because /rest/V1/carts/mine/items requires a Bearer token in pure headless,
                // and we are in frontend rendering, we use a generic ajax fallback to a standard magento controller if possible,
                // OR we can use the form_key submission to standard quick order if module exists.
                // Here we simulate the API call that a custom QuickOrder module would have, or standard add by SKU if customized.
                $.ajax({
                    url: urlBuilder.build('rest/V1/carts/mine/items'),
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function(res) {
                        statusCell.html('<span style="color: green;">Adicionado ✓</span>');
                        row.removeClass('pending-item').addClass('success-item');
                        currentIndex++;
                        processNext();
                    },
                    error: function(err) {
                        // Se falhar REST puro, mostramos erro visual
                        console.error('Add to cart failed for ' + sku, err);
                        statusCell.html('<span style="color: red;">Falha/Sem Estoque</span>');
                        currentIndex++;
                        processNext();
                    }
                });
            }

            processNext();
        });
    });
});
</script>
