<?php
/**
 * Compact B2B mode badge for Ayo top header (theme-level integration)
 *
 * @var \GrupoAwamotos\B2B\Block\Header\StatusPanel $block
 */
?>
<?php if (!$block->shouldDisplay()): ?>
    <?php return; ?>
<?php endif; ?>
<?php $data = $block->getCustomerData(); ?>
<?php
$groupName = trim((string) ($data['group_name'] ?? 'B2B'));
$accent = (string) (($data['group_badge']['color'] ?? '#b73337'));
$dashboardUrl = $block->getUrl('b2b/account/dashboard');
$label = $groupName !== '' ? __('Modo B2B: %1', $groupName) : __('Modo B2B');
?>
<a class="awa-b2b-mode-badge"
   href="<?= $block->escapeUrl($dashboardUrl) ?>"
   style="--awa-b2b-mode-accent: <?= $block->escapeHtmlAttr($accent) ?>"
   title="<?= $block->escapeHtmlAttr($label) ?>"
   aria-label="<?= $block->escapeHtmlAttr($label) ?>">
    <span class="awa-b2b-mode-badge__dot" aria-hidden="true"></span>
    <span class="awa-b2b-mode-badge__label"><?= $block->escapeHtml(__('Modo B2B')) ?></span>
    <?php if ($groupName !== ''): ?>
    <span class="awa-b2b-mode-badge__tier"><?= $block->escapeHtml($groupName) ?></span>
    <?php endif; ?>
</a>
