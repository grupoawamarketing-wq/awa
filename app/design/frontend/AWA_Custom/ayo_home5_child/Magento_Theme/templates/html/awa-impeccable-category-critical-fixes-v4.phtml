<?php
declare(strict_types=1);
/**
 * PLP critical CSS movido para awa-plp-critical-fixes.min.css (head-preload, rota catalog).
 * Este bloco mantém apenas o guard de ingest loopback.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
?>
<script id="awa-loopback-ingest-guard-v1">
(function (w) {
  'use strict';
  var allowDebug = /(?:\?|&)awa_debug_logs=1(?:&|$)/.test(w.location.search) ||
    /^(localhost|127\.0\.0\.1)$/i.test(w.location.hostname);
  if (allowDebug || w.__awaLoopbackIngestGuardInstalled) {
    return;
  }
  w.__awaLoopbackIngestGuardInstalled = true;

  function isIngestUrl(url) {
    return /^http:\/\/(?:localhost|127\.0\.0\.1):\d+\/ingest\//i.test(String(url || ''));
  }

  if (typeof w.fetch === 'function') {
    var nativeFetch = w.fetch.bind(w);
    w.fetch = function (input, init) {
      var url = typeof input === 'string' ? input : (input && input.url) || '';
      if (isIngestUrl(url)) {
        return Promise.resolve(new Response(null, { status: 204, statusText: 'No Content' }));
      }
      return nativeFetch(input, init);
    };
  }
})(window);
</script>
