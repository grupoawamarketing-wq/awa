<?php
declare(strict_types=1);

/**
 * @var \Magento\Framework\View\Element\Template $block
 * @var \GrupoAwamotos\Theme\ViewModel\ContactInfo|\GrupoAwamotos\Theme\ViewModel\FooterData $contactInfo
 */
$contactInfo = $block->getData('view_model');

$whatsAppUrl = method_exists($contactInfo, 'getWhatsAppUrl') ? (string) $contactInfo->getWhatsAppUrl() : '';
$phoneLabel = method_exists($contactInfo, 'getPhone') ? trim((string) $contactInfo->getPhone()) : '';
$phoneUrl = method_exists($contactInfo, 'getPhoneUrl') ? (string) $contactInfo->getPhoneUrl() : '';
$emailLabel = method_exists($contactInfo, 'getEmail') ? trim((string) $contactInfo->getEmail()) : '';
$emailUrl = method_exists($contactInfo, 'getEmailUrl') ? (string) $contactInfo->getEmailUrl() : '';

$hasAnyContact = $whatsAppUrl !== '' || $phoneLabel !== '' || $emailLabel !== '';
?>
<?php if ($hasAnyContact): ?>
<section class="awa-footer-business-contact" aria-labelledby="awa-footer-business-contact-title">
    <div class="container">
        <div class="awa-footer-business-contact__shell">
            <div class="awa-footer-business-contact__intro">
                <span class="awa-footer-business-contact__eyebrow"><?= $block->escapeHtml(__('Canal Comercial')) ?></span>
                <h4 id="awa-footer-business-contact-title" class="awa-footer-business-contact__title">
                    <?= $block->escapeHtml(__('Suporte direto para atacado, cotação e recompra')) ?>
                </h4>
                <p class="awa-footer-business-contact__copy">
                    <?= $block->escapeHtml(__('Os canais abaixo usam a configuração do admin para manter WhatsApp, telefone e e-mail comerciais sempre sincronizados com a operação.')) ?>
                </p>
            </div>
            <div class="awa-footer-business-contact__actions">
                <?php if ($whatsAppUrl !== ''): ?>
                    <a class="awa-footer-business-contact__action awa-footer-business-contact__action--primary"
                       href="<?= $block->escapeUrl($whatsAppUrl) ?>"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="<?= $block->escapeHtmlAttr(__('Abrir WhatsApp comercial')) ?>">
                        <span class="awa-footer-business-contact__action-icon" aria-hidden="true"><i class="fa fa-whatsapp"></i></span>
                        <span class="awa-footer-business-contact__action-copy">
                            <strong><?= $block->escapeHtml(__('WhatsApp Comercial')) ?></strong>
                            <small><?= $block->escapeHtml(__('Resposta rápida para pedidos e cotações')) ?></small>
                        </span>
                    </a>
                <?php endif; ?>
                <?php if ($phoneLabel !== ''): ?>
                    <a class="awa-footer-business-contact__action"
                       href="<?= $block->escapeUrl($phoneUrl) ?>"
                       aria-label="<?= $block->escapeHtmlAttr(__('Ligar para %1', $phoneLabel)) ?>">
                        <span class="awa-footer-business-contact__action-icon" aria-hidden="true"><i class="fa fa-phone"></i></span>
                        <span class="awa-footer-business-contact__action-copy">
                            <strong><?= $block->escapeHtml($phoneLabel) ?></strong>
                            <small><?= $block->escapeHtml(__('Atendimento por telefone')) ?></small>
                        </span>
                    </a>
                <?php endif; ?>
                <?php if ($emailLabel !== ''): ?>
                    <a class="awa-footer-business-contact__action"
                       href="<?= $block->escapeUrl($emailUrl) ?>"
                       aria-label="<?= $block->escapeHtmlAttr(__('Enviar e-mail para %1', $emailLabel)) ?>">
                        <span class="awa-footer-business-contact__action-icon" aria-hidden="true"><i class="fa fa-envelope-o"></i></span>
                        <span class="awa-footer-business-contact__action-copy">
                            <strong><?= $block->escapeHtml($emailLabel) ?></strong>
                            <small><?= $block->escapeHtml(__('Canal para compras corporativas')) ?></small>
                        </span>
                    </a>
                <?php endif; ?>
            </div>
        </div>
    </div>
</section>
<?php endif; ?>
