/**
 * AWA PDP — carrega CSS da PDP de forma não-bloqueante (print trick).
 *
 * BUG-07: awa-round3-pdp-conversion.css e awa-pdp-final-polish.css eram servidos
 * como <link media="all"> bloqueante pelo ayo_home5. O layout XML do tema filho
 * remove-os do head e este template os recarrega async.
 *
 * MELHORIA-01/02: awa-pdp-premium.css contém os estilos de compatibilidade inline
 * e o badge de estoque verde.
 *
 * Sem <noscript>: dedupeStylesheetHrefs em OptimizeHeadStylesPlugin interpreta
 * <noscript><link> como versão "ativa", removendo o link media="print" correto.
 * Magento 2 exige JS para funcionar; não há cenário real sem JS.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
declare(strict_types=1);

$conversionUrl = $block->getViewFileUrl('css/awa-round3-pdp-conversion.css');
$polishUrl     = $block->getViewFileUrl('css/awa-pdp-final-polish.css');
