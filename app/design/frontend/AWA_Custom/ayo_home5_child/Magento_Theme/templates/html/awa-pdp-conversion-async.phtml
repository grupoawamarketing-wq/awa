$faqUrl        = $block->getViewFileUrl('css/awa-pdp-faq-2026-06-27.css');
?>
<link rel="stylesheet" href="<?= $block->escapeUrl($conversionUrl) ?>" media="print" onload="this.media='all'" data-awa-pdp-css="conversion"/>
