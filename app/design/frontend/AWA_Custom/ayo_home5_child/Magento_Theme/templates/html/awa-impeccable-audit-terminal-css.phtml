<?php declare(strict_types=1);

/**
 * Impeccable audit — camada terminal via link (FPC-safe) — APENAS HOME.
 * Usado em awa-head-preload.phtml (home) como alternativa ao global v10.
 * Tudo async (print trick) — home já tem awa-focus-visible via awa-head-preload.
 *
 * Refine v9: --awa-cc-focus-ring em :root; .min.css (42KB vs 53KB).
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$impeccableUrl   = $block->getViewFileUrl('css/awa-impeccable-audit-2026-05-28.min.css');
$focusVisibleUrl = $block->getViewFileUrl('css/awa-focus-visible.min.css');
$refineUrl       = $block->getViewFileUrl('css/awa-commerce-impeccable-refine.min.css');
?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($impeccableUrl) ?>"
      media="print"
      onload="this.media='all'"
      data-awa-impeccable-terminal="final"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($impeccableUrl) ?>"/></noscript>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($focusVisibleUrl) ?>"
      media="print"
      onload="this.media='all'"
      data-awa-a11y="focus-visible"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($focusVisibleUrl) ?>"/></noscript>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($refineUrl) ?>?v=20260605-fix16"
      media="print"
      onload="this.media='all'"
      data-awa-impeccable-terminal="refine"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($refineUrl) ?>?v=20260605-fix16"/></noscript>
