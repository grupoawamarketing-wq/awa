<?php declare(strict_types=1);

/**
 * Impeccable audit — camada terminal via link (FPC-safe).
 * CSS estático; sem inline duplicado (economiza ~11KB no HTML).
 * Inclui awa-focus-visible (WCAG 2.4.7 — keyboard focus rings).
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$impeccableUrl  = $block->getViewFileUrl('css/awa-impeccable-audit-2026-05-28.min.css');
$focusVisibleUrl = $block->getViewFileUrl('css/awa-focus-visible.min.css');
?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($impeccableUrl) ?>"
      media="print"
      onload="this.media='all'"
      data-awa-impeccable-terminal="final"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($impeccableUrl) ?>"/></noscript>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($focusVisibleUrl) ?>"
      media="print"
      onload="this.media='all'"
      data-awa-a11y="focus-visible"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($focusVisibleUrl) ?>"/></noscript>
