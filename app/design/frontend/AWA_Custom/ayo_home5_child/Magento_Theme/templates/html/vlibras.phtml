<?php
declare(strict_types=1);
?>
<div vw class="enabled" data-awa-vlibras-root="true">
    <div
        vw-access-button
        class="active"
        aria-label="Acessibilidade em Libras"
        title="Abrir VLibras - Tradução para Língua Brasileira de Sinais"></div>
    <div vw-plugin-wrapper>
        <div class="vw-plugin-top-wrapper"></div>
    </div>
</div>
<script>
    (function initAwaVlibras(windowRef, documentRef) {
        'use strict';

        if (!windowRef || !documentRef) {
            return;
        }

        if (documentRef.documentElement.dataset.awaVlibrasInit === '1') {
            return;
        }

        var existingScript = documentRef.getElementById('awa-vlibras-script');

        function bootWidget() {
            if (!windowRef.VLibras || typeof windowRef.VLibras.Widget !== 'function') {
                return;
            }

            if (documentRef.documentElement.dataset.awaVlibrasInit === '1') {
                return;
            }

            documentRef.documentElement.dataset.awaVlibrasInit = '1';
            new windowRef.VLibras.Widget('https://vlibras.gov.br/app');
        }

        if (windowRef.VLibras && typeof windowRef.VLibras.Widget === 'function') {
            bootWidget();
            return;
        }

        if (existingScript) {
            existingScript.addEventListener('load', bootWidget, { once: true });
            return;
        }

        var script = documentRef.createElement('script');
        script.id = 'awa-vlibras-script';
        script.src = 'https://vlibras.gov.br/app/vlibras-plugin.js';
        script.defer = true;
        script.addEventListener('load', bootWidget, { once: true });
        documentRef.head.appendChild(script);
    }(window, document));
</script>
