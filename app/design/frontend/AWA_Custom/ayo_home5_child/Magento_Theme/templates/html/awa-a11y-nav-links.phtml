<?php
/**
 * A11Y-003 — Nav "Ver tudo" Links Accessibility Fix
 *
 * Adds aria-label="Ver tudo: {Categoria}" to ambiguous text links.
 * Runs eagerly and also watches for portal-teleported nav elements
 * (Rokanthemes vertical mega menu moves content to .awa-vmf-portal).
 */
declare(strict_types=1);

$request = $block->getRequest();
$layoutHandles = $block->getLayout() ? $block->getLayout()->getUpdate()->getHandles() : [];
$isCmsHomeRoute = in_array('cms_index_index', $layoutHandles, true);
?>
<?php if ($isCmsHomeRoute): ?>
<script>
(function (w, d) {
    'use strict';

    var observer = null;
    var booted = false;

    function slugToLabel(href) {
        var slug = (href || '').replace(/^.*\//, '').replace(/\.html$/i, '');
        return slug ? slug.replace(/-/g, ' ').replace(/\b\w/g, function (c) { return c.toUpperCase(); }) : null;
    }

    function fixNavImageLinks(root) {
        var scope = root && root.querySelectorAll ? root : d;
        var links = scope.querySelectorAll('a.navigation__inner-link');
        links.forEach(function (link) {
            var txt = (link.textContent || '').trim();
            if (txt) { return; }
            if (link.getAttribute('aria-label') || link.getAttribute('aria-labelledby')) { return; }
            var img = link.querySelector('img');
            if (!img) { return; }

            var catName = null;
            var panel = link.closest('[class*="navigation__inner"], .awa-vmf-portal, .level0.submenu');
            if (panel) {
                var titleEl = panel.querySelector('[class*="subcategory-title"] span, [class*="subcategory-title"] a, [class*="nav-title"]');
                if (titleEl) { catName = (titleEl.textContent || '').trim() || null; }
            }
            if (!catName) { catName = slugToLabel(link.getAttribute('href')); }

            if (catName) {
                link.setAttribute('aria-label', catName);
                if (!img.getAttribute('alt')) { img.setAttribute('alt', catName); }
            }
        });
    }

    function fixNavLinks(root) {
        var scope = root && root.querySelectorAll ? root : d;
        var links = scope.querySelectorAll('a.navigation__inner-link');

        links.forEach(function (link) {
            var txt = (link.textContent || '').trim().toLowerCase();
            if (txt !== 'ver tudo' && txt !== 'ver todos') {
                return;
            }
            if (link.getAttribute('aria-label') || link.getAttribute('aria-labelledby')) {
                return;
            }

            var catName = null;
            var panel = link.closest(
                '.navigation__inner-item--all,' +
                '.navigation__inner-list--level1,' +
                '.awa-vmf-portal,' +
                '.level0.submenu,' +
                '[class*="navigation__inner"]'
            );

            if (panel) {
                var imgEl = panel.querySelector('a.navigation__inner-link img[alt]');
                if (imgEl && imgEl.alt) {
                    catName = imgEl.alt.trim();
                }
            }

            if (!catName && panel) {
                var titleEl = panel.querySelector('[class*="subcategory-title"] span,[class*="subcategory-title"] a');
                if (titleEl && titleEl.textContent) {
                    catName = titleEl.textContent.trim();
                }
            }

            if (!catName) {
                catName = slugToLabel(link.getAttribute('href'));
            }

            if (catName) {
                link.setAttribute('aria-label', 'Ver tudo: ' + catName);
            }
        });
    }

    function watchPortals() {
        if (!w.MutationObserver || observer) {
            return;
        }

        observer = new MutationObserver(function (mutations) {
            mutations.forEach(function (mutation) {
                mutation.addedNodes.forEach(function (node) {
                    if (!node || node.nodeType !== 1) {
                        return;
                    }
                    if (
                        (node.classList && (node.classList.contains('awa-vmf-portal') || node.className.includes('navigation__inner'))) ||
                        (node.querySelector && node.querySelector('a.navigation__inner-link'))
                    ) {
                        fixNavLinks(node);
                    }
                });
            });
        });

        observer.observe(d.body || d.documentElement, { childList: true, subtree: true });
        w.setTimeout(function () {
            if (observer) {
                observer.disconnect();
                observer = null;
            }
        }, 10000);
    }

    function bootNavA11y() {
        if (booted) {
            return;
        }
        booted = true;
        fixNavImageLinks(d);
        fixNavLinks(d);
        w.setTimeout(function () { fixNavImageLinks(d); fixNavLinks(d); }, 400);
        watchPortals();
    }

    function scheduleBoot() {
        if ('requestIdleCallback' in w) {
            w.requestIdleCallback(bootNavA11y, { timeout: 5500 });
        } else {
            w.addEventListener('load', function () {
                w.setTimeout(bootNavA11y, 3000);
            }, { once: true });
        }
    }

    d.addEventListener('pointerdown', function (ev) {
        var target = ev && ev.target;
        if (target && target.closest && target.closest('.block-vertical-nav, .block-vmenu, .navigation, .nav-sections')) {
            bootNavA11y();
        }
    }, { capture: true, passive: true, once: true });

    if (d.readyState === 'loading') {
        d.addEventListener('DOMContentLoaded', scheduleBoot, { once: true });
    } else {
        scheduleBoot();
    }
}(window, document));
</script>
<?php else: ?>
<script>
(function () {
    'use strict';

    function slugToLabel(href) {
        var slug = (href || '').replace(/^.*\//, '').replace(/\.html$/i, '');
        return slug ? slug.replace(/-/g, ' ').replace(/\b\w/g, function (c) { return c.toUpperCase(); }) : null;
    }

    function fixNavImageLinks(root) {
        var scope = root && root.querySelectorAll ? root : document;
        scope.querySelectorAll('a.navigation__inner-link').forEach(function (link) {
            var txt = (link.textContent || '').trim();
            if (txt || link.getAttribute('aria-label') || link.getAttribute('aria-labelledby')) { return; }
            var img = link.querySelector('img');
            if (!img) { return; }
            var catName = null;
            var panel = link.closest('[class*="navigation__inner"], .awa-vmf-portal, .level0.submenu');
            if (panel) {
                var titleEl = panel.querySelector('[class*="subcategory-title"] span, [class*="subcategory-title"] a, [class*="nav-title"]');
                if (titleEl) { catName = (titleEl.textContent || '').trim() || null; }
            }
            if (!catName) { catName = slugToLabel(link.getAttribute('href')); }
            if (catName) {
                link.setAttribute('aria-label', catName);
                if (!img.getAttribute('alt')) { img.setAttribute('alt', catName); }
            }
        });
    }

    function fixNavLinks(root) {
        var scope = root && root.querySelectorAll ? root : document;
        var links = scope.querySelectorAll('a.navigation__inner-link');

        links.forEach(function (link) {
            var txt = (link.textContent || '').trim().toLowerCase();
            if (txt !== 'ver tudo' && txt !== 'ver todos') return;
            if (link.getAttribute('aria-label') || link.getAttribute('aria-labelledby')) return;

            var catName = null;
            var panel = link.closest(
                '.navigation__inner-item--all,' +
                '.navigation__inner-list--level1,' +
                '.awa-vmf-portal,' +
                '.level0.submenu,' +
                '[class*="navigation__inner"]'
            );

            if (panel) {
                var imgEl = panel.querySelector('a.navigation__inner-link img[alt]');
                if (imgEl && imgEl.alt) catName = imgEl.alt.trim();
            }

            if (!catName && panel) {
                var titleEl = panel.querySelector('[class*="subcategory-title"] span,[class*="subcategory-title"] a');
                if (titleEl && titleEl.textContent) catName = titleEl.textContent.trim();
            }

            if (!catName) { catName = slugToLabel(link.getAttribute('href')); }

            if (catName) link.setAttribute('aria-label', 'Ver tudo: ' + catName);
        });
    }

    function runAll() {
        fixNavImageLinks(document);
        fixNavLinks(document);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', runAll);
    } else {
        runAll();
    }

    // Also run after likely mega-menu portal creation
    setTimeout(runAll, 200);
    setTimeout(runAll, 800);

    // Watch for dynamically appended portal nodes
    if (window.MutationObserver) {
        var obs = new MutationObserver(function (mutations) {
            mutations.forEach(function (m) {
                m.addedNodes.forEach(function (node) {
                    if (node.nodeType !== 1) return;
                    if (
                        (node.classList && (node.classList.contains('awa-vmf-portal') || node.className.includes('navigation__inner'))) ||
                        node.querySelector('a.navigation__inner-link')
                    ) {
                        fixNavLinks(node);
                    }
                });
            });
        });

        obs.observe(document.body || document.documentElement, { childList: true, subtree: true });

        // Disconnect after navigation JS is done (10s safety window)
        setTimeout(function () { obs.disconnect(); }, 10000);
    }
}());
</script>
<?php endif; ?>
