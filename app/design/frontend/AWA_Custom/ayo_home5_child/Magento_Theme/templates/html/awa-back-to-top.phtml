/**
 * AWA B2B — Back to Top Button
 * Botão suave de retorno ao topo com SVG chevron.
 */
?>
<button type="button"
        class="awa-back-to-top"
        id="awa-back-to-top"
        aria-label="Voltar ao topo"
        title="Voltar ao topo">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
    </svg>
</button>
<script>
(function(){
    var btn = document.getElementById('awa-back-to-top');
    if (!btn) return;
    var shown = false;
    function toggle() {
        var y = window.pageYOffset || document.documentElement.scrollTop;
        if (y > 600 && !shown) { btn.classList.add('is-visible'); shown = true; }
        else if (y <= 600 && shown) { btn.classList.remove('is-visible'); shown = false; }
    }
    window.addEventListener('scroll', toggle, {passive:true});
    btn.addEventListener('click', function(){ window.scrollTo({top:0, behavior:'smooth'}); });
    toggle();
})();
</script>
