    function scheduleDeferredCss() {
        if (w.matchMedia && w.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            loadDeferredCss();
            return;
        }

        if ('requestIdleCallback' in w) {
            w.requestIdleCallback(loadDeferredCss, { timeout: 2500 });
        } else {
            w.setTimeout(loadDeferredCss, 900);
