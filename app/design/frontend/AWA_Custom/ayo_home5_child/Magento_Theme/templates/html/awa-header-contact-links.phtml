                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    <?= $block->escapeHtml(__('Sair')) ?>
                </a>
            </div>
        </span>
    </span>
</div>
<script>
require(['Magento_Customer/js/customer-data'], function (customerData) {
    var customer = customerData.get('customer');
    function toggle(data) {
        var el = document.querySelector('.awa-header-account-prompt');
        if (!el) return;
        var isLoggedIn = !!(data && data.firstname);
        el.setAttribute('data-awa-auth-state', isLoggedIn ? 'customer' : 'guest');
        var guest = el.querySelector('.awa-header-account-prompt__guest');
        var cust  = el.querySelector('.awa-header-account-prompt__customer');
        if (isLoggedIn) {
            if (guest) guest.style.setProperty('display', 'none', 'important');
            if (cust)  cust.style.removeProperty('display');
        } else {
            if (guest) guest.style.removeProperty('display');
            if (cust)  cust.style.setProperty('display', 'none', 'important');
        }
        if (isLoggedIn && data.firstname) {
            var line1 = el.querySelector('.awa-header-account-prompt__customer .awa-header-account-prompt__line1');
            if (line1) { line1.textContent = 'Olá, ' + data.firstname + '!'; }
        }
        // Setup dropdown toggle (once, when customer block is visible)
        if (isLoggedIn) {
            var trigger = el.querySelector('.awa-account-dropdown__trigger');
            if (trigger && !trigger.dataset.dropdownInit) {
                trigger.dataset.dropdownInit = '1';
                trigger.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var isOpen = this.getAttribute('aria-expanded') === 'true';
                    this.setAttribute('aria-expanded', String(!isOpen));
                });
                document.addEventListener('click', function() {
                    trigger.setAttribute('aria-expanded', 'false');
                });
                el.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape') trigger.setAttribute('aria-expanded', 'false');
                });
            }
        }
    }
    customer.subscribe(toggle);
    toggle(customer());

    // Fix: Magento's section invalidation after loginPost can miss the
    // 'customer' section if it was never in section_data_ids before login.
    // After customer-data init completes, if the section is still empty but
    // private_content_version (set by PHP on login/cart changes) is present,
    // explicitly reload the customer section so the header updates correctly.
    customerData.getInitCustomerData().done(function () {
        var data = customer();
        if (data && data.firstname) {
            return; // already loaded
        }
        // private_content_version is set by the PHP server on authenticated actions.
        // section_data_ids is client-side JS and may not be ready yet on first load.
        // Reloading customer when empty is safe: guests return {} with no UI change.
        if (document.cookie.indexOf('private_content_version') !== -1) {
            setTimeout(function () {
                if (!customer() || !customer().firstname) {
                    customerData.reload(['customer'], false);
                }
            }, 300);
        }
    });
});
</script>
