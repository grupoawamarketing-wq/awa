<?php
declare(strict_types=1);

/**
 * Header account prompt — ícone de usuário + login/cadastro (guest) ou "Minha conta" (logado).
 * Login state is resolved client-side via customer-data sections (FPC-compatible).
 *
 * @var \Magento\Framework\View\Element\Template $block
 */

/** @var \GrupoAwamotos\B2B\Helper\Config $b2bConfig */
$b2bConfig = $this->helper(\GrupoAwamotos\B2B\Helper\Config::class);
$isB2bEnabled = $b2bConfig->isEnabled();
$isStrictB2b  = $isB2bEnabled && $b2bConfig->isStrictB2B();

$loginUrl    = $isStrictB2b
    ? $block->getUrl('b2b/account/login')
    : $block->getUrl('customer/account/login');
$registerUrl = $isB2bEnabled
    ? $block->getUrl('b2b/register')
    : $block->getUrl('customer/account/create');
$accountUrl  = $block->getUrl('customer/account');
$ordersUrl   = $block->getUrl('sales/order/history');
$quotesUrl   = $isB2bEnabled ? $block->getUrl('b2b/quote') : '';
$logoutUrl   = $block->getUrl('customer/account/logout');
?>
<div class="awa-header-contact-links awa-header-account-prompt"
     data-awa-auth-state="guest"
     aria-label="<?= $block->escapeHtmlAttr(__('Área do cliente')) ?>">
    <span class="awa-header-account-prompt__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
        </svg>
    </span>
    <span class="awa-header-account-prompt__text">
        <?php /* Guest state (default, FPC-cached) */ ?>
        <span class="awa-header-account-prompt__guest">
            <span class="awa-header-account-prompt__line1"><?= $block->escapeHtml(__('Para ver os preços faça o')) ?></span>
            <span class="awa-header-account-prompt__line2">
                <a class="awa-header-account-prompt__link"
                   href="<?= $block->escapeUrl($loginUrl) ?>"
                   rel="nofollow"
                   data-awa-auth-link="true"">
                    <?= $block->escapeHtml(__('Login')) ?>
                </a>
                <span class="awa-header-account-prompt__separator"><?= $block->escapeHtml(__('ou')) ?></span>
                <a class="awa-header-account-prompt__link awa-header-account-prompt__link--register"
                   href="<?= $block->escapeUrl($registerUrl) ?>"
                   rel="nofollow"">
                    <?= $block->escapeHtml(__('Cadastre-se')) ?>
                </a>
            </span>
        </span>
        <?php /* Logged-in state (hidden by default, shown via customer-data JS) */ ?>
        <span class="awa-header-account-prompt__customer awa-account-dropdown" style="display:none">
            <span class="awa-header-account-prompt__line1"><?= $block->escapeHtml(__('Seja bem-vindo(a) à AWA Motos!')) ?></span>
            <button class="awa-header-account-prompt__line2 awa-account-dropdown__trigger"
                    type="button"
                    aria-haspopup="menu"
                    aria-expanded="false"
                    aria-label="<?= $block->escapeHtmlAttr(__('Abrir menu da conta')) ?>">
                <span class="awa-header-account-prompt__link"><?= $block->escapeHtml(__('Minha conta')) ?></span>
                <svg class="awa-account-dropdown__chevron" viewBox="0 0 10 6" width="9" height="9"
                     fill="none" stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M1 1l4 4 4-4"/>
                </svg>
            </button>
            <div class="awa-account-dropdown__menu" role="menu"
                 aria-label="<?= $block->escapeHtmlAttr(__('Opções da conta')) ?>">
                <a class="awa-account-dropdown__item"
                   href="<?= $block->escapeUrl($accountUrl) ?>"
                   role="menuitem"">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                        <rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>
                    </svg>
                    <?= $block->escapeHtml(__('Dashboard')) ?>
                </a>
                <a class="awa-account-dropdown__item"
                   href="<?= $block->escapeUrl($ordersUrl) ?>"
                   role="menuitem"">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                        <rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/>
                    </svg>
                    <?= $block->escapeHtml(__('Meus pedidos')) ?>
                </a>
                <?php if ($isB2bEnabled): ?>
                <a class="awa-account-dropdown__item"
                   href="<?= $block->escapeUrl($quotesUrl) ?>"
                   role="menuitem"">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                    <?= $block->escapeHtml(__('Minhas cotações')) ?>
                </a>
                <?php endif; ?>
                <a class="awa-account-dropdown__item awa-account-dropdown__item--logout"
