<?php
declare(strict_types=1);
/**
 * AWA Nav Quick Links — Links rápidos de categorias populares na barra de navegação.
 * Renderiza links de categorias level-2 com include_in_menu=true, posicionados
 * na nav-bar entre "Departamentos" e o locale selector.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */

$escaper = $block->getEscaper() ?? $this;

/** @var \Magento\Catalog\Model\ResourceModel\Category\CollectionFactory $collectionFactory */
$collectionFactory = $this->helper(\Magento\Catalog\Helper\Data::class);

// Categorias de destaque hardcoded (IDs das mais vendidas)
// Fallback para nomes + URLs se a collection não estiver disponível.
$quickLinks = [
    ['name' => 'Nossas Marcas', 'url' => (string) $block->getUrl('nossas-marcas')],
    ['name' => 'Lançamentos',   'url' => (string) $block->getUrl('ofertas.html')],
    ['name' => 'Catálogo',      'url' => (string) $block->getUrl('catalogo')],
];
?>
<div class="awa-nav-quick-links" data-awa-nav-quick="true" role="navigation" aria-label="<?= $escaper->escapeHtmlAttr(__('Links rápidos de categorias')) ?>">
    <ul class="awa-nav-quick-links__list">
        <?php foreach ($quickLinks as $link): ?>
        <li class="awa-nav-quick-links__item">
            <a href="<?= $escaper->escapeUrl($link['url']) ?>"
               class="awa-nav-quick-links__link"
               title="<?= $escaper->escapeHtmlAttr($link['name']) ?>">
                <?= $escaper->escapeHtml($link['name']) ?>
            </a>
        </li>
        <?php endforeach; ?>
    </ul>
</div>
