<script id="awa-home-geometry-inline-lock-v1039">
(function(d,w){
    'use strict';
    var started=Date.now();
    var mq=function(){return w.innerWidth<768;};
    var put=function(el,styles){
        if(!el){return;}
        for(var k in styles){
            if(Object.prototype.hasOwnProperty.call(styles,k) && el.style[k]!==styles[k]){el.style[k]=styles[k];}
        }
    };
    var apply=function(){
        put(d.querySelector('.header-main'),{boxSizing:'border-box',width:'calc(100% - 32px)',maxWidth:'calc(100% - 32px)',marginLeft:'16px',marginRight:'16px',overflow:'hidden'});
        var promo=d.querySelector('.awa-b2b-promo-bar__inner');
        if(promo){
            put(promo,mq()?{boxSizing:'border-box',width:'306px',maxWidth:'306px',marginLeft:'56px',marginRight:'0'}:{boxSizing:'border-box',width:'calc(100% - 176px)',maxWidth:'calc(100% - 176px)',marginLeft:'104px',marginRight:'72px'});
        }
        var form=d.getElementById('search_mini_form');
        var control=d.querySelector('#search_mini_form .control');
        put(form,mq()?{display:'block',visibility:'visible',opacity:'1',width:'326px',maxWidth:'326px'}:{display:'block',visibility:'visible',opacity:'1'});
        put(control,mq()?{display:'block',visibility:'visible',opacity:'1',width:'304px',maxWidth:'304px'}:{display:'block',visibility:'visible',opacity:'1'});
        if(!mq()){
            ['#awa-main-content.content-top-home.top-home-content--above-fold','#awa-main-content.content-top-home.top-home-content--above-fold+.ayo-home5-wrapper','#awa-main-content.content-top-home.top-home-content--above-fold .wrapper_slider.hidden-xs','#awa-main-content.content-top-home.top-home-content--above-fold .banner-slider'].forEach(function(sel){
                put(d.querySelector(sel),{boxSizing:'border-box',width:'100%',maxWidth:'100%',marginLeft:'0',marginRight:'0',paddingLeft:'0',paddingRight:'0',left:'auto',right:'auto'});
            });
        }
    };
    apply();
    var schedule=function(){apply();};
    var observer=new MutationObserver(schedule);
    observer.observe(d.documentElement,{childList:true,subtree:true,attributes:true,attributeFilter:['class','style']});
    w.addEventListener('resize',schedule,{passive:true});
    w.setTimeout(function(){apply();observer.disconnect();w.removeEventListener('resize',schedule);},12000);
})(document,window);
</script>
