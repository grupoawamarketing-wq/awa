<?php
declare(strict_types=1);

/**
 * AWA — Carregamento diferido de CSS de interação (não-bloqueante de render).
 *
 * CSS Consolidation (2026-04 — Issue #5):
 * 5 arquivos individuais mergeados em 1 bundle (awa-bundle-vendor-interaction.css):
 *  - mage/calendar.css     → datepicker (formulários com data)
 *  - jquery/uppy/…css      → file uploader (upload de imagens)
 *  - chosen.css            → dropdowns Chosen.js (filtros)
 *  - jquery.fancybox.css   → lightbox (galerias de imagem)
 *  - rokan_quickview.css   → modal QuickView (visualização rápida)
 *
 * Economia: 5 requests → 1 request (-4 requests).
 *
 * Estratégia: media="print" + onload="this.media='all'"
 * O browser faz o download sem bloquear render e aplica
 * o CSS assim que disponível — geralmente antes da primeira interação.
 *
 * <noscript> garante carregamento bloqueante como fallback sem JS.
 */

$deferredFiles = [
    $block->getViewFileUrl('css/awa-bundle-vendor-interaction.css'),
];
?>
<?php foreach ($deferredFiles as $cssUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($cssUrl) ?>"
      media="print"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($cssUrl) ?>"/></noscript>
<?php endforeach; ?>
