<?php
declare(strict_types=1);

/**
 * AWA — Carregamento diferido de CSS de interação (não-bloqueante de render).
 *
 * Estes 5 arquivos são necessários apenas após interação do usuário:
 *  - mage/calendar.css     → datepicker (formulários com data)
 *  - jquery/uppy/…css      → file uploader (upload de imagens)
 *  - chosen.css            → dropdowns Chosen.js (filtros)
 *  - jquery.fancybox.css   → lightbox (galerias de imagem)
 *  - rokan_quickview.css   → modal QuickView (visualização rápida)
 *
 * Estratégia: media="print" + onload="this.media='all'"
 * O browser faz o download sem bloquear render e aplica
 * o CSS assim que disponível — geralmente antes da primeira interação.
 *
 * <noscript> garante carregamento bloqueante como fallback sem JS.
 *
 * Removidos do head via <remove> em default_head_blocks.xml (2026-03-16).
 */

$calendarUrl     = $block->getViewFileUrl('mage/calendar.css');
$uppyUrl         = $block->getViewFileUrl('jquery/uppy/dist/uppy-custom.css');
$chosenUrl       = $block->getViewFileUrl('Rokanthemes_RokanBase::css/chosen.css');
$fancyboxUrl     = $block->getViewFileUrl('Rokanthemes_RokanBase::css/jquery.fancybox.css');
$quickviewUrl    = $block->getViewFileUrl('Rokanthemes_QuickView::css/rokan_quickview.css');
$suggestionUrl   = $block->getViewFileUrl('GrupoAwamotos_B2B::css/marketing/suggestion.css');

$deferredFiles = [
    $calendarUrl,
    $uppyUrl,
    $chosenUrl,
    $fancyboxUrl,
    $quickviewUrl,
    $suggestionUrl,
];
?>
<?php foreach ($deferredFiles as $cssUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($cssUrl) ?>"
      media="print"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($cssUrl) ?>"/></noscript>
<?php endforeach; ?>
