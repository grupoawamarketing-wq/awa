<?php
/**
 * AWA Product Shelf Carousel — loader global
 */
declare(strict_types=1);

/** @var \Magento\Framework\View\Element\Template $block */
$cssUrl = $block->getViewFileUrl('css/awa-shelf-carousel.min.css');
$jsUrl = $block->getViewFileUrl('js/awa-shelf-carousel.min.js');
$request = $block->getRequest();
$isHomePage = $request && $request->getFullActionName() === 'cms_index_index';
?>
<link rel="stylesheet" href="<?= $block->escapeUrl($cssUrl) ?>" media="print" onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($cssUrl) ?>"/></noscript>
<?php if ($isHomePage): ?>
<script>
(function (w, d) {
    'use strict';
    var jsSrc = <?= /* @noEscape */ json_encode($jsUrl, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP) ?>;
    var done = false;
    var events = ['pointerdown', 'keydown', 'touchstart'];

    function appendJs() {
        if (d.querySelector('script[data-awa-shelf-carousel-js="1"]')) {
            return;
        }
        var script = d.createElement('script');
        script.src = jsSrc;
        script.defer = true;
        script.setAttribute('data-awa-shelf-carousel-js', '1');
        (d.body || d.documentElement).appendChild(script);
    }

    function cleanup() {
        events.forEach(function (eventName) {
            w.removeEventListener(eventName, onInteract, true);
        });
    }

    function boot() {
        if (done) {
            return;
        }
        done = true;
        cleanup();
        appendJs();
    }

    function onInteract() {
        boot();
    }

    events.forEach(function (eventName) {
        w.addEventListener(eventName, onInteract, { passive: true, capture: true });
    });
})(window, document);
</script>
<?php else: ?>
<script src="<?= /* @noEscape */ $jsUrl ?>" defer></script>
<?php endif; ?>
