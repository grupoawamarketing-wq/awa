<script>
/* awa-keyboard-shortcuts: carregado via requestIdleCallback — não é crítico para first paint */
(function () {
    function loadKbShortcuts() {
        if (typeof require !== 'undefined') {
            require(['js/awa-keyboard-shortcuts'], function () {});
        }
    }
    if ('requestIdleCallback' in window) {
        window.requestIdleCallback(loadKbShortcuts, { timeout: 4000 });
    } else {
        window.setTimeout(loadKbShortcuts, 3000);
    }
}());
</script>
<script>
/* Service Worker registration — idle callback para zero impacto em TTI (2026-03-23) */
if ('serviceWorker' in navigator) {
    var _swReg = function() {
        navigator.serviceWorker.register('/sw.js', { scope: '/' })
            .then(function(reg) {
                if (reg.active) {
                    reg.active.postMessage({ type: 'SKIP_WAITING' });
                }
            })
            .catch(function() {});
    };
    if ('requestIdleCallback' in window) {
        requestIdleCallback(_swReg, { timeout: 5000 });
    } else {
        window.addEventListener('load', _swReg);
    }
}
</script>
