/**
 * AWA Motos - Custom Visual JS Loader
 * Centralized loader for child-theme behavioral scripts.
 */
$normalizeFlag = static function ($value, bool $default): bool {
    if ($value === null) {
        return $default;
    }

    if (is_bool($value)) {
        return $value;
    }

    if (is_int($value)) {
        return $value === 1;
    }

    if (is_string($value)) {
        $normalized = filter_var($value, FILTER_VALIDATE_BOOLEAN, FILTER_NULL_ON_FAILURE);
        if ($normalized !== null) {
            return $normalized;
        }
    }

    return (bool) $value;
};

