<script>
/* expresscheckout/cart overlay guard — remove overlays stuck by legacy modal/minicart scripts */
(function (w, d) {
    'use strict';

    var overlayGuardRunning = false;
    var overlayGuardInitialized = false;

    function isCartCheckoutPage() {
        return !!(d.body && d.body.classList.contains('checkout-cart-index'));
    }

    function overlayNeedsCleanup(el) {
        if (!el) {
            return false;
        }

        var style = w.getComputedStyle(el);

        return el.classList.contains('_show')
            || el.classList.contains('is-visible')
            || el.classList.contains('is-active')
            || style.display !== 'none'
            || style.visibility !== 'hidden'
            || style.opacity !== '0'
            || style.pointerEvents !== 'none';
    }

    function hideOverlay(el) {
        if (!overlayNeedsCleanup(el)) {
            return;
        }

        el.classList.remove('_show', 'is-visible', 'is-active');
        el.style.setProperty('display', 'none', 'important');
        el.style.setProperty('opacity', '0', 'important');
        el.style.setProperty('visibility', 'hidden', 'important');
        el.style.setProperty('pointer-events', 'none', 'important');
    }

    function clearStuckOverlays() {
        var overlays;
        var i;
        var hasVisibleModal;

        if (!isCartCheckoutPage() || overlayGuardRunning) {
            return;
        }

        overlayGuardRunning = true;

        try {
            overlays = d.querySelectorAll(
                '.modals-overlay, .modal-custom-overlay, .awa-mobile-drawer-overlay, .awa-nav-overlay'
            );

            for (i = 0; i < overlays.length; i += 1) {
                hideOverlay(overlays[i]);
            }

            d.querySelectorAll('.modal-popup._show, .modal-slide._show').forEach(function (modal) {
                if (!overlayNeedsCleanup(modal)) {
                    return;
                }

                modal.classList.remove('_show');
                modal.style.setProperty('display', 'none', 'important');
            });

            hasVisibleModal = !!d.querySelector('.modal-popup._show, .modal-slide._show');

            if (!hasVisibleModal && (
                d.body.classList.contains('_has-modal')
                || d.body.classList.contains('awa-mobile-drawer-open')
                || d.body.classList.contains('nav-open')
                || d.body.classList.contains('nav-before-open')
                || d.body.style.overflow
            )) {
                d.body.classList.remove('_has-modal', 'awa-mobile-drawer-open', 'nav-open', 'nav-before-open');
                d.body.style.removeProperty('overflow');
                d.documentElement.classList.remove('nav-open', 'nav-before-open');
            }

            d.querySelectorAll('.minicart-wrapper').forEach(function (wrapper) {
                wrapper.classList.remove('active', 'is-open', 'show');
            });

            d.querySelectorAll('.block-minicart').forEach(function (panel) {
                if (!overlayNeedsCleanup(panel) && !panel.classList.contains('_active')) {
                    return;
                }
                panel.classList.remove('_active');
                panel.setAttribute('aria-hidden', 'true');
                hideOverlay(panel);
            });

            d.querySelectorAll('.action.showcart[aria-expanded="true"]').forEach(function (trigger) {
                trigger.setAttribute('aria-expanded', 'false');
            });
        } finally {
            overlayGuardRunning = false;
        }
    }

    function initOverlayGuard() {
        if (!isCartCheckoutPage() || overlayGuardInitialized) {
            return;
        }

        overlayGuardInitialized = true;
        clearStuckOverlays();
        w.setTimeout(clearStuckOverlays, 120);
        w.setTimeout(clearStuckOverlays, 600);

        d.addEventListener('click', function () {
            w.setTimeout(clearStuckOverlays, 40);
        }, true);
    }

    function maybeInitOverlayGuard() {
        if (!isCartCheckoutPage()) {
            return;
        }

        initOverlayGuard();
    }

    if (d.readyState === 'loading') {
        d.addEventListener('DOMContentLoaded', maybeInitOverlayGuard, { once: true });
    } else {
        maybeInitOverlayGuard();
    }
}(window, document));
</script>
<?php endif; ?>
