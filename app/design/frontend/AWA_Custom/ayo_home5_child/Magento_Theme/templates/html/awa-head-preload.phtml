</style>
<?php if ($heroPreloadUrl): ?>
<!-- LCP Hero Image Preload — fetchpriority=high, com media queries (Swiper SlideBanner, homepage) -->
<!-- Desktop (.hidden-xs): só carregado em viewport >= 768px, evita consumo indevido no mobile -->
<!-- imagesrcset necessário para que Chrome associe o preload ao <source srcset> do <picture> gerado pelo slider_home5.phtml -->
<link rel="preload" href="<?= $block->escapeUrl($heroPreloadUrl) ?>" imagesrcset="<?= $block->escapeUrl($heroPreloadUrl) ?>" as="image" fetchpriority="high" media="(min-width: 768px)" type="image/webp"/>
<!-- Mobile (.visible-xs): só carregado em viewport <= 767px -->
<?php $heroMobileUrl = $block->getHeroImageMobileUrl() ?: $heroPreloadUrl; ?>
<link rel="preload" href="<?= $block->escapeUrl($heroMobileUrl) ?>" imagesrcset="<?= $block->escapeUrl($heroMobileUrl) ?>" as="image" fetchpriority="high" media="(max-width: 767px)" type="image/webp"/>
<?php endif; ?>
<!-- AWA Head Preload — Preconnect (precedência sobre dns-prefetch) -->
<?php foreach ($preconnect as $origin): ?>
<link rel="preconnect" href="<?= $block->escapeUrl($origin) ?>" crossorigin="anonymous"/>
<link rel="dns-prefetch" href="<?= $block->escapeUrl($origin) ?>"/>
<?php endforeach; ?>
<!-- AWA Head Preload — DNS Prefetch (demais domínios) -->
<?php foreach ($dnsPrefetch as $domain): ?>
<link rel="dns-prefetch" href="<?= $block->escapeUrl($domain) ?>"/>
<?php endforeach; ?>
<!-- AWA Head Preload — CSS Critical -->
<?php foreach ($cssPreloads as $item): ?>
<link rel="preload" href="<?= $block->escapeUrl($item['url']) ?>" as="style"<?= $item['priority'] ? ' fetchpriority="' . $block->escapeHtmlAttr($item['priority']) . '"' : '' ?>/>
<?php endforeach; ?>
<!-- AWA Head Preload — Fonts -->
<?php foreach ($fontPreloads as $item): ?>
<link rel="preload" href="<?= $block->escapeUrl($item['url']) ?>" as="font" type="font/woff2" crossorigin="anonymous"<?= $item['priority'] ? ' fetchpriority="' . $block->escapeHtmlAttr($item['priority']) . '"' : '' ?>/>
<?php endforeach; ?>
<!-- AWA Head Preload — JS (early fetch for RequireJS discovered modules) -->
<?php foreach ($jsPreloads as $jsUrl): ?>
<link rel="preload" href="<?= $block->escapeUrl($jsUrl) ?>" as="script"/>
<?php endforeach; ?>
<!-- AWA Async CSS Bundles -->
<!-- Bundles estruturais críticos não podem depender de interação do usuário.
     Home/PLP/PDP precisam receber layout completo no first paint para evitar
     colapso de grids, carrosséis e conteúdo invisível. -->
<?php foreach ($asyncBundles as $cssUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($cssUrl) ?>"
      media="all"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($cssUrl) ?>"/></noscript>
<?php endforeach; ?>
<?php if ($homeBundleUrl): ?>
<!-- awa-super-home.css: home-custom + mobile-fix + product-cards + category-carousel + cosmetic-home -->
<link rel="stylesheet"
      href="<?= $block->escapeUrl($homeBundleUrl) ?>"
      media="all"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($homeBundleUrl) ?>"/></noscript>
<?php endif; ?>
<?php /* awa-vertical-menu-modern.css — refinamento visual do menu vertical (2026-04-26) */ ?>
<?php $__vmModernUrl = $block->getViewFileUrl('css/awa-vertical-menu-modern.css'); ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($__vmModernUrl) ?>"
      media="all"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($__vmModernUrl) ?>"/></noscript>
<?php /* awa-bundle-refinements.css — safety-net overrides, LAST non-async bundle (2026-04-27) */ ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($refinementsBundleUrl) ?>"
      media="all"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($refinementsBundleUrl) ?>"/></noscript>
