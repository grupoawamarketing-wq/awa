(function (w, d) {
    function bootPhase1() {
        w.require(['js/awa-modernization-phase1']);
    }
    function schedulePhase1() {
        if (typeof w.awaRunWhenRequire === 'function') {
            w.awaRunWhenRequire(bootPhase1, { key: 'modernization-phase1' });
            return;
        }
        if (typeof w.awaWhenRequire === 'function') {
            w.awaWhenRequire(bootPhase1, { key: 'modernization-phase1' });
            return;
        }
        if (typeof w.require === 'function') {
            bootPhase1();
        }
    }
    if ('requestIdleCallback' in w) {
        w.requestIdleCallback(schedulePhase1, { timeout: 3500 });
    } else {
        w.addEventListener('load', function () {
            w.setTimeout(schedulePhase1, 0);
        }, { once: true });
    }
})(window, document);
