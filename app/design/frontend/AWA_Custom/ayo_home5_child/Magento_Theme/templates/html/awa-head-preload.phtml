/**
 * CSS estrutural: sempre media=print + stagger (layout correto no 1º paint).
 * Interaction gate desativado em PLP/checkout — causava layout quebrado até scroll/clique.
 */
$__emitDeferredCss = static function (
    string $url,
    bool $preload = false,
    bool $lowPriority = false,
    bool $interactionGate = false
) use (
    $block,
    $isHomePage,
    &$__gatedCssUrls,
    $__cssStagger
): void {
    $path = parse_url($url, PHP_URL_PATH) ?? '';
    if ($path !== '' && preg_match('#/css/([^/?]+)$#', $path, $cssMatch)) {
        $cssFile = $cssMatch[1];
        $themeCssDir = BP . '/app/design/frontend/AWA_Custom/ayo_home5_child/web/css/';
        $candidates = [$cssFile, (string) preg_replace('/\.min\.css$/', '.css', $cssFile)];
        $exists = false;
        foreach ($candidates as $candidate) {
            if ($candidate !== '' && is_readable($themeCssDir . $candidate)) {
                $exists = true;
                break;
            }
        }
        if (!$exists) {
            foreach (['pt_BR', 'en_US'] as $locale) {
                $pubPath = BP . '/pub/static/frontend/AWA_Custom/ayo_home5_child/'
                    . $locale . '/css/' . $cssFile;
                if (is_readable($pubPath)) {
                    $exists = true;
                    break;
                }
            }
        }
        if (!$exists && preg_match('#/GrupoAwamotos_([^/]+)/css/(.+)$#', $path, $modMatch)) {
            $moduleSegment = 'GrupoAwamotos_' . $modMatch[1];
            $moduleCss = $modMatch[2];
            foreach (['pt_BR', 'en_US'] as $locale) {
                $pubPath = BP . '/pub/static/frontend/AWA_Custom/ayo_home5_child/'
                    . $locale . '/' . $moduleSegment . '/css/' . $moduleCss;
                if (is_readable($pubPath)) {
                    $exists = true;
                    break;
                }
            }
            if (!$exists) {
                $moduleView = BP . '/app/code/GrupoAwamotos/' . $modMatch[1]
                    . '/view/frontend/web/css/' . $moduleCss;
                if (is_readable($moduleView)) {
                    $exists = true;
                }
            }
        }
        if (!$exists) {
            return;
        }
    }

    // Interaction gate reservado só para cosmetic home (Lighthouse); nunca bloquear CSS estrutural.
    if ($isHomePage && $interactionGate) {
        $__gatedCssUrls[$url] = $url;
        return;
    }
    $escaped = $block->escapeUrl($url);
    if ($preload) {
        echo '<link rel="preload" href="' . $escaped . '" as="style"'
            . ($lowPriority ? ' fetchpriority="low"' : '') . '/>' . "\n";
    }
    $fpAttr = $lowPriority ? ' fetchpriority="low"' : '';
    echo '<link rel="stylesheet" href="' . $escaped . '" media="print"' . $fpAttr
        . ' onload="' . $__cssStagger . '"/>' . "\n";
    echo '<noscript><link rel="stylesheet" href="' . $escaped . '"/></noscript>' . "\n";
};
?>
