        if (!$exists) {
            foreach (['pt_BR', 'en_US'] as $locale) {
                $pubPath = BP . '/pub/static/frontend/AWA_Custom/ayo_home5_child/'
                    . $locale . '/css/' . $cssFile;
                if (is_readable($pubPath)) {
                    $exists = true;
                    break;
                }
            }
        }
        if (!$exists && preg_match('#/GrupoAwamotos_([^/]+)/css/(.+)$#', $path, $modMatch)) {
            $moduleSegment = 'GrupoAwamotos_' . $modMatch[1];
            $moduleCss = $modMatch[2];
            foreach (['pt_BR', 'en_US'] as $locale) {
                $pubPath = BP . '/pub/static/frontend/AWA_Custom/ayo_home5_child/'
                    . $locale . '/' . $moduleSegment . '/css/' . $moduleCss;
                if (is_readable($pubPath)) {
                    $exists = true;
                    break;
