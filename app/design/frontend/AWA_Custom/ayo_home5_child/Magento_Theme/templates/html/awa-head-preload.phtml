        $cssFile = $cssMatch[1];
        $themeCssDir = BP . '/app/design/frontend/AWA_Custom/ayo_home5_child/web/css/';
        $candidates = [$cssFile, (string) preg_replace('/\.min\.css$/', '.css', $cssFile)];
        $exists = false;
        foreach ($candidates as $candidate) {
            if ($candidate !== '' && is_readable($themeCssDir . $candidate)) {
                $exists = true;
                break;
            }
