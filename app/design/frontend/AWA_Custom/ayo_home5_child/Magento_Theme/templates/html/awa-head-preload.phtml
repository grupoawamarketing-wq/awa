<?php
declare(strict_types=1);

/**
 * AWA — DNS Prefetch + CSS/Font Preload + Async CSS Bundles
 *
 * Estes elementos NÃO podem ficar no layout XML porque o schema do Magento
 * (page_configuration.xsd) não suporta:
 *  - <link href="..."> (só aceita src)
 *  - <css onload="..."> (atributo não permitido)
 *  - <noscript> (elemento não esperado em <head>)
 *
 * Adicionado em head.additional via default_head_blocks.xml.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */

// === Preconnect (economiza handshake DNS + TCP + TLS — ~200-400ms por domínio) ===
$preconnect = [
    'https://www.googletagmanager.com',
    'https://www.google-analytics.com',
];
// === DNS Prefetch (outros domínios externos — menor benefício que preconnect) ===
$dnsPrefetch = [
    '//connect.facebook.net',
];

// === CSS Preload ===
// awa-bundle-core, awa-bundle-refinements, awa-visual-fixes-critical:
// já carregados como <link rel="stylesheet"> bloqueante via default_head_blocks.xml
// → preload redundante removido (browser já descobre imediatamente).
$cssPreloads = [];

// === Font Preload ===
// A tipografia base volta a ser controlada pelo Theme Options do Rokanthemes.
$fontPreloads = [];

// === JS Preload (early fetch for modules loaded later by RequireJS) ===
// Swiper preload removed — IntersectionObserver defers loading until carousel enters viewport.
// Preloading a resource not used on initial load wastes bandwidth and triggers PSI warnings.
$jsPreloads = [];

// === Async CSS Bundles (defer via media="print" + onload — não bloqueiam render) ===
// CSS Consolidation (2026-04 — Issue #5):
// - awa-animate-theme → merged into awa-bundle-phases
// - awa-visual-fixes-critical → merged into awa-bundle-site
// - awa-polish-sweep → merged into awa-bundle-refinements
// - awa-bundle-accessibility-af001 → merged into awa-bundle-refinements
// Total: 9 requests → 5 (-4 requests)
$asyncBundles = [
    // swiper-bundle.min.css movido para sync (default_head_blocks.xml) — fix carrossel em branco
    // PageSpeed fix 2026-04-11: themes.css (1.3MB) + vendor-libs (175KB) moved from sync to async
    $block->getViewFileUrl('css/awa-bundle-vendor-libs.css'),  // Bootstrap+FA+Owl+icons (175KB)
    $block->getViewFileUrl('css/awa-bundle-custom.css'),
    $block->getViewFileUrl('css/awa-bundle-phases.css'),       // + animate-theme
    $block->getViewFileUrl('css/awa-bundle-tail.css'),          // + cosmetic (global)
    $block->getViewFileUrl('css/awa-bundle-site.css'),          // + visual-fixes-critical
    // merged into awa-bundle-refinements: $block->getViewFileUrl('css/awa-improvements-grid.css'),    // grid 4-col override
    // Moved from sync (2026-04-09): -666 KB render-blocking -> async
    // merged into awa-bundle-refinements: $block->getViewFileUrl('css/awa-visual-audit-consolidated.css'),  // visual-audit v2-v12
    // merged into awa-bundle-refinements: $block->getViewFileUrl('css/awa-global-modern-clean.css'),        // sitewide standardization
    // merged into awa-bundle-refinements: $block->getViewFileUrl('css/awa-home-vertical-menu-shell-fix.css'), // vertical menu
    // MCP Header + Classic Redesign: movidos para SYNC (default_head_blocks.xml)
    // Removidos do async para evitar carregamento duplo (2026-04-09)
    // merged into awa-bundle-refinements: $block->getViewFileUrl('css/awa-color-standardization.css'),     // color standardization + visual polish (last)
    // merged into awa-bundle-refinements: $block->getViewFileUrl('css/awa-ux-improvements.css'),
    // awa-layout-standardization.css removido daqui e carregado APÓS refinements
    // para garantir que nossas overrides !important vençam o dark footer do refinements bundle
];

// Homepage-only: owl-tabs + overrides + b2b-foundation + compat + premium + polish
$homeBundleUrl = null;
if (in_array('cms_index_index', $block->getLayout()->getUpdate()->getHandles(), true)) {
    $homeBundleUrl = $block->getViewFileUrl('css/awa-bundle-home-custom.css');
}

// Refinements bundle stays async, but is rendered explicitly below because
// it contains foundational UI behavior/styles for compare bar, floating tools,
// and several layout polish layers used across the storefront.
$refinementsBundleUrl = $block->getViewFileUrl('css/awa-bundle-refinements.css');
?>
<!-- =========================================================
     AWA Anti-FOUC — Critical Inline CSS
     Pinta cores e estrutura antes dos bundles async carregarem.
     Mantém abaixo de 600 bytes. NÃO adicionar regras complexas aqui.
     ========================================================= -->
<style>
/* Anti-FOUC v7 — 2026-04-11 */
/* Legacy utility bar = hidden, header = white, footer = white AWA */
body .page-wrapper .nav-sections:not(.category-dropdown,.category-dropdown-items,.category-dropdown-item-content){background:#b73337}
body .page-wrapper .awa-benefits-bar,.awa-benefits-bar{background:#fff !important;color:#333}
body .page-wrapper .awa-utility-bar-legacy{display:none !important}
body .page-wrapper .panel.wrapper{background:#1a1a1a !important;background-image:none !important;color:#ccc;border:none}
body .page-wrapper .header-content .top-header .header,.page-header,.header.content{background:#fff}
body .page-wrapper .page_footer,.page-footer{background:#6b1a1e !important;background-image:linear-gradient(180deg,#6b1a1e 0%,#b73337 100%) !important;color:rgba(255,255,255,.85);border-top:3px solid rgba(255,255,255,.2)}
.page_footer .footer-container,.page_footer #footer,.page_footer .footer-container.layout2{background:transparent !important;background-image:none !important;color:rgba(255,255,255,.85)}
</style>
<!-- AWA Head Preload — Preconnect (precedência sobre dns-prefetch) -->
<?php foreach ($preconnect as $origin): ?>
<link rel="preconnect" href="<?= $block->escapeUrl($origin) ?>" crossorigin="anonymous"/>
<link rel="dns-prefetch" href="<?= $block->escapeUrl($origin) ?>"/>
<?php endforeach; ?>
<!-- AWA Head Preload — DNS Prefetch (demais domínios) -->
<?php foreach ($dnsPrefetch as $domain): ?>
<link rel="dns-prefetch" href="<?= $block->escapeUrl($domain) ?>"/>
<?php endforeach; ?>
<!-- AWA Head Preload — CSS Critical -->
<?php foreach ($cssPreloads as $item): ?>
<link rel="preload" href="<?= $block->escapeUrl($item['url']) ?>" as="style"<?= $item['priority'] ? ' fetchpriority="' . $block->escapeHtmlAttr($item['priority']) . '"' : '' ?>/>
<?php endforeach; ?>
<!-- AWA Head Preload — Fonts -->
<?php foreach ($fontPreloads as $item): ?>
<link rel="preload" href="<?= $block->escapeUrl($item['url']) ?>" as="font" type="font/woff2" crossorigin="anonymous"<?= $item['priority'] ? ' fetchpriority="' . $block->escapeHtmlAttr($item['priority']) . '"' : '' ?>/>
<?php endforeach; ?>
<!-- AWA Head Preload — JS (early fetch for RequireJS discovered modules) -->
<?php foreach ($jsPreloads as $jsUrl): ?>
<link rel="preload" href="<?= $block->escapeUrl($jsUrl) ?>" as="script"/>
<?php endforeach; ?>
<!-- AWA Async CSS Bundles — media="print" swap (non-render-blocking) -->
<!-- themes.css: kept blocking — async caused CLS 0.511 (reverted 2026-04-11) -->
<?php foreach ($asyncBundles as $cssUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($cssUrl) ?>"
      media="print"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($cssUrl) ?>"/></noscript>
<?php endforeach; ?>
<!-- T2.4 (2026-03-28): -299KB do critical path — AOF styles now in awa-critical-fold.css -->
<link rel="stylesheet"
    href="<?= $block->escapeUrl($refinementsBundleUrl) ?>"
    media="print"
    data-awa-refinements="1"
    onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($refinementsBundleUrl) ?>"/></noscript>
<!-- awa-layout-standardization carregado APÓS refinements — garante que footer light e
     demais overrides !important vençam o dark-footer do refinements bundle (last-wins) -->
<link rel="stylesheet"
    href="<?= $block->escapeUrl($block->getViewFileUrl('css/awa-layout-standardization.css')) ?>"
    media="print"
    data-awa-layout-std="1"
    onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($block->getViewFileUrl('css/awa-layout-standardization.css')) ?>"/></noscript>
<?php if ($homeBundleUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($homeBundleUrl) ?>"
      media="print"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($homeBundleUrl) ?>"/></noscript>
<?php endif; ?>

<!-- styles-l.css carregado em awa.styles.l.last (after awa.search.autocomplete.head.css) -->