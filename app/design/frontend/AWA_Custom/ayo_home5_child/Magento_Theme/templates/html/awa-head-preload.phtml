/**
 * AWA — DNS Prefetch + CSS/Font Preload + Async CSS Bundles
 *
 * Estes elementos NÃO podem ficar no layout XML porque o schema do Magento
 * (page_configuration.xsd) não suporta:
 *  - <link href="..."> (só aceita src)
 *  - <css onload="..."> (atributo não permitido)
 *  - <noscript> (elemento não esperado em <head>)
 *
 * Adicionado em head.additional via default_head_blocks.xml.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */

// === Preconnect (economiza handshake DNS + TCP + TLS — ~200-400ms por domínio) ===
$preconnect = [
    'https://www.googletagmanager.com',
    'https://www.google-analytics.com',
];
// === DNS Prefetch (outros domínios externos — menor benefício que preconnect) ===
$dnsPrefetch = [
    '//connect.facebook.net',
];

// === CSS Preload ===
// awa-bundle-core, awa-bundle-refinements, awa-visual-fixes-critical:
// já carregados como <link rel="stylesheet"> bloqueante via default_head_blocks.xml
// → preload redundante removido (browser já descobre imediatamente).
$cssPreloads = [];

// === Font Preload ===
// Plus Jakarta Sans (Fase 6) — body via --awa-font; Google Fonts / awa-super-global.
// Preload Rubik removido (legado). Montserrat: Rokanthemes_Themeoption/head.phtml.
$fontPreloads = [];

// === JS Preload (early fetch for modules loaded later by RequireJS) ===
// Swiper preload removed — IntersectionObserver defers loading until carousel enters viewport.
// Preloading a resource not used on initial load wastes bandwidth and triggers PSI warnings.
$jsPreloads = [];

// === Async CSS Bundles (CSS Consolidation 2026-04-25 — Issue #6) ===
$__superGlobalUrl = $block->getViewFileUrl('css/awa-super-global.min.css');
$__deferGlobalUrl = $block->getViewFileUrl('css/awa-defer-global-bundle.min.css');
$__cssGateJsUrl = $block->getViewFileUrl('js/awa-css-gate.min.js');

$__requestForPage = $block->getRequest();
$__fullActionForPage = $__requestForPage ? (string) $__requestForPage->getFullActionName() : '';
$handles = $block->getLayout()->getUpdate()->getHandles();
// Handles + FA name: garante HOME mesmo se merge de handles divergir (Varnish/FPC/contextos).
$isHomePage = in_array('cms_index_index', $handles, true)
    || $__fullActionForPage === 'cms_index_index';
$isCheckoutFlow = in_array('checkout_index_index', $handles, true)
    || in_array('checkout_cart_index', $handles, true)
    || in_array('onepagecheckout_index_index', $handles, true);
$isProductPage = $__fullActionForPage === 'catalog_product_view';
$isCatalogCssGate = in_array($__fullActionForPage, [
    'catalog_category_view',
    'catalogsearch_result_index',
], true);
$isLightCssGate = in_array($__fullActionForPage, [
    'checkout_cart_index',
    'checkout_index_index',
], true);
$__cssGateFull = static function () use ($isCatalogCssGate): bool {
    return $isCatalogCssGate;
};
$__cssGateAny = static function () use ($isCatalogCssGate, $isLightCssGate): bool {
    return $isCatalogCssGate || $isLightCssGate;
};

// Homepage-only super bundle
$homeBundleUrl = null;
if ($isHomePage) {
    $homeBundleUrl = $block->getViewFileUrl('css/awa-super-home.min.css');
}

// URL base para derivação de CSS de módulos (getViewFileUrl falha em prod para módulos)
// awa-bundle-refinements.min.css — safety-net CSS: carrega POR ÚLTIMO para overrides (footer-light, etc.)
$refinementsBundleUrl = $block->getViewFileUrl('css/awa-bundle-refinements.min.css');
?>
