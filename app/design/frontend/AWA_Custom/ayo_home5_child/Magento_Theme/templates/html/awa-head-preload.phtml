         Requer <remove src="css/styles-l.css"/> em default_head_blocks.xml (já adicionado).
         Reduz merged bundle de 9.5MB → ~5.2MB (retira 4.3MB de CSS desktop do blocking path). */ ?>
<?php $__stylesLUrl = $block->getViewFileUrl('css/styles-l.min.css'); ?>
<?php /* Home mobile: sem <link> styles-l — Chrome/Lighthouse ainda baixavam ~3.8MB com media query desktop.
         Desktop home: injeta stylesheet só se matchMedia(768px). Demais páginas: link + media desktop. */ ?>
<?php if ($isHomePage): ?>
<script>
(function (w, d) {
    'use strict';
    var href = <?= /* @noEscape */ json_encode($__stylesLUrl, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP) ?>;
    function inject() {
        if (!w.matchMedia('(min-width: 768px)').matches) {
            return;
        }
        if (d.querySelector('link[data-awa-styles-l="1"]')) {
            return;
        }
        var link = d.createElement('link');
        link.rel = 'stylesheet';
        link.href = href;
        link.setAttribute('data-awa-styles-l', '1');
        d.head.appendChild(link);
    }
    if (w.matchMedia('(min-width: 768px)').matches) {
        inject();
    } else {
        w.matchMedia('(min-width: 768px)').addEventListener('change', function (e) {
            if (e.matches) {
                inject();
            }
        });
    }
})(window, document);
</script>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($__stylesLUrl) ?>"/></noscript>
