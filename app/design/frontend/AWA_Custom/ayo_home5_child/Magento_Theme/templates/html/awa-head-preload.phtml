/* Design tokens inline — elimina 1 HTTP request bloqueante (awa-design-tokens.css 2026-04-22) */
:root{--awa-primary:#b73337;--awa-primary-hover:#8e2629;--awa-primary-dark:#6d1c1f;--awa-primary-light:#fef2f2;--awa-primary-subtle:rgba(183,51,55,0.08);--awa-text:#1a1a1a;--awa-text-secondary:#555;--awa-text-muted:#888;--awa-text-disabled:#bbb;--awa-text-inverse:#ffffff;--awa-bg:#ffffff;--awa-bg-subtle:#fafafa;--awa-bg-muted:#f5f5f5;--awa-border:#e5e5e5;--awa-border-strong:#d0d0d0;--awa-radius-xs:4px;--awa-radius-sm:6px;--awa-radius-md:8px;--awa-radius-lg:12px;--awa-radius-xl:16px;--awa-radius-pill:9999px;--awa-shadow-xs:0 1px 2px rgba(0,0,0,0.05);--awa-shadow-sm:0 2px 8px rgba(0,0,0,0.08);--awa-shadow-md:0 4px 16px rgba(0,0,0,0.10);--awa-shadow-lg:0 8px 24px rgba(0,0,0,0.12);--awa-shadow-xl:0 16px 40px rgba(0,0,0,0.15);--awa-shadow-brand:0 4px 16px rgba(183,51,55,0.25);--awa-font-2xs:10px;--awa-font-xs:11px;--awa-font-sm:12px;--awa-font-base:14px;--awa-font-md:15px;--awa-font-lg:16px;--awa-font-xl:18px;--awa-font-2xl:20px;--awa-font-3xl:24px;--awa-font-4xl:28px;--awa-weight-normal:400;--awa-weight-medium:500;--awa-weight-semibold:600;--awa-weight-bold:700;--awa-weight-extrabold:800;--awa-space-1:4px;--awa-space-2:8px;--awa-space-3:12px;--awa-space-4:16px;--awa-space-5:20px;--awa-space-6:24px;--awa-space-8:32px;--awa-space-10:40px;--awa-space-12:48px;--awa-ease:cubic-bezier(0.4,0,0.2,1);--awa-ease-out:cubic-bezier(0,0,0.2,1);--awa-duration-fast:0.15s;--awa-duration:0.25s;--awa-duration-slow:0.4s;--awa-z-base:1;--awa-z-overlay:100;--awa-z-drawer:200;--awa-z-modal:300;--awa-z-toast:400}
</style>
<!-- LCP Hero Image Preload — fetchpriority=high (Swiper SlideBanner, homepage) -->
<?php if ($heroPreloadUrl): ?>
<link rel="preload" href="<?= $block->escapeUrl($heroPreloadUrl) ?>" as="image" fetchpriority="high"/>
<?php endif; ?>
<!-- AWA Head Preload — Preconnect (precedência sobre dns-prefetch) -->
<?php foreach ($preconnect as $origin): ?>
<link rel="preconnect" href="<?= $block->escapeUrl($origin) ?>" crossorigin="anonymous"/>
<link rel="dns-prefetch" href="<?= $block->escapeUrl($origin) ?>"/>
<?php endforeach; ?>
<!-- AWA Head Preload — DNS Prefetch (demais domínios) -->
<?php foreach ($dnsPrefetch as $domain): ?>
<link rel="dns-prefetch" href="<?= $block->escapeUrl($domain) ?>"/>
<?php endforeach; ?>
<!-- AWA Head Preload — CSS Critical -->
<?php foreach ($cssPreloads as $item): ?>
<link rel="preload" href="<?= $block->escapeUrl($item['url']) ?>" as="style"<?= $item['priority'] ? ' fetchpriority="' . $block->escapeHtmlAttr($item['priority']) . '"' : '' ?>/>
<?php endforeach; ?>
<!-- AWA Head Preload — Fonts -->
<?php foreach ($fontPreloads as $item): ?>
<link rel="preload" href="<?= $block->escapeUrl($item['url']) ?>" as="font" type="font/woff2" crossorigin="anonymous"<?= $item['priority'] ? ' fetchpriority="' . $block->escapeHtmlAttr($item['priority']) . '"' : '' ?>/>
<?php endforeach; ?>
<!-- AWA Head Preload — JS (early fetch for RequireJS discovered modules) -->
<?php foreach ($jsPreloads as $jsUrl): ?>
<link rel="preload" href="<?= $block->escapeUrl($jsUrl) ?>" as="script"/>
<?php endforeach; ?>
<!-- AWA Async CSS Bundles — media="print" swap (non-render-blocking) -->
<!-- themes.css: kept blocking — async caused CLS 0.511 (reverted 2026-04-11) -->
<?php foreach ($asyncBundles as $cssUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($cssUrl) ?>"
      media="print"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($cssUrl) ?>"/></noscript>
<?php endforeach; ?>
<!-- T2.4 (2026-03-28): -299KB do critical path — AOF styles now in awa-critical-fold.css -->
<link rel="stylesheet"
    href="<?= $block->escapeUrl($refinementsBundleUrl) ?>"
    media="print"
    data-awa-refinements="1"
    onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($refinementsBundleUrl) ?>"/></noscript>
<!-- awa-layout-standardization carregado APÓS refinements — garante que footer light e
     demais overrides !important vençam o dark-footer do refinements bundle (last-wins) -->
<link rel="stylesheet"
    href="<?= $block->escapeUrl($block->getViewFileUrl('css/awa-layout-standardization.css')) ?>"
    media="print"
    data-awa-layout-std="1"
    onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($block->getViewFileUrl('css/awa-layout-standardization.css')) ?>"/></noscript>
<?php if ($homeBundleUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($homeBundleUrl) ?>"
      media="print"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($homeBundleUrl) ?>"/></noscript>
<?php endif; ?>
<?php if ($homeMobileFixUrl): ?>
<!-- awa-home-mobile-fix: seções 1+2 inline no Anti-FOUC; async para seções 3+4 (footer cosmetics) -->
<link rel="stylesheet"
      href="<?= $block->escapeUrl($homeMobileFixUrl) ?>"
      media="print"
      data-awa-home-mobile-fix="1"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($homeMobileFixUrl) ?>"/></noscript>
<?php endif; ?>
<?php if ($homeProductCardsUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($homeProductCardsUrl) ?>"
      media="print"
      data-awa-home-product-cards="1"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($homeProductCardsUrl) ?>"/></noscript>
<?php endif; ?>
<?php if ($homeCategoryCarouselUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($homeCategoryCarouselUrl) ?>"
      media="print"
      data-awa-category-carousel-async="1"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($homeCategoryCarouselUrl) ?>"/></noscript>
<?php endif; ?>
<?php /* rexis-recommendations: async — widget nunca está above-fold */ ?>
<?php $__rexisUrl = str_replace('css/awa-bundle-refinements.css', 'GrupoAwamotos_ProductIntelligence/css/rexis-recommendations.css', $refinementsBundleUrl); ?>
<?php if ($__rexisUrl !== $refinementsBundleUrl): ?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($__rexisUrl) ?>"
      media="print"
      data-rexis-async="1"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($__rexisUrl) ?>"/></noscript>
<?php endif; ?>

