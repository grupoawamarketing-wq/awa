<?php
/**
 * AWA Motos — Open Graph + Twitter Card Meta Tags
 *
 * Injeta meta tags de compartilhamento social em todas as páginas.
 * Suporta contextos: Home, PLP (categoria), PDP (produto), CMS pages.
 *
 * Audit 2026-04-23: nenhuma og:* encontrada — compartilhamento social
 * mostra preview genérico no WhatsApp/Facebook/Instagram.
 *
 * Carregado via: Magento_Theme/layout/default_head_blocks.xml
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\View\TemplateEngine\Php $this
 */

use Magento\Framework\App\ObjectManager;
use Magento\Framework\View\Page\Config as PageConfig;
use Magento\Store\Model\StoreManagerInterface;

$objectManager = ObjectManager::getInstance();

/** @var \Magento\Framework\App\Request\Http $request */
$request = $block->getRequest();
$actionName = $request->getFullActionName(); // cms_index_index, catalog_category_view, catalog_product_view, etc.

/** @var StoreManagerInterface $storeManager */
$storeManager = $objectManager->get(StoreManagerInterface::class);
$store = $storeManager->getStore();
$storeUrl = rtrim($store->getBaseUrl(), '/');
$storeName = $store->getName() ?: 'AWA Motos';

// ── Defaults ──────────────────────────────────────────────────────────────────
$ogTitle       = $storeName . ' — Peças e Acessórios para Motos';
$ogDescription = 'Peças e acessórios para motocicletas com entrega para todo Brasil. Preços especiais para revendedores B2B.';
$ogImage       = $storeUrl . '/media/logo/stores/1/awamotos-og-default.jpg';
$ogUrl         = $storeUrl . $request->getPathInfo();
$ogType        = 'website';

// ── Contexto: PDP ─────────────────────────────────────────────────────────────
if ($actionName === 'catalog_product_view') {
    try {
        /** @var \Magento\Framework\Registry $registry */
        $registry = $objectManager->get(\Magento\Framework\Registry::class);
        $product = $registry->registry('current_product');

        if ($product && $product->getId()) {
            $ogTitle       = $product->getName() . ' | ' . $storeName;
            $ogDescription = $product->getMetaDescription()
                ?: ($product->getShortDescription()
                    ? strip_tags($product->getShortDescription())
                    : $ogDescription);
            $ogDescription = mb_substr(strip_tags($ogDescription), 0, 200);
            $ogType        = 'product';
            $ogUrl         = $product->getProductUrl();

            // Imagem do produto
            /** @var \Magento\Catalog\Helper\Image $imageHelper */
            $imageHelper = $objectManager->get(\Magento\Catalog\Helper\Image::class);
            $productImage = $imageHelper->init($product, 'product_page_image_large')
                ->setImageFile($product->getImage())
                ->getUrl();
            if ($productImage && !str_contains($productImage, 'placeholder')) {
                $ogImage = $productImage;
            }
        }
    } catch (\Exception $e) { /* silently fail */ }

// ── Contexto: PLP (Categoria) ─────────────────────────────────────────────────
} elseif ($actionName === 'catalog_category_view') {
    try {
        /** @var \Magento\Framework\Registry $registry */
        $registry = $objectManager->get(\Magento\Framework\Registry::class);
        $category = $registry->registry('current_category');

        if ($category && $category->getId()) {
            $ogTitle       = $category->getName() . ' | ' . $storeName;
            $ogDescription = $category->getMetaDescription()
                ?: 'Compre ' . $category->getName() . ' na ' . $storeName . '. ' . $ogDescription;
            $ogDescription = mb_substr(strip_tags($ogDescription), 0, 200);
            $ogUrl         = $category->getUrl();

            if ($category->getImageUrl()) {
                $ogImage = $category->getImageUrl();
            }
        }
    } catch (\Exception $e) { /* silently fail */ }

// ── Contexto: CMS Page ────────────────────────────────────────────────────────
} elseif ($actionName === 'cms_page_view' || $actionName === 'cms_index_index') {
    try {
        /** @var \Magento\Framework\Registry $registry */
        $registry = $objectManager->get(\Magento\Framework\Registry::class);
        $cmsPage = $registry->registry('cms_page');

        if ($cmsPage && $cmsPage->getId()) {
            $cmsTitle = $cmsPage->getTitle() ?: $storeName;
            $ogTitle  = $cmsTitle . ($cmsTitle !== $storeName ? ' | ' . $storeName : '');
            if ($cmsPage->getMetaDescription()) {
                $ogDescription = mb_substr(strip_tags($cmsPage->getMetaDescription()), 0, 200);
            }
        }
    } catch (\Exception $e) { /* silently fail */ }
}

// Sanitize
$ogTitle       = htmlspecialchars(strip_tags($ogTitle), ENT_QUOTES, 'UTF-8');
$ogDescription = htmlspecialchars(strip_tags($ogDescription), ENT_QUOTES, 'UTF-8');
$ogImage       = htmlspecialchars($ogImage, ENT_QUOTES, 'UTF-8');
$ogUrl         = htmlspecialchars($ogUrl, ENT_QUOTES, 'UTF-8');
$ogType        = htmlspecialchars($ogType, ENT_QUOTES, 'UTF-8');
?>
<!-- AWA Motos — Open Graph / Social Meta Tags -->
<meta property="og:type"        content="<?= $ogType ?>">
<meta property="og:site_name"   content="AWA Motos">
<meta property="og:title"       content="<?= $ogTitle ?>">
<meta property="og:description" content="<?= $ogDescription ?>">
<meta property="og:image"       content="<?= $ogImage ?>">
<meta property="og:url"         content="<?= $ogUrl ?>">
<meta property="og:locale"      content="pt_BR">
<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image">
<meta name="twitter:title"       content="<?= $ogTitle ?>">
<meta name="twitter:description" content="<?= $ogDescription ?>">
<meta name="twitter:image"       content="<?= $ogImage ?>">
