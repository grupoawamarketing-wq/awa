<?php
/**
 * AWA B2B — Open Graph Meta Tags
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
declare(strict_types=1);

$viewModel = $block->getData('open_graph_view_model') ?: $block->getData('view_model');
if (!$viewModel instanceof \GrupoAwamotos\Theme\ViewModel\OpenGraph) {
    return;
}

$meta = $viewModel->getMetaData();
if ($meta === []) {
    return;
}

$isProductPage = $meta['type'] === 'product';
?>
<meta property="og:type" content="<?= $block->escapeHtmlAttr($meta['type']) ?>"/>
<meta property="og:site_name" content="<?= $block->escapeHtmlAttr($meta['site_name']) ?>"/>
<meta property="og:title" content="<?= $block->escapeHtmlAttr($meta['title']) ?>"/>
<meta property="og:description" content="<?= $block->escapeHtmlAttr($meta['description']) ?>"/>
<meta property="og:image" content="<?= $block->escapeUrl($meta['image']) ?>"/>
<meta property="og:url" content="<?= $block->escapeUrl($meta['url']) ?>"/>
<meta property="og:locale" content="<?= $block->escapeHtmlAttr($meta['locale']) ?>"/>
<meta property="og:image:alt" content="<?= $block->escapeHtmlAttr($meta['image_alt']) ?>"/>
<?php if ($isProductPage && isset($meta['price_amount'], $meta['price_currency'])): ?>
<meta property="product:price:amount" content="<?= $block->escapeHtmlAttr($meta['price_amount']) ?>"/>
<meta property="product:price:currency" content="<?= $block->escapeHtmlAttr($meta['price_currency']) ?>"/>
<?php endif; ?>
<?php if ($isProductPage && isset($meta['availability'])): ?>
<meta property="product:availability" content="<?= $block->escapeHtmlAttr($meta['availability']) ?>"/>
<?php endif; ?>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="<?= $block->escapeHtmlAttr($meta['title']) ?>"/>
<meta name="twitter:description" content="<?= $block->escapeHtmlAttr($meta['description']) ?>"/>
<meta name="twitter:image" content="<?= $block->escapeUrl($meta['image']) ?>"/>
