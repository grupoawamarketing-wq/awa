<?php
declare(strict_types=1);

/**
 * AWA Search Autocomplete live overrides.
 *
 * Separate block avoids depending on opcode refresh of the larger preload template.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$searchAutocompleteActiveUrl = $block->getViewFileUrl('css/awa-search-autocomplete-active.css');
?>
<link rel="stylesheet"
      href="<?= $block->escapeUrl($searchAutocompleteActiveUrl) ?>"
      media="print"
      data-awa-search-autocomplete="1"
      onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="<?= $block->escapeUrl($searchAutocompleteActiveUrl) ?>"/></noscript>
