</style>
<script>
(function (w, d, premiumUrl) {
    'use strict';
    if (!premiumUrl) { return; }

    function appendStylesheet(url) {
        if (d.querySelector('link[data-awa-success-premium="1"]')) { return; }
        var link = d.createElement('link');
        link.rel = 'stylesheet';
        link.href = url;
        link.setAttribute('data-awa-success-premium', '1');
        d.head.appendChild(link);
    }

    function loadDeferredCss() {
        appendStylesheet(premiumUrl);
    }

    if ('requestIdleCallback' in w) {
        w.requestIdleCallback(loadDeferredCss, { timeout: 2000 });
    } else {
        w.setTimeout(loadDeferredCss, 600);
    }

    w.addEventListener('pointerdown', loadDeferredCss, { once: true, passive: true });
}(window, document, <?= /* @noEscape */ $premiumUrlJson ?>));
</script>
<noscript>
    <link rel="stylesheet" href="<?= $block->escapeUrl($premiumUrl) ?>"/>
</noscript>
