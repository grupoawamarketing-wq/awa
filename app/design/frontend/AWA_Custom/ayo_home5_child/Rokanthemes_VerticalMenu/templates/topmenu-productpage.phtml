<?php
declare(strict_types=1);
/**
 * VerticalMenu sidebar — página de produto.
 * Fix [A7]: JS plugin VerticalMenu() não era inicializado no template vendor.
 *
 * @var \Rokanthemes\VerticalMenu\Block\VerticalmenuProduct $block
 */

$_helper = $this->helper('Rokanthemes\\VerticalMenu\\Helper\\Data');
$_config = $_helper->getConfig('verticalmenu');

if (!empty($_config['general']['enable'])):
    $_menu = $block->getVerticalMenuHtml();
?>
<nav class="navigation-product verticalmenu verticalmenu-product"
     aria-label="<?= $block->escapeHtmlAttr(__('Categorias de Produtos')) ?>">
    <ul>
        <?= /** @noEscape */ $_menu ?>
    </ul>
</nav>

<script type="text/x-magento-init">
{
    ".verticalmenu-product": {
        "rokanthemes/verticalmenu": {}
    }
}
</script>
<?php endif; ?>
