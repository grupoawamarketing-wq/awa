<?php
declare(strict_types=1);

/**
 * Child theme restore aligned with original Ayo package:
 * biblioteca/tema/ayo.zip -> app/design/frontend/ayo/ayo_default/Rokanthemes_VerticalMenu/templates/sidemenu.phtml
 *
 * Toggle: CSS controls display via .vmm-open on <ul> (awa-bundle-core.css).
 *
 * @var \GrupoAwamotos\Theme\Block\VerticalMenu\SafeVerticalmenu $block
 */

$_helper = $this->helper('Rokanthemes\VerticalMenu\Helper\Data');
$_config = $_helper->getConfig('verticalmenu');

if (!empty($_config['general']['enable'])):
    $limitShow = (int) ($_config['general']['limit_show'] ?? 0);
    $menuId = 'awa-vertical-menu-' . uniqid('', false);
    $_menu = $block->getVerticalMenuHtml();
    $menuHtml = trim((string) $_menu);
    $hasCategoryItems = $menuHtml !== '' && stripos($menuHtml, 'ui-menu-item') !== false;
    $extraHtml = trim($block->getCmsBlockHtmlByIdentifier('vertical-menu-extra'));
    $_bgImages = trim($block->getCmsBlockHtmlByIdentifier('vertical_background_images'));
?>

<nav class="navigation verticalmenu side-verticalmenu"
     aria-label="<?= $block->escapeHtmlAttr(__('Categorias de Produtos')) ?>"
     data-role="awa-vertical-menu">
    <button type="button" class="title-category-dropdown our_categories"
        data-role="awa-vertical-menu-trigger"
        aria-expanded="false"
        aria-controls="<?= $block->escapeHtmlAttr($menuId) ?>"
        aria-describedby="<?= $block->escapeHtmlAttr($menuId) ?>-status"
        aria-label="<?= $block->escapeHtmlAttr(__('Departamentos')) ?>">
        <span class="icon-menu awa-vmenu-trigger-icon vm-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </span>
        <span class="awa-vmenu-trigger-text"><?= $block->escapeHtml(__('Departamentos')) ?></span>
    </button>
    <span id="<?= $block->escapeHtmlAttr($menuId) ?>-status"
          class="awa-sr-only"
          data-role="awa-vertical-menu-status"
          aria-live="polite"
          aria-atomic="true">
        <?= $block->escapeHtml(__('Menu de departamentos fechado. Pressione Enter para abrir.')) ?>
    </span>
    <ul id="<?= $block->escapeHtmlAttr($menuId) ?>"
        class="togge-menu list-category-dropdown"
        data-role="awa-vertical-menu-panel"
        data-limit-show="<?= (int) $limitShow ?>"
        aria-hidden="true"
        data-awa-menu-state="closed">
        <li class="awa-vmenu-search-li" role="none" data-role="awa-vmenu-search-row">
            <div class="awa-vmenu-search-wrap" role="search" aria-label="<?= $block->escapeHtmlAttr(__('Buscar categoria')) ?>">
                <span class="awa-vmenu-search-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                        <circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/>
                    </svg>
                </span>
                <input type="search"
                       class="awa-vmenu-search-input"
                       data-role="awa-vmenu-search"
                       placeholder="<?= $block->escapeHtmlAttr(__('Buscar categoria...')) ?>"
                       aria-label="<?= $block->escapeHtmlAttr(__('Buscar categoria no menu')) ?>"
                       aria-controls="<?= $block->escapeHtmlAttr($menuId) ?>"
                       autocomplete="off"
                       spellcheck="false"/>
            </div>
        </li>
        <?php if ($hasCategoryItems): ?>
        <?= /** @noEscape */ $_menu ?>
        <?php else: ?>
        <li class="awa-vmenu-empty ui-menu-item level0" role="none">
            <span class="awa-vmenu-empty__text">
                <?= $block->escapeHtml(__('Nenhuma categoria disponível no momento.')) ?>
            </span>
        </li>
        <?php endif; ?>
        <?php if ($_bgImages !== ''): ?>
        <li class="vertical-bg-img"><?= /** @noEscape */ $_bgImages ?></li>
        <?php endif; ?>
        <?php if ($limitShow > 0): ?>
        <li class="expand-category-link">
            <button type="button"
               class="viewall vm-toggle-categories"
               aria-expanded="false"
               aria-label="<?= $block->escapeHtmlAttr(__('Ver mais categorias')) ?>"
               data-show-text="<?= $block->escapeHtmlAttr(__('Ver mais categorias')) ?>"
               data-show-aria="<?= $block->escapeHtmlAttr(__('Ver mais categorias')) ?>"
               data-hide-text="<?= $block->escapeHtmlAttr(__('Ver menos categorias')) ?>"
               data-hide-aria="<?= $block->escapeHtmlAttr(__('Recolher categorias')) ?>">
                <span><?= $block->escapeHtml(__('Ver mais categorias')) ?></span>
                <i class="fa fa-angle-down vm-toggle-icon" aria-hidden="true"></i>
            </button>
        </li>
        <?php endif; ?>
        <?php if ($extraHtml !== ''): ?>
        <li class="awa-vem-extra-li" role="none">
            <div id="menu.vertical.extra"
                 class="awa-vertical-extra"
                 data-role="content">
                <?= /** @noEscape */ $extraHtml ?>
            </div>
        </li>
        <?php endif; ?>
    </ul>
</nav>

<?php if ($_bgImages !== ''): ?>
<script type="text/x-magento-init">
{
    ".vertical-bg-img": {
        "js/vmenu-promo-carousel": {
            "interval": 5000
        }
    }
}
</script>
<?php endif; ?>

<?php endif; ?>
