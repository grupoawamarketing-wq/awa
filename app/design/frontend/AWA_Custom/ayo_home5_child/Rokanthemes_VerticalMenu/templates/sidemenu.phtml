<?php
declare(strict_types=1);

/**
 * Child theme restore aligned with original Ayo package:
 * biblioteca/tema/ayo.zip -> app/design/frontend/ayo/ayo_default/Rokanthemes_VerticalMenu/templates/sidemenu.phtml
 *
 * Toggle: CSS controls display via .vmm-open on <ul> (awa-bundle-core.css).
 * Hover is disabled by CSS — click is the only trigger.
 *
 * @var \Rokanthemes\VerticalMenu\Block\Verticalmenu $block
 */

$_helper = $this->helper('Rokanthemes\\VerticalMenu\\Helper\\Data');
$_config = $_helper->getConfig('verticalmenu');

if (!empty($_config['general']['enable'])):
    $_menu = $block->getVerticalMenuHtml();
?>

<nav class="navigation verticalmenu side-verticalmenu"
     aria-label="<?= $block->escapeHtmlAttr(__('Categorias de Produtos')) ?>">
    <h2 class="title-category-dropdown"
        role="button"
        tabindex="0"
        aria-expanded="false"
        aria-controls="vmenu-list-main">
        <span><?= $block->escapeHtml(__('Shop By Department')) ?></span>
    </h2>
    <ul id="vmenu-list-main" class="togge-menu list-category-dropdown">
        <?= /** @noEscape */ $_menu ?>
        <li class="expand-category-link">
            <a href="javascript:void(0);" class="viewall">
                <?= $block->escapeHtml(__('All Categories')) ?>
            </a>
        </li>
        <?= /** @noEscape */ $block->getLayout()->createBlock('Magento\\Cms\\Block\\Block')->setBlockId('vertical_background_images')->toHtml() ?>
    </ul>
</nav>

<script type="text/javascript">
    require([
        'jquery',
        'rokanthemes/verticalmenu',
        'awaVerticalMenu'
    ], function ($, _VerticalMenuPlugin, awaEnhance) {
        'use strict';

        $('.verticalmenu').VerticalMenu();

        // Apply SVG icons, Super Ofertas highlight, and active category detection.
        if (typeof awaEnhance === 'function') {
            awaEnhance();
        }

        var $nav   = $('.navigation.verticalmenu.side-verticalmenu');
        var $title = $nav.find('.title-category-dropdown');
        var $tog   = $nav.find('ul.togge-menu');

        function openMenu() {
            $tog.addClass('vmm-open');
            $title.addClass('active').attr('aria-expanded', 'true');
            $('body').addClass('background_shadow_show');
        }

        function closeMenu() {
            $tog.removeClass('vmm-open');
            $title.removeClass('active').attr('aria-expanded', 'false');
            $('body').removeClass('background_shadow_show');
        }

        function toggleMenu() {
            if ($tog.hasClass('vmm-open')) {
                closeMenu();
            } else {
                openMenu();
            }
        }

        $title
            .off('click.awaVM keydown.awaVM')
            .on('click.awaVM', toggleMenu)
            .on('keydown.awaVM', function (e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    toggleMenu();
                }
                if (e.key === 'Escape') {
                    closeMenu();
                }
            });

        // Close on shadow overlay click
        $(document).off('click.awaVMOverlay').on('click.awaVMOverlay', '.shadow_bkg_show', closeMenu);

        // Close on Escape from anywhere inside the menu
        $nav.off('keydown.awaVMEsc').on('keydown.awaVMEsc', function (e) {
            if (e.key === 'Escape' && $tog.hasClass('vmm-open')) {
                closeMenu();
                $title.trigger('focus');
            }
        });

        $(document).ready(function () {
            var lengthLi = $nav.find('.ui-menu-item.level0').length;
            var limitItemShow = <?= (int) $block->getConfig('limit_show') ?>;

            if (lengthLi > limitItemShow) {
                $nav.find('.ui-menu-item.level0').each(function (index) {
                    if (index >= (limitItemShow - 1)) {
                        $(this).addClass('orther-link').hide();
                    }
                });

                $nav.find('.expand-category-link').show();
                $nav.find('.expand-category-link').off('click.awaVM').on('click.awaVM', function () {
                    $(this).toggleClass('expanding');
                    $nav.find('.ui-menu-item.level0.orther-link').slideToggle('slow');
                });
            } else {
                $nav.find('.expand-category-link').hide();
            }
        });
    });
</script>

<script type="text/x-magento-init">
{
    ".vertical-bg-img": {
        "js/vmenu-promo-carousel": {
            "interval": 5000
        }
    }
}
</script>

<?php endif; ?>
