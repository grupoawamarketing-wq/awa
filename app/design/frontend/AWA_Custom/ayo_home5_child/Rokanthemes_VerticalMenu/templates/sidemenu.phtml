<?php
declare(strict_types=1);

/**
 * AWA Motos child-theme override — full AWA implementation.
 * Idêntico ao ayo/ayo_home5 para garantir data-role="awa-vertical-menu"
 * e a inicialização correta via js/vertical-menu-init (x-magento-init).
 *
 * @var \Rokanthemes\VerticalMenu\Block\Verticalmenu $block
 */

$_helper = $this->helper('Rokanthemes\\VerticalMenu\\Helper\\Data');
$_config = $_helper->getConfig('verticalmenu');

if (!empty($_config['general']['enable'])):
    $limitShow = (int)($_config['general']['limit_show'] ?? 0);
    $menuId    = 'awa-vertical-menu-' . uniqid('', false);
    $_menu     = $block->getVerticalMenuHtml();
?><!-- Skip navigation link for keyboard/screen reader users -->
<a class="vmm-skip-nav" href="#maincontent">
    <?= $block->escapeHtml(__('Ir para o conteúdo principal')) ?>
</a>
<nav class="navigation verticalmenu side-verticalmenu navigation--mueller"
     aria-label="<?= $block->escapeHtmlAttr(__('Categorias de Produtos')) ?>"
     data-role="awa-vertical-menu">
    <h2 class="our_categories title-category-dropdown"
        data-role="awa-vertical-menu-trigger"
        aria-controls="<?= $block->escapeHtmlAttr($menuId) ?>"
        aria-expanded="false"
        role="button"
        tabindex="0">
        <span class="vm-icon"><i class="fa fa-bars" aria-hidden="true"></i></span>
        <span><?= $block->escapeHtml(__('Todas as categorias')) ?></span>
    </h2>
    <ul id="<?= $block->escapeHtmlAttr($menuId) ?>"
        class="togge-menu list-category-dropdown navigation__list navigation__list--level0 todasascategorias"
        data-level="0"
        data-limit-show="<?= (int)$limitShow ?>">
        <?= /** @noEscape */ $_menu ?>
        <?php
            $_bgBlock  = $block->getLayout()->createBlock(\Magento\Cms\Block\Block::class);
            $_bgImages = '';

            if ($_bgBlock instanceof \Magento\Cms\Block\Block) {
                $_bgImages = trim($_bgBlock->setBlockId('vertical_background_images')->toHtml());
            }
        ?>
        <?php if ($_bgImages !== ''): ?>
        <li class="vertical-bg-img"><?= /** @noEscape */ $_bgImages ?></li>
        <?php endif; ?>
        <?php if ($limitShow > 0): ?>
        <li class="expand-category-link">
            <a class="viewall vm-toggle-categories"
               href="#"
               role="button"
               aria-expanded="false"
               data-show-text="<?= $block->escapeHtmlAttr(__('Show More')) ?>"
               data-hide-text="<?= $block->escapeHtmlAttr(__('Show Less')) ?>">
                <span><?= $block->escapeHtml(__('All Categories')) ?></span>
                <i class="fa fa-angle-down vm-toggle-icon" aria-hidden="true"></i>
            </a>
        </li>
        <?php endif; ?>
    </ul>
</nav>

<script type="text/x-magento-init">
{
    ".navigation.verticalmenu.side-verticalmenu.navigation--mueller[data-role='awa-vertical-menu']": {
        "js/awa-vertical-menu-mueller": {
            "desktopBreakpoint": 992,
            "openModeDesktop": "hover",
            "openModeMobile": "click",
            "disableOverlay": true,
            "keepOpenOnHomeDesktop": false,
            "limitShow": <?= (int)$limitShow ?>
        }
    }
}
</script>
<?php endif; ?>
