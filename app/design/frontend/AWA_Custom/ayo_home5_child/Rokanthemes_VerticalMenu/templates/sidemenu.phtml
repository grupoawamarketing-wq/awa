<?php
declare(strict_types=1);

/**
 * AWA Motos child-theme override using the standard Ayo vertical menu init.
 *
 * @var \Rokanthemes\VerticalMenu\Block\Verticalmenu $block
 */

$_helper = $this->helper('Rokanthemes\\VerticalMenu\\Helper\\Data');
$_config = $_helper->getConfig('verticalmenu');

if (!empty($_config['general']['enable'])):
    $limitShow    = (int)($_config['general']['limit_show'] ?? 0);
    $menuId       = 'awa-vertical-menu-' . uniqid('', false);
    $triggerLabel = (string) __('Departamentos');
    $statusId     = $menuId . '-status';
    $_menu        = $block->getVerticalMenuHtml();
?>
<nav class="navigation verticalmenu side-verticalmenu"
     aria-label="<?= $block->escapeHtmlAttr(__('Categorias de Produtos')) ?>"
     data-role="awa-vertical-menu">
    <button type="button"
        class="our_categories title-category-dropdown"
        data-role="awa-vertical-menu-trigger"
        aria-controls="<?= $block->escapeHtmlAttr($menuId) ?>"
        aria-describedby="<?= $block->escapeHtmlAttr($statusId) ?>"
        aria-expanded="false"
        aria-haspopup="true"
        aria-label="<?= $block->escapeHtmlAttr($triggerLabel) ?>">
        <span class="vm-icon awa-vmenu-trigger-icon" aria-hidden="true">
            <span class="awa-hamburger">
                <span class="awa-hamburger__line"></span>
                <span class="awa-hamburger__line"></span>
                <span class="awa-hamburger__line"></span>
            </span>
        </span>
        <span class="awa-vmenu-trigger-text"><?= $block->escapeHtml($triggerLabel) ?></span>
    </button>
    <span id="<?= $block->escapeHtmlAttr($statusId) ?>"
        class="awa-sr-only awa-vmenu-status"
        data-role="awa-vertical-menu-status"
        aria-live="polite"
        aria-atomic="true"><?= $block->escapeHtml(__('Menu fechado')) ?></span>
    <ul id="<?= $block->escapeHtmlAttr($menuId) ?>"
        class="togge-menu list-category-dropdown navigation__list"
        data-role="awa-vertical-menu-panel"
        data-trigger-label="<?= $block->escapeHtmlAttr($triggerLabel) ?>"
        aria-hidden="true"
        aria-label="<?= $block->escapeHtmlAttr(__('Lista de categorias')) ?>"
        tabindex="-1"
        data-limit-show="<?= (int)$limitShow ?>">
        <?= /** @noEscape */ $_menu ?>
        <?php
            $_bgBlock  = $block->getLayout()->createBlock(\Magento\Cms\Block\Block::class);
            $_bgImages = '';

            if ($_bgBlock instanceof \Magento\Cms\Block\Block) {
                $_bgImages = trim($_bgBlock->setBlockId('vertical_background_images')->toHtml());
            }
        ?>
        <?php if ($_bgImages !== ''): ?>
        <li class="vertical-bg-img"><?= /** @noEscape */ $_bgImages ?></li>
        <?php endif; ?>
        <?php if ($limitShow > 0): ?>
        <li class="expand-category-link">
            <a class="viewall vm-toggle-categories"
               href="#"
               role="button"
               aria-expanded="false"
               data-show-text="<?= $block->escapeHtmlAttr(__('Show More')) ?>"
               data-hide-text="<?= $block->escapeHtmlAttr(__('Show Less')) ?>">
                <span><?= $block->escapeHtml(__('Show More')) ?></span>
                <i class="fa fa-angle-down vm-toggle-icon" aria-hidden="true"></i>
            </a>
        </li>
        <?php endif; ?>
    </ul>
</nav>

<script type="text/x-magento-init">
{
    "[data-role='awa-vertical-menu']": {
        "js/vertical-menu-init": {
            "desktopBreakpoint": 992,
            "overlaySelector": ".shadow_bkg_show",
            "limitShow": <?= (int)$limitShow ?>
        }
    }
}
</script>

<script type="text/x-magento-init">
{
    ".vertical-bg-img": {
        "js/vmenu-promo-carousel": {
            "interval": 5000
        }
    }
}
</script>
<?php endif; ?>
