<?php
declare(strict_types=1);

/**
 * Child theme restore aligned with original Ayo package:
 * biblioteca/tema/ayo.zip -> app/design/frontend/ayo/ayo_default/Rokanthemes_VerticalMenu/templates/sidemenu.phtml
 *
 * Toggle: CSS controls display via .vmm-open on <ul> (awa-bundle-core.css).
 * Hover is disabled by CSS — click is the only trigger.
 *
 * @var \Rokanthemes\VerticalMenu\Block\Verticalmenu $block
 */

$_helper = $this->helper('Rokanthemes\\VerticalMenu\\Helper\\Data');
$_config = $_helper->getConfig('verticalmenu');

if (!empty($_config['general']['enable'])):
    $limitShow = (int) ($_config['general']['limit_show'] ?? 0);
    $menuId = 'awa-vertical-menu-' . uniqid('', false);
    $_menu = $block->getVerticalMenuHtml();
?>

<nav class="navigation verticalmenu side-verticalmenu"
     aria-label="<?= $block->escapeHtmlAttr(__('Categorias de Produtos')) ?>"
     data-role="awa-vertical-menu">
    <h2 class="title-category-dropdown our_categories"
        data-role="awa-vertical-menu-trigger"
        tabindex="0"
        aria-expanded="false"
        aria-controls="<?= $block->escapeHtmlAttr($menuId) ?>"
        aria-label="<?= $block->escapeHtmlAttr(__('Categorias')) ?>">
        <span class="icon-menu awa-vmenu-trigger-icon vm-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </span>
        <span class="awa-vmenu-trigger-text"><?= $block->escapeHtml(__('Categorias')) ?></span>
    </h2>
    <ul id="<?= $block->escapeHtmlAttr($menuId) ?>"
        class="togge-menu list-category-dropdown"
        data-limit-show="<?= (int) $limitShow ?>">
        <?= /** @noEscape */ $_menu ?>
        <?php
            $_bgBlock = $block->getLayout()->createBlock(\Magento\Cms\Block\Block::class);
            $_bgImages = $_bgBlock ? trim($_bgBlock->setBlockId('vertical_background_images')->toHtml()) : '';
        ?>
        <?php if ($_bgImages !== ''): ?>
        <li class="vertical-bg-img"><?= /** @noEscape */ $_bgImages ?></li>
        <?php endif; ?>
        <?php if ($limitShow > 0): ?>
        <li class="expand-category-link">
            <a href="#"
               class="viewall vm-toggle-categories"
                      aria-expanded="false"
               data-show-text="<?= $block->escapeHtmlAttr(__('Show More')) ?>"
               data-hide-text="<?= $block->escapeHtmlAttr(__('Show Less')) ?>">
                <span><?= $block->escapeHtml(__('All Categories')) ?></span>
                <i class="fa fa-angle-down vm-toggle-icon" aria-hidden="true"></i>
            </a>
        </li>
        <?php endif; ?>
    </ul>
</nav>

<script type="text/x-magento-init">
{
    "[data-role='awa-vertical-menu']": {
        "js/vertical-menu-init": {
            "desktopBreakpoint": 992,
            "overlaySelector": ".shadow_bkg_show",
            "limitShow": <?= (int) $limitShow ?>
        },
        "awaVerticalMenu": {}
    },
    ".vertical-bg-img": {
        "js/vmenu-promo-carousel": {
            "interval": 5000
        }
    }
}
</script>

<?php endif; ?>
