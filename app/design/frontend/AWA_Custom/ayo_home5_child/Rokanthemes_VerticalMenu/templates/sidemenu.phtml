<script>
(function () {
    'use strict';

    function initVMenuDesktopClose() {
        var nav = document.querySelector('[data-role="awa-vertical-menu"]');
        if (!nav) return;

        var trigger = nav.querySelector('.title-category-dropdown');
        if (!trigger) return;

        // Criar backdrop
        var backdrop = document.getElementById('awa-vmenu-backdrop');
        if (!backdrop) {
            backdrop = document.createElement('div');
            backdrop.id = 'awa-vmenu-backdrop';
            backdrop.className = 'awa-vmenu-backdrop';
            backdrop.setAttribute('aria-hidden', 'true');
            document.body.appendChild(backdrop);
        }

        function isOpen() {
            var ul = nav.querySelector('.togge-menu');
            return ul ? ul.classList.contains('menu-open') : false;
        }

        function closeMenu() {
            if (isOpen()) {
                trigger.click();
            }
        }

        // Backdrop fecha o menu
        backdrop.addEventListener('click', closeMenu);

        // Botão fechar dentro do painel fecha o menu
        nav.addEventListener('click', function (e) {
            if (e.target.closest('[data-role="awa-vmenu-desktop-close"]')) {
                e.stopPropagation();
                closeMenu();
            }
        });

        // MutationObserver para sincronizar o backdrop com o estado do painel
        if (window.MutationObserver) {
            var ul = nav.querySelector('.togge-menu');
            if (ul) {
                new MutationObserver(function () {
                    var open = ul.classList.contains('menu-open');
                    if (open) {
                        backdrop.classList.add('is-active');
                    } else {
                        backdrop.classList.remove('is-active');
                    }
                }).observe(ul, { attributes: true, attributeFilter: ['class'] });
            }
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initVMenuDesktopClose, { once: true });
    } else {
        initVMenuDesktopClose();
    }
}());
</script>
