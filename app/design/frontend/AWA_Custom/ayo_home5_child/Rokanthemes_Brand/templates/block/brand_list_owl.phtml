<?php
/**
 * AWA Motos - Rokanthemes Brand Block Override
 *
 * Converte inline script para padrão AMD (text/x-magento-init)
 * Melhora performance, CSP compliance e manutenibilidade.
 *
 * Override do template: app/code/Rokanthemes/Brand/view/frontend/templates/block/brand_list_owl.phtml
 */
$_brandCollection          = $block->getBrandCollection();
$_helper                   = $this->helper('Rokanthemes\Brand\Helper\Data');
$title                     = $this->getConfig('brand_block/title');
$show_brand_name           = $this->getConfig('brand_block/show_brand_name');

$blockId                   = rand() . time() . uniqid();
$number_item_per_column    = (int)$this->getConfig('brand_block/number_item_per_column');
if($number_item_per_column == '' || $number_item_per_column == 0)
$number_item_per_column = 1;

$default_items             = $this->getConfig('brand_block/default_items');
$addition_class            = $this->getConfig('brand_block/addition_class');
$mobile_items              = (int)$this->getConfig('brand_block/mobile_items',1);
$tablet_small_items        = (int)$this->getConfig('brand_block/tablet_small_items',2);
$tablet_items              = (int)$this->getConfig('brand_block/tablet_items',3);
$portrait_items            = (int)$this->getConfig('brand_block/portrait_items',4);
$large_items               = (int)$this->getConfig('brand_block/large_items',5);
$dots                      = $this->getConfig('brand_block/dots');
$nav                       = $this->getConfig('brand_block/nav');
$nav_prev                  = $this->getConfig('brand_block/nav_prev');
$nav_next                  = $this->getConfig('brand_block/nav_next');
$loop                      = $this->getConfig('brand_block/loop');
$autoplay                  = $this->getConfig('brand_block/autoplay');
$autoplay_timeout          = (int)$this->getConfig('brand_block/autoplay_timeout',3000);
$autoplay_pauseonhover     = (int)$this->getConfig('brand_block/autoplay_pauseonhover');
$auto_play                 = $this->getConfig('brand_block/auto_play');
$rtl                       = $this->getConfig('brand_block/rtl');
$pretext                   = $_helper->filter($this->getConfig('brand_block/pretext'));
?>
<?php if ( $_brandCollection->count() ){ ?>
<?php
$_collection = [];
$i = $x = 0;
$total  = $_brandCollection->count();
$column = 8;
if($total%$number_item_per_column == 0){
	$column = $total/$number_item_per_column;
}else{
	$column = floor($total/$number_item_per_column)+1;
}
if($column<$default_items) $column = $default_items;
$i = $x = 0;
foreach ($_brandCollection as $_brand) {
	if($i<$column){
		$i++;
	}else{
		$i = 1;
		$x++;
	}
	$_collection[$i][$x] = $_brand;
}
?>
<div class="block widget rokanthemes-widget brand-widget <?php echo $addition_class ? $this->escapeHtmlAttr($addition_class) : '' ?>">
	<?php if($title){ ?>
	<div class="block-title"><strong><?php echo $this->escapeHtml($title) ?></strong></div>
	<?php } ?>
	<?php if($pretext!=''){ ?>
	<div class="pretext-html"><?php echo /* @noEscape */ $pretext ?></div>
	<?php } ?>
	<div class="block-content brandowl-play" id="awa-brand-carousel-<?php echo $this->escapeHtmlAttr($blockId) ?>">
	<div class="swiper awa-brand-swiper"><div class="swiper-wrapper">
			<?php foreach ($_collection as $_brandCollection) { ?>
			<div class="swiper-slide item-load item">
				<?php foreach ($_brandCollection as $_brand) { ?>
				<div class="brand-item">
					<div class="brand-image"><a href="<?php echo $this->escapeUrl($_brand->getUrl()); ?>" title="<?php echo $this->escapeHtmlAttr($_brand->getName()); ?>"><img src="<?php echo $this->escapeUrl($_brand->getThumbnailUrl()); ?>" alt="<?php echo $this->escapeHtmlAttr($_brand->getName()); ?>" loading="lazy" decoding="async" width="120" height="60"/></a></div>
					<?php if($show_brand_name){ ?>
					<div class="brand-name"><a href="<?php echo $this->escapeUrl($_brand->getUrl()); ?>" title="<?php echo $this->escapeHtmlAttr($_brand->getName()); ?>"><?php echo $this->escapeHtml($_brand->getName()) ?></a></div>
					<?php } ?>
				</div>
				<?php } ?>
			</div>
			<?php } ?>
		</div><!-- .swiper-wrapper -->
		<?php if($nav){ ?>
		<div class="swiper-button-prev" aria-label="<?= $block->escapeHtmlAttr(__('Anterior')) ?>"></div>
		<div class="swiper-button-next" aria-label="<?= $block->escapeHtmlAttr(__('Próximo')) ?>"></div>
		<?php } ?>
		<?php if($dots){ ?>
		<div class="swiper-pagination"></div>
		<?php } ?>
	</div><!-- .awa-brand-swiper -->
	</div>
</div>
<?php } ?>
<script type="text/x-magento-init">
{
	"#awa-brand-carousel-<?php echo $this->escapeJs($blockId) ?>": {
		"js/tab-swiper-init": {
			"carouselSelector": ".awa-brand-swiper",
			"owl": {
				"items": <?php echo (int)($default_items ?: 7) ?>,
				"itemsDesktop": [1366, <?php echo (int)($large_items ?: 5) ?>],
				"itemsDesktopSmall": [991, <?php echo (int)($portrait_items ?: 4) ?>],
				"itemsTablet": [767, <?php echo (int)($tablet_items ?: 3) ?>],
				"itemsMobile": [479, <?php echo (int)($mobile_items ?: 1) ?>],
				"navigation": <?php echo $nav ? 'true' : 'false' ?>,
				"pagination": <?php echo $dots ? 'true' : 'false' ?>,
				"autoPlay": <?php echo $auto_play ? 'true' : 'false' ?>
			}
		}
	}
}
</script>
