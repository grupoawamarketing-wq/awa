<?php
/** @var \Rokanthemes\Categorytab\Block\CateWidget $block */
    $enable = $block->getConfig('enabled');
    if ($enable < 1) {
        return;
    }
    $items = $block->getConfig('items');
    $speed = $block->getConfig('speed');
    $qty = $block->getConfig('qty');
    $showCart = true;
    $showWishlist = false;
    $showCompare = false;
    $show_navigation = $block->getConfig('navigation');
    $show_pagination = $block->getConfig('pagination');
    $auto = $block->getConfig('auto');
    $rows = $block->getSlideRow();
    $slide_limit = $block->getSlideLimit();
    $title = $block->getTitle();
    $identify = trim($block->getIdentify());
    $identifyClass = preg_replace('/[^a-zA-Z0-9_-]+/', '-', $identify);
    if ($identifyClass === '') {
        $identifyClass = 'default';
    }
    $categoryIds = $block->getCategoryIds();
    $categoryIds = explode(',', $categoryIds);
    $limitQty = $block->getLimitQty() ?: ($qty ?: 8);
?>

<div class="categorytab-container awa-cat-tabs-<?php echo $block->escapeHtmlAttr($identifyClass); ?>">
<div class="container">
<header class='group-title1'><?php echo '<h2>' . $title . '</h2>'; ?></header>
  <ul class="tabs tabs-<?php echo $block->escapeHtmlAttr($identifyClass); ?>">
   <?php
    $k = 0;
    foreach ($categoryIds as $cate_id) {
        $cate_model = $block->getCategory($cate_id);
        $cateName = $cate_model->load($cate_id)->getName();
        if ($cateName) {
   ?>
            <li class="<?php if ($k == 0) { echo 'active'; } ?>" rel="tab<?php echo trim($cate_id) . '-' . $identifyClass; ?>"><?php echo $cateName; ?></li>
    <?php }
        $k++;
    } ?>
    </ul>
     <?php
        $imageBlock = $block->getLayout()->createBlock('Magento\Catalog\Block\Product\Image');
        $image = 'new_products_content_widget_grid';
        $type = 'widget-new-grid';
        $templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::DEFAULT_VIEW;
        $showWishlist = true;
        $showCompare = true;
        $showCart = true;
    ?>
    <div class="tab_container">
        <?php
        $tabIndex = 0;
        foreach ($categoryIds as $cate_id) { ?>
        <div id="tab<?php echo trim($cate_id) . '-' . $identifyClass; ?>" class="tab_content_<?php echo $identifyClass; ?>">
        <div class="owl-container">
            <?php if ($tabIndex === 0): ?>
            <div class="category_tab_slider owl-carousel">
                <?php
                $newItems = $block->getProductCate($cate_id)->getItems();
                $i = 0;
                foreach ($newItems as $_item) {
                    $productImage = $block->getImage($_item, $image);
                ?>
                <?php if ($i++ % $rows == 0) { ?> <div class="product_row"> <?php } ?>
                    <div class="item">
                        <div class="item-inner">
                            <div class="image-container">
                                <a href="<?php echo $block->getProductUrl($_item) ?>" class="product-item-photo">
                                    <?php /* Carousel images always below-fold — lazy load */
                                    $_imgHtml = $productImage->toHtml();
                                    $_imgHtml = str_replace('loading="eager"', 'loading="lazy"', $_imgHtml);
                                    if (strpos($_imgHtml, 'loading=') === false) {
                                        $_imgHtml = str_replace('<img ', '<img loading="lazy" decoding="async" ', $_imgHtml);
                                    }
                                    echo $_imgHtml; ?>
                                </a>
                                <div class="actions">
                                    <?php if ($showCart): ?>
                                        <div class="actions-primary">
                                            <?php if ($_item->isSaleable()): ?>
                                                <?php if ($_item->getTypeInstance()->hasRequiredOptions($_item)): ?>
                                                    <button class="action tocart"
                                                            data-mage-init='{"redirectUrl":{"url":"<?php echo $block->getAddToCartUrl($_item) ?>"}}'
                                                            type="button" title="<?php echo __('Add to Cart') ?>">
                                                        <span><?php echo __('Add to Cart') ?></span>
                                                    </button>
                                                <?php else: ?>
                                                    <?php
                                                        $postDataHelper = $this->helper('Magento\Framework\Data\Helper\PostHelper');
                                                        $postData = $postDataHelper->getPostData($block->getAddToCartUrl($_item), ['product' => $_item->getEntityId()])
                                                    ?>
                                                    <button class="action tocart"
                                                            data-post='<?php echo $postData; ?>'
                                                            type="button" title="<?php echo __('Add to Cart') ?>">
                                                        <span><?php echo __('Add to Cart') ?></span>
                                                    </button>
                                                <?php endif; ?>
                                            <?php else: ?>
                                                <?php if ($_item->getIsSalable()): ?>
                                                    <div class="stock available"><span><?php echo __('In stock') ?></span></div>
                                                <?php else: ?>
                                                    <div class="stock unavailable"><span><?php echo __('Out of stock') ?></span></div>
                                                <?php endif; ?>
                                            <?php endif; ?>
                                        </div>
                                    <?php endif; ?>
                                    <?php /* B2B: wishlist/compare nativos removidos */ ?>
                                </div>
                            </div>
                            <div class="des">
                                <div class="product-name">
                                    <strong class="product-item-name">
                                        <a title="<?php echo $block->escapeHtml($_item->getName()) ?>"
                                           href="<?php echo $block->getProductUrl($_item) ?>"
                                           class="product-item-link">
                                            <?php echo $block->escapeHtml($_item->getName()) ?>
                                        </a>
                                    </strong>
                                </div>
                                <?php /* @escapeNotVerified */ echo $this->helper('Rokanthemes\Themeoption\Helper\Data')->getPriceDisplayCustom($block->getProductPrice($_item)) ?>

                                <?php if ($templateType): ?>
                                    <?php echo $block->getReviewsSummaryHtml($_item, $templateType, true); ?>
                                <?php endif; ?>

                            </div>
                        </div>
                    </div>
                <?php if ($i % $rows == 0 || $i == count($newItems)) { ?> </div> <?php } ?>
                <?php
                }
                ?>
            </div>
            <?php else:
                $lazyUrl = $block->getUrl('catalogfix/categorytab/load', [
                    '_query' => [
                        'category_id' => trim($cate_id),
                        'limit' => (int)$limitQty,
                        'template' => 'grid',
                        'rows' => (int)$rows
                    ]
                ]);
            ?>
            <div class="category_tab_slider owl-carousel" data-lazy-url="<?php echo $block->escapeUrl($lazyUrl); ?>">
            </div>
            <?php endif; ?>
        </div>

         </div><!-- #tab -->
         <?php
            $tabIndex++;
        } ?>


     </div> <!-- .tab_container -->
</div>
</div>
<script type="text/x-magento-init">
{
    ".awa-cat-tabs-<?php echo $block->escapeJsQuote($identifyClass); ?>": {
        "js/tab-carousel-init": {
            "tabsSelector": "ul.tabs-<?php echo $block->escapeJsQuote($identifyClass); ?> li",
            "contentSelector": ".tab_content_<?php echo $block->escapeJsQuote($identifyClass); ?>",
            "carouselSelector": ".category_tab_slider",
            "owl": {
                "lazyLoad": true,
                "items": <?php echo (int)$items ?: 6; ?>,
                "itemsDesktop": [1366, 4],
                "itemsDesktopSmall": [1199, 3],
                "itemsTablet": [991, 3],
                "itemsMobile": [680, 2],
                "navigation": <?php echo ($show_navigation) ? 'true' : 'false'; ?>,
                "pagination": <?php echo ($show_pagination) ? 'true' : 'false'; ?>,
                "autoPlay": <?php echo ($auto) ? 'true' : 'false'; ?>
            }
        }
    }
}
</script>
