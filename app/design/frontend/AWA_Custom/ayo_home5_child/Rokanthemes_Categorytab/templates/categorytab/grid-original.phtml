                "itemsTablet": [991, 3],
                "itemsMobile": [680, 2],
                "desktopSpaceBetween": 16,
                "navigation": <?php echo ($show_navigation) ? 'true' : 'false'; ?>,
                "pagination": <?php echo ($show_pagination) ? 'true' : 'false'; ?>,
                "autoPlay": <?php echo ($auto) ? 'true' : 'false'; ?>
            }
        }
    }
}
</script>
