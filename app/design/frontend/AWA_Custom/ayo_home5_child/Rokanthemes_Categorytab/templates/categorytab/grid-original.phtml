<?php
	/** @var \Rokanthemes\Categorytab\Block\CateWidget $block */
    use Magento\Framework\App\Action\Action;
    $enable = $block->getConfig('enabled');
    if ($enable < 1) {
        return;
    }
    $items = $block->getConfig('items');
    $speed = $block->getConfig('speed');
    $qty = $block->getConfig('qty');
    $showCart = $block->getConfig('addtocart');
    $showWishlist = $block->getConfig('wishlist');
    $showCompare = $block->getConfig('compare');
    $default = $block->getdefault();
    $desktop = $block->getdesktop();
    $desktop_small = $block->getdesktop_small();
    $tablet = $block->gettablet();
    $mobile = $block->getmobile();
    $show_navigation = $block->getConfig('navigation');
    $show_pagination = $block->getConfig('pagination');
    $auto = $block->getConfig('auto');
    $rows = 1;
    $title = $block->getTitle();
    $identify = trim($block->getIdentify());
    $identifyClass = preg_replace('/[^a-zA-Z0-9_-]+/', '-', $identify);
    if ($identifyClass === '') {
        $identifyClass = 'default';
    }
    $categoryIds = $block->getCategoryIds();
    $categoryIds = explode(',', $categoryIds);

    $productsOnRow = 2;
    if (!$productsOnRow) {
        $productsOnRow = 4;
    }
?>

<div class="categorytab-container cat awa-cat-tabs-<?php echo $block->escapeHtmlAttr($identifyClass); ?>">
    <div class="rokan-product-heading rokan-featured-heading clearfix">
        <?php echo $title ? '<h2 class="pull-left">' . $block->escapeHtml($title) . ' <span class="sup-title">' . $block->escapeHtml(__('This Month')) . '</span></h2>' : ''; ?>
    </div>
    <div class="block_cat">
        <div class="row">
            <div class="col-xs-12 col-sm-5 col-md-3 col-lg-2 leftBlock">
                <?php
                $bannerHtml = trim($this->getLayout()->createBlock('Magento\Cms\Block\Block')->setBlockId('banner_lef_category1')->toHtml());
                if ($bannerHtml !== ''):
                ?>
                <a href="#" class="link-banner-box" aria-label="<?= $block->escapeHtmlAttr(__('Categorias em Destaque')) ?>">
                    <?= /* @noEscape */ $bannerHtml ?>
                </a>
                <?php endif; ?>
                <div class="cat_posion">
                    <div class="vc_tta-tabs-container">
                        <ul class="tabs tabs<?php echo '-' . $block->escapeHtmlAttr($identifyClass); ?>">
                        <?php
                            $k = 0;
                            foreach ($categoryIds as $cate_id) {
                                $cate_model = $block->getCategory($cate_id);
                                $cateName = $cate_model->load($cate_id)->getName();
                                if ($cateName) {
                        ?>
                                    <li class="<?php if ($k == 0) { echo 'active'; }?>" rel="tab<?php echo trim($cate_id) . '-' . $identifyClass; ?>"><a><?php echo $block->escapeHtml($cateName); ?></a></li>
                        <?php }
                                $k++;
                            }
                        ?>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="rightBlock col-xs-12 col-sm-7 col-md-9 col-lg-10">
                <div class="vc_tta-tabs-position-top">
                    <div class="vc_tta-panels-container">
                        <?php
                            $imageBlock = $block->getLayout()->createBlock('Magento\Catalog\Block\Product\Image');
                            $image = 'category_image_primary_small';
                            $type = 'widget-new-grid';
                            $templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::DEFAULT_VIEW;
                        ?>
                        <div class="tab_container">
                            <?php foreach ($categoryIds as $cate_id) { ?>
                            <div id="tab<?php echo trim($cate_id) . '-' . $identifyClass; ?>" class="tab_content_<?php echo $identifyClass; ?>">
                                <div class="owl-container">
                                    <div class="cat_home2 swiper">
                                        <div class="swiper-wrapper">
                                        <?php
                                            $newItems = $block->getProductCate($cate_id)->getItems();
                                            $i = 0;
                                            foreach ($newItems as $_item) {
                                                $productImage = $block->getImage($_item, $image);
                                        ?>
                                        <?php if ($i++ % $rows == 0) { ?> <div class="swiper-slide product_row"> <?php } ?>
                                            <div class="item-product">
                                                <div class="product-thumb">
                                                    <a href="<?php echo $block->escapeUrl($_item->getProductUrl()); ?>" class="product-thumb-link" aria-label="<?php echo $block->escapeHtmlAttr($_item->getName()); ?>">
                                                        <?php $productImageThumb = $block->getImage($_item, 'category_image_second_small'); ?>
                                                        <span class="first-thumb">
                                                            <?php
                                                            $_imgHtml = $productImage->toHtml();
                                                            $_imgHtml = str_replace('loading="eager"', 'loading="lazy"', $_imgHtml);
                                                            if (strpos($_imgHtml, 'loading=') === false) {
                                                                $_imgHtml = str_replace('<img ', '<img loading="lazy" decoding="async" ', $_imgHtml);
                                                            }
                                                            echo $_imgHtml;
                                                            ?>
                                                        </span>
                                                        <?php $productType = $_item->getTypeID();
                                                        if ($productType == 'simple'): ?>
                                                            <span class="second-thumb">
                                                                <?php
                                                                $_thumbHtml = $productImageThumb->toHtml();
                                                                if (strpos($_thumbHtml, 'loading=') === false) {
                                                                    $_thumbHtml = str_replace('<img ', '<img loading="lazy" decoding="async" ', $_thumbHtml);
                                                                }
                                                                echo $_thumbHtml;
                                                                ?>
                                                            </span>
                                                        <?php endif; ?>
                                                    </a>
                                                    <div class="hot-onsale">
                                                        <?php if ($_item->getFinalPrice() < $_item->getPrice()): ?>
                                                            <span class="onsale">
                                                                <span class="sale-bg"></span>
                                                                <span class="sale-text"><?php /* @noEscape */ echo $block->showLableSalePrice($_item); ?></span>
                                                            </span>
                                                        <?php endif; ?>
                                                        <?php $helper = $this->helper('Rokanthemes\RokanBase\Helper\Newlabel'); ?>
                                                        <?php if ($helper->isProductNew($_item)): ?>
                                                            <div class="onsale new-lable">
                                                                <?php echo $block->escapeHtml(__('New')); ?>
                                                            </div>
                                                        <?php endif; ?>
                                                    </div>
                                                    <div class="actions-secondary">
                                                        <ul class="product-extra-link add-to-links">
                                                        <?php if ($showWishlist || $showCompare): ?>
                                                            <?php if ($this->helper('Magento\Wishlist\Helper\Data')->isAllow() && $showWishlist): ?>
                                                            <li>
                                                                <a href="#"
                                                                   data-post='<?php echo $block->getAddToWishlistParams($_item); ?>'
                                                                   class="wishlist-link action towishlist" data-action="add-to-wishlist"
                                                                   title="<?php echo __('Add to Wishlist'); ?>">
                                                                </a>
                                                            </li>
                                                            <?php endif; ?>
                                                            <li class="quickview-product">
                                                                <a class="quickview-link" data-role="quickview-button" data-id="<?php echo $_item->getId(); ?>" href="#" data-href="<?php echo $block->getUrl('quickview/product/quickview/id/' . $_item->getId()); ?>" title="<?php echo __('Quick view');?>">
                                                                </a>
                                                            </li>
                                                            <?php if ($block->getAddToCompareUrl() && $showCompare): ?>
                                                            <?php $compareHelper = $this->helper('Magento\Catalog\Helper\Product\Compare'); ?>
                                                                <li>
                                                                    <a href="#" class="compare-link action tocompare"
                                                                       data-post='<?php echo $compareHelper->getPostDataParams($_item); ?>'
                                                                       title="<?php echo __('Add to Compare'); ?>">
                                                                    </a>
                                                                </li>
                                                            <?php endif; ?>
                                                        <?php endif; ?>
                                                        </ul>
                                                    </div>
                                                    <div class="product-info">
                                                        <h3 class="product-name">
                                                            <a title="<?php echo $block->escapeHtmlAttr($_item->getName()); ?>" href="<?php echo $block->escapeUrl($_item->getProductUrl()); ?>" class="product-item-link">
                                                                <?php echo $block->escapeHtml($_item->getName()); ?>
                                                            </a>
                                                        </h3>
														<div class="awa-b2b-sku">
															<span class="awa-b2b-sku__label"><?php echo $block->escapeHtml(__('Cod:')); ?></span>
															<span class="awa-b2b-sku__value"><?php echo $block->escapeHtml($_item->getSku()); ?></span>
														</div>
                                                        <div class="product-rating">
                                                            <?php if ($templateType): ?>
                                                                <?php echo $block->getReviewsSummaryHtml($_item, $templateType, true); ?>
                                                            <?php endif; ?>
                                                        </div>
                                                        <div class="sold-by">
                                                            <?php
                                                                $attr = $_item->getResource()->getAttribute('sold_by');
                                                                if ($attr && $attr->usesSource()) {
                                                                    $value = $attr->getSource()->getOptionText($_item->getData('sold_by'));
                                                                    if ($value) {
                                                                        /* @noEscape */ echo ' <span>' . $block->escapeHtml(__('Sold by:')) . '</span>' . $block->escapeHtml($value);
                                                                    }
                                                                }
                                                            ?>
                                                        </div>
                                                        <div class="info-price">
                                                            <?php /* @noEscape */ echo $this->helper('Rokanthemes\Themeoption\Helper\Data')->getPriceDisplayCustom($block->getProductPrice($_item)); ?>
                                                        </div>
                                                        <div class="product-info-cart">
                                                            <?php if ($showWishlist || $showCompare || $showCart): ?>
                                                                <?php if ($showCart): ?>
                                                                    <div class="actions-primary addcart-link">
                                                                    <?php if ($_item->isSaleable()): ?>
                                                                        <?php
                                                                            $postDataHelper = $this->helper('Magento\Framework\Data\Helper\PostHelper');
                                                                            $postData = $postDataHelper->getPostData($block->getAddToCartUrl($_item), ['product' => $_item->getEntityId()]);
                                                                            $postParams = json_decode($postData, true);
                                                                        ?>
                                                                        <form data-role="tocart-form" action="<?php echo $block->escapeUrl($postParams['action']); ?>" method="post">
                                                                            <input type="hidden" name="product" value="<?php echo $block->escapeHtmlAttr($postParams['data']['product']); ?>">
                                                                            <input type="hidden" name="<?php echo $block->escapeHtmlAttr(Action::PARAM_NAME_URL_ENCODED); ?>" value="<?php echo $block->escapeHtmlAttr($postParams['data'][Action::PARAM_NAME_URL_ENCODED]); ?>">
                                                                            <?php echo $block->getBlockHtml('formkey'); ?>
                                                                            <button type="submit"
                                                                                title="<?php echo $block->escapeHtml(__('Add to Cart')); ?>"
                                                                                class="btn-add-to-cart action tocart">
                                                                                <span><?php echo $block->escapeHtml(__('Add to Cart')); ?></span>
                                                                            </button>
                                                                        </form>
                                                                    <?php else: ?>
                                                                        <?php if ($_item->getIsSalable()): ?>
                                                                        <div class="stock available"><span><?php echo $block->escapeHtml(__('In stock')); ?></span></div>
                                                                        <?php else: ?>
                                                                        <div class="stock unavailable"><span><?php echo $block->escapeHtml(__('Out of stock')); ?></span></div>
                                                                        <?php endif; ?>
                                                                    <?php endif; ?>
                                                                    </div>
                                                                <?php endif; ?>
                                                            <?php endif; ?>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        <?php if ($i % $rows == 0 || $i == count($newItems)) { ?> </div> <?php }
                                            }
                                        ?>
                                    </div>
                                    <div class="swiper-button-prev"></div>
                                    <div class="swiper-button-next"></div>
                                    </div>
                                </div>
                            </div>
                            <?php } ?>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script type="text/x-magento-init">
{
    "[data-role=tocart-form], .form.map.checkout": {
        "catalogAddToCart": {}
