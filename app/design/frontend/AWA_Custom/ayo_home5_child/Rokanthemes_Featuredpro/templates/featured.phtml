<?php
/**
 * Rokanthemes_Featuredpro template override - AWA Custom child theme
 *
 * Product card structure aligned with AWA standard card system.
 */
declare(strict_types=1);

use Magento\Framework\App\Action\Action;

if (!$this->getConfig('enabled')) {
    return;
}

$_productCollection = $this->getProducts();
$_helper = $this->helper('Magento\Catalog\Helper\Output');
$image = ($block->getMode() === 'list') ? 'category_page_list' : 'category_page_grid';
$templateType = ($block->getMode() === 'list')
    ? \Magento\Catalog\Block\Product\ReviewRendererInterface::FULL_VIEW
    : \Magento\Catalog\Block\Product\ReviewRendererInterface::SHORT_VIEW;
$rows = (int) $this->getConfig('row_show');
$rows = $rows > 0 ? $rows : 1;
?>

<div class="rokan-featuredproduct">
    <?php if ($this->getConfig('title')): ?>
        <div class="rokan-product-heading rokan-featured-heading">
            <h2><?php echo $block->escapeHtml((string) $this->getConfig('title')); ?></h2>
        </div>
    <?php endif; ?>

    <?php if (!$_productCollection->getSize()): ?>
        <div class="rokan-featured-slider">
            <p class="note-msg"><?php echo $block->escapeHtml(__('There are no products matching the selection.')); ?></p>
        </div>
    <?php else: ?>
        <div class="row">
            <div class="swiper awa-featured-swiper">
                <div class="swiper-wrapper">
                    <?php $i = 0; foreach ($_productCollection as $_product): ?>
                        <?php if ($i % $rows === 0): ?><div class="swiper-slide item featuredproductslider-item"><?php endif; ?>

                        <div class="product-item item-product" data-product-id="<?php echo (int) $_product->getId(); ?>">
                            <?php
                            $productImage = $block->getImage($_product, $image);
                            $productImageThumb = $block->getImage($_product, 'category_image_second_small');
                            ?>
                            <div class="product-thumb">
                                <a href="<?php echo $block->escapeUrl($_product->getProductUrl()); ?>"
                                   class="product-thumb-link product photo product-item-photo"
                                   tabindex="-1"
                                   aria-label="<?php echo $block->escapeHtmlAttr($_product->getName()); ?>">
                                    <span class="first-thumb">
                                        <?php
                                        $_imgHtml = $productImage->toHtml();
                                        $_imgHtml = str_replace('loading="eager"', 'loading="lazy"', $_imgHtml);
                                        if (strpos($_imgHtml, 'loading=') === false) {
                                            $_imgHtml = str_replace('<img ', '<img loading="lazy" decoding="async" ', $_imgHtml);
                                        }
                                        echo $_imgHtml;
                                        ?>
                                    </span>
                                    <?php if ($_product->getTypeID() === 'simple'): ?>
                                        <span class="second-thumb">
                                            <?php
                                            $_thumbHtml = $productImageThumb->toHtml();
                                            if (strpos($_thumbHtml, 'loading=') === false) {
                                                $_thumbHtml = str_replace('<img ', '<img loading="lazy" decoding="async" ', $_thumbHtml);
                                            }
                                            echo $_thumbHtml;
                                            ?>
                                        </span>
                                    <?php endif; ?>
                                </a>

                                <div class="hot-onsale">
                                    <?php if ($_product->getFinalPrice() < $_product->getPrice()): ?>
                                        <span class="onsale">
                                            <span class="sale-bg"></span>
                                            <span class="sale-text"><?php echo $block->escapeHtml(__('Sale')); ?></span>
                                        </span>
                                    <?php else: ?>
                                        <?php $newLabelHelper = $this->helper('Rokanthemes\RokanBase\Helper\Newlabel'); ?>
                                        <?php if ($newLabelHelper->isProductNew($_product)): ?>
                                            <div class="onsale new-lable"><?php echo $block->escapeHtml(__('Hot')); ?></div>
                                        <?php endif; ?>
                                    <?php endif; ?>
                                </div>
                            </div>

                            <div class="product-info">
                                <h3 class="product-name">
                                    <a class="product-item-link"
                                       href="<?php echo $block->escapeUrl($_product->getProductUrl()); ?>"
                                       title="<?php echo $block->escapeHtmlAttr($_helper->productAttribute($_product, $_product->getName(), 'name')); ?>">
                                        <?php echo $block->escapeHtml($_helper->productAttribute($_product, $_product->getName(), 'name')); ?>
                                    </a>
                                </h3>

                                <div class="awa-b2b-sku">
                                    <span class="awa-b2b-sku__label"><?php echo $block->escapeHtml(__('Cod:')); ?></span>
                                    <span class="awa-b2b-sku__value"><?php echo $block->escapeHtml($_product->getSku()); ?></span>
                                </div>

                                <?php if ($this->getConfig('show_price')): ?>
                                    <div class="info-price">
                                        <?php /* @noEscape */ echo $this->helper('Rokanthemes\Themeoption\Helper\Data')->getPriceDisplayCustom($block->getProductPrice($_product)); ?>
                                    </div>
                                <?php endif; ?>

                                <?php if ($this->getConfig('review')): ?>
                                    <div class="product-rating">
                                        <?php echo $block->getReviewsSummaryHtml($_product, $templateType); ?>
                                    </div>
                                <?php endif; ?>

                                <div class="product-info-cart">
                                    <div class="actions-primary addcart-link">
                                        <?php if ($_product->isSaleable()): ?>
                                            <?php $postParams = $block->getAddToCartPostParams($_product); ?>
                                            <form data-role="tocart-form" action="<?php echo $block->escapeUrl($postParams['action']); ?>" method="post">
                                                <input type="hidden" name="product" value="<?php echo $block->escapeHtmlAttr($postParams['data']['product']); ?>">
                                                <input type="hidden" name="<?php echo $block->escapeHtmlAttr(Action::PARAM_NAME_URL_ENCODED); ?>" value="<?php echo $block->escapeHtmlAttr($postParams['data'][Action::PARAM_NAME_URL_ENCODED]); ?>">
                                                <?php echo $block->getBlockHtml('formkey'); ?>
                                                <button type="submit" title="<?php echo $block->escapeHtmlAttr(__('Add to Cart')); ?>" class="btn-add-to-cart action tocart primary">
                                                    <span><?php echo $block->escapeHtml(__('Add to Cart')); ?></span>
                                                </button>
                                            </form>
                                        <?php else: ?>
                                            <?php if ($_product->isAvailable()): ?>
                                                <div class="stock available"><span><?php echo $block->escapeHtml(__('In stock')); ?></span></div>
                                            <?php else: ?>
                                                <div class="stock unavailable"><span><?php echo $block->escapeHtml(__('Out of stock')); ?></span></div>
                                            <?php endif; ?>
                                        <?php endif; ?>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <?php $i++; ?>
                        <?php if ($i % $rows === 0): ?></div><?php endif; ?>
                    <?php endforeach; ?>
                    <?php if ($i % $rows !== 0): ?></div><?php endif; ?>
                </div>
                <div class="swiper-button-prev" aria-label="<?php echo $block->escapeHtmlAttr(__('Anterior')); ?>"></div>
                <div class="swiper-button-next" aria-label="<?php echo $block->escapeHtmlAttr(__('Próximo')); ?>"></div>
            </div>
        </div>

        <?php if (!$block->isRedirectToCartEnabled()): ?>
            <script type="text/x-magento-init">
            {
                "[data-role=tocart-form], .form.map.checkout": {
                    "catalogAddToCart": {}
                }
            }
            </script>
        <?php endif; ?>

        <script type="text/x-magento-init">
        {
            ".rokan-featuredproduct": {
                "js/tab-swiper-init": {
                    "carouselSelector": ".awa-featured-swiper",
                    "owl": {
                        "items": 4,
                        "itemsDesktop": [1366, 4],
                        "itemsDesktopSmall": [980, 3],
                        "itemsTablet": [768, 2],
                        "itemsMobile": [479, 1],
                        "navigation": true,
                        "pagination": false,
                        "scrollPerPage": true
                    }
                }
            }
        }
        </script>
    <?php endif; ?>
</div>
