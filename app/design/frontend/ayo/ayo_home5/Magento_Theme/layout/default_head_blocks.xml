<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="css/themes5.css"/>
        <css src="css/awa-core.css"/>
        <css src="css/awa-layout.css"/>
        <css src="css/awa-components.css"/>
        <css src="css/awa-consistency.css"/>
        <css src="css/awa-consistency-ui.css"/>
        <!-- R35: awa-consistency-home5.css movido para cms_index_index.xml (homepage-only).
             todas as regras ja sao scopadas via :is(body.cms-index-index, body.cms-home, ...)
             entao carrega-lo globalmente desperdicava ~18 kb de parse em paginas nao-homepage. -->
        <css src="css/awa-fixes.css"/>
        <css src="css/awa-grid-unified.css"/>
    </head>
    <body>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.master.fix.js"
                   template="Magento_Theme::html/awa-js-loader.phtml"/>
        </referenceContainer>
    </body>
</page>
