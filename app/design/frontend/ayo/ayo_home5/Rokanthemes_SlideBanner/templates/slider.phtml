 *
 * AWA SlideBanner Fix - 2026-02-10
 * - singleItem:true for hero banners (always 1 slide)
 * - autoHeight:true for SVG/mixed aspect ratios
 * - afterInit callback to trigger text animations
 * - touchDrag/mouseDrag for mobile swipe
 *
 * @var \Rokanthemes\SlideBanner\Block\Slider $block
 */

// @codingStandardsIgnoreFile
if ($banners = $block->getBannerCollection()):
    $slider = $block->getSlider();
    $sliderId = $block->getSliderId();
    $settings = $slider->getSliderSetting();
    $owlConfig = [
        'singleItem' => true,
        'autoHeight' => true,
        'lazyLoad' => true,
        'touchDrag' => true,
        'mouseDrag' => true,
        'transitionStyle' => 'fade',
    ];
    $booleanKeys = ['autoPlay', 'navigation', 'stopOnHover', 'pagination', 'scrollPerPage'];

    $legacyHosts = ['srv1113343.hstgr.cloud', 'www.srv1113343.hstgr.cloud'];
    $baseUrl = rtrim((string) $block->getBaseUrl(), '/');
    $baseHost = (string) parse_url($baseUrl, PHP_URL_HOST);
    $baseScheme = (string) parse_url($baseUrl, PHP_URL_SCHEME);
    $resolveSlideLink = static function (?string $link) use ($legacyHosts, $baseHost, $baseScheme): string {
        if (!is_string($link)) {
            return '';
        }

        $link = trim($link);
        if ($link === '') {
            return '';
        }

        $parts = parse_url($link);
        if (!is_array($parts)) {
            return $link;
        }

        $linkHost = isset($parts['host']) ? strtolower((string) $parts['host']) : '';
        if ($linkHost === '' || !in_array($linkHost, $legacyHosts, true) || $baseHost === '' || $baseScheme === '') {
            return $link;
        }

        $path = isset($parts['path']) ? (string) $parts['path'] : '/';
        $path = $path !== '' ? $path : '/';
        $query = isset($parts['query']) ? ('?' . $parts['query']) : '';
        $fragment = isset($parts['fragment']) ? ('#' . $parts['fragment']) : '';

        return $baseScheme . '://' . $baseHost . $path . $query . $fragment;
    };

    foreach ($settings as $key => $value) {
        if (in_array($key, $booleanKeys, true)) {
            $owlConfig[$key] = ((int) $value) === 1;
            continue;
        }

        if (is_string($value)) {
            $trimmed = trim($value);

            if (is_numeric($trimmed)) {
                $owlConfig[$key] = (strpos($trimmed, '.') !== false) ? (float) $trimmed : (int) $trimmed;
                continue;
            }
        }

        $owlConfig[$key] = $value;
    }
?>
<div class="wrapper_slider hidden-xs slider_<?php echo (int) $sliderId; ?>">
    <div class="owl">
        <?php foreach ($banners as $banner) { if ($banner->getSlideStatus() == '2') { continue; } ?>
            <div class="banner_item">
                <div class="banner_item_bg">
                    <?php
                    $slideAlt = $banner->getSlideText() ?: ($banner->getSlideTitle() ?: '');
                    $html = $block->getImageElement($banner->getSlideImage(), $slideAlt);
                    $link = $resolveSlideLink($banner->getSlideLink());
                    if ($link !== '') {
                        $html = '<a href="' . $block->escapeUrl($link) . '">' . $html . '</a>';
                    }
                    echo $html;
                    ?>
                </div>
                <div class="text-banner">
                    <?php if ($text = $banner->getSlideText()) {
                        echo $block->getContentText($text);
                    }
                    ?>
                </div>
            </div>
        <?php } ?>
    </div>
</div>
<div class="wrapper_slider visible-xs slider_<?php echo (int) $sliderId; ?>_mobile">
    <div class="owl">
        <?php foreach ($banners as $banner) { if ($banner->getSlideStatus() == '2') { continue; } ?>
            <div class="banner_item">
                <div class="banner_item_bg">
                    <?php
                    $slideAlt = $banner->getSlideText() ?: ($banner->getSlideTitle() ?: '');
                    $html = $block->getImageElementMobile($banner->getSlideImageMobile(), $slideAlt);
                    $link = $resolveSlideLink($banner->getSlideLink());
                    if ($link !== '') {
                        $html = '<a href="' . $block->escapeUrl($link) . '">' . $html . '</a>';
                    }
                    echo $html;
                    ?>
                </div>
                <div class="text-banner">
                    <?php if ($text = $banner->getSlideText()) {
                        echo $block->getContentText($text);
                    }
                    ?>
                </div>
            </div>
        <?php } ?>
    </div>
</div>
<script>
    require([
        'jquery',
        'mage/mage',
        'rokanthemes/owl'
    ], function ($) {
        'use strict';

        function doAnimations(elems) {
            var animEndEv = 'webkitAnimationEnd animationend';
            elems.each(function () {
                var $this = $(this),
                    $animationType = $this.data('animation');
                if ($animationType) {
                    $this.addClass($animationType).one(animEndEv, function () {
                        $this.removeClass($animationType);
                    });
                }
            });
        }

        var owlConfig = $.extend(true, {}, <?php echo json_encode($owlConfig, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES); ?>, {
            afterInit: function (elem) {
                var $firstSlide = elem.find('.owl-item').eq(0);
                doAnimations($firstSlide.find('.text-banner').find("[data-animation ^= 'animated']"));
            },
            afterMove: function (elem) {
                var $currentSlide = elem.find('.owl-item').eq(this.currentItem);
                doAnimations($currentSlide.find('.text-banner').find("[data-animation ^= 'animated']"));
            }
        });

        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            owlConfig.autoPlay = false;
        }

        $(".slider_<?php echo (int) $sliderId; ?> .owl").owlCarousel(owlConfig);
        $(".slider_<?php echo (int) $sliderId; ?>_mobile .owl").owlCarousel(owlConfig);
    });
</script>
<?php endif; ?>
