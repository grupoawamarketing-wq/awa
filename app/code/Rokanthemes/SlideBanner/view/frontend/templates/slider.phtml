<?php
/**
 * AWA Motos - Slideshow Template
 * Atualizado com acessibilidade, performance e <picture> responsivo
 * Eliminado HTML duplicado desktop/mobile: usa <picture><source> + <img>
 */

// @codingStandardsIgnoreFile
if ($banners = $block->getBannerCollection()):
    $slider = $block->getSlider();
    $sliderId = $block->getSliderId();
    $sliderSettings = $slider->getSliderSetting();
    $totalSlides = is_countable($banners) ? count($banners) : 0;
?>

<!-- Slider unificado com <picture> responsivo -->
<div class="wrapper_slider slider_<?php echo $sliderId; ?>"
     role="region"
     aria-label="<?php echo $block->escapeHtml(__('Apresentação de slides promocional')); ?>"
     aria-roledescription="carousel"
     aria-live="off">
    <div class="owl" role="list">
        <?php
        $slideIndex = 0;
        foreach ($banners as $banner):
            if ($banner->getSlideStatus() == '2') { continue; }
            $slideIndex++;
            $slideAlt = $banner->getSlideText() ?: ($banner->getSlideTitle() ?: __('Slide %1', $slideIndex));
        ?>
        <div class="banner_item" role="listitem" aria-label="<?php echo $block->escapeHtml(__('Slide %1 de %2', $slideIndex, $totalSlides)); ?>">
            <?php
                $isFirst = ($slideIndex === 1);
                $desktopSrc = $banner->getSlideImage();
                $mobileSrc = $banner->getSlideImageMobile();
                $rawText = (string) $banner->getSlideText();
                $hasOverlay = (strpos($rawText, '<') !== false);
                $pictureHtml = $block->getPictureElement($desktopSrc, $mobileSrc, $slideAlt, $isFirst);
                $overlayHtml = $hasOverlay
                    ? '<div class="slide-caption" aria-hidden="true">' . $block->getContentText($rawText) . '</div>'
                    : '';
                $inner = $pictureHtml . $overlayHtml;
                if ($link = $banner->getSlideLink()) {
                    $inner = '<a href="' . $block->escapeUrl($link) . '" title="' . $block->escapeHtml($slideAlt) . '">' . $inner . '</a>';
                }
                echo $inner;
            ?>
        </div>
        <?php endforeach; ?>
    </div>
</div>

<script>
    require([
        'jquery',
        'mage/mage',
        'rokanthemes/owl'
    ], function ($) {
        'use strict';

        var sliderConfig = {
            lazyLoad: true,
            singleItem: true,
            <?php
            $allowedOwlKeys = ['autoPlay','autoplay','navigation','stopOnHover','pagination','scrollPerPage','autoSpeed','speed','slideSpeed','paginationSpeed','rewindSpeed','items','itemsDesktop','itemsDesktopSmall','itemsTablet','itemsMobile','singleItem','transitionStyle','loop'];
            $boolKeys = ['autoPlay','autoplay','navigation','stopOnHover','pagination','scrollPerPage'];
            $settings = [];
            foreach ($sliderSettings as $key => $value) {
                if (!in_array($key, $allowedOwlKeys)) { continue; }
                if (in_array($key, $boolKeys)) {
                    $value = $value ? 'true' : 'false';
                } else {
                    $value = json_encode($value);
                }
                $settings[] = $key . ': ' . $value;
            }
            echo implode(',', $settings);
            ?>
        };

        // Respeitar preferências do usuário (reduce motion)
        try {
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                if (Object.prototype.hasOwnProperty.call(sliderConfig, 'autoPlay')) {
                    sliderConfig.autoPlay = false;
                }
                if (Object.prototype.hasOwnProperty.call(sliderConfig, 'autoplay')) {
                    sliderConfig.autoplay = false;
                }
            }
        } catch (e) {}

        function enhanceOwlA11y($root) {
            var $owl = $root.find('.owl');
            if (!$owl.length || typeof $owl.owlCarousel !== 'function') {
                return;
            }

            function applyState() {
                var $items = $owl.find('.owl-item');
                if (!$items.length) {
                    return;
                }

                $items.each(function () {
                    var $item = $(this);
                    var isActive = $item.hasClass('active');
                    $item.attr('aria-hidden', isActive ? 'false' : 'true');

                    var $links = $item.find('a, button');
                    if ($links.length) {
                        $links.attr('tabindex', isActive ? '0' : '-1');
                    }
                });

                var $prev = $root.find('.owl-prev');
                var $next = $root.find('.owl-next');
                $prev.attr({'aria-label': '<?php echo __('Slide anterior') ?>', 'role': 'button', 'tabindex': '0'});
                $next.attr({'aria-label': '<?php echo __('Próximo slide') ?>', 'role': 'button', 'tabindex': '0'});

                $root.find('.owl-pagination')
                    .attr({'role': 'tablist', 'aria-label': '<?php echo __('Indicadores de slides') ?>'});

                var $pages = $root.find('.owl-page');
                $pages.each(function (index) {
                    var $page = $(this);
                    var isSelected = $page.hasClass('active');
                    $page.attr({
                        'role': 'tab',
                        'aria-label': '<?php echo __('Ir para slide') ?> ' + (index + 1),
                        'aria-selected': isSelected ? 'true' : 'false',
                        'tabindex': isSelected ? '0' : '-1'
                    });
                });
            }

            $owl.on('initialized.owl.carousel refreshed.owl.carousel changed.owl.carousel', function () {
                applyState();
            });

            $root.on('keydown', '.owl-prev, .owl-next, .owl-page', function (ev) {
                if (ev.key === 'Enter' || ev.key === ' ') {
                    ev.preventDefault();
                    $(this).trigger('click');
                }
            });
        }

        var $sliderRoot = $(".slider_<?php echo $sliderId; ?>");
        $sliderRoot.find('.owl').owlCarousel(sliderConfig);
        enhanceOwlA11y($sliderRoot);
    });
</script>
<?php endif; ?>
