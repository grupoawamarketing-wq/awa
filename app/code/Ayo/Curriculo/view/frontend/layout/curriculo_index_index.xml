<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Trabalhe Conosco | AWA Motos</title>
        <css src="Ayo_Curriculo::css/curriculo-progress.css" />
    </head>
    <body>
        <attribute name="class" value="curriculo-page" />
        <referenceBlock name="page.main.title" remove="true" />
        <referenceContainer name="content">
            <block class="Ayo\Curriculo\Block\Form" name="curriculo.form" template="Ayo_Curriculo::form.phtml" />
        </referenceContainer>
        <referenceContainer name="after.body.start">
            <block class="Magento\Framework\View\Element\Template" name="curriculo.schema.jobposting" template="Ayo_Curriculo::jobposting.phtml" />
        </referenceContainer>
    </body>
</page>
