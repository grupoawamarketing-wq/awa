<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Acompanhe sua Candidatura | AWA Motos</title>
        <css src="Ayo_Curriculo::css/curriculo-progress.css" />
    </head>
    <body>
        <attribute name="class" value="curriculo-status-page" />
        <referenceBlock name="page.main.title">
            <action method="setPageTitle">
                <argument name="title" xsi:type="string" translate="true">Acompanhe sua Candidatura</argument>
            </action>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template" name="curriculo.status" template="Ayo_Curriculo::status.phtml" />
        </referenceContainer>
    </body>
</page>
