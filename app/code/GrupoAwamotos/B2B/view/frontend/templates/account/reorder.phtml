<?php
/** @var \GrupoAwamotos\B2B\Block\Account\Reorder $block */
$orders = $block->getRecentOrders(10);
?>
<div class="b2b-reorder-page b2b-page-shell"
     data-mage-init='<?= /* @noEscape */ json_encode(['GrupoAwamotos_B2B/js/account/reorder' => new \stdClass()]) ?>'>
    <div class="b2b-section-header">
        <h1><?= __('Repetir Pedido') ?></h1>
        <p class="section-subtitle"><?= __('Selecione um pedido anterior para adicionar os produtos ao carrinho com preços atualizados do seu grupo.') ?></p>
    </div>

    <?php if ($orders->getSize() > 0): ?>
        <?php foreach ($orders as $order): ?>
        <div class="reorder-card">
            <div class="reorder-card__header">
                <div class="reorder-card__info">
                    <strong><?= __('Pedido #%1', $block->escapeHtml($order->getIncrementId())) ?></strong>
                    <span class="reorder-card__date"><?= $block->escapeHtml(date('d/m/Y', strtotime($order->getCreatedAt()))) ?></span>
                    <span class="reorder-card__status reorder-status--<?= $block->escapeHtmlAttr($order->getStatus()) ?>">
                        <?= $block->escapeHtml($order->getStatusLabel()) ?>
                    </span>
                </div>
                <div class="reorder-card__total">
                    <?= /* @noEscape */ $block->formatPrice((float)$order->getGrandTotal()) ?>
                </div>
            </div>

            <form method="post" action="<?= $block->escapeUrl($block->getReorderUrl()) ?>">
                <?= $block->getBlockHtml('formkey') ?>
                <input type="hidden" name="order_id" value="<?= (int)$order->getId() ?>" />

                <table class="reorder-items">
                    <thead>
                        <tr>
                            <th class="col-select">
                                <input type="checkbox"
                                       checked
                                       class="js-reorder-toggle-all"
                                       data-order-id="<?= (int) $order->getId() ?>" />
                            </th>
                            <th><?= __('Produto') ?></th>
                            <th><?= __('SKU') ?></th>
                            <th><?= __('Qtd') ?></th>
                            <th><?= __('Preço Original') ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($order->getAllVisibleItems() as $item): ?>
                        <tr>
                            <td class="col-select">
                                <input type="checkbox" name="items[]" value="<?= (int)$item->getItemId() ?>" checked
                                       class="js-reorder-item-check"
                                       data-order-id="<?= (int) $order->getId() ?>" />
                            </td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Produto')) ?>"><?= $block->escapeHtml($item->getName()) ?></td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('SKU')) ?>"><?= $block->escapeHtml($item->getSku()) ?></td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Qtd')) ?>"><?= (int)$item->getQtyOrdered() ?></td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Preço')) ?>"><?= /* @noEscape */ $block->formatPrice((float)$item->getPrice()) ?></td>
                        </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>

                <div class="reorder-card__actions">
                    <button type="submit" class="btn-reorder">
                        <?= __('Adicionar ao Carrinho') ?>
                    </button>
                    <span class="reorder-note"><?= __('Preços serão atualizados conforme seu grupo B2B') ?></span>
                </div>
            </form>
        </div>
        <?php endforeach; ?>
    <?php else: ?>
        <p class="empty-message"><?= __('Nenhum pedido encontrado para reordenar.') ?></p>
    <?php endif; ?>
</div>
