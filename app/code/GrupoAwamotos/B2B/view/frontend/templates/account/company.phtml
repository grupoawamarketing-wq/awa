<?php
/** @var \GrupoAwamotos\B2B\Block\Account\CompanyBlock $block */
$company = $block->getCompany();
$users = $block->getCompanyUsers();
$isAdmin = $block->isCompanyAdmin();
$roles = $block->getRoles();
$companyManagerConfig = [
    'manageUrl' => $block->getManageUserUrl(),
    'messages' => [
        'emailRequired' => (string) __('Informe o e-mail.'),
        'confirmRemove' => (string) __('Remover este usuário da empresa?'),
        'requestError' => (string) __('Erro. Tente novamente.'),
    ],
];
?>
<div class="b2b-company-page b2b-page-shell"
     data-mage-init='<?= /* @noEscape */ json_encode(['GrupoAwamotos_B2B/js/account/company-manager' => $companyManagerConfig]) ?>'>
    <div class="b2b-section-header">
        <h1><?= __('Minha Empresa') ?></h1>
        <?php if ($isAdmin): ?>
            <span class="badge badge--admin"><?= __('Administrador') ?></span>
        <?php endif; ?>
    </div>

    <?php if ($company): ?>
    <!-- Dados da Empresa -->
    <div class="company-info-grid">
        <div class="company-info-card">
            <h3><?= __('Dados Cadastrais') ?></h3>
            <dl class="company-details">
                <dt><?= __('Razão Social') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('razao_social')) ?></dd>

                <?php if ($company->getData('nome_fantasia')): ?>
                <dt><?= __('Nome Fantasia') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('nome_fantasia')) ?></dd>
                <?php endif; ?>

                <dt><?= __('CNPJ') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('cnpj')) ?></dd>

                <?php if ($company->getData('inscricao_estadual')): ?>
                <dt><?= __('Inscrição Estadual') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('inscricao_estadual')) ?></dd>
                <?php endif; ?>

                <dt><?= __('E-mail') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('email')) ?></dd>

                <?php if ($company->getData('phone')): ?>
                <dt><?= __('Telefone') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('phone')) ?></dd>
                <?php endif; ?>
            </dl>
        </div>
    </div>

    <!-- Usuários da Empresa -->
    <div class="company-users-section">
        <div class="company-users-header">
            <h2><?= __('Usuários da Empresa') ?> <span class="count">(<?= count($users) ?>)</span></h2>
            <?php if ($isAdmin): ?>
                <button type="button" class="btn-add-user" data-action="toggle-add-user">
                    <?= __('+ Adicionar Usuário') ?>
                </button>
            <?php endif; ?>
        </div>

        <?php if ($isAdmin): ?>
        <div id="add-user-form" class="add-user-form hidden">
            <div class="form-row">
                <input type="email" id="new-user-email" placeholder="<?= $block->escapeHtmlAttr(__('E-mail do cliente Magento')) ?>" class="input-text" />
                <select id="new-user-role" class="select">
                    <?php foreach ($roles as $roleCode => $roleLabel): ?>
                        <option value="<?= $block->escapeHtmlAttr($roleCode) ?>"><?= $block->escapeHtml($roleLabel) ?></option>
                    <?php endforeach; ?>
                </select>
                <button type="button" class="btn-save" data-action="add-user">
                    <?= __('Adicionar') ?>
                </button>
            </div>
            <p class="form-note"><?= __('O e-mail precisa estar cadastrado na loja.') ?></p>
        </div>
        <?php endif; ?>

        <table class="data table table-company-users">
            <thead>
                <tr>
                    <th><?= __('Nome') ?></th>
                    <th><?= __('E-mail') ?></th>
                    <th><?= __('Papel') ?></th>
                    <th><?= __('Status') ?></th>
                    <?php if ($isAdmin): ?>
                        <th><?= __('Ações') ?></th>
                    <?php endif; ?>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($users as $user): ?>
                <tr>
                    <td data-th="<?= $block->escapeHtmlAttr(__('Nome')) ?>"><?= $block->escapeHtml($user['name']) ?></td>
                    <td data-th="<?= $block->escapeHtmlAttr(__('E-mail')) ?>"><?= $block->escapeHtml($user['email']) ?></td>
                    <td data-th="<?= $block->escapeHtmlAttr(__('Papel')) ?>">
                        <span class="role-badge role-badge--<?= $block->escapeHtmlAttr($user['role']) ?>">
                            <?= $block->escapeHtml($user['role_label']) ?>
                        </span>
                    </td>
                    <td data-th="<?= $block->escapeHtmlAttr(__('Status')) ?>">
                        <span class="status-dot <?= $user['is_active'] ? 'status-dot--active' : 'status-dot--inactive' ?>"></span>
                        <?= $user['is_active'] ? __('Ativo') : __('Inativo') ?>
                    </td>
                    <?php if ($isAdmin): ?>
                    <td data-th="<?= $block->escapeHtmlAttr(__('Ações')) ?>" class="user-actions">
                        <select class="select select-sm js-user-role"
                                data-customer-id="<?= (int) $user['customer_id'] ?>">
                            <?php foreach ($roles as $roleCode => $roleLabel): ?>
                                <option value="<?= $block->escapeHtmlAttr($roleCode) ?>" <?= $user['role'] === $roleCode ? 'selected' : '' ?>>
                                    <?= $block->escapeHtml($roleLabel) ?>
                                </option>
                            <?php endforeach; ?>
                        </select>
                        <button type="button" class="btn-remove"
                                data-action="remove-user"
                                data-customer-id="<?= (int) $user['customer_id'] ?>">
                            <?= __('Remover') ?>
                        </button>
                    </td>
                    <?php endif; ?>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <?php else: ?>
        <p class="empty-message"><?= __('Nenhuma empresa vinculada à sua conta. Entre em contato com o suporte.') ?></p>
    <?php endif; ?>
</div>
