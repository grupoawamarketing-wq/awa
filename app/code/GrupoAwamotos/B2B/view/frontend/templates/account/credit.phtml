<?php
/** @var \GrupoAwamotos\B2B\Block\Account\Credit $block */
$credit = $block->getCreditLimit();
$transactions = $block->getTransactions();
$usagePercent = $block->getUsagePercent();
?>
<div class="b2b-credit-page b2b-page-shell">
    <div class="b2b-section-header">
        <h1><?= __('Meu Crédito B2B') ?></h1>
    </div>

    <!-- Resumo de Crédito -->
    <div class="credit-summary-cards">
        <div class="credit-card credit-card--limit">
            <span class="credit-card__label"><?= __('Limite Total') ?></span>
            <span class="credit-card__value"><?= /* @noEscape */ $block->formatPrice($credit->getCreditLimit()) ?></span>
        </div>
        <div class="credit-card credit-card--used">
            <span class="credit-card__label"><?= __('Utilizado') ?></span>
            <span class="credit-card__value"><?= /* @noEscape */ $block->formatPrice($credit->getUsedCredit()) ?></span>
        </div>
        <div class="credit-card credit-card--available">
            <span class="credit-card__label"><?= __('Disponível') ?></span>
            <span class="credit-card__value"><?= /* @noEscape */ $block->formatPrice($credit->getAvailableCredit()) ?></span>
        </div>
    </div>

    <!-- Barra de Uso -->
    <div class="credit-usage-bar">
        <div class="credit-usage-bar__label">
            <span><?= __('Uso do Crédito') ?></span>
            <span><?= number_format(min(100.0, (float)$usagePercent), 0) ?>%</span>
        </div>
        <div class="credit-usage-bar__track">
            <div class="credit-usage-bar__fill <?= $usagePercent > 80 ? 'credit-usage-bar__fill--warning' : '' ?>"
                 style="width: <?= min(100.0, (float)$usagePercent) ?>%"></div>
        </div>
    </div>

    <!-- Histórico de Transações -->
    <div class="credit-transactions">
        <h2><?= __('Histórico de Transações') ?></h2>

        <?php if ($transactions->getSize() > 0): ?>
            <table class="data table table-credit-transactions">
                <thead>
                    <tr>
                        <th><?= __('Data') ?></th>
                        <th><?= __('Tipo') ?></th>
                        <th><?= __('Valor') ?></th>
                        <th><?= __('Saldo Após') ?></th>
                        <th><?= __('Referência') ?></th>
                        <th><?= __('Observação') ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($transactions as $txn): ?>
                        <?php $amount = (float) $txn->getData('amount'); ?>
                        <tr>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Data')) ?>">
                                <?= $block->escapeHtml(date('d/m/Y H:i', strtotime($txn->getData('created_at')))) ?>
                            </td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Tipo')) ?>">
                                <span class="txn-type txn-type--<?= $block->escapeHtmlAttr($txn->getData('type')) ?>">
                                    <?= $block->escapeHtml($block->getTransactionTypeLabel($txn->getData('type'))) ?>
                                </span>
                            </td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Valor')) ?>" class="<?= $amount >= 0 ? 'txn-positive' : 'txn-negative' ?>">
                                <?= $amount >= 0 ? '+' : '' ?><?= /* @noEscape */ $block->formatPrice($amount) ?>
                            </td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Saldo')) ?>">
                                <?= /* @noEscape */ $block->formatPrice((float) $txn->getData('balance_after')) ?>
                            </td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Ref')) ?>"><?= $block->escapeHtml($txn->getData('reference')) ?></td>
                            <td data-th="<?= $block->escapeHtmlAttr(__('Obs')) ?>"><?= $block->escapeHtml($txn->getData('comment')) ?></td>
                        </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        <?php else: ?>
            <p class="empty-message"><?= __('Nenhuma transação registrada ainda.') ?></p>
        <?php endif; ?>
    </div>
</div>
