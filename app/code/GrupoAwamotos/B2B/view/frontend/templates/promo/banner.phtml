                    <div class="benefit-icon">
                        <span class="icon-<?= $block->escapeHtmlAttr($benefit['icon']) ?>"></span>
                    </div>
                    <div class="benefit-content">
                        <strong><?= $block->escapeHtml(__($benefit['title'])) ?></strong>
                        <span><?= $block->escapeHtml(__($benefit['description'])) ?></span>
                    </div>
                </div>
                <?php endforeach; ?>
            </div>
            
            <div class="b2b-promo-actions">
                <a href="<?= $block->escapeUrl($block->isGuest() ? $block->getLoginUrl() : $block->getRegisterUrl()) ?>"
