.b2b-login-already a:hover{text-decoration:underline}
</style>
<div class="b2b-login-modal-overlay" id="b2b-login-modal" aria-hidden="true" inert>
    <div class="b2b-login-modal" role="dialog" aria-modal="true" aria-labelledby="b2b-login-title" aria-describedby="b2b-login-desc" tabindex="-1">
        <div class="b2b-login-modal-header">
            <button type="button" class="b2b-login-modal-close" data-b2b-login-close aria-label="<?= $escaper->escapeHtmlAttr(__('Fechar')) ?>">&times;</button>
            <h3 id="b2b-login-title"><?= $escaper->escapeHtml($isStrictB2B ? __('Portal de Compra Empresarial') : __('Faça login para comprar')) ?></h3>
            <p id="b2b-login-desc"><?= $escaper->escapeHtml($isStrictB2B ? __('Cadastre sua empresa ou faça login para visualizar preços e comprar no atacado.') : __('Crie sua conta e aproveite nossas ofertas!')) ?></p>
        </div>
        <div class="b2b-login-modal-body">
            <div class="b2b-login-options">
                <?php if (!$isStrictB2B): ?>
                <a href="<?= $registerUrl ?>" class="b2b-login-option">
                    <span class="b2b-login-option-title"><?= $escaper->escapeHtml(__('Cadastro Pessoa Física')) ?></span>
                    <span class="b2b-login-option-desc"><?= $escaper->escapeHtml(__('Para compras pessoais - rápido e fácil')) ?></span>
                </a>
                <?php endif; ?>

                <a href="<?= $b2bRegisterUrl ?>" class="b2b-login-option b2b-primary">
                    <span class="b2b-login-option-title"><?= $escaper->escapeHtml(__('Cadastro Empresarial (B2B)')) ?></span>
                    <span class="b2b-login-option-desc"><?= $escaper->escapeHtml($isStrictB2B ? __('Para empresas, oficinas e revendas com CNPJ e condições especiais.') : __('Revendedores e empresas - descontos especiais!')) ?></span>
                </a>
            </div>

            <div class="b2b-login-already">
                <?= $escaper->escapeHtml(__('Já tem conta?')) ?> <a href="<?= $loginUrl ?>"><?= $escaper->escapeHtml(__('Fazer login')) ?></a>
            </div>
        </div>
    </div>
</div>
<?php endif; ?>

<?php if ($isPending): ?>
<!-- Banner de Conta Pendente (Logado mas n&atilde;o aprovado) -->
<div class="b2b-pending-banner" id="b2b-pending-banner" style="display:none;">
    <div class="b2b-pending-banner-inner">
        <svg class="b2b-pending-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <div class="b2b-pending-text">
            <strong><?= $escaper->escapeHtml(__('Conta pendente de aprovação')) ?></strong>
            <span><?= $pendingMessage ?></span>
        </div>
        <a href="<?= $accountUrl ?>" class="b2b-pending-account-link"><?= $escaper->escapeHtml(__('Minha Conta')) ?></a>
    </div>
</div>
<?php endif; ?>

