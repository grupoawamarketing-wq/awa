.b2b-login-modal{background:rgba(255,255,255,0.98);border-radius:24px;max-width:480px;width:92%;padding:32px;box-shadow:0 30px 60px -12px rgba(0,0,0,0.45);border:1px solid rgba(255,255,255,0.4);transform:translateY(20px) scale(0.95);transition:transform 0.4s cubic-bezier(0.175,0.885,0.32,1.275), opacity 0.3s ease;opacity:0}
