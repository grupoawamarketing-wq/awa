<?php
declare(strict_types=1);

/**
 * Template for B2B access restriction.
 * - Guests: shows login/register modal + replaces add-to-cart buttons
 * - Non-approved users: shows pending message + hides add-to-cart and checkout buttons
 */

/** @var \GrupoAwamotos\B2B\Block\LoginToCart $block */
/** @var \Magento\Framework\Escaper $escaper */

$isGuest = $block->isGuest();
$isPending = $block->isPendingApproval();
$isStrictB2B = $block->isStrictB2B();
$loginUrl = $escaper->escapeUrl($block->getLoginUrl());
$registerUrl = $escaper->escapeUrl($block->getRegisterUrl());
$b2bRegisterUrl = $escaper->escapeUrl($block->getB2bRegisterUrl());
$accountUrl = $escaper->escapeUrl($block->getAccountUrl());
$pendingMessage = $escaper->escapeHtml($block->getPendingMessage());

// Mode determines body class and JS behavior
$mode = $isGuest ? 'guest' : 'pending';
?>

<?php if ($isGuest): ?>
<!-- Modal de Login para Comprar (Visitante) -->
<!-- M19: Critical inline CSS para overlay (evita FOUC se CSS async não carregou) -->
<style>
.b2b-login-modal-overlay{position:fixed;inset:0;z-index:var(--z-overlay,500);background:rgba(15,23,42,0.65);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);opacity:0;transition:opacity 0.3s ease;pointer-events:none}
