.b2b-login-modal-header{text-align:center;margin-bottom:24px;position:relative}
.b2b-login-modal-close{position:absolute;top:-16px;right:-16px;width:40px;height:40px;border-radius:50%;border:none;background:#f3f4f6;color:#374151;font-size:24px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s}
