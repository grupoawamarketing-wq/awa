<?php
declare(strict_types=1);
/**
 * M21: B2B Breadcrumbs
 * @var \Magento\Framework\View\Element\Template $block
 */
$homeUrl = $block->escapeUrl($block->getUrl(''));
$b2bDashUrl = $block->escapeUrl($block->getUrl('b2b/account/dashboard'));
$pageTitle = $block->escapeHtml((string) $block->getData('page_title'));
?>
<div class="container b2b-breadcrumbs-container">
    <div class="breadcrumbs b2b-breadcrumbs" aria-label="<?= $block->escapeHtmlAttr(__('Navegação')) ?>">
        <ul class="items">
            <li class="item home">
                <a href="<?= $homeUrl ?>" title="<?= $block->escapeHtmlAttr(__('Ir para a página inicial')) ?>">
                    <?= $block->escapeHtml(__('Home')) ?>
                </a>
            </li>
            <li class="item b2b-portal">
                <a href="<?= $b2bDashUrl ?>" title="<?= $block->escapeHtmlAttr(__('Portal B2B')) ?>">
                    <?= $block->escapeHtml(__('Portal B2B')) ?>
                </a>
            </li>
            <?php if ($pageTitle): ?>
            <li class="item current">
                <strong><?= /* @noEscape */ $pageTitle ?></strong>
            </li>
            <?php endif; ?>
        </ul>
    </div>
</div>
