<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\B2B\Block\Customer\ShoppingList\ListBlock"
                   name="b2b.shopping.list.index"
                   template="GrupoAwamotos_B2B::customer/shoppinglist/index.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\B2B\ViewModel\ShoppingListViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template"
                   name="b2b.breadcrumbs"
                   template="GrupoAwamotos_B2B::navigation/breadcrumbs.phtml"
                   before="-">
                <arguments>
                    <argument name="page_title" xsi:type="string"></argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
