<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="2columns-left"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Minhas Cotações</title>
    </head>
    <update handle="customer_account"/>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\B2B\Block\Quote\History"
                   name="b2b.quote.history"
                   template="GrupoAwamotos_B2B::quote/history.phtml"/>
        </referenceContainer>
        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template"
                   name="b2b.breadcrumbs"
                   template="GrupoAwamotos_B2B::navigation/breadcrumbs.phtml"
                   before="-">
                <arguments>
                    <argument name="page_title" xsi:type="string">Minhas Cotações</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
