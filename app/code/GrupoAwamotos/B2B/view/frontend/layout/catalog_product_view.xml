<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="GrupoAwamotos_B2B::css/product/login-to-cart.css"/>
    </head>
    <body>
        <!-- B2B: Customer-specific price comparison on PDP -->
        <referenceContainer name="product.info.main">
            <block class="GrupoAwamotos\B2B\Block\Product\CustomerPriceInfo"
                   name="b2b.customer.price.info"
                   template="GrupoAwamotos_B2B::product/customer-price-info.phtml"
                   after="product.info.price"/>
        </referenceContainer>

        <referenceContainer name="product.info.extrahint">
            <block class="Magento\Catalog\Block\Product\View"
                   name="b2b.secondary.ctas"
                   template="Magento_Catalog::product/view/b2b_secondary_ctas.phtml"
                   after="-"/>
        </referenceContainer>

        <!-- B2B: Botão de Solicitar Cotação na PDP (após Add to Cart) -->
        <referenceContainer name="product.info.form.content">
            <block class="GrupoAwamotos\B2B\Block\Quote\Button"
                   name="b2b.quote.button.pdp"
                   template="GrupoAwamotos_B2B::quote/button.phtml"
                   after="product.info.addtocart">
                <arguments>
                    <argument name="context" xsi:type="string">product</argument>
                </arguments>
            </block>
        </referenceContainer>

        <!-- B2B: Login-to-cart restriction for guests/pending on PDP -->
        <referenceContainer name="before.body.end">
            <block class="GrupoAwamotos\B2B\Block\LoginToCart"
                   name="b2b.login.to.cart.pdp"
                   template="GrupoAwamotos_B2B::product/login-to-cart.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
