<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Solicitar Cotação</title>
        <css src="GrupoAwamotos_B2B::css/account/pages.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\B2B\Block\Quote\Form"
                   name="b2b.quote.form"
                   template="GrupoAwamotos_B2B::quote/form.phtml">
                <block class="Magento\Checkout\Block\Cart\Sidebar"
                       name="b2b.quote.cart.items"
                       template="GrupoAwamotos_B2B::quote/items.phtml"/>
            </block>
        </referenceContainer>
        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template"
                   name="b2b.breadcrumbs"
                   template="GrupoAwamotos_B2B::navigation/breadcrumbs.phtml"
                   before="-">
                <arguments>
                    <argument name="page_title" xsi:type="string">Solicitar Cotação</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
