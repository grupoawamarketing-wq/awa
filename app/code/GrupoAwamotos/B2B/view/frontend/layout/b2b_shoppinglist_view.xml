<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\B2B\Block\Customer\ShoppingList\ViewBlock"
                   name="b2b.shopping.list.view"
                   template="GrupoAwamotos_B2B::customer/shoppinglist/view.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\B2B\ViewModel\ShoppingListViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
