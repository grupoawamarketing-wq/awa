<?xml version="1.0"?>
<!--
/**
 * Checkout Layout - B2B Fields Before Payment
 * P0-1: PO Number + Terms + P2-4.2: Order Notes
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="b2b_checkout_styles"/>
    <body>
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="billing-step" xsi:type="array">
                                            <item name="children" xsi:type="array">
                                                <item name="payment" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <!-- b2b fields before payment methods -->
                                                        <item name="beforeMethods" xsi:type="array">
                                                            <item name="children" xsi:type="array">
                                                                <item name="b2b-po-number" xsi:type="array">
                                                                    <item name="component" xsi:type="string">grupoawamotos_b2b/js/view/checkout/po-number</item>
                                                                    <item name="displayArea" xsi:type="string">beforemethods</item>
                                                                    <item name="sortOrder" xsi:type="string">5</item>
                                                                </item>
                                                                <item name="b2b-terms" xsi:type="array">
                                                                    <item name="component" xsi:type="string">grupoawamotos_b2b/js/view/checkout/b2b-terms</item>
                                                                    <item name="displayArea" xsi:type="string">beforemethods</item>
                                                                    <item name="sortOrder" xsi:type="string">10</item>
                                                                </item>
                                                                <item name="b2b-order-notes" xsi:type="array">
                                                                    <item name="component" xsi:type="string">grupoawamotos_b2b/js/view/checkout/order-notes</item>
                                                                    <item name="displayArea" xsi:type="string">beforemethods</item>
                                                                    <item name="sortOrder" xsi:type="string">15</item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
