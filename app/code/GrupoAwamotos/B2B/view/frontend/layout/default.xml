<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- awa-b2b-onda2.css carregado via tema filho (AWA_Custom/ayo_home5_child) default_head_blocks.xml -->
    </head>
    <body>
        <!-- === REMOVER ELEMENTOS B2C DO HEADER/GLOBAL === -->
        <!-- Barra de comparação de produtos no rodapé -->
        <referenceBlock name="catalog.compare.sidebar" remove="true"/>
        <!-- Link Compare no header -->
        <referenceBlock name="catalog.compare.link" remove="true"/>
        <!-- Link Wishlist no header links (top.links) -->
        <referenceBlock name="wish-list-link" remove="true"/>
        <!-- Mini Wishlist sidebar -->
        <referenceBlock name="wishlist_sidebar" remove="true"/>
        <!-- JS components wishlist (remove overhead desnecessário) -->
        <referenceBlock name="wishlist_page_head_components" remove="true"/>

        <!-- b2b.quickorder.link — DESATIVADO -->
    </body>
</page>
