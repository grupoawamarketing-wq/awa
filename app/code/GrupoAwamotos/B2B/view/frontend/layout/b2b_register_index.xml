<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="empty" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="b2b_auth_shell"/>
    <head>
        <title>Cadastro B2B - Pessoa Jurídica</title>
        <css src="GrupoAwamotos_B2B::css/account/register.css"/>
    </head>
    <body>
        <referenceContainer name="main">
            <block class="Magento\Framework\View\Element\Messages"
                   name="b2b.register.messages"
                   before="-"/>
            <block class="GrupoAwamotos\B2B\Block\Register\Form" name="b2b.register.form" template="GrupoAwamotos_B2B::register/form.phtml" cacheable="false"/>
        </referenceContainer>
    </body>
</page>
