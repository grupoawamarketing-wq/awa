<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="2columns-left"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Minha Conta B2B</title>
        <css src="GrupoAwamotos_B2B::css/account/dashboard.css"/>
        <css src="GrupoAwamotos_B2B::css/account/dashboard-refinement.css"/>
        <css src="GrupoAwamotos_B2B::css/account/dashboard-visual-upgrade.css"/>
    </head>
    <update handle="customer_account"/>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\B2B\Block\Account\Dashboard"
                   name="b2b.account.dashboard"
                   template="GrupoAwamotos_B2B::account/dashboard.phtml"
                   cacheable="false">
                <!-- ERP Suggestions block as child (data + intelligence template) -->
                <block class="GrupoAwamotos\ERPIntegration\Block\Customer\Suggestions"
                       name="erp.dashboard.suggestions"
                       template="GrupoAwamotos_B2B::account/dashboard/intelligence.phtml"/>
                <!-- RexisML AI Recommendations (data reais do pipeline) -->
                <block class="GrupoAwamotos\ProductIntelligence\Block\Recommendations"
                       name="rexisml.b2b.recommendations"
                       template="GrupoAwamotos_ProductIntelligence::b2b/recommendations-widget.phtml">
                    <arguments>
                        <argument name="limit" xsi:type="number">6</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template"
                   name="b2b.breadcrumbs"
                   template="GrupoAwamotos_B2B::navigation/breadcrumbs.phtml"
                   before="-">
                <arguments>
                    <argument name="page_title" xsi:type="string">Minha Conta B2B</argument>
                </arguments>
            </block>
        </referenceContainer>
        <referenceBlock name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="b2b.shepherd.css"
                   template="GrupoAwamotos_B2B::head/shepherd-css.phtml"/>
            <!-- Late-loading CSS: bypass merge, loads AFTER awa-bundle-refinements.css -->
            <block class="Magento\Framework\View\Element\Template"
                   name="b2b.dashboard.late.css"
                   template="GrupoAwamotos_B2B::head/b2b-dashboard-css.phtml"
                   after="b2b.shepherd.css"/>
        </referenceBlock>
    </body>
</page>
