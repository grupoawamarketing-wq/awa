        <css src="GrupoAwamotos_B2B::css/commercial-cockpit.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\B2B\CommercialPanel\Block\Adminhtml\Report\Index"
                   name="awa.commercial.report"
