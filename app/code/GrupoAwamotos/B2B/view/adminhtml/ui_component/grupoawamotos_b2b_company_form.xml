<?xml version="1.0"?>
<!--
/**
 * B2B Company Edit Form
 */
-->
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">grupoawamotos_b2b_company_form.grupoawamotos_b2b_company_form_data_source</item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="back" class="Magento\Backend\Block\Widget\Button\Back"/>
            <button name="save" class="Magento\Backend\Block\Widget\Button\Save"/>
        </buttons>
        <namespace>grupoawamotos_b2b_company_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>grupoawamotos_b2b_company_form.grupoawamotos_b2b_company_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="grupoawamotos_b2b_company_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="grupoawamotos_b2b/company/save"/>
        </settings>
        <dataProvider class="GrupoAwamotos\B2B\Ui\DataProvider\Company\FormDataProvider"
                      name="grupoawamotos_b2b_company_form_data_source"
                      primaryFieldName="company_id"
                      requestFieldName="company_id">
            <settings>
                <requestFieldName>company_id</requestFieldName>
                <primaryFieldName>company_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general" sortOrder="10">
        <settings>
            <collapsible>false</collapsible>
            <label translate="true">Informações da Empresa</label>
        </settings>

        <field name="company_id" formElement="hidden">
            <settings>
                <dataType>text</dataType>
                <dataScope>company_id</dataScope>
            </settings>
        </field>

        <field name="cnpj" formElement="input" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">CNPJ</label>
                <dataScope>cnpj</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">20</rule>
                </validation>
            </settings>
        </field>

        <field name="razao_social" formElement="input" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Razão Social</label>
                <dataScope>razao_social</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">255</rule>
                </validation>
            </settings>
        </field>

        <field name="nome_fantasia" formElement="input" sortOrder="30">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Nome Fantasia</label>
                <dataScope>nome_fantasia</dataScope>
                <validation>
                    <rule name="max_text_length" xsi:type="number">255</rule>
                </validation>
            </settings>
        </field>

        <field name="inscricao_estadual" formElement="input" sortOrder="40">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Inscrição Estadual</label>
                <dataScope>inscricao_estadual</dataScope>
                <validation>
                    <rule name="max_text_length" xsi:type="number">30</rule>
                </validation>
            </settings>
        </field>

        <field name="email" formElement="input" sortOrder="50">
            <settings>
                <dataType>text</dataType>
                <label translate="true">E-mail da Empresa</label>
                <dataScope>email</dataScope>
                <validation>
                    <rule name="validate-email" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">255</rule>
                </validation>
            </settings>
        </field>

        <field name="phone" formElement="input" sortOrder="60">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Telefone</label>
                <dataScope>phone</dataScope>
                <validation>
                    <rule name="max_text_length" xsi:type="number">20</rule>
                </validation>
            </settings>
        </field>

        <field name="admin_customer_id" formElement="input" sortOrder="70">
            <settings>
                <dataType>text</dataType>
                <label translate="true">ID do Cliente Admin (Magento)</label>
                <dataScope>admin_customer_id</dataScope>
                <notice translate="true">ID do cliente Magento administrador desta empresa.</notice>
                <validation>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="is_active" formElement="checkbox" sortOrder="80">
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Ativo</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>

</form>
