<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">awa_commercial_abandoned_cart_listing.awa_commercial_abandoned_cart_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>awa_commercial_abandoned_cart_columns</spinner>
        <deps>
            <dep>awa_commercial_abandoned_cart_listing.awa_commercial_abandoned_cart_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="awa_commercial_abandoned_cart_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::commercial_abandoned_cart</aclResource>
        <dataProvider class="GrupoAwamotos\B2B\CommercialPanel\Ui\DataProvider\AbandonedCartDataProvider"
                      name="awa_commercial_abandoned_cart_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="awa_commercial_abandoned_cart_columns">
        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
            </settings>
        </column>
        <column name="customer_display">
            <settings>
                <filter>text</filter>
                <label translate="true">Cliente</label>
            </settings>
        </column>
        <column name="customer_email">
            <settings>
                <filter>text</filter>
                <label translate="true">E-mail</label>
            </settings>
        </column>
        <column name="b2b_cnpj">
            <settings>
                <filter>text</filter>
                <label translate="true">CNPJ</label>
            </settings>
        </column>
        <column name="b2b_phone">
            <settings>
                <filter>text</filter>
                <label translate="true">Telefone</label>
            </settings>
        </column>
        <column name="cart_value">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Valor</label>
            </settings>
        </column>
        <column name="items_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Itens</label>
            </settings>
        </column>
        <column name="abandoned_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Abandonado em</label>
            </settings>
        </column>
        <column name="attendant_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Vendedora</label>
            </settings>
        </column>
        <column name="commercial_contact_status">
            <settings>
                <filter>text</filter>
                <label translate="true">Status de contato</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="GrupoAwamotos\B2B\CommercialPanel\Ui\Component\Listing\Column\AbandonedCartActions">
            <settings>
                <indexField>entity_id</indexField>
                <label translate="true">Ações</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
