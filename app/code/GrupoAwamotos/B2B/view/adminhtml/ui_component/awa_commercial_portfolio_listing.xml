<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">awa_commercial_portfolio_listing.awa_commercial_portfolio_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>awa_commercial_portfolio_columns</spinner>
        <deps>
            <dep>awa_commercial_portfolio_listing.awa_commercial_portfolio_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="awa_commercial_portfolio_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::commercial_portfolio</aclResource>
        <dataProvider class="GrupoAwamotos\B2B\CommercialPanel\Ui\DataProvider\PortfolioDataProvider"
                      name="awa_commercial_portfolio_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="awa_commercial_portfolio_columns">
        <column name="customer_display">
            <settings>
                <filter>text</filter>
                <label translate="true">Cliente</label>
            </settings>
        </column>
        <column name="b2b_cnpj">
            <settings>
                <filter>text</filter>
                <label translate="true">CNPJ</label>
            </settings>
        </column>
        <column name="city">
            <settings>
                <filter>text</filter>
                <label translate="true">Cidade</label>
            </settings>
        </column>
        <column name="email">
            <settings>
                <filter>text</filter>
                <label translate="true">E-mail</label>
            </settings>
        </column>
        <column name="attendant_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Vendedora</label>
            </settings>
        </column>
        <column name="commercial_status">
            <settings>
                <filter>text</filter>
                <label translate="true">Status Comercial</label>
            </settings>
        </column>
        <column name="last_order_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Última compra</label>
            </settings>
        </column>
        <column name="last_contact_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Último contato</label>
            </settings>
        </column>
        <column name="no_contact_flag">
            <settings>
                <filter>select</filter>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <label translate="true">Sem contato recente</label>
            </settings>
        </column>
        <column name="no_purchase_flag">
            <settings>
                <filter>select</filter>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <label translate="true">Sem compra recente</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="GrupoAwamotos\B2B\CommercialPanel\Ui\Component\Listing\Column\PortfolioActions">
            <settings>
                <indexField>entity_id</indexField>
                <label translate="true">Ações</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
