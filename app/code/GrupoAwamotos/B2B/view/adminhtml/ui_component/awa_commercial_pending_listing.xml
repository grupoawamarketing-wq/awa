<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">awa_commercial_pending_listing.awa_commercial_pending_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>awa_commercial_pending_columns</spinner>
        <deps>
            <dep>awa_commercial_pending_listing.awa_commercial_pending_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="awa_commercial_pending_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::commercial_pending</aclResource>
        <dataProvider class="GrupoAwamotos\B2B\Ui\DataProvider\CustomerPendingDataProvider"
                      name="awa_commercial_pending_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="awa_commercial_pending_columns">
        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="firstname">
            <settings>
                <filter>text</filter>
                <label translate="true">Nome</label>
            </settings>
        </column>
        <column name="lastname">
            <settings>
                <filter>text</filter>
                <label translate="true">Sobrenome</label>
            </settings>
        </column>
        <column name="email">
            <settings>
                <filter>text</filter>
                <label translate="true">E-mail</label>
            </settings>
        </column>
        <column name="b2b_cnpj">
            <settings>
                <filter>text</filter>
                <label translate="true">CNPJ</label>
            </settings>
        </column>

        <column name="b2b_receita_situacao">
            <settings>
                <filter>text</filter>
                <label translate="true">Status Receita</label>
            </settings>
        </column>

        <column name="erp_customer_sync_status" class="GrupoAwamotos\B2B\Ui\Component\Listing\Column\ErpSyncStatusLabel">
            <settings>
                <filter>select</filter>
                <options class="GrupoAwamotos\B2B\Model\Customer\Attribute\Source\ErpCustomerSyncStatus"/>
                <label translate="true">Status ERP</label>
                <dataType>select</dataType>
            </settings>
        </column>

        <column name="b2b_registration_campaign">
            <settings>
                <filter>text</filter>
                <label translate="true">Origem CNAME / Campanha</label>
            </settings>
        </column>

        <column name="b2b_origin_host">
            <settings>
                <filter>text</filter>
                <label translate="true">Origem Host</label>
            </settings>
        </column>

        <column name="b2b_utm_source">
            <settings>
                <filter>text</filter>
                <label translate="true">UTM Source</label>
            </settings>
        </column>

        <column name="b2b_utm_medium">
            <settings>
                <filter>text</filter>
                <label translate="true">UTM Medium</label>
            </settings>
        </column>

        <column name="b2b_utm_campaign">
            <settings>
                <filter>text</filter>
                <label translate="true">UTM Campaign</label>
            </settings>
        </column>

        <column name="attendant_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Vendedor Responsável</label>
            </settings>
        </column>

        <column name="b2b_razao_social">
            <settings>
                <filter>text</filter>
                <label translate="true">Razão Social</label>
            </settings>
        </column>
        <column name="b2b_cnae_profile">
            <settings>
                <filter>text</filter>
                <label translate="true">Perfil CNAE</label>
            </settings>
        </column>
        <column name="b2b_approval_score" class="GrupoAwamotos\B2B\Ui\Component\Listing\Column\ApprovalScoreColumn">
            <settings>
                <filter>select</filter>
                <options class="GrupoAwamotos\B2B\Model\Customer\Attribute\Source\ApprovalScore"/>
                <label translate="true">Score B2B</label>
                <dataType>select</dataType>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Data Cadastro</label>
            </settings>
        </column>

        <column name="last_erp_sync_display" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Última Sync ERP</label>
                <dataType>date</dataType>
            </settings>
        </column>

        <column name="erp_block_reason">
            <settings>
                <filter>text</filter>
                <label translate="true">Motivo do Bloqueio</label>
            </settings>
        </column>
    </columns>
</listing>
