<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">grupoawamotos_b2b_company_listing.grupoawamotos_b2b_company_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="grupoawamotos_b2b/company/edit"/>
                <class>primary</class>
                <label translate="true">Nova Empresa</label>
            </button>
        </buttons>
        <spinner>grupoawamotos_b2b_company_columns</spinner>
        <deps><dep>grupoawamotos_b2b_company_listing.grupoawamotos_b2b_company_listing_data_source</dep></deps>
    </settings>
    <dataSource name="grupoawamotos_b2b_company_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig><param name="indexField" xsi:type="string">company_id</param></storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::companies</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="grupoawamotos_b2b_company_listing_data_source">
            <settings>
                <requestFieldName>company_id</requestFieldName>
                <primaryFieldName>company_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings><sticky>true</sticky></settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="grupoawamotos_b2b_company_columns">
        <column name="company_id">
            <settings><filter>textRange</filter><label translate="true">ID</label><sorting>asc</sorting></settings>
        </column>
        <column name="cnpj">
            <settings><filter>text</filter><label translate="true">CNPJ</label></settings>
        </column>
        <column name="razao_social">
            <settings><filter>text</filter><label translate="true">Razão Social</label></settings>
        </column>
        <column name="nome_fantasia">
            <settings><filter>text</filter><label translate="true">Nome Fantasia</label></settings>
        </column>
        <column name="email">
            <settings><filter>text</filter><label translate="true">E-mail</label></settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter><dataType>select</dataType><label translate="true">Ativo</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings><filter>dateRange</filter><dataType>date</dataType><label translate="true">Criado em</label></settings>
        </column>
        <actionsColumn name="actions" class="Magento\Ui\Component\Listing\Columns\EditAction">
            <settings>
                <indexField>company_id</indexField>
                <editUrlPath>grupoawamotos_b2b/company/edit</editUrlPath>
            </settings>
        </actionsColumn>
    </columns>
</listing>
