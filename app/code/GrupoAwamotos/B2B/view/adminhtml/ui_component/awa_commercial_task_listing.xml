<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">awa_commercial_task_listing.awa_commercial_task_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>awa_commercial_task_columns</spinner>
        <deps>
            <dep>awa_commercial_task_listing.awa_commercial_task_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="awa_commercial_task_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::commercial_tasks</aclResource>
        <dataProvider class="GrupoAwamotos\B2B\CommercialPanel\Ui\DataProvider\TaskDataProvider"
                      name="awa_commercial_task_listing_data_source">
            <settings>
                <requestFieldName>task_id</requestFieldName>
                <primaryFieldName>task_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="awa_commercial_task_columns">
        <column name="customer_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Cliente</label>
            </settings>
        </column>
        <column name="attendant_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Vendedora</label>
            </settings>
        </column>
        <column name="task_type_label">
            <settings>
                <filter>text</filter>
                <label translate="true">Tipo</label>
            </settings>
        </column>
        <column name="priority">
            <settings>
                <filter>text</filter>
                <label translate="true">Prioridade</label>
            </settings>
        </column>
        <column name="due_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Prazo</label>
            </settings>
        </column>
        <column name="status">
            <settings>
                <filter>text</filter>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="source_label">
            <settings>
                <filter>text</filter>
                <label translate="true">Origem</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Criada em</label>
            </settings>
        </column>
        <column name="completed_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Concluída em</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="GrupoAwamotos\B2B\CommercialPanel\Ui\Component\Listing\Column\TaskActions">
            <settings>
                <indexField>task_id</indexField>
                <label translate="true">Ações</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
