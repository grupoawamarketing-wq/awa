<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">awa_commercial_goal_listing.awa_commercial_goal_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>awa_commercial_goal_columns</spinner>
        <deps>
            <dep>awa_commercial_goal_listing.awa_commercial_goal_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="awa_commercial_goal_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::commercial_goals</aclResource>
        <dataProvider class="GrupoAwamotos\B2B\CommercialPanel\Ui\DataProvider\CommercialGoalDataProvider"
                      name="awa_commercial_goal_listing_data_source">
            <settings>
                <requestFieldName>attendant_id</requestFieldName>
                <primaryFieldName>attendant_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings><sticky>true</sticky></settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="awa_commercial_goal_columns">
        <column name="attendant_name"><settings><label translate="true">Vendedora</label></settings></column>
        <column name="period_month"><settings><label translate="true">Mês</label></settings></column>
        <column name="revenue_goal"><settings><label translate="true">Meta Faturamento</label></settings></column>
        <column name="revenue_actual"><settings><label translate="true">Realizado</label></settings></column>
        <column name="revenue_pct"><settings><label translate="true">% Fatur.</label></settings></column>
        <column name="revenue_remaining"><settings><label translate="true">Pendente Fatur.</label></settings></column>
        <column name="contacts_goal"><settings><label translate="true">Meta Contatos</label></settings></column>
        <column name="contacts_actual"><settings><label translate="true">Contatos</label></settings></column>
        <column name="contacts_pct"><settings><label translate="true">% Contatos</label></settings></column>
        <column name="reactivated_goal"><settings><label translate="true">Meta Reativados</label></settings></column>
        <column name="reactivated_actual"><settings><label translate="true">Reativados</label></settings></column>
        <column name="reactivated_pct"><settings><label translate="true">% Reativ.</label></settings></column>
    </columns>
</listing>
