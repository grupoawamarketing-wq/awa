                    </div>
                    <div class="att-form-row">
                        <label><?= $block->escapeHtml(__('Status')) ?></label>
                        <select name="status" id="att-fu-status">
                            <option value="open"><?= $block->escapeHtml(__('Em aberto')) ?></option>
                            <option value="scheduled"><?= $block->escapeHtml(__('Agendado')) ?></option>
                            <option value="done"><?= $block->escapeHtml(__('Concluído')) ?></option>
                        </select>
                    </div>
                    <div class="att-form-actions">
                        <button type="button" class="att-btn-sm" onclick="attCloseFollowup()"><?= $block->escapeHtml(__('Cancelar')) ?></button>
                        <button type="button" class="att-btn-sm att-btn-primary" onclick="attSaveFollowup()"><?= $block->escapeHtml(__('Salvar Follow-up')) ?></button>
                    </div>
                </form>
            </div>
        </div>

        <script>
        var attFollowupSaveUrl = '<?= $block->escapeJs($block->getFollowupSaveUrl()) ?>';
        var attFormKey = '<?= $block->escapeJs($block->getFormKey()) ?>';

        function attOpenFollowup(followupId, customerId) {
            document.getElementById('att-fu-id').value = followupId || 0;
            document.getElementById('att-fu-customer-id').value = customerId || 0;
            document.getElementById('att-fu-modal-title').textContent = followupId
                ? '<?= $block->escapeJs(__('Editar Follow-up')) ?>'
                : '<?= $block->escapeJs(__('Novo Follow-up')) ?>';
            document.getElementById('att-fu-obs').value = '';
            document.getElementById('att-fu-result').value = '';
            document.getElementById('att-fu-next').value = '';
            document.getElementById('att-fu-type').value = 'whatsapp';
            document.getElementById('att-fu-status').value = 'open';
            document.getElementById('att-followup-modal').classList.add('open');
        }

        function attCloseFollowup() {
            document.getElementById('att-followup-modal').classList.remove('open');
        }

        function attSaveFollowup() {
            var obs = document.getElementById('att-fu-obs').value.trim();
            if (!obs) { alert('<?= $block->escapeJs(__('A observação é obrigatória.')) ?>'); return; }

            var data = {
                form_key:       attFormKey,
                followup_id:    document.getElementById('att-fu-id').value,
                customer_id:    document.getElementById('att-fu-customer-id').value,
                contact_type:   document.getElementById('att-fu-type').value,
                observation:    obs,
                result:         document.getElementById('att-fu-result').value,
                next_contact_at:document.getElementById('att-fu-next').value,
                status:         document.getElementById('att-fu-status').value,
            };

            var params = new URLSearchParams(data).toString();
            fetch(attFollowupSaveUrl, {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
                body: params
            })
            .then(r => r.json())
            .then(function(res) {
                if (res.success) {
                    attCloseFollowup();
                    window.location.reload();
                } else {
                    alert(res.message || '<?= $block->escapeJs(__('Erro ao salvar.')) ?>');
                }
            })
            .catch(function() { alert('<?= $block->escapeJs(__('Erro de comunicação com o servidor.')) ?>'); });
        }

        // Fechar modal ao clicar fora
        document.getElementById('att-followup-modal').addEventListener('click', function(e) {
            if (e.target === this) attCloseFollowup();
        });
        </script>

    </div>
<?php endif; ?>
