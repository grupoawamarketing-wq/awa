<script>
require([
    'jquery',
    'mage/translate'
], function ($, $t) {
    'use strict';

    var saveUrl = <?= /* @noEscape */ json_encode($block->getSaveUrl()) ?>;
    var indexUrl = <?= /* @noEscape */ json_encode($block->getIndexUrl()) ?>;
    var form = $('#attendant-management-form-element');
    var messageContainer = $('[data-role="attendant-form-messages"]');

    function renderMessage(type, message) {
        var wrapper = $('<div/>', {
            'class': 'message message-' + type + ' ' + type
        });

        wrapper.append($('<div/>').text(message));
        messageContainer.empty().append(wrapper);
        window.location.hash = 'attendant-management-form';
    }

    $('[data-role="save-attendant"]').on('click', function () {
        if (!form[0].reportValidity()) {
            return;
        }

        messageContainer.empty();

        $.ajax({
            url: saveUrl,
            type: 'POST',
            dataType: 'json',
            data: form.serialize(),
            showLoader: true
        }).done(function (response) {
            if (!response || response.success !== true) {
                renderMessage('error', response && response.message ? response.message : $t('Não foi possível salvar o atendente.'));
                return;
            }

            renderMessage('success', response.message || $t('Atendente salvo com sucesso.'));
            window.location.href = indexUrl + '?id=' + encodeURIComponent(response.attendant_id) + '#attendant-management-form';
        }).fail(function () {
            renderMessage('error', $t('Falha na comunicação ao salvar o atendente.'));
        });
    });
});
</script>
