    <script>
    require(['jquery'], function ($) {
        'use strict';

        function activateTab(tabId) {
            $('.awa-tab-panel').attr('hidden', true);
            $('.awa-tab-btn').removeClass('is-active');
            $('#' + tabId).removeAttr('hidden');
            $('[data-tab="' + tabId + '"]').addClass('is-active');
        }

        $('.awa-tab-btn').on('click', function () {
            activateTab($(this).data('tab'));
        });

        var hash = window.location.hash.replace('#', '');
        if (hash && $('#' + hash).length) {
            activateTab(hash);
        } else {
            activateTab('tab-resumo');
        }
    });
    </script>
<?php endif; ?>
