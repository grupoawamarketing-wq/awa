<?php
/**
 * Navegação horizontal — AWA Comercial (todas as rotas do módulo).
 *
 * @var \GrupoAwamotos\B2B\CommercialPanel\Block\Adminhtml\CommercialNavigation $block
 */

$currentAction = $block->getCurrentAction();
$navTabs = $block->getNavigationTabs();
?>

<div class="awa-commercial-navigation">
    <nav class="awa-team-tabs awa-team-tabs--global" aria-label="<?= $block->escapeHtmlAttr(__('Navegação comercial')) ?>">
        <?php foreach ($navTabs as $tab): ?>
            <?php $isActive = $currentAction === $tab['action']; ?>
            <a class="awa-team-tab<?= $isActive ? ' is-active' : '' ?>"
               href="<?= $block->escapeUrl($tab['url']) ?>"
               <?= $isActive ? 'aria-current="page"' : '' ?>>
                <?= $block->escapeHtml($tab['label']) ?>
            </a>
        <?php endforeach; ?>
    </nav>
</div>
