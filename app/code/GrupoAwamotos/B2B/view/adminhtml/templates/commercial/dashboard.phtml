/**
 * Resolve variante visual do card KPI (somente apresentação).
 */
$resolveMetricVariant = static function (int $value, string $type): string {
    if ($type === 'critical') {
        return $value > 0 ? 'critical' : 'healthy';
    }
    if ($type === 'attention') {
        return $value > 0 ? 'attention' : 'healthy';
    }

    return 'neutral';
};

/**
 * Status visual da meta por linha (somente apresentação).
 *
 * @param array<string, mixed> $goal
 * @return array{status: string, label: \Magento\Framework\Phrase}
 */
$resolveGoalStatus = static function (array $goal): array {
    $revenueGoal = (float) ($goal['revenue_goal'] ?? 0);
    $contactsGoal = (int) ($goal['contacts_goal'] ?? 0);
    $reactivatedGoal = (int) ($goal['reactivated_goal'] ?? 0);

    if ($revenueGoal <= 0 && $contactsGoal <= 0 && $reactivatedGoal <= 0) {
        return ['status' => 'neutral', 'label' => __('Sem meta')];
    }

    $pcts = [];
    if ($revenueGoal > 0) {
        $pcts[] = (float) ($goal['revenue_pct'] ?? 0);
    }
    if ($contactsGoal > 0) {
        $pcts[] = (float) ($goal['contacts_pct'] ?? 0);
    }
    if ($reactivatedGoal > 0) {
        $pcts[] = (float) ($goal['reactivated_pct'] ?? 0);
    }

    $minPct = $pcts !== [] ? min($pcts) : 0.0;

    if ($minPct >= 100) {
        return ['status' => 'success', 'label' => __('Em dia')];
    }
    if ($minPct >= 70) {
        return ['status' => 'warning', 'label' => __('Atenção')];
    }

    return ['status' => 'danger', 'label' => __('Abaixo da meta')];
};

/**
 * Classe da barra de progresso (somente apresentação).
 */
$progressBarClass = static function (float $pct): string {
    if ($pct >= 100) {
        return 'awa-team-progress__bar--success';
    }
    if ($pct >= 70) {
        return 'awa-team-progress__bar--warning';
    }

    return 'awa-team-progress__bar--danger';
};

