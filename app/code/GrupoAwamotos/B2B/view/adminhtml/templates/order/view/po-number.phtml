<?php
/**
 * Template to display B2B checkout metadata in admin order view
 * P0-1: Purchase Order Number
 * P2-4.2: Order Notes
 *
 * @var \GrupoAwamotos\B2B\Block\Adminhtml\Order\View\PoNumber $block
 */

declare(strict_types=1);

if (!$block->hasCheckoutMetadata()) {
    return;
}

$poNumber = $block->escapeHtml($block->getPoNumber());
$orderNotes = $block->getOrderNotes();
?>

<div class="admin__page-section-item b2b-po-number-section">
    <div class="admin__page-section-item-title">
        <strong class="title"><?= $block->escapeHtml($block->getTitle()) ?></strong>
    </div>
    <div class="admin__page-section-item-content">
        <table class="admin__table-secondary">
            <tbody>
                <?php if ($block->hasPoNumber()): ?>
                    <tr>
                        <th><?= $block->escapeHtml(__('Número do PO')) ?>:</th>
                        <td>
                            <span class="b2b-po-number-value">
                                <strong><?= $poNumber ?></strong>
                            </span>
                        </td>
                    </tr>
                <?php endif; ?>
                <?php if ($block->hasOrderNotes()): ?>
                    <tr>
                        <th><?= $block->escapeHtml(__('Observações do Pedido')) ?>:</th>
                        <td><?= nl2br($block->escapeHtml((string) $orderNotes)) ?></td>
                    </tr>
                <?php endif; ?>
            </tbody>
        </table>
    </div>
</div>
