<?xml version="1.0"?>
<!--
/**
 * Database Schema for B2B Module
 */
-->
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- tabela de solicitação de cotação -->
    <table name="grupoawamotos_b2b_quote_request" resource="default" engine="innodb"
           comment="B2B Quote Requests">
        <column xsi:type="int" name="request_id" unsigned="true" nullable="false" identity="true"
                comment="Request ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="customer_email" nullable="false" length="255"
                comment="Customer Email"/>
        <column xsi:type="varchar" name="customer_name" nullable="false" length="255"
                comment="Customer Name"/>
        <column xsi:type="varchar" name="company_name" nullable="true" length="255"
                comment="Company Name"/>
        <column xsi:type="varchar" name="cnpj" nullable="true" length="20"
                comment="CNPJ"/>
        <column xsi:type="varchar" name="phone" nullable="true" length="20"
                comment="Phone"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending"
                comment="Status: pending, processing, quoted, accepted, rejected, expired"/>
        <column xsi:type="text" name="items_json" nullable="false"
                comment="Requested Items JSON"/>
        <column xsi:type="text" name="message" nullable="true"
                comment="Customer Message"/>
        <column xsi:type="text" name="admin_notes" nullable="true"
                comment="Admin Notes"/>
        <column xsi:type="decimal" name="quoted_total" scale="4" precision="20" nullable="true"
                comment="Quoted Total Amount"/>
        <column xsi:type="int" name="quote_id" unsigned="true" nullable="true"
                comment="Linked Magento Quote ID"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="true"
                comment="Converted Order ID"/>
        <column xsi:type="datetime" name="expires_at" nullable="true"
                comment="Quote Expiration Date"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="datetime" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true"
                comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="request_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_QUOTE_REQUEST_CUSTOMER_ID"
                    table="grupoawamotos_b2b_quote_request" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="SET NULL"/>
        <index referenceId="GRUPOAWAMOTOS_B2B_QUOTE_REQUEST_STATUS" indexType="btree">
            <column name="status"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_QUOTE_REQUEST_CUSTOMER_EMAIL" indexType="btree">
            <column name="customer_email"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_QUOTE_REQUEST_CREATED_AT" indexType="btree">
            <column name="created_at"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_QUOTE_REQUEST_CUSTOMER_STATUS" indexType="btree">
            <column name="customer_id"/>
            <column name="status"/>
        </index>
    </table>

    <!-- itens da solicitação de cotação -->
    <table name="grupoawamotos_b2b_quote_request_item" resource="default" engine="innodb"
           comment="B2B Quote Request Items">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" identity="true"
                comment="Item ID"/>
        <column xsi:type="int" name="request_id" unsigned="true" nullable="false"
                comment="Request ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false"
                comment="Product ID"/>
        <column xsi:type="varchar" name="sku" nullable="false" length="64"
                comment="SKU"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255"
                comment="Product Name"/>
        <column xsi:type="decimal" name="qty" scale="4" precision="12" nullable="false" default="1"
                comment="Requested Quantity"/>
        <column xsi:type="decimal" name="original_price" scale="4" precision="20" nullable="true"
                comment="Original Unit Price"/>
        <column xsi:type="decimal" name="quoted_price" scale="4" precision="20" nullable="true"
                comment="Quoted Unit Price"/>
        <column xsi:type="text" name="options_json" nullable="true"
                comment="Product Options JSON"/>
        <column xsi:type="text" name="notes" nullable="true"
                comment="Item Notes"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_QUOTE_REQUEST_ITEM_REQUEST_ID"
                    table="grupoawamotos_b2b_quote_request_item" column="request_id"
                    referenceTable="grupoawamotos_b2b_quote_request" referenceColumn="request_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_QUOTE_REQUEST_ITEM_PRODUCT_ID"
                    table="grupoawamotos_b2b_quote_request_item" column="product_id"
                    referenceTable="catalog_product_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <index referenceId="GRUPOAWAMOTOS_B2B_QUOTE_REQUEST_ITEM_REQUEST_ID" indexType="btree">
            <column name="request_id"/>
        </index>
    </table>

    <!-- log de aprovação de clientes -->
    <table name="grupoawamotos_b2b_customer_approval_log" resource="default" engine="innodb"
           comment="B2B Customer Approval Log">
        <column xsi:type="int" name="log_id" unsigned="true" nullable="false" identity="true"
                comment="Log ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="action" nullable="false" length="32"
                comment="Action: registered, approved, rejected, suspended"/>
        <column xsi:type="varchar" name="old_status" nullable="true" length="32"
                comment="Previous Status"/>
        <column xsi:type="varchar" name="new_status" nullable="false" length="32"
                comment="New Status"/>
        <column xsi:type="int" name="admin_user_id" unsigned="true" nullable="true"
                comment="Admin User ID"/>
        <column xsi:type="text" name="comment" nullable="true"
                comment="Comment"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="log_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_CUSTOMER_APPROVAL_LOG_CUSTOMER_ID"
                    table="grupoawamotos_b2b_customer_approval_log" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <index referenceId="GRUPOAWAMOTOS_B2B_CUSTOMER_APPROVAL_LOG_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
    </table>

    <!-- limite de crédito do cliente b2b -->
    <table name="grupoawamotos_b2b_credit_limit" resource="default" engine="innodb"
           comment="B2B Customer Credit Limits">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false"
                comment="Customer ID"/>
        <column xsi:type="decimal" name="credit_limit" scale="4" precision="20" nullable="false" default="0"
                comment="Credit Limit Amount"/>
        <column xsi:type="decimal" name="used_credit" scale="4" precision="20" nullable="false" default="0"
                comment="Used Credit Amount"/>
        <column xsi:type="varchar" name="currency_code" nullable="false" length="3" default="BRL"
                comment="Currency Code"/>
        <column xsi:type="varchar" name="payment_terms" nullable="true" length="255"
                comment="Allowed Payment Terms JSON array"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="datetime" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true"
                comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_CREDIT_LIMIT_CUSTOMER_ID"
                    table="grupoawamotos_b2b_credit_limit" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_B2B_CREDIT_LIMIT_CUSTOMER_UNIQUE">
            <column name="customer_id"/>
        </constraint>
    </table>

    <!-- aprovação de pedidos b2b -->
    <table name="grupoawamotos_b2b_order_approval" resource="default" engine="innodb"
           comment="B2B Order Approval Workflow">
        <column xsi:type="int" name="approval_id" unsigned="true" nullable="false" identity="true"
                comment="Approval ID"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="false"
                comment="Order ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending"
                comment="Status: pending, approved, rejected, cancelled"/>
        <column xsi:type="smallint" name="current_level" unsigned="true" nullable="false" default="1"
                comment="Current Approval Level"/>
        <column xsi:type="smallint" name="required_level" unsigned="true" nullable="false" default="2"
                comment="Required Approval Level"/>
        <column xsi:type="decimal" name="order_total" scale="4" precision="20" nullable="false"
                comment="Order Total"/>
        <column xsi:type="text" name="approval_history" nullable="true"
                comment="Approval History JSON"/>
        <column xsi:type="text" name="rejection_reason" nullable="true"
                comment="Rejection Reason"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="datetime" name="updated_at" nullable="true"
                comment="Updated At"/>
        <column xsi:type="datetime" name="approved_at" nullable="true"
                comment="Final Approval Date"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="approval_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_ORDER_APPROVAL_ORDER_ID"
                    table="grupoawamotos_b2b_order_approval" column="order_id"
                    referenceTable="sales_order" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_ORDER_APPROVAL_CUSTOMER_ID"
                    table="grupoawamotos_b2b_order_approval" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <index referenceId="GRUPOAWAMOTOS_B2B_ORDER_APPROVAL_STATUS" indexType="btree">
            <column name="status"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_ORDER_APPROVAL_LEVEL" indexType="btree">
            <column name="current_level"/>
        </index>
    </table>

    <!-- listas de compras recorrentes -->
    <table name="grupoawamotos_b2b_shopping_list" resource="default" engine="innodb"
           comment="B2B Recurring Shopping Lists">
        <column xsi:type="int" name="list_id" unsigned="true" nullable="false" identity="true"
                comment="List ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255"
                comment="List Name"/>
        <column xsi:type="text" name="description" nullable="true"
                comment="List Description"/>
        <column xsi:type="boolean" name="is_default" nullable="false" default="0"
                comment="Is Default List"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="1"
                comment="Is Active"/>
        <column xsi:type="boolean" name="is_recurring" nullable="false" default="0"
                comment="Is Recurring List"/>
        <column xsi:type="smallint" name="recurring_interval" unsigned="true" nullable="true"
                comment="Recurring Interval in Days"/>
        <column xsi:type="date" name="next_order_date" nullable="true"
                comment="Next Recurring Order Date"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="datetime" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true"
                comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="list_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_SHOPPING_LIST_CUSTOMER_ID"
                    table="grupoawamotos_b2b_shopping_list" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <index referenceId="GRUPOAWAMOTOS_B2B_SHOPPING_LIST_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_SHOPPING_LIST_RECURRING" indexType="btree">
            <column name="is_recurring"/>
            <column name="next_order_date"/>
        </index>
    </table>

    <!-- itens das listas de compras -->
    <table name="grupoawamotos_b2b_shopping_list_item" resource="default" engine="innodb"
           comment="B2B Shopping List Items">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" identity="true"
                comment="Item ID"/>
        <column xsi:type="int" name="list_id" unsigned="true" nullable="false"
                comment="List ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false"
                comment="Product ID"/>
        <column xsi:type="varchar" name="sku" nullable="false" length="64"
                comment="SKU"/>
        <column xsi:type="decimal" name="qty" scale="4" precision="12" nullable="false" default="1"
                comment="Quantity"/>
        <column xsi:type="text" name="options_json" nullable="true"
                comment="Product Options JSON"/>
        <column xsi:type="text" name="notes" nullable="true"
                comment="Item Notes"/>
        <column xsi:type="datetime" name="added_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Added At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_SHOPPING_LIST_ITEM_LIST_ID"
                    table="grupoawamotos_b2b_shopping_list_item" column="list_id"
                    referenceTable="grupoawamotos_b2b_shopping_list" referenceColumn="list_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_SHOPPING_LIST_ITEM_PRODUCT_ID"
                    table="grupoawamotos_b2b_shopping_list_item" column="product_id"
                    referenceTable="catalog_product_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <index referenceId="GRUPOAWAMOTOS_B2B_SHOPPING_LIST_ITEM_LIST_ID" indexType="btree">
            <column name="list_id"/>
        </index>
    </table>


    <!-- log de transações de crédito -->
    <table name="grupoawamotos_b2b_credit_transaction" resource="default" engine="innodb"
           comment="B2B Credit Transaction Log">
        <column xsi:type="int" name="transaction_id" unsigned="true" nullable="false" identity="true"
                comment="Transaction ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="type" nullable="false" length="32"
                comment="Type: charge, refund, adjustment, payment"/>
        <column xsi:type="decimal" name="amount" scale="4" precision="20" nullable="false"
                comment="Transaction Amount"/>
        <column xsi:type="decimal" name="balance_after" scale="4" precision="20" nullable="false"
                comment="Balance After Transaction"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="true"
                comment="Related Order ID"/>
        <column xsi:type="varchar" name="reference" nullable="true" length="255"
                comment="Reference (invoice, memo, etc)"/>
        <column xsi:type="text" name="comment" nullable="true"
                comment="Comment"/>
        <column xsi:type="int" name="admin_user_id" unsigned="true" nullable="true"
                comment="Admin User Who Made Adjustment"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="transaction_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="B2B_CREDIT_TXN_CUSTOMER_ID"
                    table="grupoawamotos_b2b_credit_transaction" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <index referenceId="B2B_CREDIT_TXN_CUSTOMER" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="B2B_CREDIT_TXN_ORDER" indexType="btree">
            <column name="order_id"/>
        </index>
        <index referenceId="B2B_CREDIT_TXN_TYPE" indexType="btree">
            <column name="type"/>
        </index>
    </table>

    <!-- empresa b2b -->
    <table name="grupoawamotos_b2b_company" resource="default" engine="innodb"
           comment="B2B Company Entity">
        <column xsi:type="int" name="company_id" unsigned="true" nullable="false" identity="true"
                comment="Company ID"/>
        <column xsi:type="varchar" name="cnpj" nullable="false" length="20"
                comment="CNPJ"/>
        <column xsi:type="varchar" name="razao_social" nullable="false" length="255"
                comment="Razao Social"/>
        <column xsi:type="varchar" name="nome_fantasia" nullable="true" length="255"
                comment="Nome Fantasia"/>
        <column xsi:type="varchar" name="inscricao_estadual" nullable="true" length="30"
                comment="Inscricao Estadual"/>
        <column xsi:type="varchar" name="email" nullable="true" length="255"
                comment="Company Email"/>
        <column xsi:type="varchar" name="phone" nullable="true" length="20"
                comment="Phone"/>
        <column xsi:type="int" name="admin_customer_id" unsigned="true" nullable="true"
                comment="Company Admin Customer ID"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="1"
                comment="Is Active"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="datetime" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true"
                comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="company_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="B2B_COMPANY_CNPJ_UNIQUE">
            <column name="cnpj"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="B2B_COMPANY_ADMIN_CUSTOMER"
                    table="grupoawamotos_b2b_company" column="admin_customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="SET NULL"/>
    </table>

    <!-- usuários da empresa b2b -->
    <table name="grupoawamotos_b2b_company_user" resource="default" engine="innodb"
           comment="B2B Company Users">
        <column xsi:type="int" name="user_id" unsigned="true" nullable="false" identity="true"
                comment="User ID"/>
        <column xsi:type="int" name="company_id" unsigned="true" nullable="false"
                comment="Company ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="role" nullable="false" length="32" default="buyer"
                comment="Role: admin, manager, buyer"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="1"
                comment="Is Active"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="user_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="B2B_COMPANY_USER_COMPANY_ID"
                    table="grupoawamotos_b2b_company_user" column="company_id"
                    referenceTable="grupoawamotos_b2b_company" referenceColumn="company_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="B2B_COMPANY_USER_CUSTOMER_ID"
                    table="grupoawamotos_b2b_company_user" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="B2B_COMPANY_USER_UNIQUE">
            <column name="company_id"/>
            <column name="customer_id"/>
        </constraint>
    </table>

    <!-- transportadoras b2b (existing) -->
    <table name="grupoawamotos_b2b_carrier" resource="default" engine="innodb"
           comment="B2B Available Carriers">
        <column xsi:type="int" name="carrier_id" unsigned="true" nullable="false" identity="true"
                comment="Carrier ID"/>
        <column xsi:type="varchar" name="code" nullable="false" length="64"
                comment="Carrier Code"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255"
                comment="Carrier Name"/>
        <column xsi:type="varchar" name="logo" nullable="true" length="255"
                comment="Logo URL"/>
        <column xsi:type="varchar" name="phone" nullable="true" length="20"
                comment="Phone"/>
        <column xsi:type="varchar" name="website" nullable="true" length="255"
                comment="Website"/>
        <column xsi:type="text" name="description" nullable="true"
                comment="Description"/>
        <column xsi:type="varchar" name="delivery_time" nullable="true" length="100"
                comment="Estimated Delivery Time"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="1"
                comment="Is Active"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0"
                comment="Sort Order"/>
        <column xsi:type="datetime" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="carrier_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_B2B_CARRIER_CODE_UNIQUE">
            <column name="code"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_B2B_CARRIER_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>

    <!-- tabela de atendentes b2b (migrada de schema patch) -->
    <table name="grupoawamotos_b2b_attendants" resource="default" engine="innodb" comment="Atendentes B2B">
        <column xsi:type="int" name="attendant_id" unsigned="true" nullable="false" identity="true" comment="ID do Atendente"/>
        <column xsi:type="varchar" name="name" length="255" nullable="false" comment="Nome do Atendente"/>
        <column xsi:type="varchar" name="email" length="255" nullable="false" comment="Email"/>
        <column xsi:type="varchar" name="phone" length="50" nullable="true" comment="Telefone"/>
        <column xsi:type="varchar" name="whatsapp" length="50" nullable="true" comment="WhatsApp"/>
        <column xsi:type="varchar" name="department" length="50" nullable="false" default="sales" comment="Departamento"/>
        <column xsi:type="smallint" name="is_active" nullable="false" default="1" comment="Ativo"/>
        <column xsi:type="int" name="customer_count" nullable="false" default="0" comment="Quantidade de Clientes"/>
        <column xsi:type="int" name="max_customers" nullable="false" default="100" comment="Máximo de Clientes"/>
        <column xsi:type="int" name="admin_user_id" unsigned="true" nullable="true" comment="ID do Usuário Admin"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Data de Criação"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Data de Atualização"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="attendant_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_B2B_ATTENDANTS_EMAIL">
            <column name="email"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_B2B_ATTENDANTS_DEPT_ACTIVE" indexType="btree">
            <column name="department"/>
            <column name="is_active"/>
        </index>
    </table>

    <!-- relacionamento cliente-atendente -->
    <table name="grupoawamotos_b2b_customer_attendant" resource="default" engine="innodb" comment="Relacionamento Cliente-Atendente B2B">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" comment="ID do Cliente"/>
        <column xsi:type="int" name="attendant_id" unsigned="true" nullable="false" comment="ID do Atendente"/>
        <column xsi:type="timestamp" name="assigned_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Data de Atribuição"/>
        <column xsi:type="text" name="notes" nullable="true" comment="Observações"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_B2B_CUST_ATTENDANT_CUSTOMER_ID">
            <column name="customer_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_CUST_ATTENDANT_CUSTOMER_ID_FK"
                    table="grupoawamotos_b2b_customer_attendant" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_B2B_CUST_ATTENDANT_ATTENDANT_ID"
                    table="grupoawamotos_b2b_customer_attendant" column="attendant_id"
                    referenceTable="grupoawamotos_b2b_attendants" referenceColumn="attendant_id"
                    onDelete="CASCADE"/>
        <index referenceId="GRUPOAWAMOTOS_B2B_CUST_ATTENDANT_ATT_ID" indexType="btree">
            <column name="attendant_id"/>
        </index>
    </table>

    <!-- log de atendimento -->
    <table name="grupoawamotos_b2b_attendant_log" resource="default" engine="innodb" comment="Log de Atendimento B2B">
        <column xsi:type="int" name="log_id" unsigned="true" nullable="false" identity="true" comment="ID do Log"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" comment="ID do Cliente"/>
        <column xsi:type="int" name="attendant_id" unsigned="true" nullable="false" comment="ID do Atendente"/>
        <column xsi:type="int" name="previous_attendant_id" unsigned="true" nullable="true" comment="ID do Atendente Anterior"/>
        <column xsi:type="varchar" name="action" length="50" nullable="false" comment="Ação"/>
        <column xsi:type="varchar" name="reason" length="500" nullable="true" comment="Motivo"/>
        <column xsi:type="int" name="admin_user_id" unsigned="true" nullable="true" comment="Admin que realizou a ação"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Data"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="log_id"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_B2B_ATT_LOG_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_ATT_LOG_ATTENDANT_ID" indexType="btree">
            <column name="attendant_id"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_ATT_LOG_CREATED_AT" indexType="btree">
            <column name="created_at"/>
        </index>
    </table>

    <!-- notificações b2b -->
    <table name="grupoawamotos_b2b_notifications" resource="default" engine="innodb" comment="Notificações B2B">
        <column xsi:type="int" name="notification_id" unsigned="true" nullable="false" identity="true" comment="ID da Notificação"/>
        <column xsi:type="varchar" name="type" length="50" nullable="false" comment="Tipo (whatsapp, email, sms, push)"/>
        <column xsi:type="varchar" name="event" length="100" nullable="false" comment="Evento"/>
        <column xsi:type="varchar" name="recipient" length="255" nullable="false" comment="Destinatário"/>
        <column xsi:type="varchar" name="recipient_name" length="255" nullable="true" comment="Nome do Destinatário"/>
        <column xsi:type="text" name="message" nullable="false" comment="Mensagem"/>
        <column xsi:type="varchar" name="status" length="20" nullable="false" default="pending" comment="Status"/>
        <column xsi:type="varchar" name="external_id" length="255" nullable="true" comment="ID Externo"/>
        <column xsi:type="text" name="error_message" nullable="true" comment="Mensagem de Erro"/>
        <column xsi:type="varchar" name="entity_type" length="50" nullable="true" comment="Tipo de Entidade"/>
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="true" comment="ID da Entidade"/>
        <column xsi:type="timestamp" name="sent_at" nullable="true" comment="Data de Envio"/>
        <column xsi:type="timestamp" name="delivered_at" nullable="true" comment="Data de Entrega"/>
        <column xsi:type="timestamp" name="read_at" nullable="true" comment="Data de Leitura"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Data de Criação"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="notification_id"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_B2B_NOTIF_TYPE_STATUS" indexType="btree">
            <column name="type"/>
            <column name="status"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_NOTIF_EVENT" indexType="btree">
            <column name="event"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_NOTIF_ENTITY" indexType="btree">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_B2B_NOTIF_CREATED_AT" indexType="btree">
            <column name="created_at"/>
        </index>
    </table>

    <!-- P0-1: PO Number column in quote -->
    <table name="quote" resource="checkout" comment="Quote (Cart)">
        <column xsi:type="varchar" name="b2b_po_number" nullable="true" length="64"
                comment="B2B Purchase Order Number"/>
        <column xsi:type="varchar" name="b2b_order_notes" nullable="true" length="500"
                comment="B2B Order Notes"/>
    </table>

    <!-- P0-1: PO Number column in sales_order -->
    <table name="sales_order" resource="sales" comment="Sales Order">
        <column xsi:type="varchar" name="b2b_po_number" nullable="true" length="64"
                comment="B2B Purchase Order Number"/>
        <column xsi:type="varchar" name="b2b_order_notes" nullable="true" length="500"
                comment="B2B Order Notes"/>
    </table>

</schema>
