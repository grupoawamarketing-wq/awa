<?xml version="1.0"?>
<!--
/**
 * Admin DI Configuration for B2B Module
 * NOTA: As configurações de CollectionFactory foram movidas para etc/di.xml (global)
 * para evitar conflitos com os data sources do Magento core.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    
    <!-- Data Provider para Grid de Transportadoras -->
    <virtualType name="B2BCarrierGridDataProvider" type="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
        <arguments>
            <argument name="collection" xsi:type="object" shared="false">GrupoAwamotos\B2B\Model\ResourceModel\Carrier\Collection</argument>
            <argument name="filterPool" xsi:type="object" shared="false">B2BCarrierGridFilterPool</argument>
        </arguments>
    </virtualType>
    
    <virtualType name="B2BCarrierGridFilterPool" type="Magento\Framework\View\Element\UiComponent\DataProvider\FilterPool">
        <arguments>
            <argument name="appliers" xsi:type="array">
                <item name="regular" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\RegularFilter</item>
                <item name="fulltext" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\FulltextFilter</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- plugin para validar CNPJ ao criar pedido no admin -->
    <type name="Magento\Sales\Model\AdminOrder\Create">
        <plugin name="grupoawamotos_b2b_validate_address_cnpj"
                type="GrupoAwamotos\B2B\Plugin\AdminOrder\ValidateAddressCnpjOnCreateOrderPlugin"
                sortOrder="10"/>
    </type>

    <!-- =========================================================
         Controle de Acesso por Atendente
         ========================================================= -->

    <!-- 1. Redireciona atendentes para "Meu Painel" após login -->
    <type name="Magento\Backend\Controller\Adminhtml\Auth\Login">
        <plugin name="grupoawamotos_b2b_attendant_login_redirect"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantLoginRedirectPlugin"
                sortOrder="10"/>
    </type>

    <!-- 2. Filtra grid de Clientes (Magento core) -->
    <type name="Magento\Customer\Model\ResourceModel\Grid\Collection">
        <plugin name="grupoawamotos_b2b_attendant_customer_grid_filter"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantCustomerGridPlugin"
                sortOrder="10"/>
    </type>

    <!-- 3. Filtra grid de Pedidos (Magento core) -->
    <type name="Magento\Sales\Model\ResourceModel\Order\Grid\Collection">
        <plugin name="grupoawamotos_b2b_attendant_order_grid_filter"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantOrderGridPlugin"
                sortOrder="10"/>
    </type>

    <!-- 4. Filtra grid de Cotações B2B (custom collection) -->
    <type name="GrupoAwamotos\B2B\Model\ResourceModel\QuoteRequest\Collection">
        <plugin name="grupoawamotos_b2b_attendant_quote_grid_filter"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantQuoteGridPlugin"
                sortOrder="10"/>
    </type>

    <!-- Redireciona atendentes para o painel B2B após login -->
    <type name="Magento\Backend\Model\Url">
        <plugin name="grupoawamotos_b2b_commercial_startup_page"
                type="GrupoAwamotos\B2B\CommercialPanel\Plugin\CockpitStartupPagePlugin"
                sortOrder="5"/>
        <plugin name="grupoawamotos_b2b_attendant_startup_page"
                type="GrupoAwamotos\B2B\Plugin\AttendantStartupPagePlugin"
                sortOrder="10"/>
    </type>

    <!-- Cockpit comercial: restringe menu e bloqueia rotas técnicas -->
    <type name="Magento\Backend\Model\Menu\Config\Reader">
        <plugin name="grupoawamotos_b2b_extended_menu_config_reader"
                type="GrupoAwamotos\B2B\Platform\Plugin\Menu\ExtendedMenuConfigReaderPlugin"
                sortOrder="1"/>
        <plugin name="grupoawamotos_b2b_platform_dashboard_menu"
                type="GrupoAwamotos\B2B\Platform\Plugin\Menu\PlatformDashboardMenuPlugin"
                sortOrder="20"/>
    </type>

    <type name="Magento\Backend\Model\Menu\Config">
        <plugin name="grupoawamotos_b2b_platform_menu_visibility"
                type="GrupoAwamotos\B2B\Platform\Plugin\Menu\PlatformMenuVisibilityPlugin"
                sortOrder="5"/>
        <plugin name="grupoawamotos_b2b_commercial_menu_restriction"
                type="GrupoAwamotos\B2B\CommercialPanel\Plugin\MenuRestrictionPlugin"
                sortOrder="10"/>
    </type>

    <type name="Magento\Backend\App\AbstractAction">
        <plugin name="grupoawamotos_b2b_commercial_access_guard"
                type="GrupoAwamotos\B2B\CommercialPanel\Plugin\CockpitAccessGuardPlugin"
                sortOrder="5"/>
    </type>

</config>
