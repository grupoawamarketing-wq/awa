<?xml version="1.0"?>
<!--
/**
 * B2B System Configuration
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="grupoawamotos_b2b" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>B2B Settings</label>
            <tab>grupoawamotos</tab>
            <resource>GrupoAwamotos_B2B::config</resource>

            <!-- Configurações Gerais -->
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Configurações Gerais</label>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Módulo B2B</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Ativa todas as funcionalidades B2B</comment>
                </field>

                <field id="b2b_mode" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Modo B2B</label>
                    <source_model>GrupoAwamotos\B2B\Model\Config\Source\B2BMode</source_model>
                    <comment>Strict: apenas B2B. Mixed: B2B + B2C</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Visibilidade de Preços -->
            <group id="price_visibility" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Visibilidade de Preços</label>

                <field id="hide_price_guests" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Ocultar Preços para Visitantes</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Exibe "Faça login para ver preços" ao invés do valor</comment>
                </field>

                <field id="hide_add_to_cart_guests" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Ocultar Botão Comprar para Visitantes</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Remove o botão "Adicionar ao Carrinho" para não logados</comment>
                </field>

                <field id="login_message" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Mensagem para Visitantes</label>
                    <comment>Texto exibido no lugar do preço</comment>
                </field>

                <field id="show_price_pending" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Mostrar Preços para Clientes Pendentes</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Clientes aguardando aprovação podem ver preços?</comment>
                </field>

                <field id="hide_price_no_erp" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Ocultar Preços para Aprovados sem Código ERP</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[Clientes B2B aprovados sem código ERP não veem preços até o departamento de vendas definir a tabela.]]></comment>
                </field>

                <field id="pending_erp_message" translate="label comment" type="textarea" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Mensagem para Clientes Aguardando Tabela ERP</label>
                    <comment><![CDATA[Exibida no lugar do preço. Suporta HTML.]]></comment>
                    <depends>
                        <field id="hide_price_no_erp">1</field>
                    </depends>
                </field>
            </group>

            <!-- Aprovação de Clientes -->
            <group id="customer_approval" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Aprovação de Clientes</label>

                <field id="require_approval" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Exigir Aprovação de Novos Clientes</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Novos cadastros ficam pendentes até aprovação manual</comment>
                </field>

                <field id="auto_approve_groups" translate="label comment" type="multiselect" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Grupos com Aprovação Automática</label>
                    <source_model>Magento\Customer\Model\Config\Source\Group</source_model>
                    <comment>Clientes destes grupos são aprovados automaticamente</comment>
                    <depends>
                        <field id="require_approval">1</field>
                    </depends>
                </field>

                <field id="pending_message" translate="label comment" type="textarea" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Mensagem para Clientes Pendentes</label>
                    <comment>Exibida ao cliente após cadastro</comment>
                </field>

                <field id="send_approval_email" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enviar E-mail de Aprovação</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="notify_admin_new_customer" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Notificar Admin sobre Novos Cadastros</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="admin_email" translate="label comment" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>E-mail do Administrador</label>
                    <validate>validate-email</validate>
                    <depends>
                        <field id="notify_admin_new_customer">1</field>
                    </depends>
                </field>
            </group>

            <!-- Quantidade Mínima -->
            <group id="minimum_qty" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Quantidade Mínima</label>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Quantidade Mínima</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="global_min_qty" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Quantidade Mínima Global</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Quantidade mínima padrão para todos os produtos</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="min_order_amount" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Valor Mínimo do Pedido (R$)</label>
                    <validate>validate-number</validate>
                    <comment>Deixe vazio para desabilitar</comment>
                </field>

                <field id="min_order_message" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Mensagem de Valor Mínimo</label>
                    <comment>Use {{min_amount}}

 para o valor mínimo</comment>
                </field>
            </group>

            <!-- Sistema de Cotação -->
            <group id="quote_request" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Sistema de Cotação (RFQ)</label>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Solicitação de Cotação</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Permite clientes solicitarem orçamentos personalizados</comment>
                </field>

                <field id="show_button" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Exibir Botão "Solicitar Cotação"</label>
                    <source_model>GrupoAwamotos\B2B\Model\Config\Source\QuoteButtonPosition</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="allow_guests" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Permitir Cotação para Visitantes</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="expiry_days" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Validade da Cotação (dias)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="notify_customer" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Notificar Cliente sobre Atualizações</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Grupos de Clientes -->
            <group id="customer_groups" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Grupos de Clientes B2B</label>

                <field id="wholesale_group" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Grupo Atacado</label>
                    <source_model>Magento\Customer\Model\Config\Source\Group</source_model>
                    <comment>Grupo para clientes atacadistas</comment>
                </field>

                <field id="wholesale_discount" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Desconto Atacado (%)</label>
                    <validate>validate-number</validate>
                    <comment>Desconto padrão para o grupo atacado</comment>
                </field>

                <field id="vip_group" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Grupo VIP</label>
                    <source_model>Magento\Customer\Model\Config\Source\Group</source_model>
                    <comment>Grupo para clientes VIP com benefícios especiais</comment>
                </field>

                <field id="vip_discount" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Desconto VIP (%)</label>
                    <validate>validate-number</validate>
                </field>

                <field id="default_b2b_group" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Grupo Padrão para Novos B2B</label>
                    <source_model>Magento\Customer\Model\Config\Source\Group</source_model>
                    <comment>Grupo atribuído automaticamente após aprovação</comment>
                </field>
            </group>

            <!-- Consulta CNPJ -->
            <group id="cnpj_lookup" translate="label" type="text" sortOrder="65" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Consulta CNPJ</label>
                <comment><![CDATA[Configura a validação e o autopreenchimento via API externa de CNPJ]]></comment>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Consulta Externa</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Quando desabilitado, apenas a validação local dos dígitos verificadores é usada</comment>
                </field>

                <field id="api_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>URL Base da API</label>
                    <comment>Ex.: https://receitaws.com.br/v1/cnpj/</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="timeout" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Timeout (segundos)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Tempo máximo de espera por consulta</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="require_active_status" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Exigir Situação Ativa</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Se habilitado, CNPJ com situação diferente de ATIVA será considerado irregular</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="allow_local_fallback" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Permitir Fallback Local em Falha da API</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Quando a API cair, segue com validação local do CNPJ</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="cache_enabled" translate="label comment" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Cache de Consulta</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Reduz chamadas repetidas para o mesmo CNPJ</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="cache_ttl" translate="label comment" type="text" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>TTL do Cache (segundos)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Tempo de vida das respostas em cache (ex.: 86400 = 24h)</comment>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="cache_enabled">1</field>
                    </depends>
                </field>

                <field id="rate_limit_enabled" translate="label comment" type="select" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Rate Limit de Consulta</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Limita requisições por IP para evitar abuso e bloqueio da API</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="rate_limit_max_requests" translate="label comment" type="text" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Máx. Requisições por Janela</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Quantidade de consultas permitidas por IP dentro da janela</comment>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="rate_limit_enabled">1</field>
                    </depends>
                </field>

                <field id="rate_limit_window_seconds" translate="label comment" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Janela do Rate Limit (segundos)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Duração da janela usada para contagem de requisições</comment>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="rate_limit_enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Classificação CNAE -->
            <group id="cnae_profiling" translate="label" type="text" sortOrder="66" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Classificação CNAE</label>
                <comment><![CDATA[Classifica automaticamente novos clientes B2B pela atividade econômica (CNAE) da Receita Federal]]></comment>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Classificação CNAE</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Classifica automaticamente novos cadastros B2B pelo código CNAE retornado da ReceitaWS</comment>
                </field>

                <field id="auto_approve_direct" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Auto-aprovar Perfil Direto</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Empresas com CNAE de motos/peças de motos são aprovadas automaticamente</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="direct_cnaes" translate="label comment" type="textarea" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CNAEs - Perfil Direto (Motos)</label>
                    <comment><![CDATA[Códigos CNAE separados por vírgula. Empresas com estes CNAEs são classificadas como <strong>Perfil Direto</strong>.<br/>
                    Padrão: 4541-2/01, 4541-2/02, 4541-2/03, 4541-2/04, 4541-2/05, 4543-9/00, 3091-1/00]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="adjacent_cnaes" translate="label comment" type="textarea" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CNAEs - Perfil Adjacente (Automotivo)</label>
                    <comment><![CDATA[Códigos CNAE separados por vírgula. Empresas com estes CNAEs são classificadas como <strong>Perfil Adjacente</strong>.<br/>
                    Padrão: 4530-7/01, 4530-7/02, 4530-7/03, 4530-7/04, 4520-0/01, 4520-0/06]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Sistema de Crédito -->
            <group id="credit" translate="label" type="text" sortOrder="62" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Sistema de Crédito</label>
                <comment><![CDATA[Configure limites de crédito e pagamento por faturamento para clientes B2B]]></comment>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Sistema de Crédito</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Permite pagamento via crédito B2B no checkout</comment>
                </field>

                <field id="default_limit" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Limite Padrão (R$)</label>
                    <validate>validate-number</validate>
                    <comment>Limite de crédito padrão para novos clientes aprovados. 0 = sem crédito inicial</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="auto_debit" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Débito Automático no Pedido</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Debita automaticamente o crédito quando o pedido é faturado</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="allow_partial" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Permitir Pagamento Parcial</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>permite que o cliente use crédito parcial + outro meio de pagamento</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="payment_title" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Título no Checkout</label>
                    <comment>Nome do método de pagamento exibido no checkout</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
            </group>

            <!-- Aprovação de Pedidos -->
            <group id="order_approval" translate="label" type="text" sortOrder="63" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Aprovação de Pedidos</label>
                <comment><![CDATA[Configure o fluxo de aprovação para pedidos B2B acima de determinados valores]]></comment>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Aprovação de Pedidos</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Pedidos acima dos limites configurados entram em aprovação</comment>
                </field>

                <field id="threshold_manager" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Limite para Gerente (R$)</label>
                    <validate>validate-number</validate>
                    <comment>Pedidos acima deste valor precisam de aprovação do gerente</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="threshold_finance" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Limite para Financeiro (R$)</label>
                    <validate>validate-number</validate>
                    <comment>Pedidos acima deste valor precisam de aprovação do financeiro</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="threshold_director" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Limite para Diretor (R$)</label>
                    <validate>validate-number</validate>
                    <comment>Pedidos acima deste valor precisam de aprovação do diretor</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="notify_approver" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Notificar Aprovador</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="auto_cancel_days" translate="label comment" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Cancelar Automaticamente Após (dias)</label>
                    <validate>validate-number</validate>
                    <comment>Pedidos pendentes há mais de X dias são cancelados. 0 = desabilitado</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
            </group>

            <!-- Notificações WhatsApp -->
            <group id="whatsapp" translate="label" type="text" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Notificações WhatsApp</label>
                <comment><![CDATA[Configure o envio de notificações via WhatsApp para equipe e clientes B2B]]></comment>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar WhatsApp</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>ativa notificações via whatsapp</comment>
                </field>

                <field id="provider" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>provedor de api</label>
                    <source_model>GrupoAwamotos\B2B\Model\Config\Source\WhatsAppProvider</source_model>
                    <comment>escolha o provedor de api do whatsapp</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

