<?xml version="1.0"?>
<!--
/**
 * B2B Module Events Configuration (Global scope)
 * Frontend-specific observers are in etc/frontend/events.xml
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">

    <!-- Aprovação de cliente B2B (custom event, fires from admin) -->
    <event name="grupoawamotos_b2b_customer_approved">
        <observer name="grupoawamotos_b2b_erp_approval_sync"
                  instance="GrupoAwamotos\B2B\Observer\ErpApprovalSyncObserver"/>
        <observer name="grupoawamotos_b2b_approval_whatsapp_notification"
                  instance="GrupoAwamotos\B2B\Observer\CustomerApprovalNotification"/>
        <observer name="grupoawamotos_b2b_company_auto_create"
                  instance="GrupoAwamotos\B2B\Observer\CustomerApprovedObserver"/>
        <observer name="grupoawamotos_b2b_attendant_assign_on_approval"
                  instance="GrupoAwamotos\B2B\Observer\AttendantAssignOnApprovalObserver"/>
    </event>

    <!-- Classificação CNAE no save do cliente (fires in admin + frontend) -->
    <event name="customer_save_after_data_object">
        <observer name="grupoawamotos_b2b_cnae_classification"
                  instance="GrupoAwamotos\B2B\Observer\CnaeClassificationObserver"/>
    </event>

    <!-- Notificação de mudança de status do pedido (admin area triggers) -->
    <event name="sales_order_save_after">
        <observer name="grupoawamotos_b2b_order_status_notification"
                  instance="GrupoAwamotos\B2B\Observer\OrderStatusNotification"/>
    </event>

    <!-- Cotações B2B (custom events) -->
    <event name="grupoawamotos_b2b_quote_submit_after">
        <observer name="grupoawamotos_b2b_quote_notification"
                  instance="GrupoAwamotos\B2B\Observer\QuoteNotification"/>
    </event>

    <event name="grupoawamotos_b2b_quote_response_after">
        <observer name="grupoawamotos_b2b_quote_response_notification"
                  instance="GrupoAwamotos\B2B\Observer\QuoteNotification"/>
    </event>

    <!-- Copia PO number da cotação para o pedido -->
    <event name="sales_model_service_quote_submit_before">
        <observer name="grupoawamotos_b2b_copy_po_number"
                  instance="GrupoAwamotos\B2B\Observer\CopyPoNumberToOrder"/>
        <observer name="grupoawamotos_b2b_validate_erp_readiness"
                  instance="GrupoAwamotos\B2B\Observer\ValidateB2bOrderErpReadinessObserver"/>
    </event>

    <!-- Private label: protege SKU de cliente ao salvar produto -->
    <event name="catalog_product_save_after">
        <observer name="grupoawamotos_b2b_private_label_product_save"
                  instance="GrupoAwamotos\B2B\Observer\PrivateLabelProductSave"/>
    </event>

</config>
