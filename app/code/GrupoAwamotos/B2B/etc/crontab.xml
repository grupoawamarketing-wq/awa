<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <!-- Expirar cotações vencidas - roda diariamente às 2h -->
        <job name="grupoawamotos_b2b_expire_quotes"
             instance="GrupoAwamotos\B2B\Cron\ExpireQuotes"
             method="execute">
            <schedule>0 2 * * *</schedule>
        </job>

        <!-- Processar listas de compras recorrentes - roda diariamente às 6h -->
        <job name="grupoawamotos_b2b_process_recurring_lists"
             instance="GrupoAwamotos\B2B\Cron\ProcessRecurringShoppingLists"
             method="execute">
            <schedule>0 6 * * *</schedule>
        </job>

        <job name="grupoawamotos_b2b_sync_attendant_erp"
             instance="GrupoAwamotos\B2B\Cron\SyncAttendantFromErp"
             method="execute">
            <schedule>0 3 * * *</schedule>
        </job>
        <job name="grupoawamotos_b2b_process_subscriptions"
             instance="GrupoAwamotos\B2B\Cron\ProcessSubscriptions"
             method="execute">
            <schedule>0 4 * * *</schedule>
        </job>

        <!-- Alertar admin sobre clientes B2B com aprovação pendente > 48h - roda diariamente às 8h -->
        <job name="grupoawamotos_b2b_notify_pending_approvals"
             instance="GrupoAwamotos\B2B\Cron\NotifyPendingApprovals"
             method="execute">
            <schedule>0 8 * * *</schedule>
        </job>

        <!-- Poll Sectra validador para prospects pendentes e libera pedidos retidos -->
        <job name="grupoawamotos_b2b_sync_sectra_prospect_status"
             instance="GrupoAwamotos\B2B\Cron\SyncSectraProspectStatus"
             method="execute">
            <schedule>*/15 * * * *</schedule>
        </job>

        <!-- Auditoria read-only de saúde cadastral B2B — exporta CSV quando há gaps -->
        <job name="grupoawamotos_b2b_registration_health_audit"
             instance="GrupoAwamotos\B2B\Cron\RegistrationHealthAudit"
             method="execute">
            <schedule>0 7 * * *</schedule>
        </job>
    </group>
</config>
