<?xml version="1.0"?>
<!--
/**
 * ACL Resources for B2B Module
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Customer::customer">
                    <resource id="GrupoAwamotos_B2B::b2b" title="B2B Management" sortOrder="100">
                        <resource id="GrupoAwamotos_B2B::dashboard" title="Meta B2B Dashboard" sortOrder="5"/>
                        <resource id="GrupoAwamotos_B2B::customer_approval" title="Customer Approval" sortOrder="10"/>
                        <resource id="GrupoAwamotos_B2B::quotes" title="Quote Requests" sortOrder="20"/>
                        <resource id="GrupoAwamotos_B2B::order_approval" title="Order Approval" sortOrder="25"/>
                        <resource id="GrupoAwamotos_B2B::credit" title="Credit Management" sortOrder="27"/>
                        <resource id="GrupoAwamotos_B2B::carrier" title="B2B Carriers" sortOrder="30"/>
                        <resource id="GrupoAwamotos_B2B::attendants" title="Attendant Management" sortOrder="35"/>
                        <resource id="GrupoAwamotos_B2B::notifications" title="Notification Log" sortOrder="40"/>
                        <resource id="GrupoAwamotos_B2B::config" title="B2B Configuration" sortOrder="100"/>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
