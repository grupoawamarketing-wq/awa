<?xml version="1.0"?>
<!--
/**
 * B2B Extension Attributes
 * P0-1: Purchase Order Number
 * P2-4.2: Order Notes
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Api/etc/extension_attributes.xsd">

    <!-- PO number on quote -->
    <extension_attributes for="Magento\Quote\Api\Data\CartInterface">
        <attribute code="b2b_po_number" type="string"/>
    </extension_attributes>

    <!-- PO number on order -->
    <extension_attributes for="Magento\Sales\Api\Data\OrderInterface">
        <attribute code="b2b_po_number" type="string"/>
    </extension_attributes>

    <!-- PO number on payment interface (checkout JS) -->
    <extension_attributes for="Magento\Quote\Api\Data\PaymentInterface">
        <attribute code="b2b_po_number" type="string"/>
    </extension_attributes>

    <!-- P2-4.2: Order notes on quote -->
    <extension_attributes for="Magento\Quote\Api\Data\CartInterface">
        <attribute code="b2b_order_notes" type="string"/>
    </extension_attributes>

    <!-- P2-4.2: Order notes on order -->
    <extension_attributes for="Magento\Sales\Api\Data\OrderInterface">
        <attribute code="b2b_order_notes" type="string"/>
    </extension_attributes>

    <!-- P2-4.2: Order notes on payment interface (checkout JS) -->
    <extension_attributes for="Magento\Quote\Api\Data\PaymentInterface">
        <attribute code="b2b_order_notes" type="string"/>
    </extension_attributes>

</config>
