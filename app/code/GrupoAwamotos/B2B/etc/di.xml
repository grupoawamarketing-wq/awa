<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="GrupoAwamotos\B2B\CommercialPanel\Api\PortfolioScopeInterface"
                type="GrupoAwamotos\B2B\CommercialPanel\Model\PortfolioScope"/>

    <!-- Filtrar grid de pedidos no admin: atendente vê apenas pedidos dos seus clientes -->
    <type name="Magento\Sales\Model\ResourceModel\Order\Grid\Collection">
        <plugin name="grupoawamotos_b2b_attendant_order_grid"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantOrderGridPlugin"/>
    </type>

    <!-- Filtrar grid de clientes no admin: atendente vê apenas seus clientes -->
    <type name="Magento\Customer\Model\ResourceModel\Grid\Collection">
        <plugin name="grupoawamotos_b2b_attendant_customer_grid"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantCustomerGridPlugin"/>
    </type>

    <!-- Redirecionar atendentes para o painel pessoal após login no admin -->
    <type name="Magento\Backend\Controller\Adminhtml\Auth\Login">
        <plugin name="grupoawamotos_b2b_attendant_login_redirect"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantLoginRedirectPlugin"/>
    </type>

    <!-- Filtrar grid de cotações B2B no admin -->
    <type name="GrupoAwamotos\B2B\Model\ResourceModel\QuoteRequest\Collection">
        <plugin name="grupoawamotos_b2b_attendant_quote_grid"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantQuoteGridPlugin"/>
    </type>

    <!-- Data sources para UI Components (CollectionFactory) -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="grupoawamotos_b2b_attendant_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\Attendant\Grid\Collection</item>
                <item name="grupoawamotos_b2b_company_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\Company\Grid\Collection</item>
                <item name="grupoawamotos_b2b_credit_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\CreditLimit\Grid\Collection</item>
                <item name="grupoawamotos_b2b_quote_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\QuoteRequest\Grid\Collection</item>
            </argument>
        </arguments>
    </type>

    <!-- Service Contracts: preferences -->
    <preference for="GrupoAwamotos\B2B\Api\QuoteRequestRepositoryInterface"
                type="GrupoAwamotos\B2B\Model\QuoteRequestRepository"/>

    <preference for="GrupoAwamotos\B2B\Api\PriceVisibilityInterface"
                type="GrupoAwamotos\B2B\Model\PriceVisibility"/>

    <preference for="GrupoAwamotos\B2B\Api\AttendantRepositoryInterface"
                type="GrupoAwamotos\B2B\Model\AttendantRepository"/>

    <preference for="GrupoAwamotos\B2B\Api\CustomerApprovalInterface"
                type="GrupoAwamotos\B2B\Model\CustomerApproval"/>

    <preference for="GrupoAwamotos\B2B\Api\ApprovalScoreServiceInterface"
                type="GrupoAwamotos\B2B\Model\ApprovalScoreService"/>

    <preference for="GrupoAwamotos\B2B\Api\Data\WhatsAppMessageInterface"
                type="GrupoAwamotos\B2B\Model\Notification\WhatsAppMessage"/>

    <!-- CLI Commands Registration -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="b2b_attendant_manage" xsi:type="object">GrupoAwamotos\B2B\Console\Command\AttendantManageCommand</item>
                <item name="b2b_attendant_sync" xsi:type="object">GrupoAwamotos\B2B\Console\Command\SyncAttendantCommand</item>
                <item name="b2b_attendant_import_erp" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ImportAttendantsFromErpCommand</item>
                <item name="b2b_approve_erp_linked" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ApproveErpLinkedPendingCommand</item>
                <item name="b2b_provision_erp_customers" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ProvisionErpCustomersCommand</item>
                <item name="b2b_carriers_seed" xsi:type="object">GrupoAwamotos\B2B\Console\Command\SeedCarriersCommand</item>
                <item name="b2b_cnpj_cache_clear" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ClearCnpjCacheCommand</item>
                <item name="b2b_whatsapp_test" xsi:type="object">GrupoAwamotos\B2B\Console\Command\TestWhatsAppCommand</item>
                <item name="b2b_attendant_repair_erp" xsi:type="object">GrupoAwamotos\B2B\Console\Command\RepairAttendantsFromErpCommand</item>
                <item name="b2b_registration_audit_health" xsi:type="object">GrupoAwamotos\B2B\Console\Command\AuditRegistrationHealthCommand</item>
                <item name="b2b_registration_audit_missing" xsi:type="object">GrupoAwamotos\B2B\Console\Command\AuditMissingDataCommand</item>
                <item name="b2b_registration_backfill_phone" xsi:type="object">GrupoAwamotos\B2B\Console\Command\BackfillPhoneFromAddressCommand</item>
                <item name="b2b_registration_backfill_razao_cnpj" xsi:type="object">GrupoAwamotos\B2B\Console\Command\BackfillRazaoSocialFromCnpjCacheCommand</item>
                <item name="b2b_registration_backfill_razao_oc" xsi:type="object">GrupoAwamotos\B2B\Console\Command\BackfillRazaoSocialFromOcLegacyCommand</item>
                <item name="b2b_registration_backfill_attribution" xsi:type="object">GrupoAwamotos\B2B\Console\Command\BackfillRegistrationAttributionCommand</item>
                <item name="b2b_registration_enrich_receita" xsi:type="object">GrupoAwamotos\B2B\Console\Command\EnrichRegistrationReceitaCommand</item>
                <item name="b2b_registration_normalize_legacy" xsi:type="object">GrupoAwamotos\B2B\Console\Command\NormalizeLegacyRegistrationCommand</item>
                <item name="b2b_cnae_classify_all" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ClassifyCnaeCommand</item>
                <item name="b2b_score_pending_customers" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ScorePendingCustomersCommand</item>
                <item name="b2b_erp_reprocess_approved_sync" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ReprocessApprovedErpSyncCommand</item>
                <item name="b2b_sectra_sync_prospect" xsi:type="object">GrupoAwamotos\B2B\Console\Command\SyncSectraProspectCommand</item>
                <item name="b2b_sectra_validate_flow" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ValidateSectraFlowCommand</item>
                <item name="b2b_sectra_validate_order_import" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ValidateSectraOrderImportCommand</item>
                <item name="b2b_sectra_cancel_stuck_orders" xsi:type="object">GrupoAwamotos\B2B\Console\Command\CancelStuckOrdersCommand</item>
            </argument>
        </arguments>
    </type>

</config>
