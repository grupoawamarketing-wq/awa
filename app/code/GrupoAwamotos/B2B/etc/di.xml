<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Filtrar grid de pedidos no admin: atendente vê apenas pedidos dos seus clientes -->
    <type name="Magento\Sales\Model\ResourceModel\Order\Grid\Collection">
        <plugin name="grupoawamotos_b2b_attendant_order_grid"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantOrderGridPlugin"/>
    </type>

    <!-- Filtrar grid de clientes no admin: atendente vê apenas seus clientes -->
    <type name="Magento\Customer\Model\ResourceModel\Grid\Collection">
        <plugin name="grupoawamotos_b2b_attendant_customer_grid"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantCustomerGridPlugin"/>
    </type>

    <!-- Redirecionar atendentes para o painel pessoal após login no admin -->
    <type name="Magento\Backend\Controller\Adminhtml\Auth\Login">
        <plugin name="grupoawamotos_b2b_attendant_login_redirect"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantLoginRedirectPlugin"/>
    </type>

    <!-- Filtrar grid de cotações B2B no admin -->
    <type name="GrupoAwamotos\B2B\Model\ResourceModel\QuoteRequest\Collection">
        <plugin name="grupoawamotos_b2b_attendant_quote_grid"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantQuoteGridPlugin"/>
    </type>

    <!-- Data sources para UI Components (CollectionFactory) -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="grupoawamotos_b2b_attendant_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\Attendant\Grid\Collection</item>
                <item name="grupoawamotos_b2b_company_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\Company\Grid\Collection</item>
                <item name="grupoawamotos_b2b_credit_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\CreditLimit\Grid\Collection</item>
                <item name="grupoawamotos_b2b_quote_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\QuoteRequest\Grid\Collection</item>
            </argument>
        </arguments>
    </type>

    <!-- Service Contracts: preferences -->
    <preference for="GrupoAwamotos\B2B\Api\QuoteRequestRepositoryInterface"
                type="GrupoAwamotos\B2B\Model\QuoteRequestRepository"/>

    <preference for="GrupoAwamotos\B2B\Api\PriceVisibilityInterface"
                type="GrupoAwamotos\B2B\Model\PriceVisibility"/>

    <preference for="GrupoAwamotos\B2B\Api\AttendantRepositoryInterface"
                type="GrupoAwamotos\B2B\Model\AttendantRepository"/>

    <preference for="GrupoAwamotos\B2B\Api\CustomerApprovalInterface"
                type="GrupoAwamotos\B2B\Model\CustomerApproval"/>

    <preference for="GrupoAwamotos\B2B\Api\Data\WhatsAppMessageInterface"
                type="GrupoAwamotos\B2B\Model\Notification\WhatsAppMessage"/>

</config>
