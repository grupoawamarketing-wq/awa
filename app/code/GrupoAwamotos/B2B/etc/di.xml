<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Filtrar grid de pedidos no admin: atendente vê apenas pedidos dos seus clientes -->
    <type name="Magento\Sales\Model\ResourceModel\Order\Grid\Collection">
        <plugin name="grupoawamotos_b2b_attendant_order_grid"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantOrderGridPlugin"/>
    </type>

    <!-- Filtrar grid de clientes no admin: atendente vê apenas seus clientes -->
    <type name="Magento\Customer\Model\ResourceModel\Grid\Collection">
        <plugin name="grupoawamotos_b2b_attendant_customer_grid"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantCustomerGridPlugin"/>
    </type>

    <!-- Redirecionar atendentes para o painel pessoal após login no admin -->
    <type name="Magento\Backend\Controller\Adminhtml\Auth\Login">
        <plugin name="grupoawamotos_b2b_attendant_login_redirect"
                type="GrupoAwamotos\B2B\Plugin\Admin\AttendantLoginRedirectPlugin"/>
    </type>

    <!--
        AttendantQuoteGridPlugin intercepts GrupoAwamotos\B2B\Model\ResourceModel\QuoteRequest\Collection.
        Declarar aqui quando a classe QuoteRequest\Collection for criada.
    -->

    <!-- Service Contracts: preferences -->
    <preference for="GrupoAwamotos\B2B\Api\QuoteRequestRepositoryInterface"
                type="GrupoAwamotos\B2B\Model\QuoteRequestRepository"/>

    <preference for="GrupoAwamotos\B2B\Api\PriceVisibilityInterface"
                type="GrupoAwamotos\B2B\Model\PriceVisibility"/>

</config>
