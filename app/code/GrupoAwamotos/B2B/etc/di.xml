<?xml version="1.0"?>
<!--
/**
 * DI Configuration for B2B Module
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Customer Approval Service -->
    <preference for="GrupoAwamotos\B2B\Api\CustomerApprovalInterface"
                type="GrupoAwamotos\B2B\Model\CustomerApproval"/>

    <!-- Quote Request Repository -->
    <preference for="GrupoAwamotos\B2B\Api\QuoteRequestRepositoryInterface"
                type="GrupoAwamotos\B2B\Model\QuoteRequestRepository"/>

    <!-- Price Visibility Service -->
    <preference for="GrupoAwamotos\B2B\Api\PriceVisibilityInterface"
                type="GrupoAwamotos\B2B\Model\PriceVisibility"/>

    <!--
        Plugins de ocultação de preço/carrinho/checkout movidos para etc/frontend/di.xml.
        Esses plugins dependem de CustomerSession e só fazem sentido no escopo frontend.
        Veja: grupoawamotos_b2b_hide_price, hide_final_price, hide_cart_totals,
              hide_cart_item_price, hide_minicart_price, hide_checkout_price
    -->

    <!-- Customer Session Proxy para performance -->
    <type name="GrupoAwamotos\B2B\Model\PriceVisibility">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\B2B\Plugin\HidePricePlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Plugin grupoawamotos_b2b_group_price movido para etc/frontend/di.xml (depende de CustomerSession) -->

    <type name="GrupoAwamotos\B2B\Plugin\GroupPricePlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Customer Price Info Block (PDP) -->
    <type name="GrupoAwamotos\B2B\Block\Product\CustomerPriceInfo">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- CNPJ Validator Helper -->
    <type name="GrupoAwamotos\B2B\Helper\CnpjValidator">
        <arguments>
            <argument name="curl" xsi:type="object">Magento\Framework\HTTP\Client\Curl</argument>
        </arguments>
    </type>

    <type name="Magento\Customer\Api\CustomerRepositoryInterface">
        <plugin name="grupoawamotos_b2b_validate_cnpj_on_save"
                type="GrupoAwamotos\B2B\Plugin\Customer\ValidateCnpjOnSavePlugin"
                sortOrder="15"/>
    </type>

    <!-- Plugin AdminOrder\Create movido para etc/adminhtml/di.xml (escopo correto) -->

    <!-- B2B Catálogo Restrito - Filtro de Produtos (plugin movido para etc/frontend/di.xml) -->
    <type name="GrupoAwamotos\B2B\Plugin\Catalog\RestrictedProductCollectionPlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
            <argument name="b2bHelper" xsi:type="object">GrupoAwamotos\B2B\Helper\Data</argument>
            <argument name="logger" xsi:type="object">Psr\Log\LoggerInterface</argument>
        </arguments>
    </type>

    <!-- Plugin grupoawamotos_b2b_restricted_product_view movido para etc/frontend/di.xml (depende de CustomerSession) -->

    <type name="GrupoAwamotos\B2B\Plugin\Catalog\RestrictedProductViewPlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- B2B Shipping Rate Enhancement Plugin -->
    <type name="Magento\Shipping\Model\Rate\Result">
        <plugin name="grupoawamotos_b2b_shipping_rate"
                type="GrupoAwamotos\B2B\Plugin\Checkout\ShippingRateResultPlugin"
                sortOrder="10"/>
    </type>

    <type name="GrupoAwamotos\B2B\Plugin\Checkout\ShippingRateResultPlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- B2B Shopping List Service -->
    <type name="GrupoAwamotos\B2B\Model\ShoppingListService">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- B2B Carrier Service -->
    <type name="GrupoAwamotos\B2B\Model\CarrierService">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- ERP Integration Service -->
    <type name="GrupoAwamotos\B2B\Model\ErpIntegration">
        <arguments>
            <argument name="customerSync" xsi:type="object">GrupoAwamotos\ERPIntegration\Model\CustomerSync</argument>
            <argument name="erpHelper" xsi:type="object">GrupoAwamotos\ERPIntegration\Helper\Data</argument>
        </arguments>
    </type>

    <!-- ERP Registration Check Observer -->
    <type name="GrupoAwamotos\B2B\Observer\ErpRegistrationCheckObserver">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- ERP Approval Sync Observer -->
    <type name="GrupoAwamotos\B2B\Observer\ErpApprovalSyncObserver">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- B2B: Bloquear placeOrder para usuários não autorizados (global scope para cobrir REST API) -->
    <type name="Magento\Checkout\Api\PaymentInformationManagementInterface">
        <plugin name="grupoawamotos_b2b_block_place_order"
                type="GrupoAwamotos\B2B\Plugin\Checkout\BlockPlaceOrderPlugin"
                sortOrder="10"/>
    </type>

    <type name="Magento\Checkout\Api\GuestPaymentInformationManagementInterface">
        <plugin name="grupoawamotos_b2b_block_guest_place_order"
                type="GrupoAwamotos\B2B\Plugin\Checkout\BlockGuestPlaceOrderPlugin"
                sortOrder="10"/>
    </type>

    <!-- CLI Commands -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="b2bSeedCarriers" xsi:type="object">GrupoAwamotos\B2B\Console\Command\SeedCarriersCommand</item>
                <item name="b2bWhatsAppTest" xsi:type="object">GrupoAwamotos\B2B\Console\Command\TestWhatsAppCommand</item>
                <item name="b2bCnpjCacheClear" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ClearCnpjCacheCommand</item>
                <item name="b2bProvisionErpCustomers" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ProvisionErpCustomersCommand</item>
                <item name="b2bApproveErpLinkedPending" xsi:type="object">GrupoAwamotos\B2B\Console\Command\ApproveErpLinkedPendingCommand</item>
            </argument>
        </arguments>
    </type>

    <!-- WhatsApp Service -->
    <type name="GrupoAwamotos\B2B\Model\Notification\WhatsAppService">
        <arguments>
            <argument name="curl" xsi:type="object">Magento\Framework\HTTP\Client\Curl</argument>
        </arguments>
    </type>

    <!-- Attendant Manager -->
    <type name="GrupoAwamotos\B2B\Model\Attendant\AttendantManager">
        <arguments>
            <argument name="resource" xsi:type="object">Magento\Framework\App\ResourceConnection</argument>
        </arguments>
    </type>

    <!-- Notification Observers com Proxy para performance -->
    <type name="GrupoAwamotos\B2B\Observer\CustomerRegistrationNotification">
        <arguments>
            <argument name="whatsAppService" xsi:type="object">GrupoAwamotos\B2B\Model\Notification\WhatsAppService</argument>
            <argument name="attendantManager" xsi:type="object">GrupoAwamotos\B2B\Model\Attendant\AttendantManager</argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\B2B\Observer\OrderNotification">
        <arguments>
            <argument name="whatsAppService" xsi:type="object">GrupoAwamotos\B2B\Model\Notification\WhatsAppService</argument>
            <argument name="attendantManager" xsi:type="object">GrupoAwamotos\B2B\Model\Attendant\AttendantManager</argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\B2B\Observer\QuoteNotification">
        <arguments>
            <argument name="whatsAppService" xsi:type="object">GrupoAwamotos\B2B\Model\Notification\WhatsAppService</argument>
            <argument name="attendantManager" xsi:type="object">GrupoAwamotos\B2B\Model\Attendant\AttendantManager</argument>
        </arguments>
    </type>

    <!-- Data Provider Collections para Grid B2B (precisa estar no global, não adminhtml) -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="grupoawamotos_b2b_customer_listing_data_source" xsi:type="string">Magento\Customer\Model\ResourceModel\Grid\Collection</item>
                <item name="b2b_carrier_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\Carrier\Grid\Collection</item>
                <item name="grupoawamotos_b2b_approval_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\OrderApproval\Grid\Collection</item>
                <item name="grupoawamotos_b2b_attendant_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\Attendant\Grid\Collection</item>
                <item name="grupoawamotos_b2b_notification_listing_data_source" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\NotificationLog\Grid\Collection</item>
            </argument>
        </arguments>
    </type>

    <virtualType name="GrupoAwamotos\B2B\Model\ResourceModel\Carrier\Grid\Collection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">grupoawamotos_b2b_carrier</argument>
            <argument name="resourceModel" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\Carrier</argument>
        </arguments>
    </virtualType>

    <virtualType name="GrupoAwamotos\B2B\Model\ResourceModel\OrderApproval\Grid\Collection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">grupoawamotos_b2b_order_approval</argument>
            <argument name="resourceModel" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\OrderApproval</argument>
        </arguments>
    </virtualType>

    <virtualType name="GrupoAwamotos\B2B\Model\ResourceModel\Attendant\Grid\Collection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">grupoawamotos_b2b_attendants</argument>
            <argument name="resourceModel" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\Attendant</argument>
        </arguments>
    </virtualType>

    <virtualType name="GrupoAwamotos\B2B\Model\ResourceModel\NotificationLog\Grid\Collection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">grupoawamotos_b2b_notifications</argument>
            <argument name="resourceModel" xsi:type="string">GrupoAwamotos\B2B\Model\ResourceModel\NotificationLog</argument>
        </arguments>
    </virtualType>

    <!-- CreditService dependencies -->
    <type name="GrupoAwamotos\B2B\Model\CreditService">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Credit Modifier for Customer Edit Form -->
    <virtualType name="Magento\Customer\Ui\Component\DataProvider" type="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
        <arguments>
            <argument name="pool" xsi:type="object">Magento\Customer\Ui\Component\DataProvider\ModifierPool</argument>
        </arguments>
    </virtualType>
    <virtualType name="Magento\Customer\Ui\Component\DataProvider\ModifierPool" type="Magento\Ui\DataProvider\Modifier\Pool">
        <arguments>
            <argument name="modifiers" xsi:type="array">
                <item name="b2b_credit" xsi:type="array">
                    <item name="class" xsi:type="string">GrupoAwamotos\B2B\Ui\Component\Customer\Form\CreditModifier</item>
                    <item name="sortOrder" xsi:type="number">100</item>
                </item>
            </argument>
        </arguments>
    </virtualType>

    <!-- CompanyService dependencies -->
    <type name="GrupoAwamotos\B2B\Model\CompanyService">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

</config>
