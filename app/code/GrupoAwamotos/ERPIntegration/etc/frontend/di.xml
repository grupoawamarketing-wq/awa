<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Stock real-time plugin -->
    <type name="Magento\CatalogInventory\Api\StockRegistryInterface">
        <plugin name="grupoawamotos_erp_stock_realtime"
                type="GrupoAwamotos\ERPIntegration\Plugin\StockPlugin"
                sortOrder="100"/>
    </type>

    <!-- PreloadCustomerPrices: Session Proxy para evitar instanciacao prematura -->
    <type name="GrupoAwamotos\ERPIntegration\Observer\PreloadCustomerPrices">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>
    <!-- Suggestions Block: Session Proxy para garantir inicializacao lazy apos session_start() completo -->
    <type name="GrupoAwamotos\ERPIntegration\Block\Customer\Suggestions">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>
</config>
