<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="grupoawamotos_erp" translate="label" sortOrder="200"
                 showInDefault="1" showInWebsite="0" showInStore="0">
            <label>ERP Integration (SQL Server)</label>
            <tab>grupoawamotos</tab>
            <resource>GrupoAwamotos_ERPIntegration::config</resource>

            <!-- Connection Settings -->
            <group id="connection" translate="label" sortOrder="10"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Conexao SQL Server</label>
                <comment><![CDATA[Configuracoes de conexao com o servidor SQL Server do ERP.]]></comment>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Integracao</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="use_env" translate="label comment" type="select" sortOrder="15"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Usar Variaveis de Ambiente</label>
                    <comment><![CDATA[<strong>Recomendado para producao!</strong> Busca credenciais de: ENV vars (ERP_SQL_*) > app/etc/env.php > config admin.
                    <br>Variaveis: ERP_SQL_HOST, ERP_SQL_PORT, ERP_SQL_DATABASE, ERP_SQL_USERNAME, ERP_SQL_PASSWORD]]></comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="host" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Host / IP do Servidor</label>
                    <comment>Sobrescrito por ERP_SQL_HOST se "Usar Variaveis de Ambiente" estiver ativo</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="port" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Porta</label>
                    <comment>Padrao SQL Server: 1433</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="database" translate="label" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Nome do Banco de Dados</label>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="username" translate="label" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Usuario</label>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="password" translate="label" type="obscure" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Senha</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="driver" translate="label comment" type="select" sortOrder="65"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Driver de Conexao</label>
                    <comment><![CDATA[<strong>Auto-detectar</strong> tentará sqlsrv > dblib > odbc em ordem de prioridade.]]></comment>
                    <source_model>GrupoAwamotos\ERPIntegration\Model\Config\Source\Driver</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="timeout" translate="label comment" type="text" sortOrder="66"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Timeout (segundos)</label>
                    <comment>Tempo limite para conexao (padrao: 30)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="trust_certificate" translate="label comment" type="select" sortOrder="67"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Confiar Certificado SSL</label>
                    <comment>Habilite para ignorar validacao de certificado (ambiente de desenvolvimento)</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="test_connection" translate="label" type="button" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Testar Conexao</label>
                    <frontend_model>GrupoAwamotos\ERPIntegration\Block\Adminhtml\System\Config\TestConnection</frontend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="circuit_breaker_info" translate="label comment" type="note" sortOrder="75"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Circuit Breaker</label>
                    <comment><![CDATA[<strong>Protecao automatica:</strong> Apos 5 falhas consecutivas de conexao, o sistema bloqueia novas tentativas por 60 segundos.
                    <br>Isso evita sobrecarga quando o ERP esta indisponivel.
                    <br>Para resetar manualmente: <code>bin/magento cache:clean</code>]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Write Connection (for B2B client registration) -->
            <group id="write_connection" translate="label" sortOrder="15"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Conexao de Escrita (Registro B2B)</label>
                <comment><![CDATA[<strong>Opcional:</strong> Credenciais com permissao INSERT na tabela GR_INTEGRACAOVALIDADOR do Sectra.
                <br>Necessario para auto-registro de clientes B2B novos na integracao Sectra "Importar Pedidos AWA".
                <br>Se nao configurado, clientes novos precisarao ser registrados manualmente no SQL Server.]]></comment>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Escrita</label>
                    <comment>Habilita auto-registro de clientes B2B no Sectra ao importar pedidos</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="username" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Usuario (Escrita)</label>
                    <comment>Usuario SQL Server com permissao INSERT em GR_INTEGRACAOVALIDADOR</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="password" translate="label" type="obscure" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Senha (Escrita)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Product Sync -->
            <group id="sync_products" translate="label" sortOrder="20"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Sincronizacao de Produtos</label>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Sync de Produtos</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="frequency" translate="label" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Frequencia (minutos)</label>
                    <source_model>GrupoAwamotos\ERPIntegration\Model\Config\Source\SyncFrequency</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="filter_comercializa" translate="label comment" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Somente Comercializaveis</label>
                    <comment>Importar apenas materiais com CKCOMERCIALIZA = S</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Category Sync -->
            <group id="sync_categories" translate="label" sortOrder="25"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Sincronizacao de Categorias</label>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Sync de Categorias</label>
                    <comment>Importa arvore de categorias da tabela MT_GRUPOCOMERCIAL do ERP</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="root_category_name" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Nome da Categoria Raiz ERP</label>
                    <comment>Nome da categoria raiz criada no Magento (padrao: Catalogo ERP)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="include_in_menu" translate="label comment" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Incluir no Menu de Navegacao</label>
                    <comment>Se as categorias importadas devem aparecer no menu principal</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Stock Sync -->
            <group id="sync_stock" translate="label" sortOrder="30"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Sincronizacao de Estoque</label>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Sync de Estoque</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="realtime" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Consulta em Tempo Real</label>
                    <comment>Verificar estoque no ERP ao adicionar ao carrinho</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="filial" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Filial</label>
                    <comment>Codigo da filial no ERP</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="cache_ttl" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cache TTL (segundos)</label>
                    <comment>Tempo de cache da consulta de estoque (padrao: 300 = 5 min)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="negative_cache_ttl" translate="label comment" type="text" sortOrder="45"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cache Negativo TTL (segundos)</label>
                    <comment>Tempo de cache para SKUs nao encontrados no ERP (padrao: 60 = 1 min). Evita consultas repetidas.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="multi_branch" translate="label comment" type="select" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Multi-Filial</label>
                    <comment>Agrega estoque de multiplas filiais do ERP</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="filiais" translate="label comment" type="text" sortOrder="55"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Filiais para Agregacao</label>
                    <comment>Lista de codigos de filiais separados por virgula (ex: 1,2,3). Deixe vazio para usar a filial padrao.</comment>
                    <depends>
                        <field id="multi_branch">1</field>
                    </depends>
                </field>
                <field id="aggregation_mode" translate="label comment" type="select" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Modo de Agregacao</label>
                    <comment>Como agregar o estoque de multiplas filiais</comment>
                    <source_model>GrupoAwamotos\ERPIntegration\Model\Config\Source\AggregationMode</source_model>
                    <depends>
                        <field id="multi_branch">1</field>
                    </depends>
                </field>
            </group>

            <!-- Customer Sync -->
            <group id="sync_customers" translate="label" sortOrder="40"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Sincronizacao de Clientes</label>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Sync de Clientes</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="frequency" translate="label" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Frequencia (minutos)</label>
                    <source_model>GrupoAwamotos\ERPIntegration\Model\Config\Source\SyncFrequency</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Order Sync -->
            <group id="sync_orders" translate="label" sortOrder="50"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Sincronizacao de Pedidos</label>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Envio de Pedidos ao ERP</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="send_on_place" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enviar ao Finalizar Pedido</label>
                    <comment>Envia o pedido automaticamente ao ERP quando o cliente finaliza a compra</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="use_queue" translate="label comment" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Usar Fila de Mensagens (Recomendado)</label>
                    <comment><![CDATA[<strong>Recomendado!</strong> Processa pedidos de forma assincrona via Message Queue com retry automatico.
                    <br>Isso evita que o checkout fique lento se o ERP estiver indisponivel.
                    <br>Execute: <code>bin/magento queue:consumers:start erp.order.sync.consumer</code>]]></comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="send_on_place">1</field>
                    </depends>
                </field>
            </group>

            <!-- Price Sync -->
            <group id="sync_prices" translate="label" sortOrder="60"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Sincronizacao de Precos</label>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Sync de Precos</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="frequency" translate="label" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Frequencia (minutos)</label>
                    <source_model>GrupoAwamotos\ERPIntegration\Model\Config\Source\SyncFrequency</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="default_price_list" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Lista de Preco Padrao (FATORPRECO)</label>
                    <comment><![CDATA[Codigo da lista de precos no ERP (tabela VE_FATORPRECO) usada como preco base no Magento.
                    <br>Padrao: <strong>24 (NACIONAL)</strong> — 3.341 itens, a maior cobertura.
                    <br>Use o comando <code>bin/magento erp:sync:prices --list</code> para ver todas as listas disponiveis.]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Image Sync -->
            <group id="sync_images" translate="label" sortOrder="65"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Sincronizacao de Imagens</label>
                <comment><![CDATA[Configuracoes para importar imagens de produtos do ERP.]]></comment>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Sync de Imagens</label>
                    <comment>Importa imagens de produtos do ERP para o Magento</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="source" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Fonte das Imagens</label>
                    <comment>De onde buscar as imagens dos produtos</comment>
                    <source_model>GrupoAwamotos\ERPIntegration\Model\Config\Source\ImageSource</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="base_path" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Caminho Base (pasta local/rede)</label>
                    <comment><![CDATA[Caminho absoluto para pasta de imagens. Ex: /var/erp/imagens ou \\servidor\imagens<br>
                    As imagens devem estar nomeadas com o SKU: SKU.jpg, SKU_1.jpg, etc.]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="base_url" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>URL Base (imagens remotas)</label>
                    <comment><![CDATA[URL com placeholder {sku} para buscar imagens. Ex: https://erp.empresa.com/imagens/{sku}.jpg]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="replace_existing" translate="label comment" type="select" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Substituir Imagens Existentes</label>
                    <comment>Se desabilitado, apenas adiciona imagens que nao existem no produto</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="frequency" translate="label comment" type="select" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Frequencia de Sync</label>
                    <source_model>GrupoAwamotos\ERPIntegration\Model\Config\Source\SyncFrequency</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <!-- Orphan Cleanup -->
                <field id="clean_orphans_enabled" translate="label comment" type="select" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Limpeza de Orfas</label>
                    <comment><![CDATA[Remove imagens que existem no Magento mas nao no ERP.<br>
                    <strong>ATENCAO:</strong> Use com cuidado. Recomendamos testar primeiro com Modo Simulacao.]]></comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="clean_orphans_dry_run" translate="label comment" type="select" sortOrder="80"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Modo Simulacao (Dry Run)</label>
                    <comment>Se habilitado, apenas lista imagens que seriam removidas sem deletar</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="clean_orphans_enabled">1</field>
                    </depends>
                </field>
                <field id="clean_orphans_keep_manual" translate="label comment" type="select" sortOrder="90"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Manter Imagens Manuais</label>
                    <comment>Nao remove imagens que foram adicionadas manualmente (nao sincronizadas do ERP)</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="clean_orphans_enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Suggestions -->
            <group id="suggestions" translate="label" sortOrder="70"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Sugestoes de Produtos</label>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Sugestoes</label>
                    <comment>Sugere produtos baseado no historico de compras do cliente no ERP</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="max_suggestions" translate="label" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximo de Sugestoes</label>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="cart_enabled" translate="label comment" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Carrinho Sugerido</label>
                    <comment>Monta um carrinho completo com produtos sugeridos para o cliente</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="cart_min_products" translate="label" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Minimo de Produtos no Carrinho</label>
                    <comment>Numero minimo de produtos para exibir o carrinho sugerido</comment>
                    <depends>
                        <field id="cart_enabled">1</field>
                    </depends>
                </field>
                <field id="cart_max_products" translate="label" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximo de Produtos no Carrinho</label>
                    <comment>Numero maximo de produtos sugeridos por secao</comment>
                    <depends>
                        <field id="cart_enabled">1</field>
                    </depends>
                </field>
                <field id="free_shipping_threshold" translate="label comment" type="text" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Valor Minimo para Frete Gratis</label>
                    <comment>Valor em R$ para frete gratis (padrao: 1500)</comment>
                    <depends>
                        <field id="cart_enabled">1</field>
                    </depends>
                </field>
                <field id="cache_ttl" translate="label comment" type="text" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cache TTL (segundos)</label>
                    <comment>Tempo de cache das sugestoes (padrao: 1800 = 30 min)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="show_in_sidebar" translate="label comment" type="select" sortOrder="80"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Exibir na Sidebar do Carrinho</label>
                    <comment>Exibe widget compacto de sugestoes na sidebar do carrinho (alem do widget principal)</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="cart_enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- RFM Analysis -->
            <group id="rfm" translate="label" sortOrder="80"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Analise RFM (Segmentacao de Clientes)</label>
                <comment><![CDATA[<strong>RFM</strong> = Recencia, Frequencia, Valor Monetario. Segmenta clientes para acoes direcionadas.]]></comment>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Analise RFM</label>
                    <comment>Calcula scores RFM e segmenta clientes automaticamente</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="analysis_period" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Periodo de Analise (meses)</label>
                    <comment>Quantos meses de historico considerar (padrao: 24)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="cache_ttl" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cache TTL (segundos)</label>
                    <comment>Tempo de cache da analise RFM (padrao: 86400 = 24h)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="alert_at_risk" translate="label comment" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Alertar Clientes em Risco</label>
                    <comment>Envia email quando clientes valiosos estao em risco de churn</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="alert_email" translate="label" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Email para Alertas</label>
                    <validate>validate-email</validate>
                    <depends>
                        <field id="alert_at_risk">1</field>
                    </depends>
                </field>
            </group>

            <!-- Coupon Generation -->
            <group id="coupon" translate="label" sortOrder="85"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Cupons de Re-engajamento</label>
                <comment><![CDATA[Geracao automatica de cupons para clientes inativos baseado no segmento RFM.]]></comment>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Geracao de Cupons</label>
                    <comment>Gera cupons personalizados para clientes em risco</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="auto_send" translate="label comment" type="select" sortOrder="15"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Envio Automatico</label>
                    <comment>Envia cupom automaticamente por email junto com alerta de re-engajamento</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="valid_days" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Validade (dias)</label>
                    <comment>Dias de validade do cupom (padrao: 30)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="default_discount" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Desconto Padrao (%)</label>
                    <comment>Percentual de desconto padrao (padrao: 10)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="min_order_amount" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Valor Minimo do Pedido (R$)</label>
                    <comment>Deixe vazio para nao exigir valor minimo</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="discount_cant_lose" translate="label comment" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Desconto - Can't Lose (%)</label>
                    <comment>Clientes valiosos em risco critico (sugerido: 20)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="discount_at_risk" translate="label comment" type="text" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Desconto - At Risk (%)</label>
                    <comment>Clientes em risco de churn (sugerido: 15)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="discount_lost" translate="label comment" type="text" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Desconto - Lost (%)</label>
                    <comment>Clientes perdidos - ultima tentativa (sugerido: 25)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- WhatsApp Z-API -->
            <group id="whatsapp" translate="label" sortOrder="88"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>WhatsApp (Z-API)</label>
                <comment><![CDATA[<strong>Integracao Z-API</strong> para envio de mensagens WhatsApp.
                <br>Acesse <a href="https://z-api.io" target="_blank">z-api.io</a> para criar sua conta.
                <br><strong>Credenciais por ENV (recomendado):</strong> ZAPI_INSTANCE_ID, ZAPI_TOKEN, ZAPI_CLIENT_TOKEN]]></comment>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar WhatsApp</label>
                    <comment>Ativa envio de mensagens via Z-API WhatsApp</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="zapi_instance_id" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Instance ID</label>
                    <comment><![CDATA[ID da instancia Z-API. Encontre em: Painel Z-API > Sua Instancia.
                    <br>Ou use ENV: <code>ZAPI_INSTANCE_ID</code>]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="zapi_token" translate="label comment" type="obscure" sortOrder="25"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Token</label>
                    <comment><![CDATA[Token de seguranca da instancia Z-API.
                    <br>Ou use ENV: <code>ZAPI_TOKEN</code>]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="zapi_client_token" translate="label comment" type="obscure" sortOrder="26"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Client Token (Opcional)</label>
                    <comment><![CDATA[Token de seguranca adicional (Security > Client Token).
                    <br>Ou use ENV: <code>ZAPI_CLIENT_TOKEN</code>]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="admin_phone" translate="label comment" type="text" sortOrder="27"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Telefone Admin (Teste)</label>
                    <comment>Numero para receber mensagens de teste (com DDD, ex: 11999999999)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="test_connection" translate="label" type="button" sortOrder="28"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Testar Conexao</label>
                    <frontend_model>GrupoAwamotos\ERPIntegration\Block\Adminhtml\System\Config\TestWhatsApp</frontend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="connection_status" translate="label comment" type="note" sortOrder="29"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Status</label>
                    <comment><![CDATA[Use o comando CLI para verificar status: <code>bin/magento erp:whatsapp:status</code>]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="order_status_enabled" translate="label comment" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Notificar Mudanca de Status</label>
                    <comment>Envia WhatsApp quando status do pedido muda</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="new_order_enabled" translate="label comment" type="select" sortOrder="45"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Notificar Novo Pedido</label>
                    <comment>Envia confirmacao quando pedido e realizado</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="payment_enabled" translate="label comment" type="select" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Notificar Pagamento</label>
                    <comment>Envia confirmacao quando pagamento e aprovado</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="shipping_enabled" translate="label comment" type="select" sortOrder="55"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Notificar Envio</label>
                    <comment>Envia codigo de rastreio quando pedido e enviado</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="reengagement_enabled" translate="label comment" type="select" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enviar Re-engajamento</label>
                    <comment>Envia cupom para clientes inativos (baseado em RFM)</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Sales Forecast -->
            <group id="forecast" translate="label" sortOrder="90"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Projecao de Vendas</label>
                <comment><![CDATA[Configuracoes para previsao de vendas e fechamento de mes.]]></comment>
                <depends>
                    <field id="grupoawamotos_erp/connection/enabled">1</field>
                </depends>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Habilitar Projecoes</label>
                    <comment>Calcula projecoes de vendas e fechamento de mes</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="method" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Metodo de Projecao</label>
                    <source_model>GrupoAwamotos\ERPIntegration\Model\Config\Source\ForecastMethod</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="confidence_level" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Nivel de Confianca (%)</label>
                    <comment>Intervalo de confianca para projecoes (padrao: 85)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="monthly_target" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Meta Mensal (R$)</label>
                    <comment>Meta de vendas do mes atual. Deixe vazio para usar mes anterior como referencia.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="alert_enabled" translate="label comment" type="select" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Alertar se Abaixo da Meta</label>
                    <comment>Notifica quando projecao esta abaixo da meta</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
