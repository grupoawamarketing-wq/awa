// Helper function for status labels
function getStatusLabel($status) {
    $labels = [
        'achieved' => 'Atingida',
        'missed' => 'Não atingida',
        'on_track' => 'No caminho',
        'attention' => 'Atenção',
        'critical' => 'Crítico',
    ];
    return $labels[$status] ?? ucfirst($status);
}
?>

<!-- ApexCharts -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script>
require(['jquery'], function($) {
    'use strict';

    var goalsData = <?= /* @noEscape */ $block->getGoalsChartJson() ?>;
    var quarterlyData = <?= /* @noEscape */ $block->getQuarterlyChartJson() ?>;
    var yearlyData = <?= /* @noEscape */ $block->getYearlyChartJson() ?>;

    var saveUrl = '<?= $block->escapeUrl($block->getSaveUrl()) ?>';
    var dataUrl = '<?= $block->escapeUrl($block->getDataUrl()) ?>';

    // Format currency
    function formatCurrency(value) {
        return 'R$ ' + value.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
    }

    function formatShort(value) {
        if (value >= 1000000) return 'R$ ' + (value/1000000).toFixed(1) + 'M';
        if (value >= 1000) return 'R$ ' + (value/1000).toFixed(0) + 'K';
        return 'R$ ' + value.toFixed(0);
    }

    // Main Goals Chart
    if (goalsData.length > 0 && document.querySelector("#chart-goals-monthly")) {
        var categories = goalsData.map(function(g) { return g.short_name + '/' + g.year; });
        var targets = goalsData.map(function(g) { return g.target; });
        var actuals = goalsData.map(function(g) { return g.is_future ? null : g.actual; });
        var projections = goalsData.map(function(g) { return g.is_past ? null : g.projection; });

        var goalsChart = new ApexCharts(document.querySelector("#chart-goals-monthly"), {
            chart: {
                type: 'bar',
                height: 400,
                toolbar: { show: true },
                animations: { enabled: true }
            },
            series: [
                { name: 'Meta', type: 'line', data: targets },
                { name: 'Realizado', type: 'bar', data: actuals },
                { name: 'Projeção', type: 'bar', data: projections }
            ],
            xaxis: { categories: categories },
            yaxis: {
                labels: { formatter: formatShort }
            },
            stroke: { width: [3, 0, 0], curve: 'smooth', dashArray: [5, 0, 0] },
            colors: ['var(--erp-red)', 'var(--erp-green)', 'var(--erp-amber)'],
            plotOptions: {
                bar: { columnWidth: '60%', borderRadius: 4 }
            },
            dataLabels: { enabled: false },
            tooltip: {
                shared: true,
                y: { formatter: formatCurrency }
            },
            legend: { position: 'top' },
            annotations: {
                xaxis: [{
                    x: '<?= $block->getShortMonthName((int)date('n')) ?>/<?= date('Y') ?>',
                    borderColor: '#775DD0',
                    label: {
                        text: 'Mês Atual',
                        style: { color: 'var(--erp-white)', background: '#775DD0' }
                    }
                }]
            }
        });
        goalsChart.render();
    }

    // Progress Gauge
    if (document.querySelector("#chart-progress-gauge")) {
        var currentProgress = <?= (float)($currentMonth['progress_percentage'] ?? 0) ?>;
        var progressChart = new ApexCharts(document.querySelector("#chart-progress-gauge"), {
            chart: { type: 'radialBar', height: 350 },
            series: [Math.min(100, currentProgress)],
            plotOptions: {
                radialBar: {
                    startAngle: -135,
                    endAngle: 135,
                    hollow: { size: '65%' },
                    track: { background: '#e7e7e7' },
                    dataLabels: {
                        name: { fontSize: '14px', offsetY: 80 },
                        value: {
                            fontSize: '30px',
                            offsetY: 0,
                            formatter: function(val) { return val.toFixed(1) + '%'; }
                        }
                    }
                }
            },
            colors: [currentProgress >= 100 ? 'var(--erp-green)' : currentProgress >= 80 ? 'var(--erp-amber)' : 'var(--erp-red)'],
            labels: ['Progresso da Meta'],
            stroke: { lineCap: 'round' }
        });
        progressChart.render();
    }

    // Quarterly Chart
    if (quarterlyData.length > 0 && document.querySelector("#chart-quarterly")) {
        var quarterlyChart = new ApexCharts(document.querySelector("#chart-quarterly"), {
            chart: { type: 'bar', height: 300, stacked: false },
            series: [
                { name: 'Meta', data: quarterlyData.map(function(q) { return q.target; }) },
                { name: 'Realizado', data: quarterlyData.map(function(q) { return q.actual; }) }
            ],
            xaxis: { categories: quarterlyData.map(function(q) { return q.label; }) },
            yaxis: { labels: { formatter: formatShort } },
            colors: ['#008FFB', 'var(--erp-green)'],
            plotOptions: { bar: { columnWidth: '50%', borderRadius: 4 } },
            dataLabels: { enabled: false },
            tooltip: { y: { formatter: formatCurrency } }
        });
        quarterlyChart.render();
    }

    // Yearly Chart
    if (yearlyData.length > 0 && document.querySelector("#chart-yearly")) {
        var yearlyChart = new ApexCharts(document.querySelector("#chart-yearly"), {
            chart: { type: 'bar', height: 300 },
            series: [
                { name: 'Meta', data: yearlyData.map(function(y) { return y.target; }) },
                { name: 'Realizado', data: yearlyData.map(function(y) { return y.actual; }) }
            ],
            xaxis: { categories: yearlyData.map(function(y) { return y.year.toString(); }) },
            yaxis: { labels: { formatter: formatShort } },
            colors: ['#775DD0', 'var(--erp-cyan)'],
            plotOptions: { bar: { horizontal: true, borderRadius: 4 } },
            dataLabels: { enabled: false },
            tooltip: { y: { formatter: formatCurrency } }
        });
        yearlyChart.render();
    }

    // Regional Chart (placeholder - will be loaded via AJAX)
    if (document.querySelector("#chart-regional")) {
        var regionalChart = new ApexCharts(document.querySelector("#chart-regional"), {
            chart: { type: 'donut', height: 300 },
            series: [30, 25, 20, 15, 10],
            labels: ['SP', 'MG', 'RJ', 'PR', 'Outros'],
            colors: ['#008FFB', 'var(--erp-green)', 'var(--erp-amber)', 'var(--erp-red)', '#775DD0'],
            legend: { position: 'bottom' },
            plotOptions: {
                pie: {
                    donut: {
                        size: '60%',
                        labels: { show: true, total: { show: true, label: 'Total' } }
                    }
                }
            }
        });
        regionalChart.render();
    }

    // Modal handling
    var $modal = $('#goal-modal');

    $('#btn-new-goal').on('click', function() {
        $('#modal-year-month').val('<?= date('Y-m') ?>');
        $('#modal-target').val('');
        $('#modal-notes').val('');
        $modal.fadeIn(200);
    });

    $('.btn-edit-goal').on('click', function() {
        var $btn = $(this);
        $('#modal-year-month').val($btn.data('year-month'));
        $('#modal-target').val($btn.data('target'));
        $('#modal-notes').val($btn.data('notes'));
        $modal.fadeIn(200);
    });

    $('.modal-close, .modal-cancel').on('click', function() {
        $modal.fadeOut(200);
    });

    $('#btn-save-goal').on('click', function() {
        var data = {
            year_month: $('#modal-year-month').val(),
            target: $('#modal-target').val(),
            notes: $('#modal-notes').val()
        };

        $.ajax({
            url: saveUrl,
            type: 'POST',
            data: data,
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    location.reload();
                } else {
                    alert(response.message);
                }
            },
            error: function() {
                alert('Erro ao salvar meta');
            }
        });
    });

    // Filter handling
    $('#btn-apply-filters').on('click', function() {
        loadFilteredData();
    });

    $('#btn-clear-filters').on('click', function() {
        $('#filter-period-start').val('<?= date('Y-m', strtotime('-6 months')) ?>');
        $('#filter-period-end').val('<?= date('Y-m', strtotime('+6 months')) ?>');
        $('#filter-region').val('');
        $('#filter-seller').val('');
        loadFilteredData();
    });

    function loadFilteredData() {
        var filters = {
            period_start: $('#filter-period-start').val(),
            period_end: $('#filter-period-end').val(),
            region: $('#filter-region').val(),
            seller: $('#filter-seller').val()
        };

        $.ajax({
            url: dataUrl,
            type: 'GET',
            data: filters,
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    updateCharts(response.data);
                }
            }
        });
    }

    function updateCharts(data) {
        // Update regional chart with actual data
        if (data.by_region && data.by_region.length > 0) {
            var regions = data.by_region.slice(0, 5);
            var values = regions.map(function(r) { return r.value; });
            var labels = regions.map(function(r) { return r.region; });

            ApexCharts.exec('chart-regional', 'updateOptions', {
                series: values,
                labels: labels
            });
        }
    }

    // Refresh button
    $('#btn-refresh').on('click', function() {
        location.reload();
    });

    // Export buttons
    $('.btn-export').on('click', function() {
        var format = $(this).data('format');
        alert('Exportação ' + format.toUpperCase() + ' será implementada em breve!');
    });
});
</script>

