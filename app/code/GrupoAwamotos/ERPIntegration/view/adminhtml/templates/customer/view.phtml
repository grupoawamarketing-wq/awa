<script>
require(['jquery', 'apexcharts'], function($, ApexCharts) {
    'use strict';

    var customerCode = <?= (int)$block->getCustomerCode() ?>;
    var oppUrl = '<?= $block->escapeJs($block->getUrl('erpintegration/customer/opportunitydata')) ?>';
    var historyUrl = '<?= $block->escapeJs($block->getUrl('erpintegration/customer/filteredhistorydata')) ?>';

    var oppBadgeColors = {
        'monthly': '#2196F3',
        'quarterly_not_bought': '#FF9800',
        'quarterly_bought': '#4CAF50',
        'expansion_monthly': '#9C27B0',
        'expansion_quarterly': '#673AB7',
        'irregular': '#607D8B',
        'churn': '#F44336',
        'cross_sell': '#00BCD4'
    };

    var oppLabels = {
        'monthly': 'Mensal',
        'quarterly_not_bought': 'Trim. Não Comprou',
        'quarterly_bought': 'Trim. Comprou',
        'expansion_monthly': 'Expansão Mensal',
        'expansion_quarterly': 'Expansão Trim.',
        'irregular': 'Irregular',
        'churn': 'Churn',
        'cross_sell': 'Cross-sell'
    };

    function esc(str) {
        return $('<div>').text(str || '').html();
    }

    function formatPrice(val) {
        return 'R$ ' + parseFloat(val || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    }

    // ========== ApexCharts ==========

    // Monthly Trend Chart (Area)
    <?php if (!empty($trendData)): ?>
    (function() {
        var trend = <?= json_encode($trendData) ?>;
        if (trend.length > 0) {
            new ApexCharts(document.querySelector('#erp-trend-chart'), {
                chart: {
                    type: 'area',
                    height: 280,
                    toolbar: { show: false },
                    fontFamily: 'inherit'
                },
                series: [
                    { name: 'Receita (R$)', data: trend.map(function(t) { return parseFloat(t.revenue || 0); }) },
                    { name: 'Pedidos', data: trend.map(function(t) { return parseInt(t.order_count || 0); }) }
                ],
                xaxis: {
                    categories: trend.map(function(t) { return t.month; }),
                    labels: { style: { fontSize: '11px' } }
                },
                colors: ['#b73337', '#2196F3'],
                stroke: { curve: 'smooth', width: 2 },
                fill: {
                    type: 'gradient',
                    gradient: { opacityFrom: 0.35, opacityTo: 0.05 }
                },
                yaxis: [
                    {
                        title: { text: 'Receita (R$)', style: { fontSize: '12px' } },
                        labels: { formatter: function(v) { return 'R$ ' + (v/1000).toFixed(0) + 'k'; } }
                    },
                    {
                        opposite: true,
                        title: { text: 'Pedidos', style: { fontSize: '12px' } },
                        labels: { formatter: function(v) { return Math.round(v); } }
                    }
                ],
                tooltip: {
                    shared: true,
                    y: {
                        formatter: function(val, opts) {
                            if (opts.seriesIndex === 0) return formatPrice(val);
                            return Math.round(val) + ' pedidos';
                        }
                    }
                },
                dataLabels: { enabled: false },
                grid: { borderColor: '#f1f1f1' }
            }).render();
        }
    })();
    <?php endif; ?>

    // Opportunity Donut Chart
    <?php if (!empty($oppChartCounts)): ?>
    (function() {
        var donutData = <?= json_encode($oppChartCounts) ?>;
        var donutLabels = <?= json_encode($oppChartLabels) ?>;
        var donutColors = <?= json_encode($oppChartColors) ?>;
        var donutTypes = <?= json_encode($oppChartTypes) ?>;

        if (donutData.length > 0) {
            new ApexCharts(document.querySelector('#erp-opp-donut-chart'), {
                chart: {
                    type: 'donut',
                    height: 300,
                    events: {
                        dataPointSelection: function(event, chartContext, config) {
                            var type = donutTypes[config.dataPointIndex];
                            if (type) {
                                // Navigate to opportunities tab and filter
                                $('.erp-tab-btn[data-tab="opportunities"]').click();
                                $('#opp-type-filter').val(type);
                                oppPage = 1;
                                loadOpportunities();
                            }
                        }
                    }
                },
                series: donutData,
                labels: donutLabels,
                colors: donutColors,
                legend: {
                    position: 'bottom',
                    fontSize: '12px'
                },
                plotOptions: {
                    pie: {
                        donut: {
                            size: '55%',
                            labels: {
                                show: true,
                                total: {
                                    show: true,
                                    label: 'Total',
                                    fontSize: '14px',
                                    fontWeight: 700
                                }
                            }
                        }
                    }
                },
                dataLabels: {
                    enabled: true,
                    formatter: function(val) { return Math.round(val) + '%'; },
                    style: { fontSize: '11px' }
                },
                tooltip: {
                    y: {
                        formatter: function(val) { return val + ' produtos'; }
                    }
                }
            }).render();
        }
    })();
    <?php endif; ?>

    // Products Bar Chart — render on tab open (hidden containers can't size correctly)
    <?php if (!empty($products)): ?>
    var productsChartRendered = false;
    function renderProductsChart() {
        if (productsChartRendered) return;
        productsChartRendered = true;
        var top10 = <?= json_encode(array_slice($products, 0, 10)) ?>;
        var el = document.querySelector('#erp-products-bar-chart');
        if (top10.length > 0 && el) {
            new ApexCharts(el, {
                chart: {
                    type: 'bar',
                    height: 350,
                    toolbar: { show: false },
                    fontFamily: 'inherit'
                },
                series: [{
                    name: 'Quantidade Total',
                    data: top10.map(function(p) { return parseFloat(p.quantidade_total || 0); })
                }],
                xaxis: {
                    categories: top10.map(function(p) {
                        var d = p.descricao || '';
                        return d.length > 30 ? d.substring(0, 28) + '...' : d;
                    }),
                    labels: { style: { fontSize: '11px' } }
                },
                colors: ['#b73337'],
                plotOptions: {
                    bar: { borderRadius: 4, horizontal: true }
                },
                dataLabels: {
                    enabled: true,
                    style: { fontSize: '11px' }
                },
                tooltip: {
                    y: {
                        formatter: function(val, opts) {
                            var p = top10[opts.dataPointIndex];
                            return val + ' un. | ' + formatPrice(p ? p.preco_medio : 0) + ' médio';
                        }
                    }
                },
                grid: { borderColor: '#f1f1f1' }
            }).render();
        }
    }
    <?php endif; ?>

    // ========== Tab Navigation ==========
    $('.erp-tab-btn').on('click', function() {
        var tabId = $(this).data('tab');
        $('.erp-tab-btn').removeClass('active');
        $(this).addClass('active');
        $('.erp-tab-content').removeClass('active');
        $('#tab-' + tabId).addClass('active');

        // Render deferred charts when their tab becomes visible
        <?php if (!empty($products)): ?>
        if (tabId === 'products') {
            setTimeout(renderProductsChart, 50);
        }
        <?php endif; ?>
    });

    // ========== Clickable Opportunity Summary Cards ==========
    $('.erp-opp-clickable').on('click', function() {
        var type = $(this).data('opp-type');
        if (type) {
            $('.erp-tab-btn[data-tab="opportunities"]').click();
            $('#opp-type-filter').val(type);
            oppPage = 1;
            oppLoaded = true;
            loadOpportunities();
        }
    });

    // ========== Opportunity Loader ==========
    var oppPage = 1;
    var oppLoaded = false;

    function loadOpportunities() {
        var params = {
            id: customerCode,
            opportunity_type: $('#opp-type-filter').val(),
            sort_by: $('#opp-sort-filter').val(),
            sort_dir: $('#opp-dir-filter').val(),
            page: oppPage,
            limit: 20
        };

        $('#opp-loading').show();
        $('#opp-results, #opp-pagination').empty();

        $.ajax({
            url: oppUrl,
            data: params,
            dataType: 'json',
            method: 'GET'
        }).done(function(resp) {
            if (!resp.success || !resp.items || resp.items.length === 0) {
                $('#opp-results').html('<p class="erp-empty">' + esc(resp.message || 'Nenhuma oportunidade encontrada.') + '</p>');
                return;
            }

            var html = '<table class="data-grid"><thead><tr>';
            html += '<th>SKU</th><th>Produto</th><th>Tipo</th>';
            html += '<th class="_right">Pedidos</th><th class="_right">Qtd Total</th>';
            html += '<th class="_right">Dias</th><th class="_right">Preço Médio</th>';
            html += '<th>Magento</th></tr></thead><tbody>';

            $.each(resp.items, function(i, item) {
                var type = item.opportunity_type || '';
                var color = oppBadgeColors[type] || '#9E9E9E';
                var label = oppLabels[type] || type;
                var inStore = item.available_in_store || (item.magento && item.magento.in_stock);

                html += '<tr>';
                html += '<td><code>' + esc(item.sku || item.codigo_material) + '</code></td>';
                html += '<td>' + esc(item.name || item.descricao) + '</td>';
                html += '<td><span class="erp-opp-badge" style="background:' + color + '">' + esc(label) + '</span></td>';
                html += '<td class="_right">' + (item.order_count || 0) + '</td>';
                html += '<td class="_right">' + (item.total_qty || 0) + '</td>';
                html += '<td class="_right">' + (item.days_since_last || '-') + '</td>';
                html += '<td class="_right">' + formatPrice(item.avg_price) + '</td>';
                html += '<td>';
                if (inStore) {
                    html += '<span class="erp-badge erp-badge-success">Sim</span>';
                } else {
                    html += '<span class="erp-badge erp-badge-muted">Não</span>';
                }
                html += '</td></tr>';
            });
            html += '</tbody></table>';
            html += '<div class="erp-admin-results-count">' + resp.total_count + ' produtos encontrados</div>';

            $('#opp-results').html(html);
            renderPagination('#opp-pagination', resp.page, resp.total_pages, resp.total_count, function(p) {
                oppPage = p;
                loadOpportunities();
            });
        }).fail(function() {
            $('#opp-results').html('<p class="message message-error">Erro de conexão ao carregar oportunidades.</p>');
        }).always(function() {
            $('#opp-loading').hide();
        });
    }

    $('#opp-filter-btn').on('click', function() {
        oppPage = 1;
        loadOpportunities();
    });

    $('.erp-tab-btn[data-tab="opportunities"]').on('click', function() {
        if (!oppLoaded) {
            oppLoaded = true;
            loadOpportunities();
        }
    });

    // ========== CSV Export ==========
    $('#opp-export-btn').on('click', function() {
        var $btn = $(this);
        $btn.prop('disabled', true).find('span').text('Exportando...');

        var params = {
            id: customerCode,
            opportunity_type: $('#opp-type-filter').val(),
            sort_by: $('#opp-sort-filter').val(),
            sort_dir: $('#opp-dir-filter').val(),
            limit: 1000,
            page: 1
        };

        $.getJSON(oppUrl, params, function(resp) {
            if (!resp.items || resp.items.length === 0) {
                alert('Nenhum dado para exportar.');
                return;
            }
            var csv = '\uFEFF'; // BOM for Excel UTF-8
            csv += 'SKU;Produto;Tipo;Pedidos;Qtd Total;Dias Desde Ultima;Preco Medio\n';
            resp.items.forEach(function(item) {
                var name = (item.name || item.descricao || '').replace(/"/g, '""');
                var typeLabel = oppLabels[item.opportunity_type] || item.opportunity_type || '';
                csv += '"' + (item.sku || '') + '";"' + name + '";"' + typeLabel + '";'
                    + (item.order_count || 0) + ';'
                    + (item.total_qty || 0) + ';'
                    + (item.days_since_last || 0) + ';'
                    + parseFloat(item.avg_price || 0).toFixed(2).replace('.', ',') + '\n';
            });
            var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            var a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'oportunidades_cliente_' + customerCode + '.csv';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }).fail(function() {
            alert('Erro ao exportar dados.');
        }).always(function() {
            $btn.prop('disabled', false).find('span').text('Exportar CSV');
        });
    });

    // ========== History Loader ==========
    var historyPage = 1;
    var historyLoaded = false;

    function loadHistory() {
        var params = {
            id: customerCode,
            period: $('#history-period-filter').val(),
            sort_by: $('#history-sort-filter').val(),
            page: historyPage,
            limit: 20
        };

        $('#history-loading').show();
        $('#history-results, #history-pagination').empty();

        $.ajax({
            url: historyUrl,
            data: params,
            dataType: 'json',
            method: 'GET'
        }).done(function(resp) {
            if (!resp.success || !resp.items || resp.items.length === 0) {
                $('#history-results').html('<p class="erp-empty">' + esc(resp.message || 'Nenhum item encontrado no período.') + '</p>');
                return;
            }

            var html = '<table class="data-grid"><thead><tr>';
            html += '<th>SKU</th><th>Produto</th>';
            html += '<th class="_right">Pedidos</th><th class="_right">Qtd Total</th>';
            html += '<th class="_right">Preço Médio</th><th>Última Compra</th>';
            html += '<th>Magento</th></tr></thead><tbody>';

            $.each(resp.items, function(i, item) {
                var sku = item.codigo_material || item.sku || '';
                var name = (item.magento && item.magento.name) ? item.magento.name : (item.descricao || item.name || sku);
                var inStore = item.available_in_store || (item.magento && item.magento.in_stock);

                html += '<tr>';
                html += '<td><code>' + esc(sku) + '</code></td>';
                html += '<td>' + esc(name) + '</td>';
                html += '<td class="_right">' + (item.vezes_comprado || item.order_count || 0) + '</td>';
                html += '<td class="_right">' + (item.quantidade_total || item.total_qty || 0) + '</td>';
                html += '<td class="_right">' + formatPrice(item.preco_medio || item.avg_price) + '</td>';
                html += '<td>' + esc(item.ultima_compra || item.last_order_date || '-') + '</td>';
                html += '<td>';
                if (inStore) {
                    html += '<span class="erp-badge erp-badge-success">Sim</span>';
                } else {
                    html += '<span class="erp-badge erp-badge-muted">Não</span>';
                }
                html += '</td></tr>';
            });
            html += '</tbody></table>';
            html += '<div class="erp-admin-results-count">' + resp.total_count + ' produtos encontrados</div>';

            $('#history-results').html(html);
            renderPagination('#history-pagination', resp.page, resp.total_pages, resp.total_count, function(p) {
                historyPage = p;
                loadHistory();
            });
        }).fail(function() {
            $('#history-results').html('<p class="message message-error">Erro de conexão ao carregar histórico.</p>');
        }).always(function() {
            $('#history-loading').hide();
        });
    }

    $('#history-filter-btn').on('click', function() {
        historyPage = 1;
        loadHistory();
    });

    $('.erp-tab-btn[data-tab="history"]').on('click', function() {
        if (!historyLoaded) {
            historyLoaded = true;
            loadHistory();
        }
    });

    // ========== Pagination Helper ==========
    function renderPagination(selector, currentPage, totalPages, totalCount, callback) {
        if (totalPages <= 1) {
            $(selector).empty();
            return;
        }

        var html = '<span class="erp-pag-info">Página ' + currentPage + ' de ' + totalPages + '</span>';

        if (currentPage > 1) {
            html += '<button class="action-default scalable erp-pag-prev" type="button">Anterior</button>';
        }
        if (currentPage < totalPages) {
            html += '<button class="action-default scalable primary erp-pag-next" type="button">Próxima</button>';
        }

        var $el = $(selector).html(html);

        $el.find('.erp-pag-prev').on('click', function() { callback(currentPage - 1); });
        $el.find('.erp-pag-next').on('click', function() { callback(currentPage + 1); });
    }
});
</script>
