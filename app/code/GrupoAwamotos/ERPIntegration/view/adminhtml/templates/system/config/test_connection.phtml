<div id="erp_test_connection_result" class="erp-conn-result"></div>

<?= /* @noEscape */ $block->getButtonHtml() ?>

<script type="text/javascript">
    require(['jquery', 'Magento_Ui/js/modal/alert'], function($, alert) {
        // Check available drivers on page load
        var pdoDrivers = '<?= implode(", ", \PDO::getAvailableDrivers()) ?>';
        var sqlDrivers = [];
        if (pdoDrivers.indexOf('sqlsrv') !== -1) sqlDrivers.push('sqlsrv');
        if (pdoDrivers.indexOf('dblib') !== -1) sqlDrivers.push('dblib');
        if (pdoDrivers.indexOf('odbc') !== -1) sqlDrivers.push('odbc');

        if (sqlDrivers.length > 0) {
            $('#erp_available_drivers').html(sqlDrivers.join(', ')).addClass('erp-text-success');
        } else {
            $('#erp_available_drivers').html('Nenhum driver SQL Server instalado').addClass('erp-text-error');
        }

        $('#erp_test_connection_btn').on('click', function() {
            var $btn = $(this);
            var $result = $('#erp_test_connection_result');
            $btn.prop('disabled', true).text('<?= __('Testando conexao...') ?>');
            $result.hide();

            $.ajax({
                url: '<?= $block->escapeUrl($block->getAjaxUrl()) ?>',
                type: 'POST',
                dataType: 'json',
                data: {
                    form_key: window.FORM_KEY
                },
                success: function(response) {
                    $btn.prop('disabled', false).text('<?= __('Testar Conexao') ?>');

                    if (response.success) {
                        var html = '<div class="erp-result-header">' +
                            '<span class="erp-icon-success">&#10004;</span> ' +
                            '<strong class="erp-title">Conexao estabelecida com sucesso!</strong>' +
                            '</div>';

                        html += '<table class="erp-table">';
                        html += '<tr><td class="erp-td-label">Driver:</td><td class="erp-td-value"><strong>' + (response.driver_used || 'N/A') + '</strong></td></tr>';
                        html += '<tr><td class="erp-td-label">Servidor:</td><td class="erp-td-value">' + (response.server_name || 'N/A') + '</td></tr>';
                        html += '<tr><td class="erp-td-label">Versao:</td><td class="erp-td-value">' + (response.version || 'N/A') + '</td></tr>';
                        html += '<tr><td class="erp-td-label">Banco:</td><td class="erp-td-value"><strong>' + (response.database || 'N/A') + '</strong></td></tr>';
                        html += '<tr><td class="erp-td-label">Tabelas:</td><td class="erp-td-value">' + (response.table_count || 0) + ' tabelas</td></tr>';
                        html += '<tr><td class="erp-td-label">Hora Servidor:</td><td class="erp-td-value">' + (response.server_time || 'N/A') + '</td></tr>';
                        html += '<tr><td class="erp-td-label">Conexao:</td><td class="erp-td-value-mono">' + (response.connection_string || 'N/A') + '</td></tr>';
                        html += '</table>';

                        if (response.sample_tables && response.sample_tables.length > 0) {
                            html += '<div class="erp-success-footer">';
                            html += '<small class="erp-text-muted">Primeiras tabelas: ' + response.sample_tables.slice(0, 5).join(', ') + '</small>';
                            html += '</div>';
                        }

                        $result.attr('class', 'erp-conn-result erp-conn-success').html(html).show();

                    } else {
                        var html = '<div class="erp-result-header">' +
                            '<span class="erp-icon-error">&#10008;</span> ' +
                            '<strong class="erp-title">Falha na conexao</strong>' +
                            '</div>';

                        html += '<div class="erp-error-box">';
                        html += '<code class="erp-error-code">' + (response.message || 'Erro desconhecido') + '</code>';
                        html += '</div>';

                        if (response.available_drivers && response.available_drivers.length > 0) {
                            html += '<div class="erp-mb-8"><small><strong>Drivers disponiveis:</strong> ' + response.available_drivers.join(', ') + '</small></div>';
                        }

                        if (response.troubleshooting && response.troubleshooting.length > 0) {
                            html += '<div class="erp-error-footer">';
                            html += '<strong class="erp-title-small">Dicas de solucao:</strong><ul class="erp-error-list">';
                            response.troubleshooting.forEach(function(tip) {
                                html += '<li class="erp-error-li">' + tip + '</li>';
                            });
                            html += '</ul></div>';
                        }

                        if (response.installation_tips) {
                            html += '<div class="erp-error-footer">';
                            html += '<strong class="erp-title-small">Instalar drivers (Ubuntu/Debian):</strong>';
                            html += '<pre class="erp-error-pre">';
                            html += 'sudo apt-get install php-sqlsrv  # Microsoft Driver\n';
                            html += 'sudo apt-get install php-sybase   # FreeTDS\n';
                            html += 'sudo apt-get install php-odbc     # ODBC</pre>';
                            html += '</div>';
                        }

                        $result.attr('class', 'erp-conn-result erp-conn-fail').html(html).show();
                    }
                },
                error: function(xhr, status, error) {
                    $btn.prop('disabled', false).text('<?= __('Testar Conexao') ?>');
                    $result.attr('class', 'erp-conn-result erp-conn-warning').html(
                        '<strong>Erro de comunicacao com o servidor Magento.</strong><br>' +
                        '<small>Status: ' + status + ' | Erro: ' + error + '</small>'
                    ).show();
                }
            });
        });
    });
</script>
