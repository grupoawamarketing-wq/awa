<?php
/**
 * WhatsApp Z-API Test Button Template
 * @var \GrupoAwamotos\ERPIntegration\Block\Adminhtml\System\Config\TestWhatsApp $block
 */
?>
<div class="whatsapp-test-container">
    <div class="button-container">
        <?= /* @noEscape */ $block->getButtonHtml() ?>
        <?= /* @noEscape */ $block->getSendTestButtonHtml() ?>
    </div>
    <div id="whatsapp_test_result" class="message" style="display:none; margin-top: 10px;"></div>
</div>

<script type="text/javascript">
require(['jquery', 'Magento_Ui/js/modal/alert'], function($, alert) {
    'use strict';

    var testUrl = '<?= $block->escapeUrl($block->getAjaxUrl()) ?>';

    // Test Connection Button
    $('#test_whatsapp_btn').on('click', function() {
        var $button = $(this);
        var $result = $('#whatsapp_test_result');

        $button.prop('disabled', true).addClass('disabled');
        $result.removeClass('message-success message-error message-warning')
               .html('<span>Verificando conexao...</span>')
               .show();

        $.ajax({
            url: testUrl,
            type: 'POST',
            dataType: 'json',
            data: {
                action: 'test',
                form_key: FORM_KEY
            },
            success: function(response) {
                if (response.success) {
                    $result.addClass('message-success')
                           .html('<span>' + response.message + '</span>');

                    if (response.phone) {
                        $result.append('<br><small>Telefone conectado: ' + response.phone + '</small>');
                    }
                } else {
                    $result.addClass('message-error')
                           .html('<span>' + response.message + '</span>');
                }
            },
            error: function(xhr, status, error) {
                $result.addClass('message-error')
                       .html('<span>Erro de conexao: ' + error + '</span>');
            },
            complete: function() {
                $button.prop('disabled', false).removeClass('disabled');
            }
        });
    });

    // Send Test Message Button
    $('#send_test_whatsapp_btn').on('click', function() {
        var $button = $(this);
        var $result = $('#whatsapp_test_result');

        // Get admin phone from config field
        var adminPhone = $('#grupoawamotos_erp_whatsapp_admin_phone').val();

        if (!adminPhone) {
            alert({
                title: 'Telefone Necessario',
                content: 'Preencha o campo "Telefone Admin (Teste)" para enviar mensagem de teste.'
            });
            return;
        }

        $button.prop('disabled', true).addClass('disabled');
        $result.removeClass('message-success message-error message-warning')
               .html('<span>Enviando mensagem de teste...</span>')
               .show();

        $.ajax({
            url: testUrl,
            type: 'POST',
            dataType: 'json',
            data: {
                action: 'send_test',
                phone: adminPhone,
                form_key: FORM_KEY
            },
            success: function(response) {
                if (response.success) {
                    $result.addClass('message-success')
                           .html('<span>' + response.message + '</span>');
                } else {
                    $result.addClass('message-error')
                           .html('<span>' + response.message + '</span>');
                }
            },
            error: function(xhr, status, error) {
                $result.addClass('message-error')
                       .html('<span>Erro: ' + error + '</span>');
            },
            complete: function() {
                $button.prop('disabled', false).removeClass('disabled');
            }
        });
    });
});
</script>

<style>
.whatsapp-test-container .button-container {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
.whatsapp-test-container .message {
    padding: 10px 15px;
    border-radius: 4px;
}
.whatsapp-test-container .message-success {
    background-color: var(--erp-wa-c6);
    border: 1px solid var(--erp-wa-c4);
    color: var(--erp-wa-c5);
}
.whatsapp-test-container .message-error {
    background-color: var(--erp-wa-c3);
    border: 1px solid var(--erp-wa-c2);
    color: var(--erp-wa-c7);
}
.whatsapp-test-container .message-warning {
    background-color: var(--erp-wa-c1);
    border: 1px solid var(--erp-wa-c8);
    color: var(--erp-wa-c9);
}
</style>
