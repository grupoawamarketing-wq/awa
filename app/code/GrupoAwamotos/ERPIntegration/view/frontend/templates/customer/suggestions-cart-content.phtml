<?php
/**
 * Suggestions Widget Content (loaded via AJAX)
 *
 * @var \GrupoAwamotos\ERPIntegration\Block\Customer\Suggestions $block
 */
declare(strict_types=1);

if (!$block->isEnabled() || !$block->isLoggedIn()) {
    return;
}

$customerCode = $block->getErpCustomerCode();
if (!$customerCode) {
    return;
}

$suggestedCart = $block->getSuggestedCart();

$emptyLabel = __('Nenhuma sugestão disponível no momento.');
$suggestionsTitle = __('Sugestões para Você');
$viewFullCartLabel = __('Ver carrinho completo');
$crossSellLabel = __('Comprado junto');
$popularLabel = __('Popular');
$addToCartLabel = __('Adicionar ao carrinho');
$viewSuggestedCartLabel = __('Ver Carrinho Sugerido Completo');

if (empty($suggestedCart['sections']) || isset($suggestedCart['error'])) {
    ?>
    <div class="erp-cart-suggestions-widget" id="erp-cart-suggestions">
        <div class="erp-widget-empty"><?= $block->escapeHtml($emptyLabel) ?></div>
    </div>
    <?php
    return;
}

// Flatten items from all sections, limit to 6
$allItems = [];
foreach ($suggestedCart['sections'] as $sectionKey => $section) {
    if (!empty($section['items'])) {
        foreach ($section['items'] as $item) {
            $item['section'] = $sectionKey;
            $item['section_title'] = $section['title'] ?? '';
            $allItems[] = $item;
            if (count($allItems) >= 6) {
                break 2;
            }
        }
    }
}

if (empty($allItems)) {
    ?>
    <div class="erp-cart-suggestions-widget" id="erp-cart-suggestions">
        <div class="erp-widget-empty"><?= $block->escapeHtml($emptyLabel) ?></div>
    </div>
    <?php
    return;
}
?>

<div class="erp-cart-suggestions-widget" id="erp-cart-suggestions">
    <div class="erp-widget-header">
        <h3 class="erp-widget-title">
            <span class="erp-icon">💡</span>
            <?= $block->escapeHtml($suggestionsTitle) ?>
        </h3>
        <a href="<?= $block->escapeUrl($block->getUrl('erpintegration/customer/suggestedcart')) ?>" class="erp-view-all">
            <?= $block->escapeHtml($viewFullCartLabel) ?> →
        </a>
    </div>

    <div class="erp-widget-items">
        <?php foreach ($allItems as $item): ?>
        <div class="erp-widget-item" data-sku="<?= $block->escapeHtmlAttr((string) ($item['sku'] ?? '')) ?>">
            <div class="erp-widget-item-info">
                <span class="erp-widget-sku"><?= $block->escapeHtml((string) ($item['sku'] ?? '')) ?></span>
                <a href="<?= $block->escapeUrl($item['url'] ?? '#') ?>" class="erp-widget-name" title="<?= $block->escapeHtmlAttr((string) ($item['name'] ?? '')) ?>">
                    <?= $block->escapeHtml(mb_strimwidth((string) ($item['name'] ?? ''), 0, 50, '...')) ?>
                </a>
                <div class="erp-widget-meta">
                    <?php if ($item['section'] === 'reorder' && !empty($item['metadata']['reorder_status'])): ?>
                        <span class="erp-widget-badge <?= $block->escapeHtmlAttr($block->getReorderStatusClass($item['metadata']['reorder_status'])) ?>">
                            <?= $block->escapeHtml($block->getReorderStatusLabel($item['metadata']['reorder_status'])) ?>
                        </span>
                    <?php elseif ($item['section'] === 'cross_sell'): ?>
                        <span class="erp-widget-badge erp-badge-cross"><?= $block->escapeHtml($crossSellLabel) ?></span>
                    <?php elseif ($item['section'] === 'similar_customers'): ?>
                        <span class="erp-widget-badge erp-badge-similar"><?= $block->escapeHtml($popularLabel) ?></span>
                    <?php endif; ?>
                </div>
            </div>
            <div class="erp-widget-item-price">
                <span class="erp-widget-price"><?= $block->formatPrice($item['unit_price']) ?></span>
            </div>
            <div class="erp-widget-item-action">
                <button type="button"
                        class="erp-widget-add-btn"
                        data-sku="<?= $block->escapeHtmlAttr((string) ($item['sku'] ?? '')) ?>"
                        data-qty="<?= (int)$item['suggested_quantity'] ?>"
                        title="<?= $block->escapeHtmlAttr($addToCartLabel) ?>"
                        aria-label="<?= $block->escapeHtmlAttr(__('Adicionar %1 ao carrinho', (string) ($item['name'] ?? 'produto'))) ?>">
                    <span class="btn-text">+</span>
                    <span class="btn-loading" style="display:none;">...</span>
                </button>
            </div>
        </div>
        <?php endforeach; ?>
    </div>

    <div class="erp-widget-footer">
        <a href="<?= $block->escapeUrl($block->getUrl('erpintegration/customer/suggestedcart')) ?>" class="erp-btn erp-btn-outline erp-btn-full">
            <?= $block->escapeHtml($viewSuggestedCartLabel) ?> (<?= (int)($suggestedCart['summary']['total_items'] ?? 0) ?> <?= $block->escapeHtml(__('produtos')) ?>)
        </a>
    </div>
</div>

<script type="text/x-magento-init">
{
    "#erp-cart-suggestions": {
        "GrupoAwamotos_ERPIntegration/js/cart-suggestions": {
            "mode": "main",
            "addBySkuUrl": "<?= $block->escapeJs($block->getUrl('erpintegration/cart/addBySku')) ?>",
            "reloadDelay": 1500
        }
    }
}
</script>
