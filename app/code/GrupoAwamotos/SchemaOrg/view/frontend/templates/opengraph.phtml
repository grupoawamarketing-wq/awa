<?php
/**
 * Open Graph Meta Tags
 *
 * Usa ViewModel (GrupoAwamotos\SchemaOrg\ViewModel\OpenGraph) via DI —
 * nenhum ObjectManager direto, compatível com Full Page Cache (FPC).
 *
 * @var $block \Magento\Framework\View\Element\Template
 * @var \GrupoAwamotos\SchemaOrg\ViewModel\OpenGraph $og
 */
$og = $block->getData('og_viewmodel') ?: $block->getData('view_model');
if (!$og instanceof \GrupoAwamotos\SchemaOrg\ViewModel\OpenGraph) {
    // Fallback seguro: sem ViewModel válido não renderiza tags, mas não quebra a página.
    return;
}

$baseUrl    = $og->getBaseUrl();
$storeName  = $og->getStoreName();
$currentUrl = $og->getCurrentUrl();

// Detectar tipo de página
$product  = $og->getCurrentProduct();
$category = $og->getCurrentCategory();

// Título e descrição
$title       = $og->getPageTitle();
$description = $og->getPageDescription();

// Imagem
$imageSrc = $og->getDefaultImage();
if ($product && $product->getId()) {
    $imageSrc    = $og->getProductImageUrl($product);
    $title       = $product->getName();
    $productDesc = $product->getShortDescription() ?: $product->getDescription();
    $description = $productDesc ? strip_tags($productDesc) : '';
    $description = mb_substr($description, 0, 200);
} elseif ($category && $category->getId()) {
    if ($category->getImageUrl()) {
        $imageSrc = $category->getImageUrl();
    }
    $title       = $category->getName();
    $categoryDesc = $category->getDescription() ?: 'Peças e acessórios para motos';
    $description = strip_tags($categoryDesc);
    $description = mb_substr($description, 0, 200);
}
?>
<!-- Open Graph Protocol -->
<meta property="og:type" content="<?= $product ? 'product' : 'website' ?>" />
<meta property="og:title" content="<?= $escaper->escapeHtmlAttr($title) ?>" />
<meta property="og:description" content="<?= $escaper->escapeHtmlAttr($description) ?>" />
<meta property="og:url" content="<?= $escaper->escapeUrl($currentUrl) ?>" />
<meta property="og:image" content="<?= $escaper->escapeUrl($imageSrc) ?>" />
<meta property="og:site_name" content="<?= $escaper->escapeHtmlAttr($storeName) ?>" />
<meta property="og:locale" content="pt_BR" />

<?php if ($product && $product->getId()): ?>
<!-- Open Graph Product -->
<?php $ogFinalPrice = (float) $product->getFinalPrice(); ?>
<?php if ($ogFinalPrice > 0): ?>
<meta property="product:price:amount" content="<?= number_format($ogFinalPrice, 2, '.', '') ?>" />
<meta property="product:price:currency" content="BRL" />
<?php endif; ?>
<?php if ($product->isAvailable()): ?>
<meta property="product:availability" content="in stock" />
<?php endif; ?>
<?php endif; ?>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="<?= $escaper->escapeHtmlAttr($title) ?>" />
<meta name="twitter:description" content="<?= $escaper->escapeHtmlAttr($description) ?>" />
<meta name="twitter:image" content="<?= $escaper->escapeUrl($imageSrc) ?>" />

<!-- WhatsApp (usa Open Graph) -->
<meta property="og:image:alt" content="<?= $escaper->escapeHtmlAttr($title) ?>" />
