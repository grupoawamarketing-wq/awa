<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            Open Graph Meta Tags REMOVIDOS deste módulo.
            OG/Twitter tags agora gerenciados exclusivamente pelo bloco awa.og.meta
            em default_head_blocks.xml (tema AWA_Custom/ayo_home5_child).
            Removido para eliminar duplicação de og:title, og:description, etc.
        -->

        <!-- Schema.org Organization (não-homepage; homepage usa awa-seo-head.phtml @graph) -->
        <referenceContainer name="after.body.start">
            <block class="Magento\Framework\View\Element\Template"
                   name="grupoawamotos.schema.organization"
                   template="GrupoAwamotos_SchemaOrg::organization.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\SchemaOrg\ViewModel\OpenGraph</argument>
                    <argument name="og_viewmodel" xsi:type="object">GrupoAwamotos\SchemaOrg\ViewModel\OpenGraph</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
