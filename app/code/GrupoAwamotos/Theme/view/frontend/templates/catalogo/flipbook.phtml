?>
<header class="awa-catalog-revista-header">
    <p class="awa-catalog-revista-header__eyebrow"><?= $escaper->escapeHtml(__('Catálogo Digital')) ?></p>
    <h1 class="awa-catalog-revista-header__title"><?= $escaper->escapeHtml(__('Catálogo em Revista — AWA 2026')) ?></h1>
    <p class="awa-catalog-revista-header__subtitle">
        <?= $escaper->escapeHtml(__('Folheie as páginas com efeito de revista ou baixe o PDF completo.')) ?>
