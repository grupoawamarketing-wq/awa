<?php
declare(strict_types=1);
/**
 * Menu lateral do catálogo — modos de visualização + links institucionais.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \GrupoAwamotos\Theme\ViewModel\CatalogNav $navViewModel
 */

$navViewModel = $block->getData('nav_view_model');
$modeLinks = $navViewModel->getCatalogModeLinks();
$cmsLinks = $navViewModel->getCmsNavLinks();
?>
<nav class="awa-catalog-nav" aria-label="<?= $escaper->escapeHtmlAttr(__('Navegação do catálogo')) ?>">
    <div class="awa-catalog-nav__section">
        <p class="awa-catalog-nav__eyebrow"><?= $escaper->escapeHtml(__('Catálogo')) ?></p>
        <ul class="awa-catalog-nav__list">
            <?php foreach ($modeLinks as $link): ?>
                <li class="awa-catalog-nav__item">
                    <a href="<?= $escaper->escapeUrl($link['url']) ?>"
                       class="awa-catalog-nav__link<?= !empty($link['active']) ? ' is-active' : '' ?><?= !empty($link['highlight']) ? ' is-highlight' : '' ?>"
                       <?= !empty($link['active']) ? ' aria-current="page"' : '' ?>>
                        <?php if (!empty($link['highlight'])): ?>
                            <svg class="awa-catalog-nav__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H18a2 2 0 0 1 2 2v14a1 1 0 0 1-1.447.894L12 17.118l-6.553 3.776A1 1 0 0 1 4 20.5v-15Z" stroke="currentColor" stroke-width="1.6"/>
                            </svg>
                        <?php endif; ?>
                        <span><?= $escaper->escapeHtml($link['label']) ?></span>
                    </a>
                </li>
            <?php endforeach; ?>
        </ul>
    </div>

    <?php if ($cmsLinks !== []): ?>
        <details class="awa-catalog-nav__section awa-catalog-nav__section--institutional">
            <summary class="awa-catalog-nav__eyebrow awa-catalog-nav__summary">
                <?= $escaper->escapeHtml(__('Institucional')) ?>
            </summary>
            <ul class="awa-catalog-nav__list">
                <?php foreach ($cmsLinks as $link): ?>
                    <li class="awa-catalog-nav__item">
                        <a href="<?= $escaper->escapeUrl($link['url']) ?>"
                           class="awa-catalog-nav__link">
                            <span><?= $escaper->escapeHtml($link['label']) ?></span>
                        </a>
                    </li>
                <?php endforeach; ?>
            </ul>
        </details>
    <?php endif; ?>
</nav>
