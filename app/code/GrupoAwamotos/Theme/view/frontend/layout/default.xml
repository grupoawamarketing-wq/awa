<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="cookie_config" template="GrupoAwamotos_Theme::core/cookie-config.phtml"/>
        <referenceBlock name="authentication-popup" template="GrupoAwamotos_Theme::core/authentication-popup.phtml"/>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="grupoawamotos_whatsapp_btn"
                   template="GrupoAwamotos_Theme::core/whatsapp-btn.phtml">
                <arguments>
                    <argument name="contact_info" xsi:type="object">GrupoAwamotos\Theme\ViewModel\ContactInfo</argument>
                </arguments>
            </block>
            <!-- AWA UX: Botão Voltar ao Topo — visível em todas as páginas -->
            <block class="Magento\Framework\View\Element\Template"
                   name="grupoawamotos_back_to_top"
                   template="GrupoAwamotos_Theme::core/back-to-top.phtml"
                   after="grupoawamotos_whatsapp_btn"/>
        </referenceContainer>
    </body>
</page>
