<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="2columns-left"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="GrupoAwamotos_Theme::css/catalogo-viewer.css"/>
        <css src="GrupoAwamotos_Theme::css/awa-catalog-flipbook.css"/>
    </head>
    <body>
        <attribute name="class" value="catalogo-revista-index awa-catalog-flipbook-page awa-catalog-page"/>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceBlock name="sale.reorder.sidebar" remove="true"/>
        <referenceContainer name="sidebar.main">
            <block class="Magento\Framework\View\Element\Template"
                   name="catalogo.nav.sidebar"
                   template="GrupoAwamotos_Theme::catalogo/nav-sidebar.phtml"
                   before="-">
                <arguments>
                    <argument name="nav_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\CatalogNav</argument>
                    <argument name="viewer_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\CatalogViewer</argument>
                </arguments>
            </block>
        </referenceContainer>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="catalogo.flipbook"
                   template="GrupoAwamotos_Theme::catalogo/flipbook.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\CatalogViewer</argument>
                    <argument name="nav_view_model" xsi:type="object">GrupoAwamotos\Theme\ViewModel\CatalogNav</argument>
                </arguments>
            </block>
        </referenceContainer>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="catalogo.flipbook.scripts"
                   template="GrupoAwamotos_Theme::catalogo/flipbook-scripts.phtml"/>
        </referenceContainer>
    </body>
</page>
