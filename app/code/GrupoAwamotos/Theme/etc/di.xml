<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Rokanthemes\VerticalMenu\Block\Verticalmenu"
                type="GrupoAwamotos\Theme\Block\VerticalMenu\SafeVerticalmenu"/>

    <type name="Magento\Customer\Block\Form\Register">
        <plugin name="grupoawamotos_theme_register_button_lock_manager"
                type="GrupoAwamotos\Theme\Plugin\Customer\Form\RegisterButtonLockManagerPlugin"
                sortOrder="10"/>
    </type>

    <type name="Magento\Framework\App\Cache\Manager">
        <plugin name="grupoawamotos_theme_cache_manager_warmup"
                type="GrupoAwamotos\Theme\Plugin\Framework\App\Cache\ManagerWarmupPlugin"
                sortOrder="10"/>
    </type>

    <type name="Magento\Framework\App\MaintenanceMode">
        <plugin name="grupoawamotos_theme_maintenance_mode_warmup"
                type="GrupoAwamotos\Theme\Plugin\Framework\App\MaintenanceModeWarmupPlugin"
                sortOrder="10"/>
    </type>

    <type name="Magento\Catalog\Block\Product\AbstractProduct">
        <plugin name="grupoawamotos_theme_hide_pdp_review_summary"
                type="GrupoAwamotos\Theme\Plugin\Catalog\Block\Product\HidePdpReviewSummaryPlugin"
                sortOrder="10"/>
    </type>

    <type name="Rokanthemes\SlideBanner\Block\Slider">
        <plugin name="grupoawamotos_theme_slide_alt_normalize"
                type="GrupoAwamotos\Theme\Plugin\SlideBanner\SliderSlideAltNormalizePlugin"
                sortOrder="1"/>
        <plugin name="grupoawamotos_theme_hero_preload"
                type="GrupoAwamotos\Theme\Plugin\SlideBanner\HeroPreloadPlugin"
                sortOrder="5"/>
    </type>
    <type name="Magento\Framework\View\Page\Config\Renderer">
        <plugin name="grupoawamotos_theme_head_asset_rubik_async"
                type="GrupoAwamotos\Theme\Plugin\Framework\View\Page\Config\HeadAssetRendererPlugin"
                sortOrder="5"/>
    </type>
    <type name="Magento\Framework\App\Response\Http">
        <plugin name="grupoawamotos_theme_defer_home_scripts"
                type="GrupoAwamotos\Theme\Plugin\Response\DeferHomeScriptsPlugin"
                sortOrder="15"/>
    </type>
</config>
