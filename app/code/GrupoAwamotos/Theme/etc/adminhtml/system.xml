<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="grupoawamotos" translate="label" sortOrder="900">
            <label>AWA Motos</label>
        </tab>
        <section id="grupoawamotos_theme" translate="label" sortOrder="10"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Tema &amp; Contato</label>
            <tab>grupoawamotos</tab>
            <resource>Magento_Config::config</resource>
            <group id="contact" translate="label" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Informações de Contato</label>
                <field id="whatsapp_enabled" translate="label comment" type="select" sortOrder="5"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Botão WhatsApp — Ativo</label>
                    <comment>Exibe o botão flutuante do WhatsApp no frontend</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="whatsapp_number" translate="label comment" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>WhatsApp (número)</label>
                    <comment>Formato internacional sem + e sem espaços. Ex: 5516997367588</comment>
                    <validate>validate-digits</validate>
                </field>
                <field id="whatsapp_message" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>WhatsApp (mensagem padrão)</label>
                    <comment>Mensagem pré-preenchida ao abrir WhatsApp</comment>
                </field>
                <field id="whatsapp_hide_checkout" translate="label comment" type="select" sortOrder="45"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Ocultar no Checkout</label>
                    <comment>Esconde o botão durante o processo de finalização de compra</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="whatsapp_hide_account" translate="label comment" type="select" sortOrder="46"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Ocultar na Área do Cliente</label>
                    <comment>Esconde o botão nas páginas de conta do cliente</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="phone" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Telefone (formato E.164)</label>
                    <comment>Ex: +5516997367588 — usado em JSON-LD e Schema.org</comment>
                </field>
                <field id="email" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>E-mail de contato</label>
                    <validate>validate-email</validate>
                </field>
                <field id="quote_fab_enabled" translate="label comment" type="select" sortOrder="70"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Botão Cotação Rápida (FAB) — Ativo</label>
                    <comment>Exibe o botão flutuante de solicitação de cotação no frontend</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
            <group id="header_experiment" translate="label" sortOrder="20"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Header Experimentação</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Feature Flag — Header Progressivo</label>
                    <comment>Ativa melhorias progressivas do header com rollout controlado.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="rollout_percentage" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Percentual de Rollout (0-100)</label>
                    <comment>Define o tráfego no experimento B. Exemplo: 25.</comment>
                    <validate>validate-number validate-number-range number-range-0-100</validate>
                </field>
                <field id="variant_seed" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Seed da Variante</label>
                    <comment>Texto fixo para versionar buckets do experimento.</comment>
                </field>
            </group>
            <group id="footer_experiment" translate="label" sortOrder="30"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Footer Experimentação</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Feature Flag — Footer Progressivo</label>
                    <comment>Ativa melhorias progressivas do footer com rollout controlado.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="rollout_percentage" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Percentual de Rollout (0-100)</label>
                    <comment>Define o tráfego no experimento B. Exemplo: 20.</comment>
                    <validate>validate-number validate-number-range number-range-0-100</validate>
                </field>
                <field id="variant_seed" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Seed da Variante</label>
                    <comment>Texto fixo para versionar buckets do experimento do rodapé.</comment>
                </field>
            </group>
            <group id="catalogo" translate="label" sortOrder="30"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Catálogo Digital</label>
                <field id="nav_links" translate="label comment" type="textarea" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Links do menu lateral</label>
                    <comment><![CDATA[Um link por linha: Rótulo|identificador. Use route:b2b/register para rotas Magento. Exemplo: Condições Atacado|atacado/condicoes]]></comment>
                </field>
            </group>
        </section>
    </system>
</config>
