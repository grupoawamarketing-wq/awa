<?php
/**
 * Template para exibir recomendações personalizadas (dados reais RexisML)
 *
 * @var $block \GrupoAwamotos\RexisML\Block\Recommendations
 */
declare(strict_types=1);

$recommendations = $block->getRecommendedProducts();
if (empty($recommendations)) {
    return;
}
$rfm = $block->getCustomerRfm();
$counts = $block->getRecommendationCounts();
?>

<div class="rexis-recommendations-wrapper">
    <div class="rexis-recommendations-header">
        <h2 class="rexis-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <?= $block->escapeHtml($block->getTitle()) ?>
            <span class="rexis-badge">IA</span>
        </h2>
        <p class="rexis-subtitle">
            <?= $block->escapeHtml(__('Selecionados especialmente para você com base em Inteligência Artificial')) ?>
        </p>
        <?php if ($rfm && isset($rfm['classificacao_cliente'])): ?>
            <span class="rexis-rfm-badge"><?= $block->escapeHtml($rfm['classificacao_cliente']) ?></span>
        <?php endif; ?>
    </div>

    <div class="rexis-products-grid">
        <?php foreach ($recommendations as $item): ?>
            <?php
            $product = $item['product'];
            $score = $item['score'] * 100;
            $classificacao = $item['classificacao'];
            $info = $block->getClassificationInfo($classificacao);
            $recencia = $item['recencia'] ?? 0;
            ?>
            <div class="rexis-product-item <?= $block->escapeHtmlAttr($info['class']) ?>">
                <!-- Badge de Classificação -->
                <div class="rexis-classification-badge">
                    <span style="--rexis-badge-bg:<?= $block->escapeHtmlAttr($info['color']) ?>">
                        <?= $block->escapeHtml($info['label']) ?>
                    </span>
                </div>

                <!-- Score de ML -->
                <?php if ($score >= 40): ?>
                    <div class="rexis-ml-score">
                        <span><?= round($score) ?>% Match</span>
                    </div>
                <?php endif; ?>

                <!-- Imagem do Produto -->
                <div class="rexis-product-image">
                    <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>" title="<?= $block->escapeHtmlAttr($product->getName()) ?>">
                        <?php $imgUrl = $block->getProductImageUrl($product); ?>
                        <?php if ($imgUrl): ?>
                            <img src="<?= $block->escapeUrl($imgUrl) ?>"
                                   alt="<?= $block->escapeHtmlAttr($product->getName()) ?>"
                                   loading="lazy" decoding="async" width="160" height="160" />
                        <?php else: ?>
                            <div class="rexis-no-image">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                            </div>
                        <?php endif; ?>
                    </a>
                </div>

                <!-- SKU -->
                <div class="rexis-product-sku">
                    SKU: <?= $block->escapeHtml($product->getSku()) ?>
                </div>

                <!-- Detalhes do Produto -->
                <div class="rexis-product-details">
                    <h3 class="rexis-product-name">
                        <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>">
                            <?= $block->escapeHtml($product->getName()) ?>
                        </a>
                    </h3>

                    <div class="rexis-product-price">
                        <?php
                        try {
                            echo $block->getLayout()->createBlock('Magento\Catalog\Pricing\Render')->render(
                                'final_price',
                                $product,
                                ['zone' => 'item_list']
                            );
                        } catch (\Exception $e) {
                            // Fallback
                            echo 'R$ ' . number_format((float)$product->getFinalPrice(), 2, ',', '.');
                        }
                        ?>
                    </div>

                    <!-- Info adicional para Churn -->
                    <?php if ($classificacao === 'churn' && $recencia > 0): ?>
                        <div class="rexis-special-offer">
                            <span><?= $block->escapeHtml(__('Há %1 dias sem comprar - Oferta exclusiva!', (int)$recencia)) ?></span>
                        </div>
                    <?php endif; ?>

                    <!-- Valor previsto -->
                    <?php if ($item['predicted_value'] > 0): ?>
                        <div class="rexis-predicted-value">
                            <?= $block->escapeHtml(__('Previsão: R$ %1', number_format((float)$item['predicted_value'], 2, ',', '.'))) ?>
                        </div>
                    <?php endif; ?>

                    <!-- Add to Cart -->
                    <div class="rexis-product-actions">
                        <?php $postParams = $block->getAddToCartPostParams($product); ?>
                        <?php if ($postParams): ?>
                            <form data-role="tocart-form"
                                  action="<?= $block->escapeUrl($postParams['action']) ?>"
                                  method="post">
                                <?php foreach ($postParams['data'] as $key => $value): ?>
                                    <input type="hidden" name="<?= $block->escapeHtmlAttr($key) ?>"
                                           value="<?= $block->escapeHtmlAttr($value) ?>">
                                <?php endforeach; ?>
                                <button type="submit"
                                        class="action tocart primary rexis-add-to-cart"
                                        title="<?= $block->escapeHtmlAttr(__('Adicionar ao Carrinho')) ?>">
                                    <span><?= $block->escapeHtml(__('Adicionar ao Carrinho')) ?></span>
                                </button>
                            </form>
                        <?php endif; ?>
                    </div>
                </div>
            </div>
        <?php endforeach; ?>
    </div>

    <?php if ((int)$counts['total'] > count($recommendations)): ?>
        <div class="rexis-see-more">
            <p><?= $block->escapeHtml(__('Mais %1 recomendações disponíveis para você', (int)$counts['total'] - count($recommendations))) ?></p>
        </div>
    <?php endif; ?>
</div>
