<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content.aside">
            <block class="GrupoAwamotos\RexisML\Block\Product\CrossSell"
                   name="rexisml.product.crosssell"
                   template="GrupoAwamotos_RexisML::product/crosssell.phtml"
                   after="product.info.upsell">
                <arguments>
                    <argument name="limit" xsi:type="number">8</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
