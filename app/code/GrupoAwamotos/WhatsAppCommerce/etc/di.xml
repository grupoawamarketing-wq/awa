<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Logger dedicado para WhatsApp Commerce -->
    <virtualType name="GrupoAwamotos\WhatsAppCommerce\Logger\Handler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/whatsapp_commerce.log</argument>
        </arguments>
    </virtualType>

    <virtualType name="GrupoAwamotos\WhatsAppCommerce\Logger\Logger"
                 type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">whatsapp_commerce</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Preferences -->
    <preference for="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface"
                type="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppCatalog"/>
    <preference for="GrupoAwamotos\WhatsAppCommerce\Api\TrackingInterface"
                type="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppTracking"/>
    <preference for="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface"
                type="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppCart"/>

    <!-- Injetar logger dedicado nos Models -->
    <type name="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppCatalog">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>
    <type name="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppTracking">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>
    <type name="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppCart">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>
    <type name="GrupoAwamotos\WhatsAppCommerce\Model\MessageSender">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>

    <preference for="GrupoAwamotos\WhatsAppCommerce\Api\AttendantInterface"
                type="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppAttendant"/>

    <type name="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppAttendant">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- Controller: Injetar logger dedicado -->
    <type name="GrupoAwamotos\WhatsAppCommerce\Controller\Checkout\SaveOptin">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- Optin API -->
    <preference for="GrupoAwamotos\WhatsAppCommerce\Api\OptinInterface"
                type="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppOptin"/>

    <type name="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppOptin">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- Rate Limiter: 60 req/min por token nas APIs /V1/awa-whatsapp/* -->
    <type name="Magento\Webapi\Controller\Rest">
        <plugin name="grupoawamotos_whatsapp_rate_limiter"
                type="GrupoAwamotos\WhatsAppCommerce\Plugin\ApiRateLimiter"
                sortOrder="10"/>
    </type>
    <type name="GrupoAwamotos\WhatsAppCommerce\Plugin\ApiRateLimiter">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- ==================== B2B WhatsApp (Fase 4) ==================== -->

    <!-- B2B Registration -->
    <preference for="GrupoAwamotos\WhatsAppCommerce\Api\B2BRegistrationInterface"
                type="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppB2BRegistration"/>

    <type name="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppB2BRegistration">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- B2B Quote -->
    <preference for="GrupoAwamotos\WhatsAppCommerce\Api\B2BQuoteInterface"
                type="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppB2BQuote"/>

    <type name="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppB2BQuote">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- B2B Reorder -->
    <preference for="GrupoAwamotos\WhatsAppCommerce\Api\B2BReorderInterface"
                type="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppB2BReorder"/>

    <type name="GrupoAwamotos\WhatsAppCommerce\Model\WhatsAppB2BReorder">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- B2B Alerts Cron -->
    <type name="GrupoAwamotos\WhatsAppCommerce\Cron\B2BAlerts">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\WhatsAppCommerce\Logger\Logger</argument>
        </arguments>
    </type>
</config>
