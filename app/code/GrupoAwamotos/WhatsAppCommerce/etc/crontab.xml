<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <!-- B2B Alerts: stock, new products, credit reminders — runs daily at 9:00 AM -->
        <job name="whatsapp_commerce_b2b_alerts"
             instance="GrupoAwamotos\WhatsAppCommerce\Cron\B2BAlerts"
             method="execute">
            <schedule>0 9 * * *</schedule>
        </job>

        <!-- Health Check: every 5 minutes -->
        <job name="whatsapp_commerce_health_check"
             instance="GrupoAwamotos\WhatsAppCommerce\Cron\HealthCheck"
             method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>

        <!-- Phase 6: Review Request — daily at 10:00 AM -->
        <job name="whatsapp_commerce_review_request"
             instance="GrupoAwamotos\WhatsAppCommerce\Cron\ReviewRequest"
             method="execute">
            <schedule>0 10 * * *</schedule>
        </job>

        <!-- Phase 6: Meta Description Generator — weekly Sunday at 3:00 AM -->
        <job name="whatsapp_commerce_meta_generator"
             instance="GrupoAwamotos\WhatsAppCommerce\Cron\MetaDescriptionGenerator"
             method="execute">
            <schedule>0 3 * * 0</schedule>
        </job>

        <!-- Phase 6: Retargeting Campaign — daily at 11:00 AM -->
        <job name="whatsapp_commerce_retargeting"
             instance="GrupoAwamotos\WhatsAppCommerce\Cron\RetargetingCampaign"
             method="execute">
            <schedule>0 11 * * *</schedule>
        </job>

    </group>
</config>
