<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <!-- B2B Alerts: stock, new products, credit reminders — runs daily at 9:00 AM -->
        <job name="whatsapp_commerce_b2b_alerts"
             instance="GrupoAwamotos\WhatsAppCommerce\Cron\B2BAlerts"
             method="execute">
            <schedule>0 9 * * *</schedule>
        </job>
    </group>
</config>
