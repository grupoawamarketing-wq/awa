<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="grupoawamotos" translate="label" sortOrder="200">
            <label>AWA Motos</label>
        </tab>
        <section id="whatsapp_commerce" translate="label" sortOrder="30"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>WhatsApp Commerce</label>
            <tab>grupoawamotos</tab>
            <resource>GrupoAwamotos_WhatsAppCommerce::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Configurações Gerais</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Habilitar</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="max_products_per_response" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Produtos por Resposta</label>
                    <comment>Máximo de produtos retornados por busca no WhatsApp</comment>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="checkout_base_url" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>URL Base do Checkout</label>
                    <comment>Se vazio, usa a URL padrão da loja (ex: https://awamotos.com/checkout)</comment>
                </field>
            </group>
            <group id="notifications" translate="label" type="text" sortOrder="20"
                   showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Notificações por WhatsApp</label>
                <field id="order_placed" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Pedido Confirmado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="order_paid" translate="label" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Pagamento Confirmado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="order_shipped" translate="label" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Pedido Enviado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="order_refunded" translate="label" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Reembolso Processado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
                    <group id="b2b" translate="label" type="text" sortOrder="30"
                   showInDefault="1" showInWebsite="1" showInStore="0">
                <label>B2B WhatsApp (Fase 4)</label>
                <comment>Configurações das funcionalidades B2B via WhatsApp: cadastro, cotações, recompra e alertas.</comment>
                <field id="alerts_enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Habilitar Alertas B2B</label>
                    <comment>Envia alertas automáticos via WhatsApp para clientes B2B (estoque, novidades, crédito)</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="stock_alert_enabled" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Alerta de Estoque</label>
                    <comment>Notifica clientes B2B quando produtos que compram voltam ao estoque</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="alerts_enabled">1</field>
                    </depends>
                </field>
                <field id="new_product_alert_enabled" translate="label comment" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Alerta de Novos Produtos</label>
                    <comment>Notifica clientes B2B sobre novos produtos nas categorias que compram</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="alerts_enabled">1</field>
                    </depends>
                </field>
                <field id="credit_reminder_enabled" translate="label comment" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Lembrete de Crédito</label>
                    <comment>Envia lembretes quando o crédito B2B do cliente está acima de 70% de uso</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="alerts_enabled">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
