<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- Catálogo: Busca por texto -->
    <route url="/V1/awa-whatsapp/catalog/search" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="search"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Catálogo: Busca por Fitment (marca/modelo/ano) -->
    <route url="/V1/awa-whatsapp/catalog/fitment" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="searchByFitment"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Catálogo: Categorias top-level -->
    <route url="/V1/awa-whatsapp/catalog/categories" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="getCategories"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Catálogo: Produtos da categoria -->
    <route url="/V1/awa-whatsapp/catalog/category/:categoryId" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="getProductsByCategory"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Catálogo: Detalhe do produto -->
    <route url="/V1/awa-whatsapp/catalog/product/:sku" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="getProduct"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Carrinho: Criar -->
    <route url="/V1/awa-whatsapp/cart/create" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface" method="createCart"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Carrinho: Adicionar item -->
    <route url="/V1/awa-whatsapp/cart/add" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface" method="addItem"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Carrinho: Ver -->
    <route url="/V1/awa-whatsapp/cart/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface" method="viewCart"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Carrinho: Link de checkout -->
    <route url="/V1/awa-whatsapp/cart/:phone/checkout-link" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface" method="getCheckoutLink"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Tracking: Pedidos por telefone -->
    <route url="/V1/awa-whatsapp/tracking/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\TrackingInterface" method="getOrders"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>


    <route url="/V1/awa-whatsapp/attendant/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\AttendantInterface" method="getByPhone"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>
    <!-- Opt-in: Get status by phone -->
    <route url="/V1/awa-whatsapp/optin/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\OptinInterface" method="getOptin"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>

    <!-- Opt-in: Set opt-in/opt-out by phone -->
    <route url="/V1/awa-whatsapp/optin" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\OptinInterface" method="setOptin"/>
        <resources>
            <resource ref="GrupoAwamotos_WhatsAppCommerce::api"/>
        </resources>
    </route>
</routes>
