<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <route url="/V1/awa-whatsapp/catalog/search" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="search"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/catalog/fitment" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="searchByFitment"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/catalog/categories" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="getCategories"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/catalog/category/:categoryId" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="getProductsByCategory"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/catalog/product/:sku" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CatalogInterface" method="getProduct"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/cart/create" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface" method="createCart"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/cart/add" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface" method="addItem"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/cart/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface" method="viewCart"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/cart/:phone/checkout-link" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\CartInterface" method="getCheckoutLink"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/tracking/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\TrackingInterface" method="getOrders"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/attendant/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\AttendantInterface" method="getByPhone"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/optin/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\OptinInterface" method="getOptin"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <route url="/V1/awa-whatsapp/optin" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\OptinInterface" method="setOptin"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Registration: Validate CNPJ -->
    <route url="/V1/awa-whatsapp/b2b/validate-cnpj/:cnpj" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BRegistrationInterface" method="validateCnpj"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Registration: Register lead -->
    <route url="/V1/awa-whatsapp/b2b/register" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BRegistrationInterface" method="register"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Registration: Check status -->
    <route url="/V1/awa-whatsapp/b2b/status/:identifier" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BRegistrationInterface" method="checkStatus"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Quote: Submit -->
    <route url="/V1/awa-whatsapp/b2b/quote/submit" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BQuoteInterface" method="submitQuote"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Quote: List by phone -->
    <route url="/V1/awa-whatsapp/b2b/quotes/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BQuoteInterface" method="getQuotes"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Quote: Detail -->
    <route url="/V1/awa-whatsapp/b2b/quote/:requestId/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BQuoteInterface" method="getQuoteDetail"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Quote: Accept -->
    <route url="/V1/awa-whatsapp/b2b/quote/accept" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BQuoteInterface" method="acceptQuote"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Reorder: List orders -->
    <route url="/V1/awa-whatsapp/b2b/reorder/list/:phone" method="GET">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BReorderInterface" method="getReorderableOrders"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Reorder: Specific order -->
    <route url="/V1/awa-whatsapp/b2b/reorder/:phone/:orderIncrementId" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BReorderInterface" method="reorderByOrderId"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>

    <!-- B2B Reorder: Last order -->
    <route url="/V1/awa-whatsapp/b2b/reorder-last/:phone" method="POST">
        <service class="GrupoAwamotos\WhatsAppCommerce\Api\B2BReorderInterface" method="reorderLast"/>
        <resources><resource ref="GrupoAwamotos_WhatsAppCommerce::api"/></resources>
    </route>
</routes>
