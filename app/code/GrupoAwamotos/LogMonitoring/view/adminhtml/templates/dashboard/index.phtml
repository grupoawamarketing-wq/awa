<style>
.awa-log-monitoring-dashboard { padding: 20px; }
.health-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin: 20px 0; }
.health-card { background: var(--log-dash-c6); border: 1px solid var(--log-dash-c4); border-radius: 4px; padding: 15px; }
.health-score { font-size: 24px; font-weight: bold; margin: 10px 0; }
.health-score.excellent, .health-score.healthy { color: var(--log-dash-c2); }
.health-score.warning { color: var(--log-dash-c3); }
.health-score.critical, .health-score.failing { color: var(--log-dash-c1); }
.loading-indicator { text-align: center; padding: 40px; color: var(--log-dash-c5); }
</style>

<script>
require(['jquery'], function($) {
    loadDashboardData();
    setInterval(loadDashboardData, 30000);

    function loadDashboardData() {
        $.get('<?= $block->escapeJs($block->getApiUrl('dashboard')) ?>')
            .done(function(data) {
                updateAwaMetrics(data.awamotos_metrics);
            })
            .fail(function() {
                $('#awa-metrics-dashboard .loading-indicator').text('Error loading data');
            });
    }
    
    function updateAwaMetrics(metrics) {
        if (metrics && !metrics.error) {
            let html = '<div class="awa-metrics-grid">';
            
            if (metrics.erp_sync) {
                html += '<div class="metric-card erp">';
                html += '<h4>ERP Integration</h4>';
                html += '<div class="metric-value">' + (metrics.erp_sync.health_score || 0) + '/100</div>';
                html += '</div>';
            }

            if (metrics.performance) {
                html += '<div class="metric-card performance">';
                html += '<h4>Performance</h4>';
                html += '<div class="metric-value">' + (metrics.performance.health_score || 0) + '/100</div>';
                html += '</div>';
            }
            
            html += '</div>';
            $('#awa-metrics-dashboard').html(html);
        }
    }
    
    window.refreshDashboard = function() { location.reload(); };
    window.triggerAnalysis = function() {
        $.post('<?= $block->escapeJs($block->getTriggerAnalysisUrl()) ?>')
            .done(function() { alert('Analysis triggered successfully'); });
    };
});
</script>