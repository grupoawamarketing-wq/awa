<script>
require(['jquery', 'Magento_Ui/js/modal/confirm'], function($, confirm) {
    
    window.acknowledgeAlert = function(alertId) {
        confirm({
            title: 'Acknowledge Alert',
            content: 'Are you sure you want to acknowledge this alert?',
            actions: {
                confirm: function() {
                    $.ajax({
                        url: '<?= $block->escapeJs($block->getAcknowledgeUrl()) ?>/' + alertId + '/acknowledge',
                        type: 'PUT',
                        data: { acknowledgedBy: 'admin' },
                        success: function() {
                            location.reload();
                        },
                        error: function(xhr) {
                            alert('Error acknowledging alert: ' + xhr.responseText);
                        }
                    });
                }
            }
        });
    };
    
    window.resolveAlert = function(alertId) {
        confirm({
            title: 'Resolve Alert',
            content: 'Are you sure you want to resolve this alert?',
            actions: {
                confirm: function() {
                    $.ajax({
                        url: '<?= $block->escapeJs($block->getResolveUrl()) ?>/' + alertId + '/resolve',
                        type: 'PUT',
                        data: { resolvedBy: 'admin' },
                        success: function() {
                            location.reload();
                        },
                        error: function(xhr) {
                            alert('Error resolving alert: ' + xhr.responseText);
                        }
                    });
                }
            }
        });
    };
});
</script>