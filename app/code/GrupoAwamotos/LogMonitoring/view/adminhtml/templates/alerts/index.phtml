                        </div>
                        
                        <div class="alert-content">
                            <p><?= $block->escapeHtml($alert->getMessage()) ?></p>
                            
                            <?php if ($alert->getOccurrences() > 1): ?>
                                <div class="alert-occurrences">
                                    <?= $block->escapeHtml(__('Occurrences: %1', $alert->getOccurrences())) ?>
