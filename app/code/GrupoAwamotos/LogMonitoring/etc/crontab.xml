<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <!-- Main log analysis every 15 minutes -->
        <job name="awa_log_monitoring_analyze" instance="GrupoAwamotos\LogMonitoring\Cron\LogAnalysis" method="execute">
            <schedule>*/15 * * * *</schedule>
        </job>
        
        <!-- System health check every 30 minutes -->
        <job name="awa_log_monitoring_health" instance="GrupoAwamotos\LogMonitoring\Cron\SystemHealthCheck" method="execute">
            <schedule>*/30 * * * *</schedule>
        </job>
        
        <!-- Alert processing every 5 minutes -->
        <job name="awa_log_monitoring_alerts" instance="GrupoAwamotos\LogMonitoring\Cron\AlertProcessor" method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>
        
        <!-- Cleanup old data daily at 2 AM -->
        <job name="awa_log_monitoring_cleanup" instance="GrupoAwamotos\LogMonitoring\Cron\DataCleanup" method="execute">
            <schedule>0 2 * * *</schedule>
        </job>
    </group>
</config>