<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- Monitoring Dashboard API -->
    <route url="/V1/log-monitoring/dashboard" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="getDashboardData"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <!-- System Health API -->
    <route url="/V1/log-monitoring/system-health" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="getSystemHealth"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <!-- Log Analysis API -->
    <route url="/V1/log-monitoring/log-analysis" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="getLogAnalysis"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <route url="/V1/log-monitoring/log-analysis/:logType" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="getLogAnalysis"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <!-- AWA Metrics API -->
    <route url="/V1/log-monitoring/awa-metrics" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="getAwamotosMetrics"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <!-- Performance Metrics API -->
    <route url="/V1/log-monitoring/performance" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="getPerformanceMetrics"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <!-- Alert Summary API -->
    <route url="/V1/log-monitoring/alert-summary" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="getAlertSummary"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::alerts"/>
        </resources>
    </route>

    <!-- Trigger Analysis API -->
    <route url="/V1/log-monitoring/trigger-analysis" method="POST">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="triggerLogAnalysis"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::manage"/>
        </resources>
    </route>

    <!-- Alert Management APIs -->
    <route url="/V1/log-monitoring/alerts/:alertId/acknowledge" method="PUT">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="acknowledgeAlert"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::alerts"/>
        </resources>
    </route>

    <route url="/V1/log-monitoring/alerts/:alertId/resolve" method="PUT">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="resolveAlert"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::alerts"/>
        </resources>
    </route>

    <!-- Test Notifications API -->
    <route url="/V1/log-monitoring/test-notifications" method="POST">
        <service class="GrupoAwamotos\LogMonitoring\Api\MonitoringInterface" method="testNotifications"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::manage"/>
        </resources>
    </route>

    <!-- Log Metrics Repository APIs -->
    <route url="/V1/log-monitoring/metrics" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\LogMetricsRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <route url="/V1/log-monitoring/metrics/:id" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\LogMetricsRepositoryInterface" method="getById"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <route url="/V1/log-monitoring/metrics/type/:logType" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\LogMetricsRepositoryInterface" method="getMetricsByType"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <route url="/V1/log-monitoring/metrics/trend/:logType" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\LogMetricsRepositoryInterface" method="getTrendData"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::monitoring"/>
        </resources>
    </route>

    <!-- Alert Repository APIs -->
    <route url="/V1/log-monitoring/alerts" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\AlertRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::alerts"/>
        </resources>
    </route>

    <route url="/V1/log-monitoring/alerts/:id" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\AlertRepositoryInterface" method="getById"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::alerts"/>
        </resources>
    </route>

    <route url="/V1/log-monitoring/alerts/active" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\AlertRepositoryInterface" method="getActiveAlerts"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::alerts"/>
        </resources>
    </route>

    <route url="/V1/log-monitoring/alerts/critical" method="GET">
        <service class="GrupoAwamotos\LogMonitoring\Api\AlertRepositoryInterface" method="getCriticalAlerts"/>
        <resources>
            <resource ref="GrupoAwamotos_LogMonitoring::alerts"/>
        </resources>
    </route>

</config>