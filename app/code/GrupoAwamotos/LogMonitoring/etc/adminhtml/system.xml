<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="awamotos" translate="label" sortOrder="100">
            <label>AWA Motos</label>
        </tab>
        
        <section id="log_monitoring" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Log Monitoring</label>
            <tab>awamotos</tab>
            <resource>GrupoAwamotos_LogMonitoring::configuration</resource>
            
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Log Monitoring</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Enable or disable the log monitoring system</comment>
                </field>
                
                <field id="analysis_frequency" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Analysis Frequency</label>
                    <source_model>Magento\Cron\Model\Config\Source\Frequency</source_model>
                    <comment>How often to run automatic log analysis</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                
                <field id="retention_days" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Data Retention (Days)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Number of days to keep log metrics and alerts data</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <group id="notifications" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Notification Settings</label>
                
                <field id="email_enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Email Notifications</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                
                <field id="email_recipients" translate="label" type="textarea" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Email Recipients</label>
                    <comment>Comma-separated list of email addresses</comment>
                    <depends>
                        <field id="email_enabled">1</field>
                    </depends>
                </field>
                
                <field id="slack_enabled" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Slack Notifications</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                
                <field id="slack_webhook" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Slack Webhook URL</label>
                    <comment>Slack webhook URL for notifications</comment>
                    <depends>
                        <field id="slack_enabled">1</field>
                    </depends>
                </field>
                
                <field id="webhook_enabled" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Webhook Notifications</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                
                <field id="webhook_url" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Webhook URL</label>
                    <comment>Custom webhook URL for notifications</comment>
                    <depends>
                        <field id="webhook_enabled">1</field>
                    </depends>
                </field>
            </group>

            <group id="awa_specific" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>AWA Specific Settings</label>
                
                <field id="erp_monitoring" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable ERP Monitoring</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Monitor ERP integration logs and performance</comment>
                </field>
                
                <field id="chatwoot_monitoring" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Chatwoot Monitoring</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Monitor Chatwoot integration health</comment>
                </field>
                
                <field id="performance_monitoring" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Performance Monitoring</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Monitor system performance and cache efficiency</comment>
                </field>
                
                <field id="alert_thresholds" translate="label" type="textarea" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Alert Thresholds (JSON)</label>
                    <comment>JSON configuration for custom alert thresholds</comment>
                </field>
            </group>

            <group id="advanced" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Advanced Settings</label>
                
                <field id="debug_mode" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Debug Mode</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Enable debug logging for troubleshooting</comment>
                </field>
                
                <field id="api_rate_limit" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>API Rate Limit (per minute)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Maximum API requests per minute</comment>
                </field>
                
                <field id="max_file_size" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Log File Size (MB)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Maximum log file size to analyze in MB</comment>
                </field>
            </group>
        </section>
    </system>
</config>