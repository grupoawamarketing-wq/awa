<?php
/**
 * Tawk.to Widget with B2B/RFM enrichment
 *
 * @var \GrupoAwamotos\TawkIntegration\Block\Widget $block
 */
declare(strict_types=1);

$propertyId = $block->escapeJs($block->getPropertyId());
$widgetId = $block->escapeJs($block->getWidgetId());
$visitorData = $block->getVisitorData();
$attributes = $block->getEnrichmentAttributes();
$tags = $block->getAutoTags();
?>
<script type="text/javascript">
    var Tawk_API = Tawk_API || {};
    var Tawk_LoadStart = new Date();

    <?php if ($visitorData !== null): ?>
    Tawk_API.visitor = {
        name: <?= /* @noEscape */ json_encode($visitorData['name']) ?>,
        email: <?= /* @noEscape */ json_encode($visitorData['email']) ?>
        <?php if ($visitorData['hash'] !== ''): ?>
        , hash: <?= /* @noEscape */ json_encode($visitorData['hash']) ?>
        <?php endif; ?>
    };
    <?php endif; ?>

    Tawk_API.onLoad = function () {
        Tawk_API.setLanguage('pt-br');
        <?php if (!empty($attributes)): ?>
        Tawk_API.setAttributes(<?= /* @noEscape */ json_encode($attributes, JSON_UNESCAPED_UNICODE) ?>, function (error) {
            if (error) {
                console.warn('[TawkIntegration] setAttributes error:', error);
            }
        });
        <?php endif; ?>

        <?php if (!empty($tags)): ?>
        Tawk_API.addTags(<?= /* @noEscape */ json_encode($tags, JSON_UNESCAPED_UNICODE) ?>, function (error) {
            if (error) {
                console.warn('[TawkIntegration] addTags error:', error);
            }
        });
        <?php endif; ?>
    };

    Tawk_API.onChatStarted = function () {
        Tawk_API.addEvent('chat-iniciado', {
            pagina: window.location.pathname
        }, function (error) {
            if (error) {
                console.warn('[TawkIntegration] addEvent error:', error);
            }
        });
    };

    (function () {
        var s1 = document.createElement("script"), s0 = document.getElementsByTagName("script")[0];
        s1.async = true;
        s1.src = 'https://embed.tawk.to/<?= /* @noEscape */ $propertyId ?>/<?= /* @noEscape */ $widgetId ?>';
        s1.charset = 'UTF-8';
        s0.parentNode.insertBefore(s1, s0);
    })();
</script>
