<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block class="GrupoAwamotos\TawkIntegration\Block\Widget"
                   name="tawk.integration.widget"
                   template="GrupoAwamotos_TawkIntegration::widget.phtml"
                   ifconfig="grupoawamotos_tawk/general/enabled"/>
        </referenceContainer>
        <!-- Desativa botão flutuante de WhatsApp: Tawk.to assume o atendimento -->
        <referenceBlock name="grupoawamotos_whatsapp_btn" remove="true"/>
    </body>
</page>
