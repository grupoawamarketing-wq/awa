<?php
/**
 * Admin Customer Tab — Tawk.to Chat Log
 *
 * @var \GrupoAwamotos\TawkIntegration\Block\Adminhtml\Customer\Tab\ChatLog $block
 */
declare(strict_types=1);

$chatLogs        = $block->getChatLogs();
$assignedAtt     = $block->getAssignedAttendant();
$attendantList   = $block->getAttendantList();
$assignUrl       = $block->getAssignUrl();
$customerId      = $block->getCustomerId();
?>
<div class="fieldset-wrapper" id="tawk-chat-log">

    <!-- ===== Attendant Assignment Section ===== -->
    <div class="fieldset-wrapper-title">
        <strong class="title">
            <span><?= $block->escapeHtml(__('Atendente Responsável')) ?></span>
        </strong>
    </div>
    <div class="fieldset-wrapper-content" style="margin-bottom:24px">
        <?php if ($assignedAtt): ?>
            <p style="margin:0 0 12px;font-size:14px">
                <strong><?= $block->escapeHtml(__('Atendente atual:')) ?></strong>
                <?= $block->escapeHtml($assignedAtt['name']) ?>
                <span style="color:#777;font-size:12px">(<?= $block->escapeHtml($assignedAtt['email']) ?>)</span>
            </p>
        <?php else: ?>
            <p style="margin:0 0 12px;color:#888"><?= $block->escapeHtml(__('Nenhum atendente atribuído ainda.')) ?></p>
        <?php endif; ?>

        <form action="<?= $block->escapeUrl($assignUrl) ?>" method="post" style="display:inline-flex;align-items:center;gap:10px">
            <?= $block->getBlockHtml('formkey') ?>
            <input type="hidden" name="customer_id" value="<?= $block->escapeHtmlAttr((string) $customerId) ?>">
            <label for="tawk_attendant_select" style="font-weight:bold;font-size:13px"><?= $block->escapeHtml(__('Atribuir:')) ?></label>
            <select id="tawk_attendant_select" name="attendant_code" class="admin__control-select" style="min-width:220px">
                <?php foreach ($attendantList as $code => $info): ?>
                    <option value="<?= $block->escapeHtmlAttr($code) ?>"
                        <?= (isset($assignedAtt['code']) && $assignedAtt['code'] === $code) ? 'selected' : '' ?>>
                        <?= $block->escapeHtml($info['name']) ?> (<?= $block->escapeHtml($code) ?>)
                    </option>
                <?php endforeach; ?>
            </select>
            <button type="submit" class="action-default scalable save primary" style="padding:6px 16px;font-size:13px">
                <?= $block->escapeHtml(__('Salvar')) ?>
            </button>
        </form>
    </div>

    <!-- ===== Chat History Section ===== -->
    <div class="fieldset-wrapper-title">
        <strong class="title">
            <span><?= $block->escapeHtml(__('Histórico de Chat — Tawk.to')) ?></span>
        </strong>
    </div>
    <div class="fieldset-wrapper-content">
        <?php if ($chatLogs->getSize() === 0): ?>
            <p class="empty-text"><?= $block->escapeHtml(__('Nenhum chat registrado para este cliente.')) ?></p>
        <?php else: ?>
            <table class="data-grid" style="width:100%">
                <thead>
                    <tr>
                        <th><?= $block->escapeHtml(__('Chat ID')) ?></th>
                        <th><?= $block->escapeHtml(__('Evento')) ?></th>
                        <th><?= $block->escapeHtml(__('Visitante')) ?></th>
                        <th><?= $block->escapeHtml(__('Email')) ?></th>
                        <th><?= $block->escapeHtml(__('Cidade / País')) ?></th>
                        <th><?= $block->escapeHtml(__('Início')) ?></th>
                        <th><?= $block->escapeHtml(__('Fim')) ?></th>
                        <th><?= $block->escapeHtml(__('Registrado Em')) ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($chatLogs as $log): ?>
                        <?php
                        $event = $log->getEvent();
                        $badgeClass = match ($event) {
                            'chat:start' => 'grid-severity-notice',
                            'chat:end' => 'grid-severity-minor',
                            'ticket:create' => 'grid-severity-major',
                            default => 'grid-severity-notice',
                        };
                        $eventLabel = match ($event) {
                            'chat:start' => __('Chat Iniciado'),
                            'chat:end' => __('Chat Encerrado'),
                            'ticket:create' => __('Ticket Criado'),
                            default => $event,
                        };
                        ?>
                        <tr>
                            <td><?= $block->escapeHtml($log->getChatId()) ?></td>
                            <td><span class="<?= $block->escapeHtmlAttr($badgeClass) ?>"><?= $block->escapeHtml((string) $eventLabel) ?></span></td>
                            <td><?= $block->escapeHtml((string) $log->getVisitorName()) ?></td>
                            <td><?= $block->escapeHtml((string) $log->getVisitorEmail()) ?></td>
                            <td><?= $block->escapeHtml(trim(($log->getVisitorCity() ?? '') . ' / ' . ($log->getVisitorCountry() ?? ''), ' /')) ?></td>
                            <td><?= $block->escapeHtml((string) $log->getStartedAt()) ?></td>
                            <td><?= $block->escapeHtml((string) $log->getEndedAt()) ?></td>
                            <td><?= $block->escapeHtml((string) $log->getData('created_at')) ?></td>
                        </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        <?php endif; ?>
    </div>
</div>
