<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="awamotos_tawk_chat_log" resource="default" engine="innodb"
           comment="Tawk.to Chat Log">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false"
                identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="chat_id" nullable="false" length="64"
                comment="Tawk.to Chat ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true"
                comment="Magento Customer ID"/>
        <column xsi:type="varchar" name="visitor_name" nullable="true" length="255"
                comment="Visitor Name"/>
        <column xsi:type="varchar" name="visitor_email" nullable="true" length="255"
                comment="Visitor Email"/>
        <column xsi:type="varchar" name="event" nullable="false" length="32"
                comment="Event Type"/>
        <column xsi:type="text" name="payload" nullable="true"
                comment="Raw Webhook Payload JSON"/>
        <column xsi:type="varchar" name="visitor_city" nullable="true" length="128"
                comment="Visitor City"/>
        <column xsi:type="varchar" name="visitor_country" nullable="true" length="8"
                comment="Visitor Country ISO"/>
        <column xsi:type="timestamp" name="started_at" on_update="false" nullable="true"
                comment="Chat Started At"/>
        <column xsi:type="timestamp" name="ended_at" on_update="false" nullable="true"
                comment="Chat Ended At"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false"
                default="CURRENT_TIMESTAMP" comment="Record Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="AWAMOTOS_TAWK_CHAT_LOG_CHAT_ID_EVENT">
            <column name="chat_id"/>
            <column name="event"/>
        </constraint>
        <index referenceId="AWAMOTOS_TAWK_CHAT_LOG_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="AWAMOTOS_TAWK_CHAT_LOG_VISITOR_EMAIL" indexType="btree">
            <column name="visitor_email"/>
        </index>
        <index referenceId="AWAMOTOS_TAWK_CHAT_LOG_CREATED_AT" indexType="btree">
            <column name="created_at"/>
        </index>
    </table>

    <table name="awamotos_tawk_attendant_assignment" resource="default" engine="innodb"
           comment="Tawk.to Attendant Assignment per Customer">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false"
                identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false"
                comment="Magento Customer ID"/>
        <column xsi:type="varchar" name="attendant_code" nullable="false" length="32"
                comment="Attendant Code"/>
        <column xsi:type="smallint" name="auto_assigned" unsigned="true" nullable="false"
                default="1" comment="1 = auto, 0 = manual"/>
        <column xsi:type="timestamp" name="assigned_at" on_update="false" nullable="false"
                default="CURRENT_TIMESTAMP" comment="Assignment Date"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="AWAMOTOS_TAWK_ATTENDANT_ASSIGNMENT_CUSTOMER_ID">
            <column name="customer_id"/>
        </constraint>
        <index referenceId="AWAMOTOS_TAWK_ATTENDANT_ASSIGNMENT_ATTENDANT_CODE" indexType="btree">
            <column name="attendant_code"/>
        </index>
    </table>
</schema>
