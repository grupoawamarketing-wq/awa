<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="tawk_embed" type="host">https://embed.tawk.to</value>
                <value id="tawk_cdn" type="host">*.tawk.to</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="tawk_api" type="host">*.tawk.to</value>
                <value id="tawk_wss" type="host">wss://*.tawk.to</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="tawk_frame" type="host">*.tawk.to</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="tawk_img" type="host">*.tawk.to</value>
            </values>
        </policy>
        <policy id="style-src">
            <values>
                <value id="tawk_style" type="host">*.tawk.to</value>
            </values>
        </policy>
        <policy id="font-src">
            <values>
                <value id="tawk_font" type="host">*.tawk.to</value>
            </values>
        </policy>
        <policy id="media-src">
            <values>
                <value id="tawk_media" type="host">*.tawk.to</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
