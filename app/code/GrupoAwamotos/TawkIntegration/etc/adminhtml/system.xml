<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="grupoawamotos" translate="label" sortOrder="900">
            <label>AWA Motos</label>
        </tab>
        <section id="grupoawamotos_tawk" translate="label" sortOrder="80"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Tawk.to Chat</label>
            <tab>grupoawamotos</tab>
            <resource>GrupoAwamotos_TawkIntegration::config</resource>
            <group id="general" translate="label" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Configurações Gerais</label>
                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Ativar Widget Tawk.to</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="property_id" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Property ID</label>
                    <comment><![CDATA[Admin → Settings → Chat Widget → Direct Chat Link]]></comment>
                    <validate>required-entry</validate>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="widget_id" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Widget ID</label>
                    <comment><![CDATA[ID do widget na URL do snippet Tawk.to]]></comment>
                    <validate>required-entry</validate>
                    <depends><field id="enabled">1</field></depends>
                </field>
            </group>
            <group id="secure_mode" translate="label" sortOrder="20"
                   showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Secure Mode (HMAC)</label>
                <field id="api_key" translate="label comment" type="obscure" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API Key (Secure Mode)</label>
                    <comment><![CDATA[Chave API HMAC-SHA256. Admin → Settings → Property Settings]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>
            <group id="webhook" translate="label" sortOrder="30"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Webhook</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Ativar Webhook Receiver</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[Recebe eventos chat:start, chat:end e ticket:create]]></comment>
                </field>
                <field id="secret" translate="label comment" type="obscure" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Webhook Secret</label>
                    <comment><![CDATA[Chave secreta HMAC-SHA1 — configure no painel Tawk.to → Webhooks]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="endpoint_url" translate="label" type="note" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>URL do Webhook</label>
                    <comment><![CDATA[Configure no Tawk.to: <code>https://SUA_LOJA/tawk/webhook/receive</code>]]></comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
            </group>
            <group id="enrichment" translate="label" sortOrder="40"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Enriquecimento de Dados (Atendentes)</label>
                <field id="send_b2b_data" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enviar Dados B2B</label>
                    <comment>CNPJ, grupo, status aprovação, crédito</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="send_rfm_data" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enviar Perfil RFM</label>
                    <comment>Segmentação (Campeão, Em Risco, etc.)</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="send_order_data" translate="label comment" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enviar Dados de Pedido</label>
                    <comment>Último pedido, total, data</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="send_cart_data" translate="label comment" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enviar Dados do Carrinho</label>
                    <comment>Total atual do carrinho e quantidade de itens</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
