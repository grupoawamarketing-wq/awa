<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="snippetblock" template="GrupoAwamotos_LiveChat::snippetblock.phtml">
            <arguments>
                <argument name="livechat_context_view_model" xsi:type="object">
                    GrupoAwamotos\LiveChat\ViewModel\ChatContext
                </argument>
                <argument name="livechat_widget_bootstrap_view_model" xsi:type="object">
                    GrupoAwamotos\LiveChat\ViewModel\WidgetBootstrapConfig
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
