if ($viewModel instanceof ChatContext) {
    $pageVariablesJson = $viewModel->getPageVariablesJson();
}

$additionalCustomVariablesJson = $block->getAdditionalCustomVariablesJson();
?>
<?php if (null !== $block->getLicenseId()): ?>
<script src="<?= $block->escapeUrl($block->getUrl('livechat/getvisitor')) ?>"></script>
<script>
    window.__lc = window.__lc || {};
    window.__lc.integration_name = 'magento';
    window.__lc.product_name = 'livechat';
    window.__lc.license = <?= (int) $block->getLicenseId() ?>;
    window.__lc.asyncInit = true;

    if (typeof livechat_visitor_data !== 'undefined' && livechat_visitor_data) {
        window.__lc.visitor = livechat_visitor_data;
    }

    var awaLiveChatPageVariables = <?= /* @noEscape */ $pageVariablesJson ?>;
    var awaLiveChatAdditionalVariables = <?= /* @noEscape */ $additionalCustomVariablesJson ?>;

    window.__lc.params = (window.__lc.params || []).concat(awaLiveChatPageVariables);

    (function (n, t, c) {
        function i(args) {
            return e._h ? e._h.apply(null, args) : e._q.push(args);
        }

        var e = {
            _q: [],
            _h: null,
            _v: '2.0',
            on: function () {
                i(['on', c.call(arguments)]);
            },
            once: function () {
                i(['once', c.call(arguments)]);
            },
            off: function () {
                i(['off', c.call(arguments)]);
            },
            get: function () {
                if (!e._h) {
                    throw new Error('[LiveChatWidget] You cannot use getters before load.');
                }

                return i(['get', c.call(arguments)]);
            },
            call: function () {
                i(['call', c.call(arguments)]);
            },
            init: function () {
                var script = t.createElement('script');
                script.async = true;
                script.type = 'text/javascript';
                script.src = 'https://cdn.livechatinc.com/tracking.js';
                t.head.appendChild(script);
            }
        };

        if (!n.__lc.asyncInit) {
