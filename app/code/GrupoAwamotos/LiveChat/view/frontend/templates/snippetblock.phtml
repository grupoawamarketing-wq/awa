        }

        n.LiveChatWidget = n.LiveChatWidget || e;
    }(window, document, [].slice));

  var LC_API = window.LC_API = window.LC_API || {};

  function awaMergeCustomVariables(runtimeVariables) {
    var mergedVariables = {}
;
    [].concat(awaLiveChatPageVariables || [], awaLiveChatAdditionalVariables || [], runtimeVariables || []).forEach(function (variable) {
      if (!variable || !variable.name || variable.value === undefined || variable.value === null || variable.value === '') {
        return;
      }

      mergedVariables[String(variable.name)] = {
        name: String(variable.name),
        value: String(variable.value)
      };
    });

    return Object.keys(mergedVariables).map(function (key) {
      return mergedVariables[key];
    });
  }

  function awaApplyCustomVariables(dynamicVariables) {
    var mergedVariables = awaMergeCustomVariables(Array.isArray(dynamicVariables) ? dynamicVariables : []);

        if (mergedVariables.length > 0) {
            LC_API.set_custom_variables(mergedVariables);
        }
    }

  <?php if ($block->isCartSet()): ?>
    function awaSyncCartVariables() {
        var xhttp = new XMLHttpRequest();

        xhttp.onreadystatechange = function () {
            if (this.readyState !== 4 || this.status !== 200) {
                return;
            }

            try {
                awaApplyCustomVariables(JSON.parse(this.responseText));
            } catch (error) {
                awaApplyCustomVariables([]);
            }
        };

        xhttp.open(
            'GET',
          '<?= $block->escapeUrl($block->getUrl('livechat/getcart', ['success' => (int) $block->isOrderPlacedPage()])) ?>',
            true
        );
        xhttp.send();
    }
      <?php endif; ?>

    (function () {
        var previousAfterLoad = LC_API.on_after_load;

        LC_API.on_after_load = function () {
            if (typeof previousAfterLoad === 'function') {
                previousAfterLoad();
            }

            awaApplyCustomVariables([]);

            <?php if ($block->isCartSet()): ?>
            awaSyncCartVariables();
            require(['Magento_Customer/js/customer-data'], function (customerData) {
                var cart = customerData.get('cart');
              var previousCount = cart().summary_count;

              try {
                var storageCount = window.localStorage ? window.localStorage.getItem('lcCount') : null;

                if (parseInt(storageCount, 10) !== previousCount) {
                  awaSyncCartVariables();
                }

                if (window.localStorage) {
                  window.localStorage.setItem('lcCount', previousCount);
                }
              } catch (error) {
                awaSyncCartVariables();
              }

                cart.subscribe(function () {
                    if (cart().summary_count !== previousCount) {
                        previousCount = cart().summary_count;
                        awaSyncCartVariables();

                  try {
                    if (window.localStorage) {
                      window.localStorage.setItem('lcCount', previousCount);
                    }
                  } catch (error) {
                    // No-op: storage is an optimization only.
                  }
                    }
                });
            });
            <?php endif; ?>
        };
    }());

        (function (w) {
          var events = ['pointerdown', 'touchstart', 'keydown', 'mouseover', 'scroll'];
          var initialized = false;

          function initWidget() {
            if (initialized) {
              return;
            }

            initialized = true;
            events.forEach(function (eventName) {
              w.removeEventListener(eventName, initWidget, true);
            });

            if (w.LiveChatWidget) {
              w.LiveChatWidget.init();
            }
          }

          events.forEach(function (eventName) {
            w.addEventListener(eventName, initWidget, {passive: true, capture: true, once: true});
          });

          if ('requestIdleCallback' in w) {
            w.requestIdleCallback(initWidget, {timeout: 4000});
          } else {
            w.setTimeout(initWidget, 4000);
          }
        }(window));
</script>
<?php else: ?>
