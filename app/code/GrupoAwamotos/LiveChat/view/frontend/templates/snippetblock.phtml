<?php
/**
 * @var \LiveChat\LiveChat\Block\SnippetBlock $block
 * @var \Magento\Framework\Escaper $escaper
 */

use GrupoAwamotos\LiveChat\ViewModel\ChatContext;

$viewModel = $block->getData('livechat_context_view_model');
$pageVariablesJson = '[]';

if ($viewModel instanceof ChatContext) {
    $pageVariablesJson = $viewModel->getPageVariablesJson();
}
?>
<?php if (null !== $block->getLicenseId()): ?>
<script>
    window.__lc = window.__lc || {};
    window.__lc.integration_name = 'magento';
    window.__lc.product_name = 'livechat';
    window.__lc.license = <?= (int) $block->getLicenseId() ?>;

    if (typeof livechat_visitor_data !== 'undefined' && livechat_visitor_data) {
        window.__lc.visitor = livechat_visitor_data;
    }

    var awaLiveChatPageVariables = <?= /* @noEscape */ $pageVariablesJson ?>;
    window.__lc.params = (window.__lc.params || []).concat(awaLiveChatPageVariables);

    (function (n, t, c) {
        function i(args) {
            return e._h ? e._h.apply(null, args) : e._q.push(args);
        }

        var e = {
            _q: [],
            _h: null,
            _v: '2.0',
            on: function () {
                i(['on', c.call(arguments)]);
            },
            once: function () {
                i(['once', c.call(arguments)]);
            },
            off: function () {
                i(['off', c.call(arguments)]);
            },
            get: function () {
                if (!e._h) {
                    throw new Error('[LiveChatWidget] You cannot use getters before load.');
                }

                return i(['get', c.call(arguments)]);
            },
            call: function () {
                i(['call', c.call(arguments)]);
            },
            init: function () {
                var script = t.createElement('script');
                script.async = true;
                script.type = 'text/javascript';
                script.src = 'https://cdn.livechatinc.com/tracking.js';
                t.head.appendChild(script);
            }
        };

        if (!n.__lc.asyncInit) {
            e.init();
        }

        n.LiveChatWidget = n.LiveChatWidget || e;
    }(window, document, [].slice));

    var LC_API = window.LC_API || {};

    function awaApplyCustomVariables(dynamicVariables) {
        var safeDynamicVariables = Array.isArray(dynamicVariables) ? dynamicVariables : [];
        var mergedVariables = awaLiveChatPageVariables.concat(safeDynamicVariables);

        if (mergedVariables.length > 0) {
            LC_API.set_custom_variables(mergedVariables);
        }
    }

    function awaSyncCartVariables() {
        var xhttp = new XMLHttpRequest();

        xhttp.onreadystatechange = function () {
            if (this.readyState !== 4 || this.status !== 200) {
                return;
            }

            try {
                awaApplyCustomVariables(JSON.parse(this.responseText));
            } catch (error) {
                awaApplyCustomVariables([]);
            }
        };

        xhttp.open(
            'GET',
            '<?= $block->escapeUrl($block->getUrl('livechat/getcart')) ?>' +
                '?success=<?= $block->escapeJs((string) $block->isOrderPlacedPage()) ?>',
            true
        );
        xhttp.send();
    }

    (function () {
        var previousAfterLoad = LC_API.on_after_load;

        LC_API.on_after_load = function () {
            if (typeof previousAfterLoad === 'function') {
                previousAfterLoad();
            }

            awaSyncCartVariables();

            require(['Magento_Customer/js/customer-data'], function (customerData) {
                var cart = customerData.get('cart');
                var previousCount = cart().summary_count;

                cart.subscribe(function () {
                    if (cart().summary_count !== previousCount) {
                        previousCount = cart().summary_count;
                        awaSyncCartVariables();
                    }
                });
            });
        };
    }());
</script>
<?php else: ?>
<script>
    console.log('Please go to "Stores => Settings => Configuration" and configure your LiveChat account.');
</script>
<?php endif; ?>
