<script>
document.addEventListener('DOMContentLoaded', function() {
    try {
        var chartData = <?= /* @noEscape */ $chartJson ?>;
        var ctx = document.getElementById('si-sales-chart');
        if (!ctx || !chartData.labels || !chartData.labels.length) return;

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: chartData.labels,
                datasets: [
                    {
                        label: 'Receita Real',
                        data: chartData.revenues,
                        backgroundColor: 'rgba(5, 150, 105, 0.7)',
                        borderColor: '#059669',
                        borderWidth: 1,
                        borderRadius: 4,
                        order: 2
                    },
                    {
                        label: 'Projecao',
                        data: chartData.projection,
                        type: 'line',
                        borderColor: '#2563eb',
                        borderWidth: 2,
                        borderDash: [6, 3],
                        pointRadius: 4,
                        pointBackgroundColor: '#2563eb',
                        fill: false,
                        spanGaps: true,
                        order: 1
                    },
                    {
                        label: 'Meta',
                        data: chartData.target,
                        type: 'line',
                        borderColor: '#dc2626',
                        borderWidth: 1.5,
                        borderDash: [4, 4],
                        pointRadius: 0,
                        fill: false,
                        order: 0
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { intersect: false, mode: 'index' },
                plugins: {
                    legend: { position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                var val = ctx.parsed.y;
                                if (val === null) return '';
                                return ctx.dataset.label + ': R$ ' + val.toLocaleString('pt-BR', {minimumFractionDigits: 2});
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(val) {
                                return 'R$ ' + (val/1000).toLocaleString('pt-BR') + 'k';
                            }
                        }
                    }
                }
            }
        });
    } catch (e) {
        console.warn('Sales chart init error:', e);
    }
});
</script>

