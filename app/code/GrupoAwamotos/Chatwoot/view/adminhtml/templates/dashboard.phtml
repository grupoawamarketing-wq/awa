<?php
/** @var \GrupoAwamotos\Chatwoot\Block\Adminhtml\Dashboard $block */

$config = $block->getConfig();
$metrics = $block->getLogMetrics();
$recentEvents = $block->getRecentEvents(20);
$chatwootUrl = $block->escapeUrl($block->getChatwootUrl());
$settingsUrl = $block->escapeUrl($block->getSettingsUrl());
?>
<style>
    .awa-chat-dashboard { max-width: 1200px; }
    .awa-chat-dashboard .awa-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .awa-chat-dashboard .awa-card { background: #fff; border: 1px solid #d6d6d6; border-radius: 8px; padding: 20px; text-align: center; }
