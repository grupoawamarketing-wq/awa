    .awa-chat-dashboard .awa-events-table td { padding: 6px 12px; border-bottom: 1px solid #eee; }
    .awa-chat-dashboard .awa-events-table tr:hover td { background: #f9f9f9; }
    .awa-chat-dashboard .awa-event-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .awa-chat-dashboard .awa-event-badge--conversation { background: #e3f2fd; color: #1565c0; }
    .awa-chat-dashboard .awa-event-badge--message { background: #e8f5e9; color: #2e7d32; }
    .awa-chat-dashboard .awa-event-badge--contact { background: #fff3e0; color: #e65100; }
    .awa-chat-dashboard .awa-event-badge--other { background: #f3e5f5; color: #7b1fa2; }
    .awa-chat-dashboard .awa-actions { display: flex; gap: 12px; margin-bottom: 24px; }
    .awa-chat-dashboard .awa-actions a { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; border-radius: 6px; font-size: 14px; font-weight: 600; text-decoration: none; }
    .awa-chat-dashboard .awa-btn-primary { background: #1979c3; color: #fff; }
    .awa-chat-dashboard .awa-btn-primary:hover { background: #1565c0; }
    .awa-chat-dashboard .awa-btn-secondary { background: #f5f5f5; color: #333; border: 1px solid #d6d6d6; }
    .awa-chat-dashboard .awa-btn-secondary:hover { background: #eee; }
    .awa-chat-dashboard .awa-status { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
    .awa-chat-dashboard .awa-status--on { background: #e8f5e9; color: #2e7d32; }
    .awa-chat-dashboard .awa-status--off { background: #ffebee; color: #c62828; }
    .awa-chat-dashboard .awa-bar-chart { display: flex; align-items: flex-end; gap: 8px; height: 120px; padding-top: 8px; }
    .awa-chat-dashboard .awa-bar { display: flex; flex-direction: column; align-items: center; flex: 1; }
    .awa-chat-dashboard .awa-bar-fill { width: 100%; min-width: 30px; border-radius: 4px 4px 0 0; }
    .awa-chat-dashboard .awa-bar-label { font-size: 10px; margin-top: 4px; text-align: center; color: #666; word-break: break-word; }
    .awa-chat-dashboard .awa-bar-count { font-size: 11px; font-weight: 700; margin-bottom: 2px; }
</style>

<div class="awa-chat-dashboard">
    <div class="awa-actions">
        <a href="<?= $chatwootUrl ?>/app" target="_blank" rel="noopener" class="awa-btn-primary">&#128172; Abrir Chatwoot</a>
        <a href="<?= $settingsUrl ?>" class="awa-btn-secondary">&#9881; Configurações</a>
    </div>

    <div class="awa-cards">
        <div class="awa-card <?= $config['enabled'] ? 'awa-card--ok' : 'awa-card--warn' ?>">
            <div><span class="awa-status <?= $config['enabled'] ? 'awa-status--on' : 'awa-status--off' ?>"><?= $config['enabled'] ? 'Ativo' : 'Inativo' ?></span></div>
            <div class="awa-card-label">Widget do Chat</div>
        </div>
        <div class="awa-card <?= $config['bot_enabled'] ? 'awa-card--ok' : 'awa-card--warn' ?>">
            <div><span class="awa-status <?= $config['bot_enabled'] ? 'awa-status--on' : 'awa-status--off' ?>"><?= $config['bot_enabled'] ? 'Ativo' : 'Inativo' ?></span></div>
            <div class="awa-card-label">Bot de Triagem</div>
        </div>
        <div class="awa-card awa-card--info">
            <div class="awa-card-value"><?= (int) $metrics['conversations_unique'] ?></div>
            <div class="awa-card-label">Conversas Únicas</div>
        </div>
        <div class="awa-card awa-card--info">
            <div class="awa-card-value"><?= (int) $metrics['messages'] ?></div>
            <div class="awa-card-label">Mensagens</div>
        </div>
        <div class="awa-card awa-card--info">
            <div class="awa-card-value"><?= (int) $metrics['contacts_created'] ?></div>
            <div class="awa-card-label">Contatos Criados</div>
        </div>
        <div class="awa-card awa-card--info">
            <div class="awa-card-value"><?= (int) $metrics['total'] ?></div>
            <div class="awa-card-label">Eventos no Log</div>
        </div>
    </div>

    <?php if (!empty($metrics['events'])): ?>
    <div class="awa-section">
        <h3>Eventos por Tipo</h3>
        <?php
        $maxVal = max($metrics['events']);
        $colors = [
            'conversation_updated' => '#1979c3', 'conversation_created' => '#42a5f5',
            'conversation_status_changed' => '#0d47a1', 'conversation_opened' => '#64b5f6',
            'message_created' => '#66bb6a', 'message_updated' => '#a5d6a7',
            'contact_created' => '#ff9800', 'contact_updated' => '#ffb74d',
            'webwidget_triggered' => '#ab47bc',
        ];
        ?>
        <div class="awa-bar-chart">
            <?php foreach ($metrics['events'] as $event => $count): ?>
                <?php $heightPct = $maxVal > 0 ? round(($count / $maxVal) * 100) : 0; $color = $colors[$event] ?? '#90a4ae'; ?>
                <div class="awa-bar">
                    <div class="awa-bar-count"><?= (int) $count ?></div>
                    <div class="awa-bar-fill" style="height: <?= $heightPct ?>%; background: <?= $block->escapeHtmlAttr($color) ?>;"></div>
                    <div class="awa-bar-label"><?= $block->escapeHtml($block->formatEventName($event)) ?></div>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
    <?php endif; ?>

    <?php if ($metrics['first_date'] || $metrics['last_date']): ?>
    <div class="awa-section">
        <h3>Período do Log</h3>
        <p style="margin: 0; font-size: 13px; color: #666;">
            <?php if ($metrics['first_date']): ?><strong>Início:</strong> <?= $block->escapeHtml($metrics['first_date']) ?><?php endif; ?>
            <?php if ($metrics['last_date']): ?> | <strong>Último:</strong> <?= $block->escapeHtml($metrics['last_date']) ?><?php endif; ?>
        </p>
    </div>
    <?php endif; ?>

    <?php if (!empty($recentEvents)): ?>
    <div class="awa-section">
        <h3>Eventos Recentes</h3>
        <table class="awa-events-table">
            <thead><tr><th>Data/Hora</th><th>Evento</th><th>Conversa</th><th>Detalhe</th></tr></thead>
            <tbody>
                <?php foreach ($recentEvents as $ev): ?>
                    <?php
                    $badgeClass = 'awa-event-badge--other';
                    if (str_starts_with($ev['event'], 'conversation')) { $badgeClass = 'awa-event-badge--conversation'; }
                    elseif (str_starts_with($ev['event'], 'message')) { $badgeClass = 'awa-event-badge--message'; }
                    elseif (str_starts_with($ev['event'], 'contact')) { $badgeClass = 'awa-event-badge--contact'; }
                    $dateFormatted = '';
                    if ($ev['date']) {
                        try { $dt = new \DateTime($ev['date']); $dt->setTimezone(new \DateTimeZone('America/Sao_Paulo')); $dateFormatted = $dt->format('d/m H:i:s'); }
                        catch (\Exception $e) { $dateFormatted = $ev['date']; }
                    }
                    ?>
                    <tr>
                        <td><?= $block->escapeHtml($dateFormatted) ?></td>
                        <td><span class="awa-event-badge <?= $badgeClass ?>"><?= $block->escapeHtml($block->formatEventName($ev['event'])) ?></span></td>
                        <td><?php if ($ev['conversation_id']): ?><a href="<?= $chatwootUrl ?>/app/accounts/1/conversations/<?= (int) $ev['conversation_id'] ?>" target="_blank" rel="noopener">#<?= (int) $ev['conversation_id'] ?></a><?php else: ?>—<?php endif; ?></td>
                        <td><?= $block->escapeHtml($ev['detail']) ?></td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <?php endif; ?>

    <div class="awa-section">
        <h3>Conexão</h3>
        <table style="font-size: 13px;">
            <tr><td style="padding: 4px 16px 4px 0; color: #666;">Chatwoot URL:</td><td><a href="<?= $chatwootUrl ?>" target="_blank" rel="noopener"><?= $block->escapeHtml($block->getChatwootUrl()) ?></a></td></tr>
            <tr><td style="padding: 4px 16px 4px 0; color: #666;">Webhook URL:</td><td><code><?= $block->escapeHtml($block->getBaseUrl() . 'chatwoot/webhook/receive') ?></code></td></tr>
            <tr><td style="padding: 4px 16px 4px 0; color: #666;">Bot URL:</td><td><code><?= $block->escapeHtml($block->getBaseUrl() . 'chatwoot/bot/respond') ?></code></td></tr>
        </table>
    </div>
</div>