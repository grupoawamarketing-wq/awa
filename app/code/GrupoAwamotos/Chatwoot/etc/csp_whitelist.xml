<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="chatwoot_sdk" type="host">awamotos.com</value>
                <value id="chatwoot_dashboard" type="host">chat.awamotos.com</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="chatwoot_api" type="host">awamotos.com</value>
                <value id="chatwoot_ws" type="host">wss://awamotos.com</value>
                <value id="chatwoot_dashboard_api" type="host">chat.awamotos.com</value>
                <value id="chatwoot_dashboard_ws" type="host">wss://chat.awamotos.com</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="chatwoot_widget" type="host">awamotos.com</value>
                <value id="chatwoot_dashboard_frame" type="host">chat.awamotos.com</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="chatwoot_images" type="host">awamotos.com</value>
                <value id="chatwoot_dashboard_img" type="host">chat.awamotos.com</value>
                <value id="chatwoot_gravatar" type="host">www.gravatar.com</value>
            </values>
        </policy>
        <policy id="media-src">
            <values>
                <value id="chatwoot_audio" type="host">awamotos.com</value>
                <value id="chatwoot_dashboard_audio" type="host">chat.awamotos.com</value>
            </values>
        </policy>
        <policy id="style-src">
            <values>
                <value id="chatwoot_styles" type="host">awamotos.com</value>
                <value id="chatwoot_dashboard_styles" type="host">chat.awamotos.com</value>
            </values>
        </policy>
        <policy id="font-src">
            <values>
                <value id="chatwoot_fonts" type="host">awamotos.com</value>
                <value id="chatwoot_dashboard_fonts" type="host">chat.awamotos.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
