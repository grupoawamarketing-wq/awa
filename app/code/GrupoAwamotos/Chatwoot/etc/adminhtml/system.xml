<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="grupoawamotos_chatwoot" translate="label" type="text" sortOrder="900" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Chat ao Vivo (Chatwoot)</label>
            <tab>general</tab>
            <resource>GrupoAwamotos_Chatwoot::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Configurações Gerais</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Ativa ou desativa o widget de chat ao vivo no frontend.</comment>
                </field>
                <field id="base_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>URL do Chatwoot</label>
                    <comment>Ex: https://chat.awamotos.com</comment>
                    <validate>validate-url</validate>
                </field>
                <field id="website_token" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Website Token</label>
                    <comment>Token do canal Website criado no painel do Chatwoot.</comment>
                </field>
                <field id="locale" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Idioma</label>
                    <comment>Código do idioma (ex: pt_BR, en, es)</comment>
                </field>
                <field id="position" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Posição do Widget</label>
                    <source_model>GrupoAwamotos\Chatwoot\Model\Config\Source\Position</source_model>
                </field>
                <field id="identify_customer" translate="label comment" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Identificar Cliente Logado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Envia nome e e-mail do cliente logado para o Chatwoot automaticamente.</comment>
                </field>
                <field id="hmac_token" translate="label comment" type="obscure" sortOrder="70" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>HMAC Token (Identity Validation)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Token HMAC do inbox para validação de identidade. Obtido em Chatwoot > Inbox > Configuration > Identity Validation. <strong>Previne impersonação de clientes.</strong>]]></comment>
                </field>
            </group>
            <group id="appearance" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Aparência e Comportamento</label>
                <field id="dark_mode" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Modo Escuro</label>
                    <source_model>GrupoAwamotos\Chatwoot\Model\Config\Source\DarkMode</source_model>
                    <comment>Controla o tema do widget de chat.</comment>
                </field>
                <field id="show_popout_button" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Botão Popout (Abrir em Janela)</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Exibe botão para abrir o chat em janela separada.</comment>
                </field>
                <field id="widget_color" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Cor do Widget</label>
                    <comment>Cor hexadecimal do botão do chat (ex: #1F93FF). Deixe vazio para usar a cor padrão do Chatwoot.</comment>
                    <validate>validate-no-html-tags</validate>
                </field>
            </group>
            <group id="notifications" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Notificações e Sons</label>
                <field id="enable_sounds" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Sons de Notificação</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Toca som quando o visitante recebe uma resposta do agente.</comment>
                </field>
                <field id="use_push_notifications" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Notificações Push</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Solicita permissão para enviar notificações push do navegador (requer HTTPS).</comment>
                </field>
            </group>
            <group id="bot" translate="label" type="text" sortOrder="35" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Bot de Triagem</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Bot Habilitado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Ativa o bot de triagem automática que exibe menu de opções antes de conectar com agente.</comment>
                </field>
                <field id="api_token" translate="label comment" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API Token do Bot</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Token de API gerado para o Agent Bot no Chatwoot (Super Admin > Agent Bots). Necessário para o bot enviar mensagens via API.]]></comment>
                </field>
                <field id="api_url" translate="label comment" type="text" sortOrder="25" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>URL da API do Chatwoot</label>
                    <comment><![CDATA[URL interna para chamadas API do bot (ex: http://127.0.0.1:3000). Se vazio, usa a URL geral do widget.]]></comment>
                    <validate>validate-url</validate>
                </field>
                <field id="admin_api_token" translate="label comment" type="obscure" sortOrder="26" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Admin API Token</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Token de API de um administrador Chatwoot. Usado pelo bot para atribuir labels e teams (ações que o bot token não pode fazer).]]></comment>
                </field>
                <field id="secret_token" translate="label comment" type="obscure" sortOrder="28" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Secret Token do Bot</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Token secreto para validar a assinatura HMAC dos eventos do AgentBot. Configure o mesmo valor em Chatwoot: Super Admin &gt; Agent Bots &gt; Configurar Bot.]]></comment>
                </field>
                <field id="webhook_url_info" translate="label comment" type="label" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>URL do Webhook do Bot</label>
                    <comment><![CDATA[Configure no Chatwoot Super Admin > Agent Bots:<br/><code>https://awamotos.com/chatwoot/bot/respond</code>]]></comment>
                </field>
            </group>
            <group id="webhook" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Webhook (Chatwoot → Magento)</label>
                <field id="webhook_url_info" translate="label comment" type="label" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>URL do Webhook</label>
                    <comment><![CDATA[Configure no Chatwoot: <strong>Configurações → Integrações → Webhooks → Novo Webhook</strong><br/>URL: <code>https://awamotos.com/chatwoot/webhook/receive</code><br/>Eventos: Conversation Created, Conversation Resolved, Message Created]]></comment>
                </field>
                <field id="secret_token" translate="label comment" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Secret Token do Webhook</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Token secreto para validar a assinatura HMAC dos webhooks recebidos. Configure o mesmo valor em Chatwoot ao criar o webhook. Logs em <code>var/log/chatwoot_webhook.log</code>.]]></comment>
                </field>
            </group>
        </section>
    </system>
</config>
