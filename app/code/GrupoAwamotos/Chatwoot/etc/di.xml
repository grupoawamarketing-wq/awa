<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Logger dedicado: var/log/chatwoot_webhook.log -->
    <virtualType name="GrupoAwamotos\Chatwoot\Logger\Handler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/chatwoot_webhook.log</argument>
        </arguments>
    </virtualType>

    <virtualType name="GrupoAwamotos\Chatwoot\Logger\Logger"
                 type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">chatwoot</argument>
            <argument name="handlers" xsi:type="array">
                <item name="chatwoot" xsi:type="object">GrupoAwamotos\Chatwoot\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Injeta o logger dedicado no webhook controller -->
    <type name="GrupoAwamotos\Chatwoot\Controller\Webhook\Receive">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\Chatwoot\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- Injeta o logger dedicado no bot controller -->
    <type name="GrupoAwamotos\Chatwoot\Controller\Bot\Respond">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\Chatwoot\Logger\Logger</argument>
        </arguments>
    </type>

</config>
