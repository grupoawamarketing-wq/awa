<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- social-proof.css async (non-blocking) — badge below fold (AWA 2026-04-25) -->
        <css src="GrupoAwamotos_SocialProof::css/social-proof.css" media="print"/>
    </head>
    <body>
        <!-- Social Proof Badges na pagina de produto — carregado via AJAX para nao bloquear FPC/Varnish -->
        <referenceContainer name="product.info.main">
            <block class="GrupoAwamotos\SocialProof\Block\ProductInfo"
                   name="product.info.social.proof"
                   template="GrupoAwamotos_SocialProof::product/social-proof.phtml"
                   after="product.info.price"/>
        </referenceContainer>
    </body>
</page>
