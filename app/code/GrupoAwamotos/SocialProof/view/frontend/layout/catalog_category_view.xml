<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- social-proof.css async (non-blocking) — badge below fold (AWA 2026-04-25) -->
        <css src="GrupoAwamotos_SocialProof::css/social-proof.css" media="print"/>
    </head>
    <body>
        <!-- Social Proof Badges na listagem de produtos -->
        <referenceBlock name="category.product.addto">
            <block class="Magento\Catalog\Block\Product\ProductList\Item\Block"
                   name="product.list.social.proof"
                   template="GrupoAwamotos_SocialProof::product/list-badge.phtml"
                   after="-"/>
        </referenceBlock>
    </body>
</page>
