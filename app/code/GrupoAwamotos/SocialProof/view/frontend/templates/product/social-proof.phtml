<?php
declare(strict_types=1);

/**
 * Social Proof Badges — placeholder para carregamento AJAX.
 *
 * O JS GrupoAwamotos_SocialProof/js/social-proof-inject.js faz fetch
 * em /socialproof/product/data?product_id=X e popula este container.
 *
 * Abordagem: bloco sem cacheable="false", PDP permanece cacheavel no FPC/Varnish.
 * Badges carregam assincronamente apos o HTML (nao bloqueia LCP/TTFB).
 *
 * @var \GrupoAwamotos\SocialProof\Block\ProductInfo $block
 * @var \Magento\Framework\Escaper $escaper
 */

$productId = (int) ($block->getProduct() ? $block->getProduct()->getId() : 0);
if (!$productId) {
    return;
}

$baseUrl = $block->getBaseUrl();
?>
<div id="awa-social-proof-pdp"
     role="region"
     aria-label="<?= $escaper->escapeHtmlAttr(__("Informações de popularidade do produto")) ?>"
     aria-live="polite"
     aria-atomic="false"
     data-product-id="<?= $escaper->escapeHtmlAttr($productId) ?>"
     data-label-views="<?= $escaper->escapeHtmlAttr(__('pessoas visualizaram este produto hoje')) ?>"
     data-label-low-stock-pre="<?= $escaper->escapeHtmlAttr(__('Ultimas')) ?>"
     data-label-low-stock-suf="<?= $escaper->escapeHtmlAttr(__('unidades!')) ?>"
     data-label-stock-msg="<?= $escaper->escapeHtmlAttr(__('Aproveite enquanto ha estoque')) ?>"
     data-label-bestseller="<?= $escaper->escapeHtmlAttr(__('MAIS VENDIDO')) ?>"
     class="social-proof-container"></div>
<script type="text/x-magento-init">
{
    "#awa-social-proof-pdp": {
        "GrupoAwamotos_SocialProof/js/social-proof-inject": {
            "baseUrl": "<?= $escaper->escapeJs($baseUrl) ?>"
        }
    }
}
</script>
