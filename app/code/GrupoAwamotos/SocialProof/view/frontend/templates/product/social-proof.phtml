<?php
declare(strict_types=1);

/**
 * Social Proof Badges — renderiza dados reais de prova social.
 * Usa ProductInfo block para obter viewsToday, isBestSeller, isLowStock.
 *
 * @var \GrupoAwamotos\SocialProof\Block\ProductInfo $block
 * @var \Magento\Framework\Escaper $escaper
 */

$viewsToday  = $block->getViewsToday();
$isBestSeller = $block->isBestSeller();
$isLowStock  = $block->isLowStock();
$qty         = $block->getStockQty();
$hasBadges   = ($viewsToday > 0) || $isLowStock || $isBestSeller;
?>

<?php if ($hasBadges): ?>
<div class="social-proof-container awa-sp-pdp">

    <?php if ($viewsToday > 0): ?>
    <!-- Contador de Visualizações -->
    <div class="social-proof-badge views-badge" role="note" aria-label="<?= $escaper->escapeHtmlAttr(__('%1 visualizações hoje', $viewsToday)) ?>">
        <i class="fa fa-eye" aria-hidden="true"></i>
        <span class="badge-text">
            <strong><?= $escaper->escapeHtml($viewsToday) ?></strong>
            <?= $escaper->escapeHtml(__('pessoas visualizaram este produto hoje')) ?>
        </span>
    </div>
    <?php endif; ?>

    <?php if ($isLowStock): ?>
    <!-- Badge Últimas Unidades -->
    <div class="social-proof-badge low-stock-badge urgency" role="note" aria-label="<?= $escaper->escapeHtmlAttr(__('Últimas %1 unidades em estoque', $qty)) ?>">
        <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
        <span class="badge-text">
            <strong><?= $escaper->escapeHtml(__('Últimas %1 unidades!', $qty)) ?></strong>
            <?= $escaper->escapeHtml(__('Aproveite enquanto há estoque')) ?>
        </span>
    </div>
    <?php endif; ?>

    <?php if ($isBestSeller): ?>
    <!-- Badge Mais Vendido -->
    <div class="social-proof-badge bestseller-badge" role="note" aria-label="<?= $escaper->escapeHtmlAttr(__('Produto mais vendido')) ?>">
        <i class="fa fa-star" aria-hidden="true"></i>
        <span class="badge-text">
            <strong><?= $escaper->escapeHtml(__('MAIS VENDIDO')) ?></strong>
        </span>
    </div>
    <?php endif; ?>

</div>
<?php endif; ?>
