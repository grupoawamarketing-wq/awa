<?php
declare(strict_types=1);

/**
 * Social Proof Badges - Listagem de Produtos
 * Versão compacta para grid/list de produtos
 *
 * @var \Magento\Catalog\Block\Product\AbstractProduct $block
 * @var \Magento\Framework\Escaper $escaper
 */

$_product = $block->getProduct();
$viewsToday = (int)$_product->getData('views_today');
$isBestSeller = (bool)$_product->getData('is_best_seller');

// Verificar estoque
$extensionAttributes = $_product->getExtensionAttributes();
$stockItem = $extensionAttributes ? $extensionAttributes->getStockItem() : null;
$qty = $stockItem ? (int)$stockItem->getQty() : 0;
$isLowStock = ($qty > 0 && $qty < 10);

// Mostrar apenas se tiver algum badge
if (!$viewsToday && !$isLowStock && !$isBestSeller) {
    return;
}
?>

<div class="social-proof-list">

    <?php if ($isBestSeller): ?>
    <span class="badge badge-bestseller">
        <i class="fa fa-star"></i> <?= $escaper->escapeHtml(__('Mais Vendido')) ?>
    </span>
    <?php endif; ?>

    <?php if ($isLowStock): ?>
    <span class="badge badge-low-stock">
        <i class="fa fa-fire"></i> <?= $escaper->escapeHtml(__('Últimas %1!', $qty)) ?>
    </span>
    <?php endif; ?>

    <?php if ($viewsToday > 20): ?>
    <span class="badge badge-popular">
        <i class="fa fa-eye"></i> <?= $escaper->escapeHtml(__('%1 visualizações', $viewsToday)) ?>
    </span>
    <?php endif; ?>

</div>
