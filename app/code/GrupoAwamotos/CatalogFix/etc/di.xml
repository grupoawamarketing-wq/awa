<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Catalog\Pricing\Render\FinalPriceBox">
        <plugin name="grupoawamotos_catalogfix_finalpricebox_has_special_price_guard"
                type="GrupoAwamotos\CatalogFix\Plugin\FinalPriceBoxPlugin"
                sortOrder="10"/>
    </type>

    <!-- Fix: prevent InvalidArgumentException for non-mview indexer action classes -->
    <type name="Magento\Framework\Mview\ActionFactory">
        <plugin name="grupoawamotos_catalogfix_mview_action_factory_guard"
                type="GrupoAwamotos\CatalogFix\Plugin\MviewActionFactoryPlugin"
                sortOrder="10"/>
    </type>

    <!-- Fix: add unmapped_type to position sort to prevent OpenSearch 400 errors -->
    <type name="Magento\Elasticsearch\SearchAdapter\Query\Builder\Sort\Position">
        <plugin name="grupoawamotos_catalogfix_position_sort_unmapped"
                type="GrupoAwamotos\CatalogFix\Plugin\PositionSortUnmappedPlugin"
                sortOrder="10"/>
    </type>

    <!-- Fix: suppress "Broken reference" INFO log for product.info.media/product.info.main. -->
    <type name="Magento\Framework\View\Layout\ScheduledStructure">
        <plugin name="grupoawamotos_catalogfix_suppress_media_sort_broken_ref"
                type="GrupoAwamotos\CatalogFix\Plugin\ScheduledStructureSortPlugin"
                sortOrder="10"/>
    </type>

    <!-- Fix: converte nomes de produtos ALL CAPS (do ERP) para Title Case no frontend -->
    <type name="Magento\Catalog\Model\Product">
        <plugin name="grupoawamotos_catalogfix_product_name_title_case"
                type="GrupoAwamotos\CatalogFix\Plugin\ProductNameTitleCasePlugin"
                sortOrder="100"/>
    </type>

    <!-- NAV-001: aria-hidden nos badges do CustomMenu (Quente, Novo, etc.) -->
    <type name="Rokanthemes\CustomMenu\Block\Topmenu">
        <plugin name="grupoawamotos_catalogfix_custommenu_badge_aria"
                type="GrupoAwamotos\CatalogFix\Plugin\CustomMenuBadgeAriaPlugin"
                sortOrder="10"/>
    </type>
    <!-- Fix: prevent NoSuchEntityException crash when ordered product is deleted/disabled -->
    <type name="Magento\Sales\CustomerData\LastOrderedItems">
        <plugin name="grupoawamotos_catalogfix_last_ordered_items_no_such_entity"
                type="GrupoAwamotos\CatalogFix\Plugin\LastOrderedItemsPlugin"
                sortOrder="10"/>
    </type>


    <!-- Fix: CssUrls null pointer during static-content:deploy (email-fonts.css) -->
    <preference for="Magento\Deploy\Package\Processor\PostProcessor\CssUrls"
                type="GrupoAwamotos\CatalogFix\Deploy\CssUrlsSafe"/>


    <!-- Production: raise debug handler minimum level to WARNING to stop cron INFO/DEBUG
         from filling var/log/debug.log (Monolog\Logger::WARNING = 300). -->
    <type name="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="debug" xsi:type="object">GrupoAwamotos\CatalogFix\Logger\Handler\ProductionDebug</item>
            </argument>
        </arguments>
    </type>


    <!-- GraphQL fallback: evita falha quando scalar built-in cai em lookup de config -->
    <type name="Magento\Framework\GraphQl\Config">
        <plugin name="grupoawamotos_catalogfix_graphql_scalar_fallback"
                type="GrupoAwamotos\CatalogFix\Plugin\GraphQl\ConfigScalarFallbackPlugin"
                sortOrder="999"/>
    </type>

    <!-- PDP-001: Normaliza <title> ALL CAPS (do ERP via meta_title mágico) para Title Case -->
    <type name="Magento\Framework\View\Page\Title">
        <plugin name="grupoawamotos_catalogfix_title_case_normalization"
                type="GrupoAwamotos\CatalogFix\Plugin\View\Page\Config\TitleNormalizationPlugin"
                sortOrder="10"/>
    </type>

    <!-- Fix Magento 2.4.8: ProductRenderSearchResults class missing from vendor.
         di.xml references Magento\Catalog\Model\ProductRenderSearchResults but the actual
         class is Magento\Catalog\Model\ProductRenderInfoSearchResults. Override the
         preference to point to the correct class. -->
    <preference for="Magento\Catalog\Api\Data\ProductRenderSearchResultsInterface"
                type="Magento\Catalog\Model\ProductRenderInfoSearchResults"/>

    <!-- Fix: retorna HTTP 404 real quando Magento redireciona URL inexistente para busca (soft 404 -> hard 404) -->
    <type name="Magento\CatalogSearch\Controller\Result\Index">
        <plugin name="grupoawamotos_catalogfix_soft404_header"
                type="GrupoAwamotos\CatalogFix\Plugin\Soft404Plugin"
                sortOrder="10"/>
    </type>

</config>
