<?php
/** @var \GrupoAwamotos\CatalogFix\Block\Categorytab\AjaxProducts $block */
declare(strict_types=1);

$products = $block->getProducts()->getItems();
$rows = (int) ($block->getData('rows') ?: 1);
$image = 'new_products_content_widget_grid';
$templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::DEFAULT_VIEW;
$postDataHelper = $this->helper('Magento\Framework\Data\Helper\PostHelper');
$priceHelper = $this->helper('Rokanthemes\Themeoption\Helper\Data');

$i = 0;
?>
<div class="swiper-wrapper">
<?php foreach ($products as $_item) {
    $productImage = $block->getImage($_item, $image);
    $productUrl = $block->getProductUrl($_item);
?>
<?php if ($i++ % $rows == 0) { ?> <div class="swiper-slide product_row"> <?php } ?>
    <div class="item">
        <div class="item-inner">
            <div class="image-container">
                <a href="<?php echo $block->escapeUrl($productUrl); ?>" class="product-item-photo" title="<?php echo $block->escapeHtmlAttr($_item->getName()); ?>">
                    <?php echo $productImage->toHtml(); ?>
                </a>
                <div class="actions">
                    <div class="actions-primary">
                        <?php if ($_item->isSaleable()): ?>
                            <?php
                            $postData = $postDataHelper->getPostData(
                                $block->getAddToCartUrl($_item),
                                ['product' => $_item->getEntityId()]
                            );
                            $postDataConfig = json_decode($postData, true);
                            ?>
                            <?php if (is_array($postDataConfig) && isset($postDataConfig['action'], $postDataConfig['data']) && is_array($postDataConfig['data'])): ?>
                                <form data-role="tocart-form"
                                      action="<?php echo $block->escapeUrl((string) $postDataConfig['action']); ?>"
                                      method="post"
                                      class="catalogfix-tocart-form">
                                    <?php foreach ($postDataConfig['data'] as $key => $value): ?>
                                        <input type="hidden"
                                               name="<?php echo $block->escapeHtmlAttr((string) $key); ?>"
                                               value="<?php echo $block->escapeHtmlAttr((string) $value); ?>" />
                                    <?php endforeach; ?>
                                    <button class="action tocart"
                                            type="submit"
                                            title="<?php echo $block->escapeHtmlAttr(__('Adicionar')); ?>">
                                        <span><?php echo $block->escapeHtml(__('Adicionar')); ?></span>
                                    </button>
                                </form>
                            <?php else: ?>
                                <button class="action tocart disabled"
                                        type="button"
                                        disabled="disabled"
                                        aria-disabled="true"
                                        title="<?php echo $block->escapeHtmlAttr(__('Produto indisponível')); ?>">
                                    <span><?php echo $block->escapeHtml(__('Produto indisponível')); ?></span>
                                </button>
                            <?php endif; ?>
                        <?php else: ?>
                            <?php if ($_item->getIsSalable()): ?>
                                <div class="stock available"><span><?php echo __('Disponível'); ?></span></div>
                            <?php else: ?>
                                <div class="stock unavailable"><span><?php echo __('Produto esgotado'); ?></span></div>
                            <?php endif; ?>
                        <?php endif; ?>
                    </div>
                </div>
            </div>
            <div class="des">
                <div class="product-name">
                    <strong class="product-item-name">
                        <a title="<?php echo $block->escapeHtmlAttr($_item->getName()); ?>"
                           href="<?php echo $block->escapeUrl($productUrl); ?>"
                           class="product-item-link">
                            <?php echo $block->escapeHtml($_item->getName()); ?>
                        </a>
                    </strong>
                </div>
                <?php echo $priceHelper->getPriceDisplayCustom($block->getProductPrice($_item)); ?>
            </div>
        </div>
    </div>
<?php if ($i % $rows == 0 || $i == count($products)) { ?> </div> <?php } ?>
<?php } ?>
</div>
<div class="swiper-button-prev"></div>
<div class="swiper-button-next"></div>
