<?xml version="1.0"?>
<!--
/**
 * GrupoAwamotos CatalogFix
 *
 * The vendor catalog layout defines product.info.media with before="product.info.main".
 * The Ayo theme moves product.info.main into product.col.info (a different container),
 * which causes a "Broken reference" INFO log in developer mode.
 *
 * The structural fix is in Plugin/ScheduledStructureSortPlugin.php which intercepts
 * ScheduledStructure::setElementToSortList() and suppresses the invalid sort instruction
 * before it reaches Layout\Data\Structure::reorderChildElement().
 *
 * The Ayo theme's own <move> instructions (destination="product.col.media") correctly
 * position product.info.media via the scheduledMoves list, which is unaffected.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
    </body>
</page>
