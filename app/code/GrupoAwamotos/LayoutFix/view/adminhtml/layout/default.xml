<?xml version="1.0"?>
<!--
/**
 * GrupoAwamotos LayoutFix
 *
 * Fix 1: notification.messages broken reference
 * Clears the module-level "before=user" ordering from notification.messages
 * so the theme can safely move both blocks to header.inner.right without
 * a "Broken reference" reorder warning.
 *
 * Fix 2: mst.feature-request broken reference
 * Mirasvit Core tries to add mst.feature-request to page.main.container
 * which does not exist in adminhtml. Remove the block to suppress the warning.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            Garante parent consistente para ordering de notification.messages after="user".
            Em alguns contextos o bloco "user" fica em "header" e causa Broken reference.
        -->
        <move element="user" destination="header.inner.right" before="-"/>

        <!--
            Neutraliza o bloco original do Magento_AdminNotification (before="user")
            e recria sem ordering cruzado com "user". Alguns contextos/admin themes não
            posicionam "user" no mesmo parent do notification.messages e isso gera
            "Broken reference ... tries to reorder itself towards user".
        -->
        <referenceBlock name="notification.messages" remove="true"/>
        <referenceContainer name="header.inner.right">
            <block class="Magento\AdminNotification\Block\ToolbarEntry"
                   name="notification.messages"
                   after="-"
                   aclResource="Magento_AdminNotification::show_toolbar"
                   template="Magento_AdminNotification::toolbar_entry.phtml"/>
        </referenceContainer>
    </body>
</page>
