<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            Fix 1 — Passo 1: Garantir que header.inner.right existe antes do
            Magento_AdminNotification processar o before="user" de notification.messages.
        -->
        <referenceContainer name="header">
            <container name="header.inner.right" as="header_inner_right_compat" after="header.inner.left"/>
        </referenceContainer>

        <!--
            Fix 1 — Passo 2: Mover "user" para header.inner.right antes que
            notification.messages seja declarado com before="user". Assim quando
            o constraint for avaliado, ambos estarão no mesmo parent.
        -->
        <move element="user" destination="header.inner.right" before="-"/>

        <!--
            Fix 1 — Passo 3: Remover notification.messages (declarado com before="user"
            pelo Magento_AdminNotification) e recriar sem ordering cruzado.
        -->
        <referenceBlock name="notification.messages" remove="true"/>
        <referenceContainer name="header.inner.right">
            <block class="Magento\AdminNotification\Block\ToolbarEntry"
                   name="notification.messages"
                   after="user"
                   aclResource="Magento_AdminNotification::show_toolbar"
                   template="Magento_AdminNotification::toolbar_entry.phtml"/>
        </referenceContainer>

        <!--
            Fix 2: Mirasvit Core adiciona mst.feature-request a page.main.container,
            que não existe em admin-popup e outros layouts sem esse container.
            Remover suprime o broken reference nesses contextos.
        -->
        <referenceBlock name="mst.feature-request" remove="true"/>
    </body>
</page>
