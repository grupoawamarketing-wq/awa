<?xml version="1.0"?>
<!--
  GrupoAwamotos_CspFix
  Mitiga corrupsão/race-condition do sri-hashes.json (CSP/SRI) com escrita atômica e load tolerante.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Csp\Model\SubresourceIntegrity\Storage\File">
        <plugin name="grupoawamotos_cspfix_sri_atomic_storage" type="GrupoAwamotos\CspFix\Plugin\Csp\SubresourceIntegrity\Storage\FileAtomicPlugin" sortOrder="10" />
    </type>
    <!-- Fix: trim trailing newline from deployed_version.txt to prevent broken RequireJS baseUrl -->
    <type name="Magento\Framework\App\View\Deployment\Version\Storage\File">
        <plugin name="grupoawamotos_cspfix_static_version_trim" type="GrupoAwamotos\CspFix\Plugin\Deployment\Version\Storage\FileTrimPlugin" sortOrder="10" />
    </type>
</config>
