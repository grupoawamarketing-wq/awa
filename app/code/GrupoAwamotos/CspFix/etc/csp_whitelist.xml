<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="facebook_connect" type="host">connect.facebook.net</value>
                <value id="facebook_connect_https" type="host">https://connect.facebook.net</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="livechat_frame" type="host">*.livechatinc.com</value>
                <value id="livechat_frame_lc_chat" type="host">*.lc.chat</value>
                <value id="livechat_frame_text" type="host">*.text.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
