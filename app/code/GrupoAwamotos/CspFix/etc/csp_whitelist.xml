<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="facebook_connect" type="host">connect.facebook.net</value>
                <value id="facebook_connect_https" type="host">https://connect.facebook.net</value>
                <value id="zendesk_snippet" type="host">static.zdassets.com</value>
                <value id="zendesk_ekr" type="host">ekr.zdassets.com</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="zendesk_api" type="host">*.zendesk.com</value>
                <value id="zendesk_assets" type="host">*.zdassets.com</value>
                <value id="zendesk_zopim" type="host">*.zopim.com</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="zendesk_frame" type="host">*.zendesk.com</value>
                <value id="zendesk_zopim_frame" type="host">*.zopim.com</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="zendesk_img" type="host">*.zdassets.com</value>
                <value id="zendesk_img_zendesk" type="host">*.zendesk.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
