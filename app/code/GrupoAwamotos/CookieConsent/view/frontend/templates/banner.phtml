<?php if ($block->isEnabled()): ?>
<link rel="stylesheet" type="text/css"
      href="<?= $block->escapeUrl($block->getViewFileUrl('GrupoAwamotos_CookieConsent::css/cookie-consent.css')) ?>"
      media="print" onload="this.media='all'"/>
<noscript><link rel="stylesheet" type="text/css" media="all"
      href="<?= $block->escapeUrl($block->getViewFileUrl('GrupoAwamotos_CookieConsent::css/cookie-consent.css')) ?>"/></noscript>
<div id="awa-cookie-banner"
     role="alertdialog"
     aria-live="polite"
     aria-label="<?= $block->escapeHtmlAttr(__('Aviso de uso de cookies')) ?>"
     aria-describedby="awa-cookie-desc"
     style="display:none">
    <div class="awa-cookie-banner__inner">
        <div class="awa-cookie-banner__icon" aria-hidden="true">&#x1F36A;</div>
        <p class="awa-cookie-banner__text" id="awa-cookie-desc">
            <?= $block->escapeHtml(__('Usamos cookies para personalizar conteudo e melhorar sua experiencia. Ao continuar, voce concorda com nossa')) ?>
            <a class="awa-cookie-banner__link"
               href="<?= $block->escapeUrl($block->getPolicyUrl()) ?>"
               target="_blank" rel="noopener">
                <?= $block->escapeHtml(__('Politica de Privacidade')) ?>
            </a>.
        </p>
        <div class="awa-cookie-banner__actions">
            <button type="button"
                    id="awa-cookie-accept"
                    class="awa-cookie-banner__btn awa-cookie-banner__btn--accept">
                <?= $block->escapeHtml(__('Permitir cookies')) ?>
            </button>
            <button type="button"
                    id="awa-cookie-decline"
                    class="awa-cookie-banner__btn awa-cookie-banner__btn--decline">
                <?= $block->escapeHtml(__('Apenas essenciais')) ?>
            </button>
        </div>
    </div>
</div>
<script>
(function () {
    function loadCookieConsent() {
        require(['GrupoAwamotos_CookieConsent/js/cookie-consent'], function (cookieConsent) {
            cookieConsent.init();
        });
    }
    if (window.requestIdleCallback) {
        // timeout 12s: evita long task dentro da janela LH (FCP->TTI ~4s com 4x CPU)
        requestIdleCallback(loadCookieConsent, { timeout: 12000 });
    } else {
        setTimeout(loadCookieConsent, 6000);
    }
}());
</script>
<?php endif; ?>
