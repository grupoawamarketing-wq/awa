<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Logger dedicado: var/log/leadlovers.log -->
    <virtualType name="GrupoAwamotos\LeadLovers\Logger\Handler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/leadlovers.log</argument>
        </arguments>
    </virtualType>

    <virtualType name="GrupoAwamotos\LeadLovers\Logger\Logger"
                 type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">leadlovers</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">GrupoAwamotos\LeadLovers\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="GrupoAwamotos\LeadLovers\Model\LeadLoversClient">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\LeadLovers\Logger\Logger</argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\LeadLovers\Observer\OrderPlaceAfter">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\LeadLovers\Logger\Logger</argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\LeadLovers\Observer\CustomerRegisterSuccess">
        <arguments>
            <argument name="logger" xsi:type="object">GrupoAwamotos\LeadLovers\Logger\Logger</argument>
        </arguments>
    </type>

</config>
