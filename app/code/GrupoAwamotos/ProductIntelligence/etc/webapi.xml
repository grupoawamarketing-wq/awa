<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- GET /rest/V1/rexis/recommendations/:customerId -->
    <route url="/V1/rexis/recommendations/:customerId" method="GET">
        <service class="GrupoAwamotos\ProductIntelligence\Api\RecommendationRepositoryInterface" method="getByCustomer"/>
        <resources>
            <resource ref="GrupoAwamotos_ProductIntelligence::recommendations"/>
        </resources>
    </route>

    <!-- GET /rest/V1/rexis/crosssell/:sku -->
    <route url="/V1/rexis/crosssell/:sku" method="GET">
        <service class="GrupoAwamotos\ProductIntelligence\Api\RecommendationRepositoryInterface" method="getCrosssellBySku"/>
        <resources>
            <resource ref="GrupoAwamotos_ProductIntelligence::recommendations"/>
        </resources>
    </route>

    <!-- GET /rest/V1/rexis/rfm/:customerId -->
    <route url="/V1/rexis/rfm/:customerId" method="GET">
        <service class="GrupoAwamotos\ProductIntelligence\Api\RecommendationRepositoryInterface" method="getRfmByCustomer"/>
        <resources>
            <resource ref="GrupoAwamotos_ProductIntelligence::recommendations"/>
        </resources>
    </route>

    <!-- POST /rest/V1/rexis/convert -->
    <route url="/V1/rexis/convert" method="POST">
        <service class="GrupoAwamotos\ProductIntelligence\Api\RecommendationRepositoryInterface" method="registerConversion"/>
        <resources>
            <resource ref="GrupoAwamotos_ProductIntelligence::recommendations"/>
        </resources>
    </route>

    <!-- GET /rest/V1/rexis/metrics -->
    <route url="/V1/rexis/metrics" method="GET">
        <service class="GrupoAwamotos\ProductIntelligence\Api\RecommendationRepositoryInterface" method="getMetrics"/>
        <resources>
            <resource ref="GrupoAwamotos_ProductIntelligence::dashboard"/>
        </resources>
    </route>

</routes>
