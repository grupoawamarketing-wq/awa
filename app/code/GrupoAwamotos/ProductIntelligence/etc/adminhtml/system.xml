<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="grupoawamotos" translate="label" sortOrder="200">
            <label>Grupo Awamotos</label>
        </tab>

        <section id="rexisml" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Product Intelligence - Recomendações</label>
            <tab>grupoawamotos</tab>
            <resource>GrupoAwamotos_ProductIntelligence::config</resource>

            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Configurações Gerais</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Product Intelligence</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Ativar/desativar o sistema de recomendações</comment>
                </field>
                <field id="min_score" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Score Mínimo para Exibição</label>
                    <validate>validate-number validate-number-range number-range-0-1</validate>
                    <comment>Score mínimo (0-1) para exibir recomendações (padrão: 0.7)</comment>
                </field>
            </group>

            <group id="alerts" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Alertas por Email</label>
                <field id="churn_enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Alertas de Churn</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Enviar email diário com oportunidades de churn</comment>
                </field>
                <field id="churn_email_recipients" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Destinatários (Churn)</label>
                    <comment>Emails separados por vírgula</comment>
                    <depends>
                        <field id="churn_enabled">1</field>
                    </depends>
                </field>
                <field id="churn_min_score" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Score Mínimo (Churn)</label>
                    <validate>validate-number validate-number-range number-range-0-1</validate>
                    <comment>Score mínimo para incluir no alerta (padrão: 0.85)</comment>
                    <depends>
                        <field id="churn_enabled">1</field>
                    </depends>
                </field>
                <field id="churn_min_value" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Valor Mínimo (Churn)</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                    <comment>Valor mínimo previsto em R$ para incluir no alerta (padrão: 500)</comment>
                    <depends>
                        <field id="churn_enabled">1</field>
                    </depends>
                </field>
                <field id="crosssell_enabled" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar Alertas de Cross-sell</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Enviar email diário com oportunidades de cross-sell</comment>
                </field>
                <field id="crosssell_email_recipients" translate="label comment" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Destinatários (Cross-sell)</label>
                    <comment>Emails separados por vírgula</comment>
                    <depends>
                        <field id="crosssell_enabled">1</field>
                    </depends>
                </field>
                <field id="crosssell_min_score" translate="label comment" type="text" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Score Mínimo (Cross-sell)</label>
                    <validate>validate-number validate-number-range number-range-0-1</validate>
                    <comment>Score mínimo para incluir no alerta (padrão: 0.75)</comment>
                    <depends>
                        <field id="crosssell_enabled">1</field>
                    </depends>
                </field>
                <field id="crosssell_min_value" translate="label comment" type="text" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Valor Mínimo (Cross-sell)</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                    <comment>Valor mínimo previsto em R$ para incluir no alerta (padrão: 300)</comment>
                    <depends>
                        <field id="crosssell_enabled">1</field>
                    </depends>
                </field>
            </group>

            <group id="whatsapp" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Integração WhatsApp</label>
                <comment><![CDATA[Provider configurado em <strong>Sugestões Inteligentes → WhatsApp</strong>]]></comment>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar WhatsApp</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Ativar notificações de alertas ML via WhatsApp</comment>
                </field>
                <field id="recipients" translate="label comment" type="textarea" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Números de Destinatários</label>
                    <comment>Números separados por vírgula no formato: 5511999998888,5511988887777</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="crosssell_min_score" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Score Mínimo (Cross-sell)</label>
                    <validate>validate-number validate-number-range number-range-0-1</validate>
                    <comment>Score mínimo para notificar cross-sell (padrão: 0.75)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <group id="sync" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Sincronização ERP</label>
                <field id="auto_sync" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Sincronização Automática</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Executar sincronização automática via cron</comment>
                </field>
                <field id="sync_frequency" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Frequência de Sincronização</label>
                    <source_model>GrupoAwamotos\ProductIntelligence\Model\Config\Source\SyncFrequency</source_model>
                    <comment>Com que frequência executar a sincronização</comment>
                    <depends>
                        <field id="auto_sync">1</field>
                    </depends>
                </field>
                <field id="last_sync" translate="label" type="label" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Última Sincronização</label>
                    <backend_model>GrupoAwamotos\ProductIntelligence\Model\Config\Backend\LastSync</backend_model>
                </field>
            </group>

        </section>
    </system>
</config>
