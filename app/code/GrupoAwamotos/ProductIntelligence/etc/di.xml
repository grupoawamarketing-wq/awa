<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Comandos CLI -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="rexis_sync" xsi:type="object">GrupoAwamotos\ProductIntelligence\Console\Command\SyncCommand</item>
                <item name="rexis_test_email" xsi:type="object">GrupoAwamotos\ProductIntelligence\Console\Command\TestEmailCommand</item>
                <item name="rexis_test_whatsapp" xsi:type="object">GrupoAwamotos\ProductIntelligence\Console\Command\TestWhatsAppCommand</item>
                <item name="rexis_stats" xsi:type="object">GrupoAwamotos\ProductIntelligence\Console\Command\StatsCommand</item>
                <item name="rexis_cleanup" xsi:type="object">GrupoAwamotos\ProductIntelligence\Console\Command\CleanupCommand</item>
            </argument>
        </arguments>
    </type>

    <!-- API Preferences -->
    <preference for="GrupoAwamotos\ProductIntelligence\Api\RecommendationRepositoryInterface"
                type="GrupoAwamotos\ProductIntelligence\Model\RecommendationRepository"/>
    <preference for="GrupoAwamotos\ProductIntelligence\Api\Data\RecommendationInterface"
                type="GrupoAwamotos\ProductIntelligence\Model\DatasetRecomendacao"/>
    <preference for="GrupoAwamotos\ProductIntelligence\Api\Data\CrosssellInterface"
                type="GrupoAwamotos\ProductIntelligence\Model\NetworkRules"/>
    <preference for="GrupoAwamotos\ProductIntelligence\Api\Data\RfmInterface"
                type="GrupoAwamotos\ProductIntelligence\Model\CustomerClassification"/>
    <preference for="GrupoAwamotos\ProductIntelligence\Api\Data\MetricsInterface"
                type="Magento\Framework\DataObject"/>

    <!-- RecommendationRepository Logger -->
    <type name="GrupoAwamotos\ProductIntelligence\Model\RecommendationRepository">
        <arguments>
            <argument name="logger" xsi:type="object">Psr\Log\LoggerInterface</argument>
        </arguments>
    </type>

    <!-- UI Component Grid Data Source -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="rexisml_recommendations_listing_data_source" xsi:type="string">GrupoAwamotos\ProductIntelligence\Model\ResourceModel\DatasetRecomendacao\Grid\Collection</item>
            </argument>
        </arguments>
    </type>
    <virtualType name="GrupoAwamotos\ProductIntelligence\Model\ResourceModel\DatasetRecomendacao\Grid\Collection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">rexis_dataset_recomendacao</argument>
            <argument name="resourceModel" xsi:type="string">GrupoAwamotos\ProductIntelligence\Model\ResourceModel\DatasetRecomendacao</argument>
        </arguments>
    </virtualType>

</config>
