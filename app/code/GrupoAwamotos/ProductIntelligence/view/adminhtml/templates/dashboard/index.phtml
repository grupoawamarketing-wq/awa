<script>
(function() {
    var chartData = {
        tipo: <?= $block->getChartDataJson('tipo_pie') ?>,
        monthly: <?= $block->getChartDataJson('monthly_line') ?>,
        rfm: <?= $block->getChartDataJson('rfm_bar') ?>,
        scores: <?= $block->getChartDataJson('score_histogram') ?>,
        products: <?= $block->getChartDataJson('top_products') ?>
    };

    function showEmpty(el, msg) {
        el.innerHTML = '<div style="text-align:center;padding:60px 20px;color:#64748b;font-style:italic">' + msg + '</div>';
    }

    function showError(el, err) {
        el.innerHTML = '<div style="text-align:center;padding:40px 20px;color:#ef4444;font-size:12px">Erro: ' + err + '</div>';
        console.error('[RexisML Chart]', err);
    }

    function initCharts(AC) {
        // ---- 1. TIPO PIE (Donut) ----
        try {
            var el1 = document.querySelector('#chart-tipo');
            var d1 = chartData.tipo;
            if (!d1.series || !d1.series.length) { showEmpty(el1, 'Sem dados de tipo'); }
            else {
                new AC(el1, {
                    series: d1.series,
                    chart: { type: 'donut', height: 300, background: 'transparent' },
                    labels: d1.labels,
                    colors: ['#ef4444', '#10b981', '#f59e0b', '#6366f1', '#64748b'],
                    legend: { position: 'bottom', labels: { colors: '#94a3b8' } },
                    stroke: { colors: ['#1e293b'] },
                    dataLabels: {
                        enabled: true,
                        style: { fontSize: '13px' },
                        formatter: function(val) { return val.toFixed(1) + '%'; }
                    },
                    plotOptions: {
                        pie: {
                            donut: {
                                size: '65%',
                                labels: {
                                    show: true,
                                    total: {
                                        show: true,
                                        label: 'Total',
                                        color: '#94a3b8',
                                        formatter: function(w) {
                                            return w.globals.seriesTotals.reduce(function(a,b){return a+b},0).toLocaleString('pt-BR');
                                        }
                                    },
                                    value: { color: '#f8fafc', fontSize: '22px', fontWeight: 700 }
                                }
                            }
                        }
                    },
                    theme: { mode: 'dark' }
                }).render();
            }
        } catch(e) { showError(document.querySelector('#chart-tipo'), e.message); }

        // ---- 2. MONTHLY EVOLUTION ----
        try {
            var el2 = document.querySelector('#chart-monthly');
            var d2 = chartData.monthly;
            if (!d2.months || !d2.months.length) {
                showEmpty(el2, 'Dados de evolucao aparecerao aqui apos mais meses de sync');
            } else if (d2.fallback) {
                // Fallback: show churn vs crosssell stacked bar per month
                new AC(el2, {
