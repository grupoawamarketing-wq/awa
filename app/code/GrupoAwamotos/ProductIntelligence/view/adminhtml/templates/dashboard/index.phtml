                            }
                        }
                    }
                }).render();
            }
        } catch(e) { showError(document.querySelector('#chart-products'), e.message); }
    }

    // Load ApexCharts bypassing RequireJS AMD detection
    // ApexCharts UMD detects define.amd and tries AMD mode which fails in Magento
    // Solution: temporarily hide window.define, load as global, restore define
    function loadScript(src, onSuccess, onError) {
        var _define = window.define;
        window.define = undefined;

        var s = document.createElement('script');
        s.src = src;
        s.onload = function() {
            window.define = _define;
            if (window.ApexCharts) {
                console.log('[RexisML] ApexCharts loaded from: ' + src);
                onSuccess(window.ApexCharts);
            } else {
                console.warn('[RexisML] ApexCharts loaded but not on window from: ' + src);
                onError();
            }
        };
        s.onerror = function() {
            window.define = _define;
            console.warn('[RexisML] Failed to load: ' + src);
            onError();
        };
        document.head.appendChild(s);
    }

    function onFail() {
        ['#chart-tipo','#chart-monthly','#chart-rfm','#chart-scores','#chart-products'].forEach(function(id) {
            var el = document.querySelector(id);
            if (el) showError(el, 'Nao foi possivel carregar a biblioteca de graficos');
        });
    }

    // Strategy: local file first (fast), CDN fallback (reliable)
    var localUrl = '<?= $block->getViewFileUrl('GrupoAwamotos_ERPIntegration::js/apexcharts.min.js') ?>';
    var cdnUrl = 'https://cdn.jsdelivr.net/npm/apexcharts@3.44.0/dist/apexcharts.min.js';

    loadScript(localUrl, function(AC) {
        initCharts(AC);
    }, function() {
        console.log('[RexisML] Local failed, trying CDN fallback...');
        loadScript(cdnUrl, function(AC) {
            initCharts(AC);
        }, onFail);
    });
})();
</script>

<script>
// Sync ERP button handler
(function() {
    var btn = document.getElementById('rx-sync-btn');
    var label = document.getElementById('rx-sync-label');
    if (!btn || !label) return;

    btn.addEventListener('click', function() {
        if (btn.disabled) return;
        btn.disabled = true;
        btn.style.opacity = '0.6';
        label.textContent = 'Sincronizando...';

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '<?= $block->escapeUrl($block->getUrl('rexisml/dashboard/sync')) ?>');
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.timeout = 300000; // 5 min

        xhr.onload = function() {
            try {
                var resp = JSON.parse(xhr.responseText);
                if (resp.success) {
                    var s = resp.stats;
                    label.textContent = 'Concluido! (' + s.elapsed + 's)';
                    btn.style.borderColor = '#10b981';
                    btn.style.color = '#10b981';
                    // Reload after 2s to refresh KPIs and charts
                    setTimeout(function() { location.reload(); }, 2000);
                } else {
                    label.textContent = 'Erro!';
                    btn.style.borderColor = '#ef4444';
                    btn.style.color = '#ef4444';
                    console.error('[RexisML Sync]', resp.message);
                    alert('Erro no sync: ' + resp.message);
                    setTimeout(function() {
                        btn.disabled = false;
                        btn.style.opacity = '1';
                        label.textContent = 'Sync ERP';
                        btn.style.borderColor = '';
                        btn.style.color = '';
                    }, 3000);
                }
            } catch (e) {
                label.textContent = 'Erro!';
                console.error('[RexisML Sync] Parse error:', e);
                btn.disabled = false;
                btn.style.opacity = '1';
            }
        };

        xhr.onerror = function() {
            label.textContent = 'Falhou';
            btn.disabled = false;
            btn.style.opacity = '1';
        };

        xhr.ontimeout = function() {
            label.textContent = 'Timeout';
            btn.disabled = false;
            btn.style.opacity = '1';
        };

        xhr.send('form_key=' + encodeURIComponent(FORM_KEY));
    });
})();
</script>
