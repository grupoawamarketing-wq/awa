<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">rexisml_recommendations_listing.rexisml_recommendations_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>rexisml_recommendations_columns</spinner>
        <deps>
            <dep>rexisml_recommendations_listing.rexisml_recommendations_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="rexisml_recommendations_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="rexisml_recommendations_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters">
            <filterSelect name="tipo_recomendacao" provider="${ $.parentName }">
                <settings>
                    <options class="GrupoAwamotos\ProductIntelligence\Ui\Component\Listing\Column\TipoOptions"/>
                    <caption translate="true">Todos os Tipos</caption>
                    <label translate="true">Tipo</label>
                    <dataScope>tipo_recomendacao</dataScope>
                </settings>
            </filterSelect>
        </filters>
        <massaction name="listing_massaction" component="Magento_Ui/js/grid/tree-massactions">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Deseja realmente excluir os registros selecionados?</message>
                        <title translate="true">Excluir</title>
                    </confirm>
                    <url path="rexisml/recommendations/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Excluir</label>
                </settings>
            </action>
        </massaction>
        <exportButton name="export_button">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="selectProvider" xsi:type="string">rexisml_recommendations_listing.rexisml_recommendations_listing.rexisml_recommendations_columns.ids</item>
                </item>
            </argument>
        </exportButton>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="rexisml_recommendations_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>id</indexField>
            </settings>
        </selectionsColumn>

        <column name="id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="mes_rexis_code" sortOrder="15">
            <settings>
                <filter>text</filter>
                <label translate="true">Mes</label>
            </settings>
        </column>

        <column name="identificador_cliente" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Cliente (ERP)</label>
            </settings>
        </column>

        <column name="identificador_produto" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Produto (SKU)</label>
            </settings>
        </column>

        <column name="tipo_recomendacao" sortOrder="40" class="GrupoAwamotos\ProductIntelligence\Ui\Component\Listing\Column\Tipo">
            <settings>
                <filter>select</filter>
                <label translate="true">Tipo</label>
                <options class="GrupoAwamotos\ProductIntelligence\Ui\Component\Listing\Column\TipoOptions"/>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>

        <column name="classificacao_cliente" sortOrder="45">
            <settings>
                <filter>text</filter>
                <label translate="true">Segmento RFM</label>
            </settings>
        </column>

        <column name="pred" sortOrder="50" class="GrupoAwamotos\ProductIntelligence\Ui\Component\Listing\Column\Score">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Score ML</label>
                <dataType>number</dataType>
            </settings>
        </column>

        <column name="previsao_gasto_round_up" sortOrder="60" class="GrupoAwamotos\ProductIntelligence\Ui\Component\Listing\Column\Currency">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Previsao Gasto</label>
                <dataType>number</dataType>
            </settings>
        </column>

        <column name="recencia" sortOrder="70">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Recencia (dias)</label>
                <dataType>number</dataType>
            </settings>
        </column>

        <column name="valor_convertida" sortOrder="80" class="GrupoAwamotos\ProductIntelligence\Ui\Component\Listing\Column\Currency">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Valor Convertido</label>
                <dataType>number</dataType>
            </settings>
        </column>

        <column name="quantidade_convertida" sortOrder="85">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Qtd Convertida</label>
                <dataType>number</dataType>
            </settings>
        </column>

        <column name="created_at" sortOrder="90" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Criado em</label>
                <dataType>date</dataType>
            </settings>
        </column>
    </columns>
</listing>
