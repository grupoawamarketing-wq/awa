<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <!-- Recomendações personalizadas no dashboard do cliente -->
            <block class="GrupoAwamotos\ProductIntelligence\Block\Recommendations"
                   name="rexisml.recommendations"
                   template="GrupoAwamotos_ProductIntelligence::recommendations.phtml"
                   after="-">
                <arguments>
                    <argument name="limit" xsi:type="number">4</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
