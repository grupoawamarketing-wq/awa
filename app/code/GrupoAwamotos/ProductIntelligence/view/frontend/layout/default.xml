<?xml version="1.0"?>
<!--
    Load ProductIntelligence CSS on all pages.
    Widgets (recommendations grid, carousel, simple, B2B) can appear anywhere,
    so the CSS must be available globally.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- rexis-recommendations.css async (non-blocking) — widgets below fold (AWA 2026-04-25) -->
        <css src="GrupoAwamotos_ProductIntelligence::css/rexis-recommendations.css" media="print"/>
    </head>
</page>
