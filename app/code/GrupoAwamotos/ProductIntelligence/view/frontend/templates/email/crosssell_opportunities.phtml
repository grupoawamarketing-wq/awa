<?php
/**
 * Template parcial para lista de oportunidades de cross-sell em email
 *
 * @var $block \GrupoAwamotos\RexisML\Block\Email\CrossSellOpportunities
 */
$opportunities = $block->getOpportunities();
?>

<?php foreach ($opportunities as $opp): ?>
<tr style="border-bottom: 1px solid #e5e7eb;">
    <td style="padding: 12px; border: 1px solid #e5e7eb;">
        <strong style="display: block; margin-bottom: 4px;"><?= $block->escapeHtml($opp['customer_name']) ?></strong>
        <span style="font-size: 12px; color: #6b7280;"><?= $block->escapeHtml($opp['customer_email']) ?></span>
    </td>
    <td style="padding: 12px; border: 1px solid #e5e7eb;">
        <strong style="display: block; margin-bottom: 4px;"><?= $block->escapeHtml($opp['product_name']) ?></strong>
        <span style="font-size: 12px; color: #6b7280;">SKU: <?= $block->escapeHtml($opp['product_sku']) ?></span>
    </td>
    <td style="padding: 12px; text-align: center; border: 1px solid #e5e7eb;">
        <span style="display: inline-block; padding: 4px 12px; background: <?= $opp['score'] >= 70 ? '#d1fae5' : '#e0f2fe' ?>; color: <?= $opp['score'] >= 70 ? '#065f46' : '#075985' ?>; border-radius: 12px; font-weight: 600; font-size: 13px;">
            <?= number_format($opp['score'], 1) ?>%
        </span>
    </td>
    <td style="padding: 12px; text-align: right; font-weight: 600; border: 1px solid #e5e7eb;">
        R$ <?= $block->escapeHtml(number_format((float) $opp['predicted_value'], 2, ',', '.')) ?>
    </td>
</tr>
<?php endforeach; ?>
