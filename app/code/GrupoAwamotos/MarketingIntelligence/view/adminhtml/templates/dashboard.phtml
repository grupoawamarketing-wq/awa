<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var scoreData = <?= /* @noEscape */ $scoreChartJson ?>;
    var ufData = <?= /* @noEscape */ $ufChartJson ?>;

    // Score Distribution - Bar Chart
    var scoreCtx = document.getElementById('mktg-score-chart');
    if (scoreCtx) {
        new Chart(scoreCtx.getContext('2d'), {
            type: 'bar',
            data: scoreData,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { precision: 0 } }
                }
            }
        });
    }

    // UF Distribution - Horizontal Bar Chart
    var ufCtx = document.getElementById('mktg-uf-chart');
    if (ufCtx) {
        new Chart(ufCtx.getContext('2d'), {
            type: 'bar',
            data: ufData,
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { beginAtZero: true, ticks: { precision: 0 } }
                }
            }
        });
    }

    // Budget Attribution - Doughnut Chart
    var budgetData = <?= /* @noEscape */ $budgetChartJson ?>;
    var budgetCtx = document.getElementById('mktg-budget-chart');
    if (budgetCtx && budgetData.datasets[0].data.length > 0) {
        new Chart(budgetCtx.getContext('2d'), {
            type: 'doughnut',
            data: budgetData,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                cutout: '60%'
            }
        });
    }
});
</script>
