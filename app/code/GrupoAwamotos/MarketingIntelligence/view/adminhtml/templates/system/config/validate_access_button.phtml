<?php
/** @var \GrupoAwamotos\MarketingIntelligence\Block\Adminhtml\System\Config\ValidateAccessButton $block */
?>
<div id="mktg-validate-result" style="margin-top:8px;display:none;padding:10px;border-radius:6px;font-size:13px;"></div>
<?= /* @noEscape */ $block->getButtonHtml() ?>
<script>
require(['jquery'], function ($) {
    'use strict';
    $('#mktg_validate_access_btn').on('click', function () {
        var $btn = $(this),
            $result = $('#mktg-validate-result');
        $btn.prop('disabled', true).text('Validando...');
        $result.hide();
        $.ajax({
            url: '<?= $block->escapeJs($block->getAjaxUrl()) ?>',
            type: 'POST',
            dataType: 'json',
            data: {form_key: window.FORM_KEY},
            success: function (data) {
                var html = '';
                if (data.success) {
                    html += '<strong style="color:#059669">✓ Acesso Validado</strong><br>';
                    html += 'Usuário: ' + (data.user.name || 'N/A') + '<br>';
                    html += 'Conta: ' + (data.account.name || 'N/A') + ' (' + (data.account.status || '') + ')<br>';
                    html += 'Moeda: ' + (data.account.currency || 'N/A') + '<br>';
                    html += 'Permissões: <strong>' + (data.permissions.length ? data.permissions.join(', ') : 'nenhuma detectada') + '</strong>';
                    $result.css({background: '#ecfdf5', border: '1px solid #059669'});
                    // Update permissions field
                    var $permField = $('[id$="_api_permissions"]').filter('input');
                    if ($permField.length) {
                        $permField.val(data.permissions.join(', '));
                    }
                } else {
                    html += '<strong style="color:#dc2626">✗ Falha na Validação</strong><br>';
                    html += (data.errors || []).join('<br>');
                    $result.css({background: '#fef2f2', border: '1px solid #dc2626'});
                }
                $result.html(html).show();
            },
            error: function () {
                $result.html('<strong style="color:#dc2626">✗ Erro de comunicação</strong>').css({background: '#fef2f2', border: '1px solid #dc2626'}).show();
            },
            complete: function () {
                $btn.prop('disabled', false).text('Validar Acesso Meta');
            }
        });
    });
});
</script>
