<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mktg_prospects_listing.mktg_prospects_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>mktg_prospects_listing_columns</spinner>
        <deps>
            <dep>mktg_prospects_listing.mktg_prospects_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="mktg_prospects_listing_data_source" component="Magento_Ui/js/grid/provider">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider</argument>
            <argument name="name" xsi:type="string">mktg_prospects_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">prospect_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>
        </argument>
        <settings>
            <updateUrl path="mui/index/render"/>
            <storageConfig>
                <param name="indexField" xsi:type="string">prospect_id</param>
            </storageConfig>
        </settings>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters">
            <filterSelect name="prospect_status" provider="${ $.parentName }">
                <settings>
                    <options class="GrupoAwamotos\MarketingIntelligence\Ui\Component\Listing\Column\ProspectStatusOptions"/>
                    <caption translate="true">Todos Status</caption>
                    <label translate="true">Status</label>
                    <dataScope>prospect_status</dataScope>
                </settings>
            </filterSelect>
            <filterSelect name="cnae_profile" provider="${ $.parentName }">
                <settings>
                    <options class="GrupoAwamotos\MarketingIntelligence\Ui\Component\Listing\Column\CnaeProfileOptions"/>
                    <caption translate="true">Todos Perfis</caption>
                    <label translate="true">Perfil CNAE</label>
                    <dataScope>cnae_profile</dataScope>
                </settings>
            </filterSelect>
        </filters>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="mktg_prospects_listing_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>prospect_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="prospect_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="cnpj" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">CNPJ</label>
            </settings>
        </column>
        <column name="nome_fantasia" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Nome Fantasia</label>
            </settings>
        </column>
        <column name="razao_social" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Razão Social</label>
                <visible>false</visible>
            </settings>
        </column>
        <column name="cnae_principal" sortOrder="50">
            <settings>
                <filter>text</filter>
                <label translate="true">CNAE</label>
            </settings>
        </column>
        <column name="cnae_profile" sortOrder="60" class="GrupoAwamotos\MarketingIntelligence\Ui\Component\Listing\Column\CnaeProfile">
            <settings>
                <filter>select</filter>
                <label translate="true">Perfil CNAE</label>
                <options class="GrupoAwamotos\MarketingIntelligence\Ui\Component\Listing\Column\CnaeProfileOptions"/>
                <dataType>select</dataType>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="uf" sortOrder="70">
            <settings>
                <filter>text</filter>
                <label translate="true">UF</label>
            </settings>
        </column>
        <column name="municipio" sortOrder="80">
            <settings>
                <filter>text</filter>
                <label translate="true">Município</label>
                <visible>false</visible>
            </settings>
        </column>
        <column name="capital_social" sortOrder="90" class="Magento\Ui\Component\Listing\Columns\Column">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Capital Social</label>
            </settings>
        </column>
        <column name="porte" sortOrder="100">
            <settings>
                <filter>text</filter>
                <label translate="true">Porte</label>
            </settings>
        </column>
        <column name="prospect_score" sortOrder="110" class="GrupoAwamotos\MarketingIntelligence\Ui\Component\Listing\Column\ProspectScore">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Score</label>
                <dataType>text</dataType>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="prospect_status" sortOrder="120" class="GrupoAwamotos\MarketingIntelligence\Ui\Component\Listing\Column\ProspectStatus">
            <settings>
                <filter>select</filter>
                <label translate="true">Status</label>
                <options class="GrupoAwamotos\MarketingIntelligence\Ui\Component\Listing\Column\ProspectStatusOptions"/>
                <dataType>select</dataType>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="email" sortOrder="130">
            <settings>
                <filter>text</filter>
                <label translate="true">Email</label>
                <visible>false</visible>
            </settings>
        </column>
        <column name="telefone" sortOrder="140">
            <settings>
                <filter>text</filter>
                <label translate="true">Telefone</label>
                <visible>false</visible>
            </settings>
        </column>
        <column name="fetched_at" sortOrder="150" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Importado Em</label>
                <dataType>date</dataType>
            </settings>
        </column>
    </columns>
</listing>
