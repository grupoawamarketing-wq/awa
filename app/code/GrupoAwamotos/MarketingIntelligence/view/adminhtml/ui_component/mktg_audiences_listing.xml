<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mktg_audiences_listing.mktg_audiences_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>mktg_audiences_listing_columns</spinner>
        <deps>
            <dep>mktg_audiences_listing.mktg_audiences_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="mktg_audiences_listing_data_source" component="Magento_Ui/js/grid/provider">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider</argument>
            <argument name="name" xsi:type="string">mktg_audiences_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">audience_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>
        </argument>
        <settings>
            <updateUrl path="mui/index/render"/>
            <storageConfig>
                <param name="indexField" xsi:type="string">audience_id</param>
            </storageConfig>
        </settings>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="mktg_audiences_listing_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>audience_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="audience_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Nome</label>
            </settings>
        </column>
        <column name="audience_type" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Tipo</label>
            </settings>
        </column>
        <column name="meta_audience_id" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Meta Audience ID</label>
            </settings>
        </column>
        <column name="customer_count" sortOrder="50">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Clientes</label>
            </settings>
        </column>
        <column name="meta_match_rate" sortOrder="60">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Match Rate %</label>
            </settings>
        </column>
        <column name="auto_refresh" sortOrder="70" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <label translate="true">Auto Refresh</label>
                <dataType>select</dataType>
                <options>
                    <option name="0" xsi:type="array">
                        <item name="value" xsi:type="string">0</item>
                        <item name="label" xsi:type="string" translate="true">Não</item>
                    </option>
                    <option name="1" xsi:type="array">
                        <item name="value" xsi:type="string">1</item>
                        <item name="label" xsi:type="string" translate="true">Sim</item>
                    </option>
                </options>
            </settings>
        </column>
        <column name="status" sortOrder="80" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <label translate="true">Status</label>
                <dataType>select</dataType>
                <options>
                    <option name="0" xsi:type="array">
                        <item name="value" xsi:type="string">active</item>
                        <item name="label" xsi:type="string" translate="true">Ativo</item>
                    </option>
                    <option name="1" xsi:type="array">
                        <item name="value" xsi:type="string">paused</item>
                        <item name="label" xsi:type="string" translate="true">Pausado</item>
                    </option>
                    <option name="2" xsi:type="array">
                        <item name="value" xsi:type="string">error</item>
                        <item name="label" xsi:type="string" translate="true">Erro</item>
                    </option>
                </options>
            </settings>
        </column>
        <column name="last_synced_at" sortOrder="90" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Último Sync</label>
                <dataType>date</dataType>
            </settings>
        </column>
        <column name="created_at" sortOrder="100" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Criado Em</label>
                <dataType>date</dataType>
            </settings>
        </column>
    </columns>
</listing>
