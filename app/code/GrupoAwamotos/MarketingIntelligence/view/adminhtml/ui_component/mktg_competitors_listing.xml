<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mktg_competitors_listing.mktg_competitors_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>mktg_competitors_listing_columns</spinner>
        <deps>
            <dep>mktg_competitors_listing.mktg_competitors_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="mktg_competitors_listing_data_source" component="Magento_Ui/js/grid/provider">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider</argument>
            <argument name="name" xsi:type="string">mktg_competitors_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">ad_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>
        </argument>
        <settings>
            <updateUrl path="mui/index/render"/>
            <storageConfig>
                <param name="indexField" xsi:type="string">ad_id</param>
            </storageConfig>
        </settings>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="mktg_competitors_listing_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>ad_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="ad_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="page_name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Página</label>
            </settings>
        </column>
        <column name="ad_creative_title" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Título do Anúncio</label>
            </settings>
        </column>
        <column name="ad_creative_body" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Texto</label>
                <visible>false</visible>
            </settings>
        </column>
        <column name="ad_creative_link" sortOrder="50">
            <settings>
                <filter>text</filter>
                <label translate="true">URL Destino</label>
                <visible>false</visible>
            </settings>
        </column>
        <column name="platforms" sortOrder="60">
            <settings>
                <filter>text</filter>
                <label translate="true">Plataformas</label>
            </settings>
        </column>
        <column name="ad_delivery_start" sortOrder="70" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Início</label>
                <dataType>date</dataType>
            </settings>
        </column>
        <column name="ad_delivery_stop" sortOrder="80" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Fim</label>
                <dataType>date</dataType>
                <visible>false</visible>
            </settings>
        </column>
        <column name="is_active" sortOrder="90" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <label translate="true">Ativo</label>
                <dataType>select</dataType>
                <options>
                    <option name="0" xsi:type="array">
                        <item name="value" xsi:type="string">0</item>
                        <item name="label" xsi:type="string" translate="true">Não</item>
                    </option>
                    <option name="1" xsi:type="array">
                        <item name="value" xsi:type="string">1</item>
                        <item name="label" xsi:type="string" translate="true">Sim</item>
                    </option>
                </options>
            </settings>
        </column>
        <column name="first_seen_at" sortOrder="100" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Primeiro Visto</label>
                <dataType>date</dataType>
            </settings>
        </column>
        <column name="last_seen_at" sortOrder="110" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Último Visto</label>
                <dataType>date</dataType>
            </settings>
        </column>
    </columns>
</listing>
