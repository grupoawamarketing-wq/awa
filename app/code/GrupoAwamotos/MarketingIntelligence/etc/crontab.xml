<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="grupoawamotos_mktg_fetch_prospects"
             instance="GrupoAwamotos\MarketingIntelligence\Cron\FetchProspects"
             method="execute">
            <schedule>0 3 * * 1</schedule>
        </job>
        <job name="grupoawamotos_mktg_refresh_audiences"
             instance="GrupoAwamotos\MarketingIntelligence\Cron\RefreshAudiences"
             method="execute">
            <schedule>0 4 * * *</schedule>
        </job>
        <job name="grupoawamotos_mktg_scan_competitor_ads"
             instance="GrupoAwamotos\MarketingIntelligence\Cron\ScanCompetitorAds"
             method="execute">
            <schedule>0 5 * * *</schedule>
        </job>
        <job name="grupoawamotos_mktg_sync_offline_conversions"
             instance="GrupoAwamotos\MarketingIntelligence\Cron\SyncOfflineConversions"
             method="execute">
            <schedule>0 */6 * * *</schedule>
        </job>
        <job name="grupoawamotos_mktg_sync_insights"
             instance="GrupoAwamotos\MarketingIntelligence\Cron\SyncInsights"
             method="execute">
            <schedule>0 2 * * *</schedule>
        </job>
        <job name="grupoawamotos_mktg_check_alerts"
             instance="GrupoAwamotos\MarketingIntelligence\Cron\CheckAlerts"
             method="execute">
            <schedule>0 8 * * *</schedule>
        </job>
    </group>
</config>
