<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- Prospects: companies found via CNAE search -->
    <table name="grupoawamotos_mktg_prospects" resource="default" engine="innodb"
           comment="Marketing Intelligence - B2B Prospects">
        <column xsi:type="int" name="prospect_id" unsigned="true" nullable="false" identity="true"
                comment="Prospect ID"/>
        <column xsi:type="varchar" name="cnpj" length="18" nullable="false" comment="CNPJ"/>
        <column xsi:type="varchar" name="razao_social" length="255" nullable="true" comment="Razao Social"/>
        <column xsi:type="varchar" name="nome_fantasia" length="255" nullable="true" comment="Nome Fantasia"/>
        <column xsi:type="varchar" name="cnae_principal" length="20" nullable="true" comment="CNAE Principal"/>
        <column xsi:type="varchar" name="cnae_descricao" length="255" nullable="true" comment="CNAE Descricao"/>
        <column xsi:type="varchar" name="cnae_profile" length="30" nullable="true" comment="CNAE Profile"/>
        <column xsi:type="varchar" name="uf" length="2" nullable="true" comment="UF"/>
        <column xsi:type="varchar" name="municipio" length="255" nullable="true" comment="Municipio"/>
        <column xsi:type="varchar" name="cep" length="10" nullable="true" comment="CEP"/>
        <column xsi:type="varchar" name="email" length="255" nullable="true" comment="Email"/>
        <column xsi:type="varchar" name="telefone" length="30" nullable="true" comment="Telefone"/>
        <column xsi:type="decimal" name="capital_social" precision="15" scale="2" nullable="true"
                comment="Capital Social"/>
        <column xsi:type="varchar" name="porte" length="30" nullable="true" comment="Porte"/>
        <column xsi:type="date" name="data_abertura" nullable="true" comment="Data Abertura"/>
        <column xsi:type="varchar" name="situacao_cadastral" length="30" nullable="true"
                comment="Situacao Cadastral"/>
        <column xsi:type="smallint" name="prospect_score" unsigned="true" nullable="false" default="0"
                comment="Prospect Score"/>
        <column xsi:type="varchar" name="prospect_status" length="20" nullable="false" default="new"
                comment="Prospect Status"/>
        <column xsi:type="varchar" name="source" length="50" nullable="true" comment="Source"/>
        <column xsi:type="text" name="notes" nullable="true" comment="Notes"/>
        <column xsi:type="timestamp" name="contacted_at" nullable="true" comment="Contacted At"/>
        <column xsi:type="int" name="converted_customer_id" unsigned="true" nullable="true"
                comment="Converted Customer ID"/>
        <column xsi:type="timestamp" name="fetched_at" nullable="true" comment="Fetched At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="true" on_update="true"
                default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="prospect_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_MKTG_PROSPECTS_CNPJ">
            <column name="cnpj"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_MKTG_PROSPECTS_CONVERTED_CSTR_ID_CSTR_ENTT_ENTT_ID"
                    table="grupoawamotos_mktg_prospects" column="converted_customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="SET NULL"/>
        <index referenceId="GRUPOAWAMOTOS_MKTG_PROSPECTS_PROSPECT_STATUS" indexType="btree">
            <column name="prospect_status"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_MKTG_PROSPECTS_PROSPECT_SCORE" indexType="btree">
            <column name="prospect_score"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_MKTG_PROSPECTS_CNAE_PRINCIPAL" indexType="btree">
            <column name="cnae_principal"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_MKTG_PROSPECTS_UF" indexType="btree">
            <column name="uf"/>
        </index>
    </table>

    <!-- Audiences: Meta custom/lookalike audiences -->
    <table name="grupoawamotos_mktg_audiences" resource="default" engine="innodb"
           comment="Marketing Intelligence - Meta Audiences">
        <column xsi:type="int" name="audience_id" unsigned="true" nullable="false" identity="true"
                comment="Audience ID"/>
        <column xsi:type="varchar" name="meta_audience_id" length="50" nullable="true"
                comment="Meta Audience ID"/>
        <column xsi:type="varchar" name="name" length="255" nullable="false" comment="Name"/>
        <column xsi:type="varchar" name="audience_type" length="30" nullable="false"
                comment="Audience Type"/>
        <column xsi:type="text" name="segment_rule" nullable="true" comment="Segment Rule JSON"/>
        <column xsi:type="int" name="customer_count" unsigned="true" nullable="false" default="0"
                comment="Customer Count"/>
        <column xsi:type="decimal" name="meta_match_rate" precision="5" scale="2" nullable="true"
                comment="Meta Match Rate"/>
        <column xsi:type="boolean" name="auto_refresh" nullable="false" default="false"
                comment="Auto Refresh"/>
        <column xsi:type="varchar" name="refresh_frequency" length="20" nullable="true"
                comment="Refresh Frequency"/>
        <column xsi:type="timestamp" name="last_synced_at" nullable="true" comment="Last Synced At"/>
        <column xsi:type="varchar" name="status" length="20" nullable="false" default="draft"
                comment="Status"/>
        <column xsi:type="int" name="source_audience_id" unsigned="true" nullable="true"
                comment="Source Audience ID"/>
        <column xsi:type="decimal" name="lookalike_ratio" precision="4" scale="2" nullable="true"
                comment="Lookalike Ratio"/>
        <column xsi:type="varchar" name="lookalike_country" length="5" nullable="true"
                comment="Lookalike Country"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="true" on_update="true"
                default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="audience_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="FK_3F2ACFD03FCBCC103774117E53816587"
                    table="grupoawamotos_mktg_audiences" column="source_audience_id"
                    referenceTable="grupoawamotos_mktg_audiences" referenceColumn="audience_id"
                    onDelete="SET NULL"/>
        <index referenceId="GRUPOAWAMOTOS_MKTG_AUDIENCES_STATUS" indexType="btree">
            <column name="status"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_MKTG_AUDIENCES_AUDIENCE_TYPE" indexType="btree">
            <column name="audience_type"/>
        </index>
    </table>

    <!-- Competitors: monitored competitor pages -->
    <table name="grupoawamotos_mktg_competitors" resource="default" engine="innodb"
           comment="Marketing Intelligence - Competitors">
        <column xsi:type="int" name="competitor_id" unsigned="true" nullable="false" identity="true"
                comment="Competitor ID"/>
        <column xsi:type="varchar" name="name" length="255" nullable="false" comment="Name"/>
        <column xsi:type="varchar" name="meta_page_id" length="50" nullable="true"
                comment="Meta Page ID"/>
        <column xsi:type="varchar" name="website" length="500" nullable="true" comment="Website"/>
        <column xsi:type="text" name="keywords" nullable="true" comment="Keywords JSON"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true"
                comment="Is Active"/>
        <column xsi:type="text" name="notes" nullable="true" comment="Notes"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="true" on_update="true"
                default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="competitor_id"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_MKTG_COMPETITORS_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>

    <!-- Competitor Ads: ads found via Meta Ad Library -->
    <table name="grupoawamotos_mktg_competitor_ads" resource="default" engine="innodb"
           comment="Marketing Intelligence - Competitor Ads">
        <column xsi:type="int" name="ad_id" unsigned="true" nullable="false" identity="true"
                comment="Ad ID"/>
        <column xsi:type="int" name="competitor_id" unsigned="true" nullable="true"
                comment="Competitor ID"/>
        <column xsi:type="varchar" name="meta_ad_id" length="50" nullable="false"
                comment="Meta Ad ID"/>
        <column xsi:type="varchar" name="page_id" length="50" nullable="true" comment="Page ID"/>
        <column xsi:type="varchar" name="page_name" length="255" nullable="true" comment="Page Name"/>
        <column xsi:type="text" name="ad_creative_body" nullable="true" comment="Ad Creative Body"/>
        <column xsi:type="varchar" name="ad_creative_title" length="500" nullable="true"
                comment="Ad Creative Title"/>
        <column xsi:type="varchar" name="ad_creative_link" length="1000" nullable="true"
                comment="Ad Creative Link"/>
        <column xsi:type="varchar" name="ad_creative_image_url" length="1000" nullable="true"
                comment="Ad Creative Image URL"/>
        <column xsi:type="date" name="ad_delivery_start" nullable="true" comment="Ad Delivery Start"/>
        <column xsi:type="date" name="ad_delivery_stop" nullable="true" comment="Ad Delivery Stop"/>
        <column xsi:type="varchar" name="platforms" length="255" nullable="true" comment="Platforms"/>
        <column xsi:type="boolean" name="is_active" nullable="true" comment="Is Active"/>
        <column xsi:type="varchar" name="category" length="50" nullable="true" comment="Category"/>
        <column xsi:type="timestamp" name="first_seen_at" nullable="true" comment="First Seen At"/>
        <column xsi:type="timestamp" name="last_seen_at" nullable="true" comment="Last Seen At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="ad_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_MKTG_COMPETITOR_ADS_META_AD_ID">
            <column name="meta_ad_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="FK_B54E9BDBACA796C60FC2AA56EF2608F4"
                    table="grupoawamotos_mktg_competitor_ads" column="competitor_id"
                    referenceTable="grupoawamotos_mktg_competitors" referenceColumn="competitor_id"
                    onDelete="SET NULL"/>
        <index referenceId="GRUPOAWAMOTOS_MKTG_COMPETITOR_ADS_COMPETITOR_ID" indexType="btree">
            <column name="competitor_id"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_MKTG_COMPETITOR_ADS_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>

    <!-- Campaign Insights: Meta campaign performance data -->
    <table name="grupoawamotos_mktg_campaign_insights" resource="default" engine="innodb"
           comment="Marketing Intelligence - Campaign Insights">
        <column xsi:type="int" name="insight_id" unsigned="true" nullable="false" identity="true"
                comment="Insight ID"/>
        <column xsi:type="varchar" name="campaign_id" length="50" nullable="false"
                comment="Campaign ID"/>
        <column xsi:type="varchar" name="campaign_name" length="255" nullable="true"
                comment="Campaign Name"/>
        <column xsi:type="varchar" name="adset_id" length="50" nullable="true" comment="Ad Set ID"/>
        <column xsi:type="varchar" name="adset_name" length="255" nullable="true"
                comment="Ad Set Name"/>
        <column xsi:type="varchar" name="ad_id" length="50" nullable="true" comment="Ad ID"/>
        <column xsi:type="varchar" name="ad_name" length="255" nullable="true" comment="Ad Name"/>
        <column xsi:type="date" name="date_start" nullable="false" comment="Date Start"/>
        <column xsi:type="date" name="date_stop" nullable="false" comment="Date Stop"/>
        <column xsi:type="decimal" name="spend" precision="12" scale="4" nullable="false" default="0"
                comment="Spend"/>
        <column xsi:type="int" name="impressions" unsigned="true" nullable="false" default="0"
                comment="Impressions"/>
        <column xsi:type="int" name="clicks" unsigned="true" nullable="false" default="0"
                comment="Clicks"/>
        <column xsi:type="int" name="reach" unsigned="true" nullable="false" default="0"
                comment="Reach"/>
        <column xsi:type="text" name="actions_json" nullable="true" comment="Actions JSON"/>
        <column xsi:type="text" name="action_values_json" nullable="true"
                comment="Action Values JSON"/>
        <column xsi:type="decimal" name="purchase_roas" precision="10" scale="4" nullable="true"
                comment="Purchase ROAS"/>
        <column xsi:type="decimal" name="cpc" precision="10" scale="4" nullable="true" comment="CPC"/>
        <column xsi:type="decimal" name="cpm" precision="10" scale="4" nullable="true" comment="CPM"/>
        <column xsi:type="decimal" name="ctr" precision="10" scale="4" nullable="true" comment="CTR"/>
        <column xsi:type="varchar" name="classification" length="30" nullable="true"
                comment="Classification"/>
        <column xsi:type="varchar" name="classified_by" length="30" nullable="true"
                comment="Classified By"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="true" on_update="true"
                default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="insight_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNQ_DBF3789B083D437EC3D0FAF09432032A">
            <column name="campaign_id"/>
            <column name="adset_id"/>
            <column name="ad_id"/>
            <column name="date_start"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_MKTG_CAMPAIGN_INSIGHTS_CAMPAIGN_ID" indexType="btree">
            <column name="campaign_id"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_MKTG_CAMPAIGN_INSIGHTS_DATE_START" indexType="btree">
            <column name="date_start"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_MKTG_CAMPAIGN_INSIGHTS_CLASSIFICATION" indexType="btree">
            <column name="classification"/>
        </index>
    </table>

</schema>