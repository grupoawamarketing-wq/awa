$currentSegment = $block->getCurrentSegment();
$totalPages = $block->getTotalPages();
$currentPage = $block->getCurrentPage();
$rfmExplanation = $block->getRfmExplanation();
?>

<div class="smart-dashboard">
    <!-- Header -->
    <div class="smart-dashboard-header">
        <h1>Análise RFM - Segmentação de Clientes</h1>
        <p>Recência, Frequência e Valor Monetário</p>
    </div>

    <!-- RFM Explanation -->
    <div class="rfm-explanation">
        <h3>O que é RFM?</h3>
        <div class="rfm-metrics">
            <?php foreach ($rfmExplanation as $letter => $info): ?>
            <div class="rfm-metric">
                <div class="rfm-letter"><?= $block->escapeHtml($letter) ?></div>
                <div class="rfm-info">
                    <strong><?= $block->escapeHtml($info['name']) ?></strong>
                    <p><?= $block->escapeHtml($info['description']) ?></p>
                    <small><?= $block->escapeHtml($info['interpretation']) ?></small>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>

    <!-- Segment Cards -->
    <div class="rfm-segments-filter">
        <h3>Filtrar por Segmento</h3>
        <div class="rfm-segment-cards">
            <a href="<?= $block->escapeUrl($block->getSegmentUrl(null)) ?>"
               class="rfm-segment-card <?= !$currentSegment ? 'active' : '' ?>">
                <span class="segment-name">Todos</span>
                <span class="segment-count"><?= $block->formatNumber(array_sum(array_column($segments, 'count'))) ?></span>
            </a>
            <?php foreach ($segments as $segment): ?>
            <a href="<?= $block->escapeUrl($block->getSegmentUrl($segment['segment'])) ?>"
               class="rfm-segment-card <?= $currentSegment === $segment['segment'] ? 'active' : '' ?>"
               style="--segment-color: <?= $block->escapeHtml($segment['color']) ?>">
                <span class="segment-name"><?= $block->escapeHtml($segment['segment']) ?></span>
                <span class="segment-count"><?= $block->formatNumber($segment['count']) ?></span>
                <span class="segment-revenue"><?= $block->formatPrice($segment['total_revenue']) ?></span>
            </a>
            <?php endforeach; ?>
        </div>
    </div>

    <!-- Recommendations for selected segment -->
    <?php if ($currentSegment): ?>
    <?php $recommendations = $block->getRecommendations($currentSegment); ?>
