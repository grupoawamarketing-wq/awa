        <h3>Recomendações para "<?= $block->escapeHtml($currentSegment) ?>"</h3>
        <div class="rfm-rec-content">
            <div class="rfm-rec-action">
                <span class="label">Ação Principal:</span>
                <span class="value"><?= $block->escapeHtml($recommendations['action']) ?></span>
            </div>
            <div class="rfm-rec-priority">
                <span class="label">Prioridade:</span>
                <span class="value priority-<?= $block->escapeHtmlAttr(strtolower(str_replace('-', '', $recommendations['priority']))) ?>">
