                            <small><?= $block->escapeHtml($customer['customer_name']) ?></small>
                            <?php endif; ?>
                        </div>
                    </td>
                    <td><?= $block->escapeHtml($customer['city'] . '/' . $customer['state']) ?></td>
                    <td>
                        <?php
                        $segmentData = array_filter($segments, fn($s) => $s['segment'] === $customer['segment']);
                        $segmentColor = !empty($segmentData) ? reset($segmentData)['color'] : '#999';
                        ?>
                        <span class="smart-badge" style="--smart-seg-color:<?= $block->escapeHtmlAttr($segmentColor) ?>;background-color:var(--smart-seg-color)20;color:var(--smart-seg-color)">
                            <?= $block->escapeHtml($customer['segment']) ?>
                        </span>
                    </td>
                    <td class="_center">
                        <span class="rfm-score rfm-score-<?= (int)$customer['r_score'] ?>"><?= (int)$customer['r_score'] ?></span>
                    </td>
                    <td class="_center">
                        <span class="rfm-score rfm-score-<?= (int)$customer['f_score'] ?>"><?= (int)$customer['f_score'] ?></span>
                    </td>
                    <td class="_center">
                        <span class="rfm-score rfm-score-<?= (int)$customer['m_score'] ?>"><?= (int)$customer['m_score'] ?></span>
                    </td>
                    <td class="_right"><?= (int)$customer['recency_days'] ?> dias</td>
                    <td class="_right"><?= $block->formatNumber($customer['frequency']) ?></td>
                    <td class="_right"><strong><?= $block->formatPrice($customer['monetary']) ?></strong></td>
                </tr>
                <?php endforeach; ?>
                <?php endif; ?>
            </tbody>
        </table>

        <!-- Pagination -->
        <?php if ($totalPages > 1): ?>
        <div class="rfm-pagination">
            <div class="pagination-info">
                Página <?= (int)$currentPage ?> de <?= (int)$totalPages ?>
            </div>
            <div class="pagination-links">
                <?php if ($currentPage > 1): ?>
                <a href="<?= $block->escapeUrl($block->getPageUrl(1)) ?>" class="action-default">Primeira</a>
                <a href="<?= $block->escapeUrl($block->getPageUrl($currentPage - 1)) ?>" class="action-default">Anterior</a>
                <?php endif; ?>

                <?php
                $startPage = max(1, $currentPage - 2);
                $endPage = min($totalPages, $currentPage + 2);
                for ($p = $startPage; $p <= $endPage; $p++):
                ?>
                <a href="<?= $block->escapeUrl($block->getPageUrl($p)) ?>"
                   class="action-default <?= $p === $currentPage ? 'primary' : '' ?>">
                    <?= (int)$p ?>
                </a>
                <?php endfor; ?>

                <?php if ($currentPage < $totalPages): ?>
                <a href="<?= $block->escapeUrl($block->getPageUrl($currentPage + 1)) ?>" class="action-default">Próxima</a>
                <a href="<?= $block->escapeUrl($block->getPageUrl($totalPages)) ?>" class="action-default">Última</a>
                <?php endif; ?>
            </div>
        </div>
        <?php endif; ?>
    </div>
</div>

