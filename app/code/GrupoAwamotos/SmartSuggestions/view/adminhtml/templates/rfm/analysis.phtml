            <div class="rfm-rec-discount">
                <span class="label">Faixa de Desconto:</span>
                <span class="value"><?= $block->escapeHtml($recommendations['discount_range']) ?></span>
            </div>
        </div>
        <div class="rfm-rec-strategies">
            <strong>Estratégias Recomendadas:</strong>
            <ul>
                <?php foreach ($recommendations['strategies'] as $strategy): ?>
                <li><?= $block->escapeHtml($strategy) ?></li>
                <?php endforeach; ?>
            </ul>
        </div>
        <div class="rfm-rec-channels">
            <strong>Canais:</strong>
            <?php foreach ($recommendations['channels'] as $channel): ?>
            <span class="channel-badge"><?= $block->escapeHtml($channel) ?></span>
            <?php endforeach; ?>
        </div>
    </div>
    <?php endif; ?>

