<!-- ApexCharts Library -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.44.0/dist/apexcharts.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Daily Sales Chart
    var salesData = <?= /* @noEscape */ $block->getSalesTrendChartData() ?>;

    if (salesData.dates && salesData.dates.length > 0) {
        var dailyOptions = {
            chart: {
                type: 'area',
                height: 350,
                toolbar: { show: true },
                zoom: { enabled: true }
            },
            series: [
                { name: 'Vendas', data: salesData.sales },
                { name: 'Média Móvel (7d)', data: salesData.moving_avg }
            ],
            xaxis: {
                categories: salesData.dates,
                type: 'datetime',
                labels: { datetimeFormatter: { day: 'dd/MM' } }
            },
            yaxis: {
                labels: {
                    formatter: function(val) {
                        return 'R$ ' + (val / 1000).toFixed(0) + 'K';
                    }
                }
            },
            stroke: { curve: 'smooth', width: [2, 2], dashArray: [0, 5] },
            fill: {
                type: 'gradient',
                gradient: { shadeIntensity: 1, opacityFrom: 0.5, opacityTo: 0.1 }
            },
            colors: ['var(--fc-indigo)', '#FEB019'],
            dataLabels: { enabled: false },
            tooltip: {
                y: {
                    formatter: function(val) {
                        return 'R$ ' + (val || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2});
                    }
                }
            }
        };

        new ApexCharts(document.querySelector("#daily-sales-chart"), dailyOptions).render();
    }

    // Monthly Chart
    var monthlyData = <?= /* @noEscape */ $block->getMonthlyChartData() ?>;

    if (monthlyData.labels && monthlyData.labels.length > 0) {
        var monthlyOptions = {
            chart: {
                type: 'bar',
                height: 350,
                toolbar: { show: true }
            },
            series: [
                { name: 'Vendas', data: monthlyData.sales }
            ],
            xaxis: {
                categories: monthlyData.labels
            },
            yaxis: {
                labels: {
                    formatter: function(val) {
                        return 'R$ ' + (val / 1000).toFixed(0) + 'K';
                    }
                }
            },
            colors: ['var(--fc-indigo)'],
            plotOptions: {
                bar: {
                    borderRadius: 8,
                    columnWidth: '60%'
                }
            },
            dataLabels: { enabled: false },
            tooltip: {
                y: {
                    formatter: function(val) {
                        return 'R$ ' + val.toLocaleString('pt-BR', {minimumFractionDigits: 2});
                    }
                }
            }
        };

        new ApexCharts(document.querySelector("#monthly-chart"), monthlyOptions).render();
    }
});
</script>

