<!-- ApexCharts Library -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.44.0/dist/apexcharts.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Sales Trend Chart
    var salesData = <?= /* @noEscape */ $block->getSalesTrendData() ?>;

    if (salesData.dates && salesData.dates.length > 0) {
        var salesOptions = {
            chart: {
                type: 'area',
                height: 320,
                toolbar: { show: true, tools: { download: true, zoom: true, pan: true } },
                animations: { enabled: true, easing: 'easeinout', speed: 800 }
            },
            series: [
                { name: 'Vendas', data: salesData.sales },
                { name: 'Média Móvel (7d)', data: salesData.moving_avg }
            ],
            xaxis: {
                categories: salesData.dates,
                type: 'datetime',
                labels: { datetimeFormatter: { day: 'dd/MM' } }
            },
            yaxis: {
                labels: {
                    formatter: function(val) {
                        return 'R$ ' + (val / 1000).toFixed(0) + 'K';
                    }
                }
            },
            stroke: { curve: 'smooth', width: [2, 2], dashArray: [0, 5] },
            fill: {
                type: 'gradient',
                gradient: { shadeIntensity: 1, opacityFrom: 0.5, opacityTo: 0.1 }
            },
            colors: ['#00E396', '#FEB019'],
            dataLabels: { enabled: false },
            tooltip: {
                y: {
                    formatter: function(val) {
                        return 'R$ ' + val.toLocaleString('pt-BR', {minimumFractionDigits: 2});
                    }
                }
            },
            legend: { position: 'top' }
        };

        var salesChart = new ApexCharts(document.querySelector("#sales-trend-chart"), salesOptions);
        salesChart.render();
    }

    // RFM Segments Chart
    var rfmData = <?= /* @noEscape */ $block->getRfmChartData() ?>;

    if (rfmData.labels && rfmData.labels.length > 0) {
        var rfmOptions = {
            chart: {
                type: 'donut',
                height: 320
            },
            series: rfmData.series,
            labels: rfmData.labels,
            colors: rfmData.colors,
            legend: {
                position: 'right',
                fontSize: '12px'
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '65%',
                        labels: {
                            show: true,
                            total: {
                                show: true,
                                label: 'Total Clientes',
                                formatter: function(w) {
                                    return w.globals.seriesTotals.reduce((a, b) => a + b, 0).toLocaleString('pt-BR');
                                }
                            }
                        }
                    }
                }
            },
            dataLabels: {
                enabled: true,
                formatter: function(val, opts) {
                    return opts.w.config.series[opts.seriesIndex];
                }
            },
            tooltip: {
                y: {
                    formatter: function(val) {
                        return val + ' clientes';
                    }
                }
            }
        };

        var rfmChart = new ApexCharts(document.querySelector("#rfm-segments-chart"), rfmOptions);
        rfmChart.render();
    }
});
</script>
