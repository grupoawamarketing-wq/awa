<script>
require(['jquery'], function($) {
    $(document).ready(function() {
        $('#btn-send-whatsapp').on('click', function() {
            var btn = $(this);
            var customerId = btn.data('customer-id');
            var phone = btn.data('customer-phone');

            if (!customerId) {
                alert('Selecione um cliente primeiro');
                return;
            }

            if (!phone) {
                phone = prompt('Digite o telefone do cliente (com DDD):');
                if (!phone) return;
            }

            btn.addClass('send-loading');
            btn.find('span').text('Enviando...');

            $.ajax({
                url: '<?= $block->escapeJs($block->getUrl('*/suggestions/send')) ?>',
                type: 'POST',
                dataType: 'json',
                data: {
                    customer_id: customerId,
                    phone: phone,
                    form_key: FORM_KEY
                },
                success: function(response) {
                    btn.removeClass('send-loading');
                    if (response.success) {
                        btn.addClass('send-success');
                        btn.find('span').text('✓ Enviado!');
                        setTimeout(function() {
                            btn.removeClass('send-success');
                            btn.find('span').text('📱 Enviar via WhatsApp');
                        }, 3000);
                    } else {
                        btn.addClass('send-error');
                        btn.find('span').text('✗ Erro');
                        alert('Erro ao enviar: ' + response.message);
                        setTimeout(function() {
                            btn.removeClass('send-error');
                            btn.find('span').text('📱 Enviar via WhatsApp');
                        }, 3000);
                    }
                },
                error: function() {
                    btn.removeClass('send-loading');
                    btn.addClass('send-error');
                    btn.find('span').text('✗ Erro');
                    alert('Erro de comunicação com o servidor');
                    setTimeout(function() {
                        btn.removeClass('send-error');
                        btn.find('span').text('📱 Enviar via WhatsApp');
                    }, 3000);
                }
            });
        });
    });
});
</script>
