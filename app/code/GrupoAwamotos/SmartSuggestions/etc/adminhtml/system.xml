<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="smart_suggestions" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Sugestões Inteligentes</label>
            <tab>grupoawamotos</tab>
            <resource>GrupoAwamotos_SmartSuggestions::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Configurações Gerais</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Módulo Habilitado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Habilita ou desabilita o módulo de sugestões inteligentes</comment>
                </field>
                <field id="debug_mode" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Modo Debug</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Ativa logs detalhados para debug</comment>
                </field>
            </group>
            <group id="rfm" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Análise RFM</label>
                <field id="analysis_period_days" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Período de Análise (dias)</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Quantos dias de histórico usar para análise RFM (padrão: 365)</comment>
                </field>
                <field id="recency_weight" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Peso Recência</label>
                    <validate>validate-number</validate>
                    <comment>Peso do fator Recência no score RFM (0.1 a 1.0)</comment>
                </field>
                <field id="frequency_weight" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Peso Frequência</label>
                    <validate>validate-number</validate>
                    <comment>Peso do fator Frequência no score RFM (0.1 a 1.0)</comment>
                </field>
                <field id="monetary_weight" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Peso Monetário</label>
                    <validate>validate-number</validate>
                    <comment>Peso do fator Monetário no score RFM (0.1 a 1.0)</comment>
                </field>
                <field id="min_orders" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Mínimo de Pedidos</label>
                    <validate>validate-digits</validate>
                    <comment>Número mínimo de pedidos para incluir cliente na análise</comment>
                </field>
            </group>
            <group id="suggestions" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Sugestões de Carrinho</label>
                <field id="max_repurchase_items" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Máx. Itens Reposição</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Número máximo de itens de reposição por sugestão</comment>
                </field>
                <field id="max_crosssell_items" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Máx. Itens Cross-Sell</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Número máximo de itens de cross-sell por sugestão</comment>
                </field>
                <field id="max_similar_items" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Máx. Itens Similares</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Número máximo de itens de clientes similares</comment>
                </field>
                <field id="cycle_tolerance_percent" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Tolerância Ciclo (%)</label>
                    <validate>validate-digits</validate>
                    <comment>Tolerância percentual para detectar ciclo de recompra (ex: 20 = ±20%)</comment>
                </field>
                <field id="min_support_crosssell" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Suporte Mínimo Cross-Sell</label>
                    <validate>validate-digits</validate>
                    <comment>Quantas vezes um par de produtos deve aparecer junto para ser considerado</comment>
                </field>
            </group>
            <group id="forecast" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Projeções de Vendas</label>
                <field id="monte_carlo_iterations" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Iterações Monte Carlo</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Número de simulações Monte Carlo para projeções (padrão: 1000)</comment>
                </field>
                <field id="moving_avg_days" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Dias Média Móvel</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Número de dias para cálculo da média móvel</comment>
                </field>
                <field id="trend_weight" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Peso Tendência</label>
                    <validate>validate-number</validate>
                    <comment>Peso do componente de tendência na projeção (0.0 a 1.0)</comment>
                </field>
                <field id="seasonality_weight" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Peso Sazonalidade</label>
                    <validate>validate-number</validate>
                    <comment>Peso do componente de sazonalidade na projeção (0.0 a 1.0)</comment>
                </field>
                <field id="monthly_goal" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Meta Mensal (R$)</label>
                    <validate>validate-number</validate>
                    <comment>Meta de vendas mensal para exibição no dashboard</comment>
                </field>
            </group>
            <group id="whatsapp" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Integração WhatsApp</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitado</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Habilita envio de sugestões via WhatsApp</comment>
                </field>
                <field id="provider" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Provedor</label>
                    <source_model>GrupoAwamotos\SmartSuggestions\Model\Config\Source\WhatsappProvider</source_model>
                    <comment>Selecione o provedor de API WhatsApp</comment>
                </field>
                <field id="api_url" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>URL da API</label>
                    <comment>URL base da API do WhatsApp</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="api_token" translate="label comment" type="obscure" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Token da API</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>Token de autenticação da API</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="phone_number_id" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Phone Number ID</label>
                    <comment>ID do número de telefone WhatsApp Business (Meta Cloud API)</comment>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="provider">meta</field>
                    </depends>
                </field>
                <field id="twilio_sid" translate="label comment" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Twilio Account SID</label>
                    <comment>SID da conta Twilio</comment>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="provider">twilio</field>
                    </depends>
                </field>
                <field id="twilio_from" translate="label comment" type="text" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Twilio From Number</label>
                    <comment>Número de origem Twilio (formato: whatsapp:+5511999999999)</comment>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="provider">twilio</field>
                    </depends>
                </field>
                <field id="zapi_instance_id" translate="label comment" type="text" sortOrder="75" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Z-API Instance ID</label>
                    <comment>ID da instância Z-API</comment>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="provider">zapi</field>
                    </depends>
                </field>
                <field id="zapi_token" translate="label comment" type="obscure" sortOrder="76" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Z-API Token</label>
                    <comment>Token de autenticação Z-API</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="provider">zapi</field>
                    </depends>
                </field>
                <field id="zapi_client_token" translate="label comment" type="obscure" sortOrder="77" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Z-API Client Token</label>
                    <comment>Client Token adicional (se exigido pela instância)</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="provider">zapi</field>
                    </depends>
                </field>
                <field id="message_template" translate="label comment" type="textarea" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Template de Mensagem</label>
                    <comment><![CDATA[Use variáveis: {{customer_name}}, {{products_list}}, {{total_value}}, {{store_name}}]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>
            <group id="cron" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Agendamento Automático</label>
                <field id="rfm_enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Recalcular RFM Automaticamente</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Recalcula scores RFM automaticamente</comment>
                </field>
                <field id="rfm_schedule" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Horário Cálculo RFM</label>
                    <comment>Expressão cron (padrão: 0 2 * * * = 2h da manhã diariamente)</comment>
                    <depends>
                        <field id="rfm_enabled">1</field>
                    </depends>
                </field>
                <field id="suggestions_enabled" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Gerar Sugestões Automaticamente</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Gera sugestões para clientes em risco automaticamente</comment>
                </field>
                <field id="suggestions_schedule" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Horário Geração Sugestões</label>
                    <comment>Expressão cron (padrão: 0 6 * * 1 = 6h segunda-feira)</comment>
                    <depends>
                        <field id="suggestions_enabled">1</field>
                    </depends>
                </field>
                <field id="auto_send_whatsapp" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enviar WhatsApp Automaticamente</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Envia sugestões geradas automaticamente via WhatsApp</comment>
                    <depends>
                        <field id="suggestions_enabled">1</field>
                    </depends>
                </field>
            </group>
            <group id="export" translate="label" type="text" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Exportação</label>
                <field id="csv_delimiter" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Delimitador CSV</label>
                    <source_model>GrupoAwamotos\SmartSuggestions\Model\Config\Source\CsvDelimiter</source_model>
                </field>
                <field id="include_headers" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Incluir Cabeçalhos</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
