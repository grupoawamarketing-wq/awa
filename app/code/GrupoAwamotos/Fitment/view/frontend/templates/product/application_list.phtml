<?php
declare(strict_types=1);

/**
 * @var \GrupoAwamotos\Fitment\Block\ApplicationList $block
 */

if (!$block->hasApplications()) {
    return;
}

$applications = $block->getApplications();
$maxVisibleModelsPerBrand = 8;
$totalBrands = count($applications);
$totalModels = 0;

foreach ($applications as $applicationGroup) {
    $groupModels = is_array($applicationGroup['models'] ?? null) ? $applicationGroup['models'] : [];
    $totalModels += count($groupModels);
}
?>

<div class="fitment-applications" id="fitment-applications">
    <div class="fitment-header">
        <h2 class="fitment-title">
            <span class="fitment-icon">🏍️</span>
            <?= $block->escapeHtml($block->getSectionTitle()) ?>
        </h2>
    </div>

    <div class="fitment-content">
        <p class="fitment-intro">
            <?= $block->escapeHtml(__('Este produto é compatível com os seguintes modelos:')) ?>
        </p>
        <div class="fitment-stats" aria-label="<?= $block->escapeHtmlAttr(__('Resumo da compatibilidade')) ?>">
            <span class="fitment-stat">
                <?= $block->escapeHtml(__('%1 marcas', $totalBrands)) ?>
            </span>
            <span class="fitment-stat">
                <?= $block->escapeHtml(__('%1 modelos', $totalModels)) ?>
            </span>
        </div>
        <?php if ($totalModels > 10): ?>
            <div class="fitment-filter">
                <label class="fitment-filter-label" for="fitment-filter-input">
                    <?= $block->escapeHtml(__('Buscar modelo')) ?>
                </label>
                <input
                    type="search"
                    id="fitment-filter-input"
                    class="fitment-filter-input"
                    data-fitment-filter
                    placeholder="<?= $block->escapeHtmlAttr(__('Ex.: Fazer 250, XTZ, YBR')) ?>"
                    autocomplete="off">
                <p class="fitment-filter-empty" data-fitment-empty hidden>
                    <?= $block->escapeHtml(__('Nenhum modelo encontrado para esse termo.')) ?>
                </p>
            </div>
        <?php endif; ?>

        <?php foreach ($applications as $brandIndex => $brandGroup): ?>
            <?php
            $models = is_array($brandGroup['models'] ?? null) ? $brandGroup['models'] : [];
            $totalModels = count($models);
            $hiddenModelsCount = max(0, $totalModels - $maxVisibleModelsPerBrand);
            $isCollapsible = $hiddenModelsCount > 0;
            $listId = 'fitment-model-list-' . (int) $brandIndex;
            ?>
            <div class="fitment-brand-group">
                <h3 class="fitment-brand-name">
                    <?= $block->escapeHtml($brandGroup['brand_name']) ?>
                </h3>
                <ul
                    class="fitment-model-list<?= $isCollapsible ? ' is-collapsible' : '' ?>"
                    id="<?= $block->escapeHtmlAttr($listId) ?>"
                    data-expanded="false">
                    <?php foreach ($models as $modelIndex => $model): ?>
                        <?php $isInitiallyHidden = $isCollapsible && $modelIndex >= $maxVisibleModelsPerBrand; ?>
                        <li class="fitment-model-item<?= $isInitiallyHidden ? ' fitment-model-item--extra' : '' ?>"<?= $isInitiallyHidden ? ' hidden' : '' ?>>
                            <span class="fitment-model-name">
                                <?= $block->escapeHtml($block->getMotorcycleLabel($model)) ?>
                            </span>
                            <?= /* @noEscape */ $block->getPositionBadge($model) ?>
                            <?= /* @noEscape */ $block->getOemBadge($model) ?>
                            <?= /* @noEscape */ $block->getNotes($model) ?>
                        </li>
                    <?php endforeach; ?>
                </ul>

                <?php if ($isCollapsible): ?>
                    <button
                        type="button"
                        class="fitment-toggle-models"
                        data-fitment-toggle
                        aria-expanded="false"
                        aria-controls="<?= $block->escapeHtmlAttr($listId) ?>"
                        data-label-more="<?= $block->escapeHtmlAttr(__('Mostrar mais %1 modelos', $hiddenModelsCount)) ?>"
                        data-label-less="<?= $block->escapeHtmlAttr(__('Mostrar menos')) ?>">
                        <?= $block->escapeHtml(__('Mostrar mais %1 modelos', $hiddenModelsCount)) ?>
                    </button>
                <?php endif; ?>
            </div>
        <?php endforeach; ?>

        <p class="fitment-disclaimer">
            <?= $block->escapeHtml(__('⚠️ Verifique sempre as especificações do seu veículo antes da compra.')) ?>
        </p>
    </div>
</div>

<script>
    (function () {
        'use strict';

        var fitmentRoot = document.getElementById('fitment-applications');

        if (!fitmentRoot) {
            return;
        }

        fitmentRoot.addEventListener('click', function (event) {
            var toggle = event.target.closest('[data-fitment-toggle]');
            var listId;
            var list;
            var shouldExpand;
            var hiddenItems;

            if (!toggle || !fitmentRoot.contains(toggle)) {
                return;
            }

            listId = toggle.getAttribute('aria-controls');
            list = listId ? document.getElementById(listId) : null;

            if (!list) {
                return;
            }

            shouldExpand = toggle.getAttribute('aria-expanded') !== 'true';
            hiddenItems = list.querySelectorAll('.fitment-model-item--extra');

            Array.prototype.forEach.call(hiddenItems, function (item) {
                item.hidden = !shouldExpand;
            });

            list.setAttribute('data-expanded', shouldExpand ? 'true' : 'false');
            toggle.setAttribute('aria-expanded', shouldExpand ? 'true' : 'false');
            toggle.textContent = shouldExpand
                ? (toggle.getAttribute('data-label-less') || 'Mostrar menos')
                : (toggle.getAttribute('data-label-more') || 'Mostrar mais');
        });

        var filterInput = fitmentRoot.querySelector('[data-fitment-filter]');
        var emptyMessage = fitmentRoot.querySelector('[data-fitment-empty]');

        if (!filterInput) {
            return;
        }

        filterInput.addEventListener('input', function () {
            var query = (filterInput.value || '').toLowerCase().trim();
            var allItems = fitmentRoot.querySelectorAll('.fitment-model-item');
            var allLists = fitmentRoot.querySelectorAll('.fitment-model-list');
            var toggles = fitmentRoot.querySelectorAll('[data-fitment-toggle]');
            var visibleCount = 0;

            Array.prototype.forEach.call(allItems, function (item) {
                var text = (item.textContent || '').toLowerCase();
                var list = item.closest('.fitment-model-list');
                var isExtra = item.classList.contains('fitment-model-item--extra');
                var isExpanded = list && list.getAttribute('data-expanded') === 'true';
                var matches = !query || text.indexOf(query) !== -1;

                if (!matches) {
                    item.hidden = true;
                    return;
                }

                if (!query && isExtra && !isExpanded) {
                    item.hidden = true;
                    return;
                }

                item.hidden = false;
                visibleCount += 1;
            });

            Array.prototype.forEach.call(toggles, function (toggle) {
                toggle.hidden = query.length > 0;
            });

            Array.prototype.forEach.call(allLists, function (list) {
                var anyVisible = list.querySelector('.fitment-model-item:not([hidden])');
                var brandGroup = list.closest('.fitment-brand-group');

                if (brandGroup) {
                    brandGroup.hidden = !anyVisible;
                }
            });

            if (emptyMessage) {
                emptyMessage.hidden = visibleCount > 0;
            }
        });
    })();
</script>
