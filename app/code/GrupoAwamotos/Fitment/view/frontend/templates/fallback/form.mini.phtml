<?php
/** @var $block \Magento\Framework\View\Element\Template */
/** @var $escaper \Magento\Framework\Escaper */
/** @var $configProvider \Magento\Search\ViewModel\ConfigProvider */
declare(strict_types=1);

$configProvider = $block->getData('configProvider');
/** @var $additionalSearchFormData \Magento\Search\ViewModel\AdditionalSearchFormData */
$additionalSearchFormData = $block->getData('additionalSearchFormData');
/** @var $helper \Magento\Search\Helper\Data */
$helper = $configProvider ? $configProvider->getSearchHelperData() : null;
$queryParam = $helper ? $helper->getQueryParamName() : 'q';
$queryText = $helper ? $helper->getEscapedQueryText() : '';

$searchLabel = __('Buscar');
$placeholderLabel = __('Buscar em toda a loja...');
?>
<div class="block block-search">
    <div class="block block-title"><strong><?= $escaper->escapeHtml($searchLabel) ?></strong></div>
    <div class="block block-content">
        <form class="form minisearch" id="search_mini_form"
              action="<?= $escaper->escapeUrl($block->getUrl('fitment/fallback/index')) ?>" method="get">
            <?php  if (isset($additionalSearchFormData) && !empty($queryParams = $additionalSearchFormData->getFormData())): ?>
                <?php foreach ($queryParams as $param): ?>
                    <input type="hidden" name="<?= $escaper->escapeHtmlAttr($param['name']) ?>"
                           value="<?= $escaper->escapeHtmlAttr($param['value']) ?>"/>
                <?php endforeach; ?>
            <?php endif; ?>
            <div class="field search">
                <label class="label" for="search" data-role="minisearch-label">
                    <span><?= $escaper->escapeHtml($searchLabel) ?></span>
                </label>
                <div class="control">
                    <input id="search"
                           type="text"
                           name="<?= $escaper->escapeHtmlAttr($queryParam) ?>"
                           value="<?= /* @noEscape */ $queryText ?>"
                           placeholder="<?= $escaper->escapeHtmlAttr($placeholderLabel) ?>"
                           class="input-text"
                           autocomplete="off"/>
                    <div id="search_autocomplete" class="search-autocomplete"></div>
                    <?= $block->getChildHtml() ?>
                </div>
            </div>
            <div class="actions">
                <button type="submit"
                        title="<?= $escaper->escapeHtmlAttr($searchLabel) ?>"
                        class="action search"
                        aria-label="<?= $escaper->escapeHtmlAttr($searchLabel) ?>"
                >
                    <span><?= $escaper->escapeHtml($searchLabel) ?></span>
                </button>
            </div>
        </form>
    </div>
    <style>
        /* evita JS do autocomplete nativo quando ES está fora */
        #search_autocomplete { display:none; }
    </style>
    <script>
        // Remove qualquer data-mage-init residual que módulos possam injetar no input
        (function(){
            try{
                var el = document.getElementById('search');
                if(el){ el.removeAttribute('data-mage-init'); }
            }catch(e){}
        })();
    </script>
    </div>
</div>
