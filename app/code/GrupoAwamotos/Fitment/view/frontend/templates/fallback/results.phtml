<?php
/** @var $block GrupoAwamotos\Fitment\Block\Fallback\Results */
declare(strict_types=1);

$addToCartLabel = __('Adicionar');
$viewDetailsLabel = __('Ver detalhes');
$soldOutLabel = __('Produto esgotado');
?>
<div class="page-title-wrapper">
    <h1 class="page-title"><span class="base"><?= __('Resultados da busca') ?></span></h1>
</div>
<div class="page-products fallback-search-results">
    <form class="fallback-search-form" action="<?= $block->escapeUrl($block->getUrl('fitment/fallback/index')) ?>" method="get" aria-label="Formulário de busca fallback">
        <input type="text" name="q" value="<?= $block->escapeHtml($block->getQuery()) ?>" placeholder="<?= __('Buscar produtos (fallback)') ?>" aria-label="Campo de busca" />
        <button type="submit" class="action primary" aria-label="<?= __('Buscar') ?>"><span><?= __('Buscar') ?></span></button>
        <div class="toolbar" role="toolbar" aria-label="Ferramentas de busca">
            <div class="sorter">
                <label for="order-select" class="visually-hidden"><?= __('Ordenar por') ?></label>
                <select id="order-select" name="order" aria-label="Ordenar por">
                    <?php foreach ($block->getAvailableOrders() as $code => $label): ?>
                        <option value="<?= $block->escapeHtmlAttr($code) ?>" <?= $block->getCurrentOrder()===$code?'selected':'' ?>><?= $block->escapeHtml($label) ?></option>
                    <?php endforeach; ?>
                </select>
                <label for="dir-select" class="visually-hidden"><?= __('Direção da ordenação') ?></label>
                <select id="dir-select" name="dir" aria-label="Direção da ordenação">
                    <option value="asc" <?= $block->getCurrentDir()==='asc'?'selected':'' ?>><?= __('Ascendente') ?></option>
                    <option value="desc" <?= $block->getCurrentDir()==='desc'?'selected':'' ?>><?= __('Descendente') ?></option>
                </select>
            </div>
            <div class="limiter">
                <label for="limit-select" class="visually-hidden"><?= __('Limite por página') ?></label>
                <select id="limit-select" name="limit" aria-label="Limite por página">
                    <?php foreach ($block->getAvailableLimits() as $val => $text): ?>
                        <option value="<?= (int)$val ?>" <?= $block->getCurrentLimit()==$val?'selected':'' ?>><?= (int)$text ?></option>
                    <?php endforeach; ?>
                </select>
            </div>
            <button type="submit" class="action secondary" aria-label="<?= __('Aplicar') ?>"><span><?= __('Aplicar') ?></span></button>
        </div>
    </form>
    <div class="visually-hidden" aria-live="polite" id="products-count-live"></div>
    <div class="fallback-skeleton" id="fallback-skeleton" aria-hidden="true">
        <div class="card"></div>
        <div class="card"></div>
        <div class="card"></div>
        <div class="card"></div>
        <div class="card"></div>
        <div class="card"></div>
        <div class="card"></div>
        <div class="card"></div>
    </div>
    <h2><?= __('Resultado da busca') ?></h2>
    <?php $collection = $block->getCollection(); ?>
    <?php if (!$collection->getSize()): ?>
        <p><?= __('Nenhum produto encontrado.') ?></p>
    <?php else: ?>
        <ol class="products list items product-items products-grid" id="fallback-products-list" aria-label="Lista de produtos">
        <?php foreach ($collection as $product): ?>
            <li class="item product product-item">
                <div class="product-item-info" role="article" aria-label="<?= $block->escapeHtmlAttr($product->getName()) ?>">
                    <?php $price = (float)$product->getPrice(); $final = (float)$product->getFinalPrice(); $hasSpecial = ($final < $price && $price > 0); ?>
                    <?php if ($hasSpecial): ?>
                        <?php $discountPercent = $price > 0 ? round((1 - ($final / $price)) * 100) : 0; ?>
                        <div class="product-label fitment-label-sale" aria-label="<?= __('Promoção') ?>">
                            <?= __('Promoção') ?> - <?= $discountPercent ?>%
                        </div>
                    <?php endif; ?>
                    <a class="product photo product-item-photo" href="<?= $block->escapeUrl($product->getProductUrl()) ?>">
                        <?php $img = $block->getImageUrl($product, 'category_page_grid'); ?>
                        <?php if ($img): ?>
                            <img src="<?= $block->escapeUrl($img) ?>" alt="<?= $block->escapeHtmlAttr($product->getName()) ?>" loading="lazy" decoding="async" />
                        <?php endif; ?>
                    </a>
                    <div class="product details product-item-details">
                        <strong class="product name product-item-name">
                            <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>"><?= $block->escapeHtml($product->getName()) ?></a>
                        </strong>
                        <div class="price-box price-final_price">
                            <?php if ($hasSpecial): ?>
                                <span class="old-price"><span class="price"><?= $block->formatPrice($price) ?></span></span>
                                <span class="special-price"><span class="price"><?= $block->formatPrice($final) ?></span></span>
                            <?php else: ?>
                                <span class="price"><?= $block->formatPrice($final ?: $price) ?></span>
                            <?php endif; ?>
                        </div>
                        <div class="stock available">
                            <?php if ($product->isAvailable()): ?>
                                <span class="availability in-stock"><span><?= __('Em estoque') ?></span></span>
                            <?php else: ?>
                                <span class="availability out-of-stock"><span><?= $block->escapeHtml($soldOutLabel) ?></span></span>
                            <?php endif; ?>
                        </div>
                        <div class="product-item-actions">
                            <?php if ($product->isSaleable() && !$product->getTypeInstance()->hasRequiredOptions($product)): ?>
                                <form data-role="tocart-form" action="<?= $block->escapeUrl($block->getUrl('checkout/cart/add')) ?>" method="post">
                                    <?= $block->getBlockHtml('formkey') ?>
                                    <input type="hidden" name="product" value="<?= (int)$product->getId() ?>" />
                                    <button type="submit" title="<?= $block->escapeHtmlAttr($addToCartLabel) ?>" class="action tocart primary">
                                        <span><?= $block->escapeHtml($addToCartLabel) ?></span>
                                    </button>
                                </form>
                            <?php else: ?>
                                <a class="action primary" href="<?= $block->escapeUrl($product->getProductUrl()) ?>"><span><?= $block->escapeHtml($viewDetailsLabel) ?></span></a>
                            <?php endif; ?>
                            <!-- B2B: Wishlist e Compare removidos - desnecessários para autopeças B2B -->
                        </div>
                    </div>
                </div>
            </li>
        <?php endforeach; ?>
        </ol>
        <?php if ($pager = $block->getChildBlock('pager')): ?>
            <?php $pager->setCollection($collection); ?>
            <?= $block->getChildHtml('pager'); ?>
        <?php endif; ?>
    <?php endif; ?>
    <script type="text/x-magento-init">
    {
        "*": {
            "GrupoAwamotos_Fitment/js/fallback-skeleton": {}
        }
    }
    </script>
</div>
