<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="GrupoAwamotos_Fitment::css/fallback.css" />
    </head>
    <body>
        <referenceBlock name="breadcrumbs">
            <action method="addCrumb">
                <argument name="crumbName" xsi:type="string">home</argument>
                <argument name="crumbInfo" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Home</item>
                    <item name="title" xsi:type="string" translate="true">Home</item>
                    <item name="link" xsi:type="string">/</item>
                </argument>
            </action>
            <action method="addCrumb">
                <argument name="crumbName" xsi:type="string">fallback-search</argument>
                <argument name="crumbInfo" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Busca</item>
                    <item name="title" xsi:type="string" translate="true">Busca</item>
                </argument>
            </action>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\Fitment\Block\Fallback\Results" name="fitment.fallback.results" template="GrupoAwamotos_Fitment::fallback/results.phtml">
                <block class="Magento\Theme\Block\Html\Pager" name="fitment.fallback.pager" as="pager" />
            </block>
        </referenceContainer>
    </body>
</page>
