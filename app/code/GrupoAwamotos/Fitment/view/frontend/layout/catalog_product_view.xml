<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- fitment-application.css async (non-blocking) — below fold on PDP (AWA 2026-04-25) -->
        <css src="GrupoAwamotos_Fitment::css/fitment-application.css" media="print"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\Fitment\Block\ApplicationList"
                   name="product.fitment.applications"
                   before="product.info.details"
                   template="GrupoAwamotos_Fitment::product/application_list.phtml"
                   cacheable="true"/>
        </referenceContainer>
    </body>
</page>
