<?php
/**
 * AWA PDP — Produtos Relacionados (mesma categoria)
 * Preço visível somente para clientes B2B aprovados.
 *
 * @var \GrupoAwamotos\RelatedProducts\Block\Product\Related $block
 * @var \Magento\Framework\Escaper $escaper
 */
declare(strict_types=1);

$collection = $block->getRelatedCollection();
if (!$collection || !$collection->getSize()) {
    return;
}

$canShowPrice = $block->canShowPrice();
$imageType    = 'category_page_grid';
$addLabel     = $escaper->escapeHtml(__('Adicionar'));
$soldOutLabel = $escaper->escapeHtml(__('Produto esgotado'));
$loginUrl     = $escaper->escapeUrl($block->getUrl('b2b/account/login'));
?>

<section class="awa-pdp-related" aria-labelledby="awa-pdp-related-heading">

    <div class="rokan-product-heading rokan-featured-heading">
        <h2 id="awa-pdp-related-heading">
            <?= $escaper->escapeHtml(__('Produtos Relacionados')) ?>
        </h2>
    </div>

    <div class="rokan-mostviewed">
        <div class="swiper products-swiper products-swiper--related">
            <div class="swiper-wrapper">
                <?php foreach ($collection as $product): ?>
                <div class="swiper-slide">
                    <div class="product-item">

                        <?php $productImage = $block->getImage($product, $imageType); ?>
                        <div class="product-thumb">
                            <a href="<?= $escaper->escapeUrl($product->getProductUrl()) ?>"
                               class="product-thumb-link product photo product-item-photo"
                               aria-label="<?= $escaper->escapeHtmlAttr($product->getName()) ?>">
                                <span class="first-thumb">
                                    <?php
                                    $imgHtml = $productImage->toHtml();
                                    $imgHtml = str_replace('loading="eager"', 'loading="lazy"', $imgHtml);
                                    if (strpos($imgHtml, 'loading=') === false) {
                                        $imgHtml = str_replace('<img ', '<img loading="lazy" decoding="async" ', $imgHtml);
                                    }
                                    echo $imgHtml;
                                    ?>
                                </span>
                            </a>
                        </div>

                        <div class="product-info">
                            <div class="product-name">
                                <a class="product-item-link"
                                   href="<?= $escaper->escapeUrl($product->getProductUrl()) ?>"
                                   title="<?= $escaper->escapeHtmlAttr($product->getName()) ?>">
                                    <?= $escaper->escapeHtml($product->getName()) ?>
                                </a>
                            </div>

                            <?php if ($canShowPrice): ?>
                            <div class="price-box">
                                <?= /* @noEscape */ $block->getProductPrice($product) ?>
                            </div>
                            <?php else: ?>
                            <div class="price-box price-box--hidden awa-related-price-box--hidden">
                                <span class="awa-related-price-notice">
                                    <a class="awa-related-price-notice__login-link"
                                       href="<?= /* @noEscape */ $loginUrl ?>">
                                        <?= $escaper->escapeHtml(__('Faça login')) ?>
                                    </a>
                                    <span class="awa-related-price-notice__suffix">
                                        <?= $escaper->escapeHtml(__('para ver preços')) ?>
                                    </span>
                                </span>
                            </div>
                            <?php endif; ?>

                            <div class="product-actions">
                                <?php if ($canShowPrice && $product->isSaleable()): ?>
                                    <?php $postParams = $block->getAddToCartPostParams($product); ?>
                                    <?php if (!empty($postParams['action']) && !empty($postParams['data']) && is_array($postParams['data'])): ?>
                                    <form data-role="tocart-form"
                                          class="related-tocart-form"
                                          action="<?= $escaper->escapeUrl((string) $postParams['action']) ?>"
                                          method="post">
                                        <?php foreach ($postParams['data'] as $key => $value): ?>
                                        <input type="hidden"
                                               name="<?= $escaper->escapeHtmlAttr((string) $key) ?>"
                                               value="<?= $escaper->escapeHtmlAttr((string) $value) ?>">
                                        <?php endforeach; ?>
                                        <button type="submit"
                                                class="action tocart primary related-addtocart"
                                                aria-label="<?= $escaper->escapeHtmlAttr(__('Adicionar %1 ao carrinho', $product->getName())) ?>">
                                            <span><?= /* @noEscape */ $addLabel ?></span>
                                        </button>
                                    </form>
                                    <?php endif; ?>
                                <?php elseif ($canShowPrice): ?>
                                    <div class="stock unavailable" aria-live="polite">
                                        <span><?= /* @noEscape */ $soldOutLabel ?></span>
                                    </div>
                                <?php endif; ?>
                            </div>
                        </div>

                    </div>
                </div>
                <?php endforeach; ?>
            </div>
            <div class="swiper-button-next" aria-label="<?= $escaper->escapeHtmlAttr(__('Próximo')) ?>"></div>
            <div class="swiper-button-prev" aria-label="<?= $escaper->escapeHtmlAttr(__('Anterior')) ?>"></div>
        </div>
    </div>

</section>

<script type="text/x-magento-init">
{
    ".awa-pdp-related": {
        "js/awa-carousel": {
            "carouselSelector": ".products-swiper--related",
            "owl": {
                "items": 4,
                "itemsDesktop": [1366, 4],
                "itemsDesktopSmall": [980, 3],
                "itemsTablet": [768, 2],
                "itemsMobile": [479, 1],
                "navigation": true,
                "pagination": false,
                "margin": 16
            }
        }
    }
}
</script>
