{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
